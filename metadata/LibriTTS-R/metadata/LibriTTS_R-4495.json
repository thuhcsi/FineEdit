        "speaker_id": "LibriTTS_R-4495",
        "content": "Knowing by experience that interference would be hopeless, under these circumstances, Miss Garth turned sharply and left the room.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
