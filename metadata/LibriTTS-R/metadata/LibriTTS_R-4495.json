        "speaker_id": "LibriTTS_R-4495",
        "content": "The Marrables are respectable people, and keep the best company in Clifton.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
