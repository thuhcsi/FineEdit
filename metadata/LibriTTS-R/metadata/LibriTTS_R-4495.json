        "speaker_id": "LibriTTS_R-4495",
        "content": "\"Made with the best intentions-but a mistake for all that.\"",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
