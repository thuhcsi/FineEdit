    {
        "item_name": "LibriTTS_R-367_293981_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/367/293981/367_293981_000004_000000.wav",
        "speaker_id": "LibriTTS_R-367",
        "content": "\"How can I sleep, curses on it!\" returned Sancho discontentedly and bitterly, \"when it is plain that all the devils have been at me this night?\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
