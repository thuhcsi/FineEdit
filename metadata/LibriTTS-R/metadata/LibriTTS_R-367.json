        "speaker_id": "LibriTTS_R-367",
        "content": "This tempest and tribulation lasted about two hours, at the end of which he was left, not like his master, but so weak and exhausted that he could not stand.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
