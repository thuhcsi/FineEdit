        "speaker_id": "LibriTTS_R-367",
        "content": "\"Then this is an inn?\" said Don Quixote.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
