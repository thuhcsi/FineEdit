        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/367/293981/367_293981_000021_000000.wav",
        "speaker_id": "LibriTTS_R-367",
        "content": "\"I would speak more politely if I were you,\" replied Don Quixote; \"is it the way of this country to address knights errant in that style, you booby?\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
