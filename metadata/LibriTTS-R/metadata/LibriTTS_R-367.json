        "speaker_id": "LibriTTS_R-367",
        "content": "\"And a very respectable one,\" said the innkeeper.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
