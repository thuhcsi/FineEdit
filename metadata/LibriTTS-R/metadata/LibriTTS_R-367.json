        "speaker_id": "LibriTTS_R-367",
        "content": "\"Didn't I say so? worse luck to my line!\" said Sancho.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
