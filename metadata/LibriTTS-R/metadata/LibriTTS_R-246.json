        "speaker_id": "LibriTTS_R-246",
        "content": "You'd never think it to look at me, would you?",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
