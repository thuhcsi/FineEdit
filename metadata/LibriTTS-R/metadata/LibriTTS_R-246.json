        "speaker_id": "LibriTTS_R-246",
        "content": "\"Marilla's eyes will never be much better than they are now, although we are so thankful to think that they will not get worse.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
