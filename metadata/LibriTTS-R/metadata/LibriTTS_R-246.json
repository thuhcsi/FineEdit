        "speaker_id": "LibriTTS_R-246",
        "content": "She takes it right out as soon as she tucks me up because she says I mustn't be a coward. I'm NOT scared, but I'd RATHER have the light.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
