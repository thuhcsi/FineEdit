        "speaker_id": "LibriTTS_R-246",
        "content": "\"Father's not very easy to get acquainted with,\" Paul had said once.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
