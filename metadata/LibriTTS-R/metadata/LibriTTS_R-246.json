        "speaker_id": "LibriTTS_R-246",
        "content": "I expect she spoiled me.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
