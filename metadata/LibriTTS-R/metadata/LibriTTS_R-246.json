        "speaker_id": "LibriTTS_R-246",
        "content": "Bath, April",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
