        "speaker_id": "LibriTTS_R-246",
        "content": "\"Friendship IS very beautiful,\" smiled mrs Allan, \"but some day . . .\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
