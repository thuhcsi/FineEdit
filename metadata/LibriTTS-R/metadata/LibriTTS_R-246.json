        "speaker_id": "LibriTTS_R-246",
        "content": "\"I never got really acquainted with him until after my little mother died. But he's splendid when you do get to know him.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
