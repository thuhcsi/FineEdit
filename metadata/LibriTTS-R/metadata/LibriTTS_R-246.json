        "speaker_id": "LibriTTS_R-246",
        "content": "Father understood pretty well, but still I couldn't talk much to him about mother, because it made him feel so bad.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
