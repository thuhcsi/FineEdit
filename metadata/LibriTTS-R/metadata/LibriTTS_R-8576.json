[
    {
        "item_name": "LibriTTS_R-8576_285176_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/285176/8576_285176_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Know thou the secret of a spirit Bow'd from its wild pride into shame. O! yearning heart!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_285176_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/285176/8576_285176_000010_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The rain came down upon my head Unshelter'd-and the heavy wind Was giantlike-so thou, my mind!-- It was but man, I thought, who shed Laurels upon me: and the rush- The torrent of the chilly air Gurgled within my ear the crush Of empires-with the captive's prayer- The hum of suiters-and the tone Of flattery 'round a sovereign's throne.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8576_285176_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/285176/8576_285176_000017_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "I was ambitious-have you known The passion, father?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_285176_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/285176/8576_285176_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "We walk'd together on the crown Of a high mountain which look'd down Afar from its proud natural towers Of rock and forest, on the hills- The dwindled hills! begirt with bowers And shouting with a thousand rills.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8576_285176_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/285176/8576_285176_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "I wrapp'd myself in grandeur then, And donn'd a visionary crown- Yet it was not that Fantasy Had thrown her mantle over me- But that, among the rabble-men, Lion ambition is chain'd down- And crouches to a keeper's hand- Not so in deserts where the grand The wild-the terrible conspire With their own breath to fan his fire.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000009_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "CHAPTER one",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "All through the sixteenth century the South Seas were regarded as a mysterious wonderworld, whence Spain drew unlimited wealth of gold and silver bullion, of pearls and precious stones.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000011_000001.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Spain had declared the Pacific 'a closed sea' to the rest of the world.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000011_000002.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "But in fifteen sixty seven it happened that Sir john Hawkins, an English mariner, was cruising in the Gulf of Mexico, when a terrific squall, as he said, drove his ships landward to Vera Cruz, and he sent a messenger to the Spanish viceroy there asking permission to dock and repair his battered vessels.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000011_000003.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Now on one of the English ships was a young officer, not yet twenty five years of age, named Francis Drake. Twelve Spanish merchantmen rigged as frigates lay in the harbour, and Drake observed that cargo of small bulk but ponderous weight, and evidently precious, was being stowed in their capacious holds.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000011_000005.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Whence did it come?",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000011_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000011_000006.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Could English privateers intercept it on the high seas?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000012_000002.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Some friendly hand threw out a rope to Hawkins, who was clad in complete armour.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000012_000003.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "In the dark, unseen by the enemy, he pulled himself up the side of a smaller ship, and, cutting hawsers, scudded for the open sea.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000012_000004.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "There escaped, also, of Hawkins's fleet another small ship, which was commanded by Francis Drake; and after much suffering both vessels reached England.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "One can imagine the effect on young Drake of the treacherous act and of the glimpse of that cargo of gold and silver treasure.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000001.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The English captains had but asked a night's lodging from a power supposed to be friendly.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000003.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Good!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000004.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Young Francis Drake eagerly took up Spain's challenge; he would meet the raid with counter raid.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000005.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Three years later he was cruising the Spanish Main, capturing and plundering ships and forts and towns.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000006.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "In fifteen seventy two he led his men across the Isthmus of Panama, and intercepted and captured a Spanish convoy of treasure coming overland.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000007.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Near the south side of the isthmus he climbed a tree and had his first glimpse of the Pacific.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000008.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "It set his blood on the leap.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000013_000009.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "On bended knee he prayed aloud to the Almighty to be permitted to sail the first English ship on that 'faire sea.' And, having recrossed the isthmus and loaded his ships with plunder, he bore away for England and reached Plymouth in august fifteen seventy three.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The raid on Panama had brought Drake enormous wealth.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000014_000001.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "At his own cost he built three frigates and two sloops to explore the South Seas, his purpose being to enter the Pacific through the Strait of Magellan, which no Englishman had yet ventured to pass.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000014_000002.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "These ships he equipped as if for royal tournament.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000014_000003.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Players of the violin and the harp discoursed music at each meal.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000014_000005.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "His men loved him as a dauntless leader; they feared him, too, with a fear that commanded obedience on the instant.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000015_000000.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Queen Elizabeth was in a quandary how to treat her gallant buccaneer and rover of the high seas.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000015_000002.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The coast of Brazil was reached in April.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000015_000004.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "In August the remaining three ships entered the tempestuous seas around Cape Horn.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000015_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000015_000007.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Perhaps there was jocose irony in the suggestion of gold and speed.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000016_000001.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The natives of South America, for the best of reasons, hated their Spanish masters, who enslaved them, treated them brutally, and forced them to work in the pearl fisheries and the mines.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000016_000003.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Never dreaming that any foreign vessel had entered the Pacific, Spanish treasure ships lay rocking to the tide in fancied security, and actually dipped colours to Drake.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000016_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000016_000006.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "In a trice the English sailors were on the Spanish deck with swords out and the rallying cry of 'God and saint George!",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000016_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000016_000007.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Down with Spanish dogs!' Dumbfounded and unarmed, down the hatches, over the bulwarks into the sea, reeled the surprised Spaniards.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000016_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000016_000009.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The treasure ships were looted of their cargoes and sent drifting out to sea.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000017_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000017_000005.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "For five days the hunt lasted, never slackening by day or by night; and when, at three in the afternoon of a day in March, Drake's brother shouted from the cross trees, 'Sail ho!' every man aboard went mad with impatience to crowd on the last inch of canvas and overtake the rich prize.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000017_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000017_000006.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The Englishmen saw that the Spanish ship was so heavily laden that she was making but slow progress; and so unconscious was the Spanish captain of danger, that when he discerned a ship approaching he actually lowered canvas and awaited what he thought might be fresh orders from the viceroy.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000017_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000017_000008.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Yards, sails, masts fell shattered and torn from the splendid Spanish ship.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000017_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000017_000009.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "The English clapped their grappling hooks to her sides, and naked swords did the rest.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000018_000001.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "It was then that legends of a north-east Passage came into his mind.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000018_000002.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "He would sail northward in search of the strait that was supposed to lead through the continent to the Atlantic-the mythical strait of Anian.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000018_000003.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "As the world knows, there was no such passage; but how far north did Drake sail seeking it?",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000018_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000018_000005.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "In july fifteen seventy nine he weighed anchor and steered south-west.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000018_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8576/300229/8576_300229_000018_000008.wav",
        "speaker_id": "LibriTTS_R-8576",
        "content": "Ballads were recited in his honour.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8576_300229_000019_000000",
