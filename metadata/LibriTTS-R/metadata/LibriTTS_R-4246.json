        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4246/12545/4246_12545_000007_000003.wav",
        "speaker_id": "LibriTTS_R-4246",
        "content": "And yet, am I sure that at some points I did not abuse him?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4246_12545_000013_000000",
