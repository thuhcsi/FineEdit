        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4246/12544/4246_12544_000040_000000.wav",
        "speaker_id": "LibriTTS_R-4246",
        "content": "About twenty miles from Scott's Bluff stands old Chimney Rock.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
