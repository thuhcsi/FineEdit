        "speaker_id": "LibriTTS_R-4246",
        "content": "Here the Laramie River and the Platte meet.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
