        "speaker_id": "LibriTTS_R-4246",
        "content": "\"What is this cow worth to you?\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
