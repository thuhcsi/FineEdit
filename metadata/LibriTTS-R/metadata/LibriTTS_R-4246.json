        "speaker_id": "LibriTTS_R-4246",
        "content": "The fact gradually became apparent that the loss of that fine ox was almost irreparable.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
