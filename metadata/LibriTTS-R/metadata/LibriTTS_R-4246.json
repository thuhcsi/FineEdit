        "speaker_id": "LibriTTS_R-4246",
        "content": "\"Thirty dollars.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
