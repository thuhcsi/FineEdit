        "speaker_id": "LibriTTS_R-4246",
        "content": "But one cow would not go at all!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
