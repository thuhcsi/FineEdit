        "speaker_id": "LibriTTS_R-4246",
        "content": "As we journeyed on down the Platte, we passed thrifty ranches and thriving little towns.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
