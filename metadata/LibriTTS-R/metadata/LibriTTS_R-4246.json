        "speaker_id": "LibriTTS_R-4246",
        "content": "All along the way was a spirit of good cheer and hearty welcome.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
