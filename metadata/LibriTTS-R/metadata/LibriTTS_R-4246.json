        "speaker_id": "LibriTTS_R-4246",
        "content": "One of the old barracks, three hundred feet long, was in good preservation in nineteen o six, being utilized by the owner, Joseph Wilde, for a store, post office, hotel, and residence.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
