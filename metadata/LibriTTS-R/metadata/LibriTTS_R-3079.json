        "speaker_id": "LibriTTS_R-3079",
        "content": "\"I'll swim to the rock!\" he said to his companion, and Oak laughed loudly.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
