        "speaker_id": "LibriTTS_R-3079",
        "content": "But there was something else in sight.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3079_164971_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3079/164971/3079_164971_000007_000003.wav",
        "speaker_id": "LibriTTS_R-3079",
        "content": "She was fishing diligently.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3079_164971_000007_000005",
