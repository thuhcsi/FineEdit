        "speaker_id": "LibriTTS_R-3079",
        "content": "Neither of the youths was yet so badly stricken.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
