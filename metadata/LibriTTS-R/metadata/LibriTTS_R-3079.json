        "speaker_id": "LibriTTS_R-3079",
        "content": "It was but a matter of endurance, he chuckled to himself.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3079_164971_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3079/164971/3079_164971_000016_000004.wav",
        "speaker_id": "LibriTTS_R-3079",
        "content": "How could a woman outswim a man like him?",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
