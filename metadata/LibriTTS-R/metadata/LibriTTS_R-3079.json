        "speaker_id": "LibriTTS_R-3079",
        "content": "All this time the girl had been eyeing every motion closely.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
