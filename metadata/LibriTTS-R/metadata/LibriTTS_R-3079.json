        "speaker_id": "LibriTTS_R-3079",
        "content": "Along the bank ran the laughing and shouting Oak.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
