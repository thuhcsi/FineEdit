        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3079/164971/3079_164971_000005_000007.wav",
        "speaker_id": "LibriTTS_R-3079",
        "content": "They were accustomed to it, for it was part of the record of every year.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
