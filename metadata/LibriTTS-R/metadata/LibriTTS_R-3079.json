        "speaker_id": "LibriTTS_R-3079",
        "content": "And then she taught him something!",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
