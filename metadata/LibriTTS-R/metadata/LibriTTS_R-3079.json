        "speaker_id": "LibriTTS_R-3079",
        "content": "The ordinary young woman of the Shell People did not worry when away from land.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
