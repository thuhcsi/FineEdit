        "speaker_id": "LibriTTS_R-3079",
        "content": "They were not destined to fish that day.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
