        "speaker_id": "LibriTTS_R-3079",
        "content": "His thought was only what now made up an overmastering aim.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3079_164971_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3079/164971/3079_164971_000015_000004.wav",
        "speaker_id": "LibriTTS_R-3079",
        "content": "He must reach and seize upon the girl before him!",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3079_164971_000016_000003",
