        "speaker_id": "LibriTTS_R-3079",
        "content": "None of these boats could sink, and the man of the time was quite at home in the water.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3079_164971_000004_000005",
