        "speaker_id": "LibriTTS_R-3079",
        "content": "They were late when, after swimming the creek, they reached the Shell village and there learned that the party had already gone.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
