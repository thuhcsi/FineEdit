        "speaker_id": "LibriTTS_R-3079",
        "content": "SHE BUT FISHED AWAY DEMURELY]",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3079_164971_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3079/164971/3079_164971_000010_000001.wav",
        "speaker_id": "LibriTTS_R-3079",
        "content": "He held no defined wish to carry her away to a new home with him, but there arose a feeling that he wanted to know her better.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
