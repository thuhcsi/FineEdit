        "speaker_id": "LibriTTS_R-3977",
        "content": "To what this appearance was owing I cannot tell, and indeed I did not examine into it.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
