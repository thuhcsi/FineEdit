        "speaker_id": "LibriTTS_R-5652",
        "content": "With Cosette's garter, Homer would construct the Iliad.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
