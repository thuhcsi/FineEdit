        "speaker_id": "LibriTTS_R-5652",
        "content": "They said what was wanted and they said it with zeal.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
