        "speaker_id": "LibriTTS_R-5652",
        "content": "The dreams of your bourgeois who set up, as they express it: a pretty boudoir freshly decorated, violet, ebony and calico.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
