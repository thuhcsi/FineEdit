        "speaker_id": "LibriTTS_R-5652",
        "content": "Ah! it is true, I regret the grace of the ancient manners.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
