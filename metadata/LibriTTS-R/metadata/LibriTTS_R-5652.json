        "speaker_id": "LibriTTS_R-5652",
        "content": "He extricated Cosette from all difficulties.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
