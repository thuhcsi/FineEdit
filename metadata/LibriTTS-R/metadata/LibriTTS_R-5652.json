        "speaker_id": "LibriTTS_R-5652",
        "content": "Moreover, the six hundred thousand francs had settled the elderly spinster's indecision.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
