        "speaker_id": "LibriTTS_R-5652",
        "content": "\"The wonderful, beautiful girl!\" he exclaimed.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
