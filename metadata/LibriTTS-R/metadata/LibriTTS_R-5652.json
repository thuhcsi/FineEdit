        "speaker_id": "LibriTTS_R-5652",
        "content": "As soon as new faith in life is given, and given even where a sincere prognosis must be a sad one, a great and not seldom unexpected improvement is secured.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
