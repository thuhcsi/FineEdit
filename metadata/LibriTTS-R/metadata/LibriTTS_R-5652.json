        "speaker_id": "LibriTTS_R-5652",
        "content": "Learn this: joy is not only joyous; it is great.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
