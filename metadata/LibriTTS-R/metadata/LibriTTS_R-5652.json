    {
        "item_name": "LibriTTS_R-5652_19215_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5652/19215/5652_19215_000031_000002.wav",
        "speaker_id": "LibriTTS_R-5652",
        "content": "You smell nothing of life.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
