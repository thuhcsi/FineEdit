        "speaker_id": "LibriTTS_R-5652",
        "content": "Again everything depends upon the experience and tact of the physician.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
