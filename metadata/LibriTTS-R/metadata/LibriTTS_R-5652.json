        "speaker_id": "LibriTTS_R-5652",
        "content": "Cosette became in the eyes of the law, Mademoiselle Euphrasie Fauchelevent.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
