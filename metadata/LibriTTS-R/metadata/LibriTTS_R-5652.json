        "speaker_id": "LibriTTS_R-5652",
        "content": "\"No,\" replied Cosette, \"but it seems to me that the good God is caring for us.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
