        "speaker_id": "LibriTTS_R-5652",
        "content": "My friends, in bygone days, in those amiable days of yore, people married wisely; they had a good contract, and then they had a good carouse.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5652_19215_000026_000033",
