        "speaker_id": "LibriTTS_R-5652",
        "content": "at being petty.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
