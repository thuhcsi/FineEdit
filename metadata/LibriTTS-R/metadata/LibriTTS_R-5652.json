        "speaker_id": "LibriTTS_R-5652",
        "content": "There is no one for whom there is not a chance for work in our social fabric.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
