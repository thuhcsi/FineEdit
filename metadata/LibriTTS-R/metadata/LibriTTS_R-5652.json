        "speaker_id": "LibriTTS_R-5652",
        "content": "Fetch me Phyllis crowned with corn flowers, and add a hundred thousand francs income.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
