        "speaker_id": "LibriTTS_R-5652",
        "content": "Jean Valjean did everything, smoothed away every difficulty, arranged everything, made everything easy.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
