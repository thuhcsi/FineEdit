        "speaker_id": "LibriTTS_R-5652",
        "content": "Only the nervous system cannot so easily be adjusted to the new regime.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
