        "speaker_id": "LibriTTS_R-5652",
        "content": "Voluntary effort is needed, and this is the field where the psychotherapist must put in his most intelligent effort.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
