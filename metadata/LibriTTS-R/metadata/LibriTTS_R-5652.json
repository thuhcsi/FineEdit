        "speaker_id": "LibriTTS_R-5652",
        "content": "He who loves well lashes well.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
