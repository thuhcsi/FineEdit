        "speaker_id": "LibriTTS_R-5652",
        "content": "He would put in his poem, a loquacious old fellow, like me, and he would call him Nestor.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
