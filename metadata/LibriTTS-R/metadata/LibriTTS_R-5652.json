        "speaker_id": "LibriTTS_R-5652",
        "content": "Nevertheless, she continued to call Jean Valjean: Father.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
