        "speaker_id": "LibriTTS_R-5652",
        "content": "Neither any bad, nor any good odor.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5652_19215_000032_000000",
