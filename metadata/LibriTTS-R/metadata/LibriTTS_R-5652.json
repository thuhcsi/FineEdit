        "speaker_id": "LibriTTS_R-5652",
        "content": "The boy may pass as all right if we meet him at a ball; only his tutor knows the whole misery.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
