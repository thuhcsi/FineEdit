        "speaker_id": "LibriTTS_R-5652",
        "content": "Yet mere flippant excitement and superficial entertainment is nothing but a cheap counterfeit of what is needed.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
