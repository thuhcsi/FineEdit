[
    {
        "item_name": "LibriTTS_R-6993_83606_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "THE IDEA OF GOD.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000007_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "If we accept the definition that mythology is the idea of God expressed in symbol, figure, and narrative, and always struggling toward a clearer utterance, it is well not only to trace this idea in its very earliest embodiment in language, but also, for the sake of comparison, to ask what is its latest and most approved expression.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000007_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "He has shown that our reason, dwelling on the facts of experience, constantly seeks the principles which connect them together, and only rests satisfied in the conviction that there is a highest and first principle which reconciles all their discrepancies and binds them into one.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000007_000004.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "It must be true, for it is evolved from the laws of reason, our only test of truth. Furthermore, the sense of personality and the voice of conscience, analyzed to their sources, can only be explained by the assumption of an infinite personality and an absolute standard of right.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000008_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "In every heart was an altar to the Unknown God.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000008_000004.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "We are speaking of a people little capable of abstraction.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000008_000005.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The exhibitions of force in nature seemed to them the manifestations of that mysterious power felt by their self consciousness; to combine these various manifestations and recognize them as the operations of one personality, was a step not easily taken.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000008_000006.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Yet He is not far from every one of us.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000009_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Therefore a word is usually found in their languages analogous to none in any European tongue, a word comprehending all manifestations of the unseen world, yet conveying no sense of personal unity.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000010_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The heavens, the upper regions, are in every religion the supposed abode of the divine.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000010_000004.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "There the sun and bright stars sojourn, emblems of glory and stability.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000011_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Numerous languages bear trace of this.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000011_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The Latin Deus, the Greek Zeus, the Sanscrit Dyaus, the Chinese Tien, all originally meant the sky above, and our own word heaven is often employed synonymously with God.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000011_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "There is at first no personification in these expressions.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000011_000004.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "They embrace all unseen agencies, they are void of personality, and yet to the illogical primitive man there is nothing contradictory in making them the object of his prayers.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "This last expression leads to another train of thought.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "As the philosopher, pondering on the workings of self consciousness, recognizes that various pathways lead up to God, so the primitive man, in forming his language, sometimes trod one, sometimes another.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "This firm belief has left its impress on language in the names devised to express the supernal, the spiritual world.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000008.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Etymologically, in fact, ghosts and gusts, breaths and breezes, the Great Spirit and the Great Wind, are one and the same.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000009.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "It is easy to guess the reason of this.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000010.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The soul is the life, the life is the breath.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000011.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Invisible, imponderable, quickening with vigorous motion, slackening in rest and sleep, passing quite away in death, it is the most obvious sign of life.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000013_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000013_000013.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "But the breath is nothing but wind. How easy, therefore, to look upon the wind that moves up and down and to and fro upon the earth, that carries the clouds, itself unseen, that calls forth the terrible tempests and the various seasons, as the breath, the spirit of God, as God himself?",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000014_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Armed with these analogies, we turn to the primitive tongues of America, and find them there as distinct as in the Old World.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000015_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The descent is, indeed, almost imperceptible which leads to the personification of the wind as God, which merges this manifestation of life and power in one with its unseen, unknown cause.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000016_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "As if man ever did or ever could draw the idea of God from nature!",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000016_000004.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "In the identity of wind with breath, of breath with life, of life with soul, of soul with God, lies the far deeper and far truer reason, whose insensible development I have here traced, in outline indeed, but confirmed by the evidence of language itself.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000017_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Let none of these expressions, however, be construed to prove the distinct recognition of One Supreme Being.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000017_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Of monotheism either as displayed in the one personal definite God of the Semitic races, or in the dim pantheistic sense of the Brahmins, there was not a single instance on the American continent.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000017_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "How could they expect it?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000017_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000017_000006.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "In most instances they are entirely of modern origin, coined at the suggestion of missionaries, applied to the white man's God.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83606_000017_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83606/6993_83606_000017_000007.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Very rarely do they bring any conception of personality to the native mind, very rarely do they signify any object of worship, perhaps never did in the olden times.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000000_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Does he wish to express still more forcibly this sentiment, he doubles the word, or prefixes an adjective, or adds an affix, as the genius of his language may dictate.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000000_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "But it still remains to him but an unapplied abstraction, a mere category of thought, a frame for the All.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000000_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "It is never the object of veneration or sacrifice, no myth brings it down to his comprehension, it is not installed in his temples.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000001_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "It is related that about the year fourteen forty, at a grand religious council held at the consecration of the newly built temple of the Sun at Cuzco, the Inca Yupanqui rose before the assembled multitude and spoke somewhat as follows:--",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000002_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "\"Many say that the Sun is the Maker of all things.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000002_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Now many things happen when the Sun is absent; therefore he cannot be the universal creator.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000002_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "And that he is alive at all is doubtful, for his trips do not tire him.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000002_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000002_000005.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "He is like a tethered beast who makes a daily round under the eye of a master; he is like an arrow, which must go whither it is sent, not whither it wishes.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000004_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "No better success attended the attempt of Nezahuatl, lord of Tezcuco, which took place about the same time.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000004_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "At length, in indignation and despair, the prince exclaimed, \"Verily, these gods that I am adoring, what are they but idols of stone without speech or feeling?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000004_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "They could not have made the beauty of the heaven, the sun, the moon, and the stars which adorn it, and which light the earth, with its countless streams, its fountains and waters, its trees and plants, and its various inhabitants.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "In neither case, be it observed, was any attempt made to substitute another and purer religion for the popular one.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000005_000004.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "They prove something in regard to a consciousness of divinity hedging us about, but nothing at all in favor of a recognition of one God; they exemplify how profound is the conviction of a highest and first principle, but they do not offer the least reason to surmise that this was a living reality in doctrine or practice.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The confusion of these distinct ideas has led to much misconception of the native creeds.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000006_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "This notion, which has its historical origin among the Parsees of ancient Iran, is unknown to savage nations.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000007_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "This view, which has obtained without question in every work on the native religions of America, has arisen partly from habits of thought difficult to break, partly from mistranslations of native words, partly from the foolish axiom of the early missionaries, \"The gods of the gentiles are devils.\" Yet their own writings furnish conclusive proof that no such distinction existed out of their own fancies.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "A passage often quoted in support of this mistaken view is one in Winslow's \"Good News from New England,\" written in sixteen twenty two.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000009_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "So in many instances it turns out that what has been reported to be the evil divinity of a nation, to whom they pray to the neglect of a better one, is in reality the highest power they recognize.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000011_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Writers anxious to discover Jewish or Christian analogies, forcibly construed myths to suit their pet theories, and for indolent observers it was convenient to catalogue their gods in antithetical classes.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000012_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Perhaps no myth has been so often quoted in its confirmation as that of the ancient Iroquois, which narrates the conflict between the first two brothers of our race.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000012_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "It is of undoubted native origin and venerable antiquity.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000012_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "At length the Good Mind turned upon his brother in anger, and crushed him into the earth.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "After a prolonged struggle, which brought on the general deluge and the destruction of the world, he won the victory.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000014_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "They narrate the struggles between the rulers of the upper and the nether world, the descent of the former into Xibalba, the Realm of Phantoms, and their victory over its lords, One Death and Seven Deaths.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000014_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The writer adds of the latter, who clearly represent to his mind the Evil One and his adjutants, \"in the old times they did not have much power; they were but annoyers and opposers of men, and in truth they were not regarded as gods.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000014_000003.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "But when they appeared it was terrible.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000015_000000.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "A little reflection will convince the most incredulous that any such dualism as has been fancied to exist in the native religions, could not have been of indigenous growth.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000015_000001.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "The gods of the primitive man are beings of thoroughly human physiognomy, painted with colors furnished by intercourse with his fellows.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000015_000002.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "These are his enemies or his friends, as he conciliates or insults them.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000015_000004.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Personal, family, or national feuds render some more inimical than others, but always from a desire to guard their own interests, never out of a delight in evil for its own sake.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6993_83607_000015_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6993/83607/6993_83607_000015_000006.wav",
        "speaker_id": "LibriTTS_R-6993",
        "content": "Moral dualism can only arise in minds where the ideas of good and evil are not synonymous with those of pleasure and pain, for the conception of a wholly good or a wholly evil nature requires the use of these terms in their higher, ethical sense.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    }
]