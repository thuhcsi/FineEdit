        "speaker_id": "LibriTTS_R-6111",
        "content": "This we see from the very nature of life itself.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
