    },
    {
        "item_name": "LibriTTS_R-6111_59777_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6111/59777/6111_59777_000005_000005.wav",
        "speaker_id": "LibriTTS_R-6111",
        "content": "The seed, lying in the granary, has life, but it is not living.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
