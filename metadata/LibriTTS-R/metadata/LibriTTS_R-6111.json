        "speaker_id": "LibriTTS_R-6111",
        "content": "Man is a thinking center, capable of originating thought; and as he does not know everything, he makes mistakes and thinks error.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
