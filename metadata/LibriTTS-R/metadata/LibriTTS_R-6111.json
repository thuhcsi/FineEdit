        "speaker_id": "LibriTTS_R-6111",
        "content": "Life, by living, increases.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
