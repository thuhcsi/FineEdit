    },
    {
        "item_name": "LibriTTS_R-6111_59777_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6111/59777/6111_59777_000011_000002.wav",
        "speaker_id": "LibriTTS_R-6111",
        "content": "That which lives in man is always seeking to live more; and since man lives most when he is well, the Principle of Nature in him can seek only health.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
