        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6111/59777/6111_59777_000007_000000.wav",
        "speaker_id": "LibriTTS_R-6111",
        "content": "Life cannot live without increasing, and the fundamental impulse of life is to live.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
