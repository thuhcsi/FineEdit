    },
    {
        "item_name": "LibriTTS_R-6111_59777_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6111/59777/6111_59777_000010_000000.wav",
        "speaker_id": "LibriTTS_R-6111",
        "content": "This must be so, because That which lives in man is seeking more life.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
