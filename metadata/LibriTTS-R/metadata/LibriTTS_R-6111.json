        "speaker_id": "LibriTTS_R-6111",
        "content": "Not knowing everything, he believes things to be true which are not true.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
