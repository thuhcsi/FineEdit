        "speaker_id": "LibriTTS_R-6111",
        "content": "Think of yourself at all times as realizing conception; as being a strong and perfectly healthy personage; and do not harbor a contrary thought.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6111_59779_000007_000000",
