        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6111/59791/6111_59791_000008_000007.wav",
        "speaker_id": "LibriTTS_R-6111",
        "content": "Fix your thoughts, with confidence, on the Principle of Health which is making such conditions within you that pain will soon be unnecessary.",
