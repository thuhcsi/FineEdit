        "speaker_id": "LibriTTS_R-6111",
        "content": "This is not natural, or a part of the plan of nature.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
