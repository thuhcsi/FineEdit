        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3866/173230/3866_173230_000049_000001.wav",
        "speaker_id": "LibriTTS_R-3866",
        "content": "His eyes dropped before hers, and his dark color deepened.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
