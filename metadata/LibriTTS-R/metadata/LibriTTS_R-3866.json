        "speaker_id": "LibriTTS_R-3866",
        "content": "My pride (Heaven help me, I was brought up like a gentlewoman, and I have sensibilities that are not blunted even yet!)--my pride got the better of me, and I left my place.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
