        "speaker_id": "LibriTTS_R-3866",
        "content": "They went on toward the town.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
