        "speaker_id": "LibriTTS_R-3866",
        "content": "What could I do?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
