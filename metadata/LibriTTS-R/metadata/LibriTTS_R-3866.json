        "speaker_id": "LibriTTS_R-3866",
        "content": "She drew back from it, after a moment's absorption in her own thoughts, with a start of terror.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
