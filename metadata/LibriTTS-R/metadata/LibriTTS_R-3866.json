        "speaker_id": "LibriTTS_R-3866",
        "content": "Let us go back to what we were talking about.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
