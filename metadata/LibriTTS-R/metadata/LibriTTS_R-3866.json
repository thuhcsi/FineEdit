        "speaker_id": "LibriTTS_R-3866",
        "content": "\"Pray excuse my anxiety, Miss Gwilt: Allan's good name is as dear to me as my own!\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
