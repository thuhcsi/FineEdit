        "speaker_id": "LibriTTS_R-3866",
        "content": "She sauntered on a few steps toward the figure advancing along the road. The spy followed her close.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
