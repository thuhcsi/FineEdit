        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3866/173230/3866_173230_000061_000008.wav",
        "speaker_id": "LibriTTS_R-3866",
        "content": "Let me go and clear it up at once.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
