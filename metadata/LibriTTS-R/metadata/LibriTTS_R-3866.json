        "speaker_id": "LibriTTS_R-3866",
        "content": "She seemed to him to be eight years old.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
