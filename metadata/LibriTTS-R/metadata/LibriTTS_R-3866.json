        "speaker_id": "LibriTTS_R-3866",
        "content": "\"If the man told you that, the man lied.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3866_173230_000061_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3866/173230/3866_173230_000061_000002.wav",
        "speaker_id": "LibriTTS_R-3866",
        "content": "I beg your pardon, Miss Gwilt; I beg your pardon from the bottom of my heart.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
