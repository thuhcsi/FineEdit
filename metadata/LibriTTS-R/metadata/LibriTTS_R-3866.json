        "speaker_id": "LibriTTS_R-3866",
        "content": "We are both victims.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
