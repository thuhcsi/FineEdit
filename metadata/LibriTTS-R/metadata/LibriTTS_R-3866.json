        "speaker_id": "LibriTTS_R-3866",
        "content": "The front of the house was dark, and closed for the night.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
