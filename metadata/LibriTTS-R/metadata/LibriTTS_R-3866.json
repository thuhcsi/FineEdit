        "speaker_id": "LibriTTS_R-3866",
        "content": "\"I am treating you like an old friend.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
