        "speaker_id": "LibriTTS_R-3866",
        "content": "\"Miss Gwilt!\" he exclaimed, and mechanically held out his hand.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
