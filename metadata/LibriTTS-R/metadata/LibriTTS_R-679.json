        "speaker_id": "LibriTTS_R-679",
        "content": "Millard entered the studio as I glanced about for him.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
