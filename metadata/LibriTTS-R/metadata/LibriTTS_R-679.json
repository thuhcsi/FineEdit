        "speaker_id": "LibriTTS_R-679",
        "content": "Shirley had left the studio floor, apparently to go to his dressing room.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
