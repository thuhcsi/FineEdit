        "speaker_id": "LibriTTS_R-679",
        "content": "\"Oh!\" I remembered.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
