        "speaker_id": "LibriTTS_R-679",
        "content": "\"You don't want Millard to get away,\" I whispered.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
