        "speaker_id": "LibriTTS_R-679",
        "content": "Under the lights the entire set sparkled with a tawdry garishness apt to fool those uninitiated into the secrets of photography.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
