        "speaker_id": "LibriTTS_R-679",
        "content": "Obviously fragile scenery would seem as heavy and substantial as the walls and beams of the finest old mansion.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
