[
    {
        "item_name": "LibriTTS_R-7644_104722_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000000_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "On august twenty first the Englishmen invited the Americans to dinner on the following Saturday.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000000_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "\"The chance is,\" wrote mr Adams, \"that before that time the whole negotiation will be at an end.\" The banquet, however, did come off, and a few more succeeded it; feasts not marked by any great geniality or warmth, except perhaps occasionally warmth of discussion.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000000_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000000_000006.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "\"We so fondly cling to the vain hope of peace, that every new proof of its impossibility operates upon us as a disappointment,\" wrote mr Adams.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000000_000007.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "No amount of pride could altogether conceal the fact that the American Commissioners represented the worsted party, and though they never openly said so even among themselves, yet indirectly they were obliged to recognize the truth.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000001_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "\"I felt so sure that [the home government] would now gladly take the state before the war as the general basis of the peace, that I was prepared to take on me the responsibility of trespassing upon their instructions thus far.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000001_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Not only so, but I would at this moment cheerfully give my life for a peace on this basis.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000001_000002.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "If peace was possible, it would be on no other.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000001_000003.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "I had indeed no hope that the proposal would be accepted.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000002_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "This was not consoling for the representatives of that side which had declared war for the purpose of curing grievances and vindicating alleged rights.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000002_000004.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "I myself think it probable.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "There were, however, some three weeks more of negotiation to be gone through before the consummation was actually achieved, and the ill blood seemed to increase as the end was approached.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The differences between the American Commissioners waxed especially serious concerning the fisheries and the navigation of the Mississippi.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000003.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "This the English Commissioners denied.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000004.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "mr Adams said it was only an exchange of privileges presumably equivalent.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000005.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "mr Clay, however, was firmly resolved to prevent all stipulations admitting such a right of navigation, and the better to do so he was quite willing to let the fisheries go.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000009.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "He was utterly averse to admitting it as an equivalent for a stipulation securing the contested part of the fisheries.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000011.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "He should be glad to get it if he could, but he was sure the British would not ultimately grant it.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000012.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "That the navigation of the Mississippi, on the other hand, was an object of immense importance, and he could see no sort of reason for granting it as an equivalent for the fisheries.\" Thus spoke the representative of the West.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000013.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The New Englander-the son of the man whose exertions had been chiefly instrumental in originally obtaining the grant of the Northeastern fishery privileges-naturally went to the other extreme.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000014.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "He thought \"the British right of navigating the Mississippi to be as nothing, considered as a grant from us.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000003_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000003_000018.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "It is evident that the United States could ill have spared either mr Adams or mr Clay from the negotiation, and the joinder of the two, however fraught with discomfort to themselves, well served substantial American interests.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "mr Adams thought the British perfidious, and suspected them of not entertaining any honest intention of concluding a peace.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000005_000003.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The British troops had taken and held Moose Island in Passamaquoddy Bay, the rightful ownership of which was in dispute.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000005_000004.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The title was to be settled by arbitrators.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000005_000005.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "But the question, whether the British should restore possession of the island pending the arbitration, aroused bitter discussion.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000005_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000005_000011.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The next day mr Clay notified his colleagues that they were going \"to make a damned bad treaty, and he did not know whether he would sign it or not;\" and mr Adams also said that he saw that the rest had made up their minds \"at last to yield the fishery point,\" in which case he also could not sign the treaty.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000005_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000005_000012.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "On the following day, however, the Americans were surprised by receiving a note from the British Commissioners, wherein they made the substantial concession of omitting from the treaty all reference to the fisheries and the navigation of the Mississippi.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000005_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000005_000013.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "But mr Clay, on reading the note, \"manifested some chagrin,\" and \"still talked of breaking off the negotiation,\" even asking mr Adams to join him in so doing, which request, however, mr Adams very reasonably refused.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000005_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000005_000014.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "mr Clay had also been anxious to stand out for a distinct abandonment of the alleged right of impressment; but upon this point he found none of his colleagues ready to back him, and he was compelled perforce to yield.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "It was an astonishing as well as a happy result.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000006_000002.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Dissension seemed to have become the mother of amity; and antipathies were mere preliminaries to a good understanding; in diplomacy as in marriage it had worked well to begin with a little aversion.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000006_000003.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "But, in truth, this consummation was largely due to what had been going on in the English Cabinet.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000006_000004.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "At the outset Lord Castlereagh had been very unwilling to conclude peace, and his disposition had found expression in the original intolerable terms prepared by the British Commissioners.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000006_000005.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "But Lord Liverpool had been equally solicitous on the other side, and was said even to have tendered his resignation to the Prince Regent, if an accommodation should not be effected.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000006_000006.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "His endeavors were fortunately aided by events in Europe.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000006_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000006_000009.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Hence, at last, came such concessions as satisfied the Americans.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Such were, in substance, the only points touched upon by this document.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Of the many subjects mooted between the negotiators scarcely any had survived the fierce contests which had been waged concerning them.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000007_000005.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The Americans were content to have nothing said about impressment; nor was any one of the many illegal rights exercised by England formally abandoned.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000007_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000007_000007.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "For the future it was hardly to be feared that she would again undertake to pursue a policy against which it was evident that the United States were willing to conduct a serious war.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000007_000008.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "There was, however, no provision for indemnification.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Upon a fair consideration, it must be admitted that though the treaty was silent upon all the points which the United States had made war for the purpose of enforcing, yet the country had every reason to be gratified with the result of the negotiation.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The five Commissioners had done themselves ample credit.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000005.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "But that fortunate battle was not fought until a few days after the eight Commissioners had signed their compact.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000006.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "It is an interesting illustration of the slowness of communication which our forefathers had to endure, that the treaty crossed the Atlantic in a sailing ship in time to travel through much of the country simultaneously with the report of this farewell victory.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000007.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Two such good pieces of news coming together set the people wild with delight.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000008.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Even on the dry pages of Niles's \"Weekly Register\" occurs the triumphant paragraph: \"Who would not be an American?",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000009.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Long live the Republic!",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000012.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Peace is signed in the arms of victory!\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000013.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "It was natural that most of the ecstasy should be manifested concerning the military triumph, and that the mass of the people should find more pleasure in glorifying General Jackson than in exalting the Commissioners. The value of their work, however, was well proved by the voice of Great Britain.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000014.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "In the London \"Times\" of december thirtieth appeared a most angry tirade against the treaty, with bitter sneers at those who called the peace an \"honorable\" one.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000015.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "England, it was said, \"had attempted to force her principles on America, and had failed.\" Foreign powers would say that the English \"had retired from the combat with the stripes yet bleeding on their backs,--with the recent defeats at Plattsburgh and on Lake Champlain unavenged.\" The most gloomy prognostications of further wars with America when her naval power should have waxed much greater were indulged.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000016.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The loss of prestige in Europe, \"the probable loss of our trans Atlantic provinces,\" were among the results to be anticipated from this treaty into which the English Commissioners had been beguiled by the Americans.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000008_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000008_000017.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "These latter were reviled with an abuse which was really the highest compliment.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "This negotiation had been brought so far towards conclusion by his colleagues before his own arrival that mr Adams had little to do in assisting them to complete it.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000009_000002.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "This little having been done, they departed and left him as Minister at the Court of saint James.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000009_000003.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Thus he fulfilled Washington's prophecy, by reaching the highest rank in the American diplomatic service.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "Of his stay in Great Britain little need be said.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "He had few duties of importance to perform.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000010_000004.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "But he succeeded in obtaining, towards the close of his stay, some slight remission of the severe restrictions placed by England upon our trade with her West Indian colonies.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000010_000005.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "His relations with a cabinet in which the principles of Castlereagh and Canning predominated could hardly be cordial, yet he seems to have been treated with perfect civility.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000010_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000010_000007.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "He remarks of Castlereagh, after one of his first interviews with that nobleman: \"His deportment is sufficiently graceful, and his person is handsome.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000010_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000010_000011.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "The relationship between the mother country and the quondam colonies, especially at that juncture, was such as to render social life intolerably trying to an under paid American minister.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7644_104722_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7644/104722/7644_104722_000011_000000.wav",
        "speaker_id": "LibriTTS_R-7644",
        "content": "mr Adams remained in England until june fifteenth eighteen seventeen, when he sailed from Cowes, closing forever his long and honorable diplomatic career, and bidding his last farewell to Europe.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    }
]