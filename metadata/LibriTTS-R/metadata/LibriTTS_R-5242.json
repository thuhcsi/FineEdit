        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5242/35926/5242_35926_000035_000000.wav",
        "speaker_id": "LibriTTS_R-5242",
        "content": "Although he had been unable to see him drop the poison into the cup, a glance at Hafela told Owen that it was there; for though he kept his face under control, he could not prevent his hands from twitching or the sweat from starting upon his brow and breast.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5242_35926_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5242/35926/5242_35926_000037_000000.wav",
        "speaker_id": "LibriTTS_R-5242",
        "content": "\"In this cup, which I drink on behalf of the nation, I pledge you, my people.\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
