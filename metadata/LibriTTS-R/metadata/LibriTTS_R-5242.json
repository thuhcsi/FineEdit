        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5242/35926/5242_35926_000039_000005.wav",
        "speaker_id": "LibriTTS_R-5242",
        "content": "To act now would be madness, his time had not yet come.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
