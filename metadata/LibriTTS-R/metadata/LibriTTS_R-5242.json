        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5242/35926/5242_35926_000039_000002.wav",
        "speaker_id": "LibriTTS_R-5242",
        "content": "When the last of them had died away, the king brought the cup to the level of his lips.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
