[
    {
        "item_name": "LibriTTS_R-1492_11251_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "CHAPTER five-WHAT SNOBS ADMIRE",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Now let us consider how difficult it is even for great men to escape from being Snobs.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "It is very well for the reader, whose fine feelings are disgusted by the assertion that Kings, Princes, Lords, are Snobs, to say 'You are confessedly a Snob yourself.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000006_000003.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "It is impossible for ANY Briton, perhaps, not to be a Snob in some degree.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000006_000005.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "If I have pointed out the disease, let us hope that other scientific characters may discover the remedy.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "As I was discoursing with my friend Eugenio in this impressive way, Lord Buckram passed us, the son of the Marquis of Bagwig, and knocked at the door of the family mansion in Red Lion Square.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000008_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "His noble father and mother occupied, as everybody knows, distinguished posts in the Courts of late Sovereigns.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000008_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The Marquis was Lord of the Pantry, and her Ladyship, Lady of the Powder Closet to Queen Charlotte.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000008_000003.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Buck (as I call him, for we are very familiar) gave me a nod as he passed, and I proceeded to show Eugenio how it was impossible that this nobleman should not be one of ourselves, having been practised upon by Snobs all his life.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "His parents resolved to give him a public education, and sent him to school at the earliest possible period.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The Reverend Otto Rose, d d, Principal of the Preparatory Academy for young noblemen and gentlemen, Richmond Lodge, took this little Lord in hand, and fell down and worshipped him.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000009_000004.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "He made Lord Buckram a bait for such a multiplicity of pupils, that a new wing was built to Richmond Lodge, and thirty five new little white dimity beds were added to the establishment.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000009_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000009_000006.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Rose used to take out the little Lord in the one horse chaise with her when she paid visits, until the Rector's lady and the Surgeon's wife almost died with envy.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000009_000007.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "His own son and Lord Buckram having been discovered robbing an orchard together, the Doctor flogged his own flesh and blood most unmercifully for leading the young Lord astray.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000009_000008.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "He parted from him with tears.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "At Eton, a great deal of Snobbishness was thrashed out of Lord Buckram, and he was birched with perfect impartiality.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Even there, however, a select band of sucking tuft hunters followed him.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Young Croesus lent him three and twenty bran new sovereigns out of his father's bank.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000010_000004.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Boys are not ALL toadies in the morning of life.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "But when he went to the University, crowds of toadies sprawled over him.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The tutors toadied him.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The fellows in hall paid him great clumsy compliments.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000003.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The Dean never remarked his absence from Chapel, or heard any noise issuing from his rooms.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000004.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "A number of respectable young fellows, (it is among the respectable, the Baker Street class, that Snobbishness flourishes, more than among any set of people in England)--a number of these clung to him like leeches.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000005.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "There was no end now to Croesus's loans of money; and Buckram couldn't ride out with the hounds, but Snaily (a timid creature by nature) was in the field, and would take any leap at which his friend chose to ride.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000006.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Young Rose came up to the same College, having been kept back for that express purpose by his father.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000007.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "He spent a quarter's allowance in giving Buckram a single dinner; but he knew there was always pardon for him for extravagance in such a cause; and a ten pound note always came to him from home when he mentioned Buckram's name in a letter.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000008.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "What wild visions entered the brains of mrs Podge and Miss Podge, the wife and daughter of the Principal of Lord Buckram's College, I don't know, but that reverend old gentleman was too profound a flunkey by nature ever for one minute to think that a child of his could marry a nobleman.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000011_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000011_000009.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "He therefore hastened on his daughter's union with Professor Crab.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "When Lord Buckram, after taking his honorary degree, (for Alma Mater is a Snob, too, and truckles to a Lord like the rest,)--when Lord Buckram went abroad to finish his education, you all know what dangers he ran, and what numbers of caps were set at him.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "If perseverance and forty thousand pounds down could have tempted him, Miss Lydia Croesus would certainly have been Lady Buckram.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "If we were to describe him it would be personal.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000014_000003.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Suppose he is an honest, highminded gentleman; so much the better for himself.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000014_000004.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "But he may be an ass, and yet respected; or a ruffian, and yet be exceedingly popular; or a rogue, and yet excuses will be found for him.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1492_11251_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/11251/1492_11251_000014_000005.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Snobs will still worship him.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_174461_000003_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/174461/1492_174461_000003_000018.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Such an origin as our little visitor's affected him visibly as dazzling, and I felt justified after a while, in stealing away into the shade.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000000_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "CHAPTER eleven.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The transaction concluded, the two still remained seated, falling into familiar conversation, by degrees verging into that confidential sort of sympathetic silence, the last refinement and luxury of unaffected good feeling.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "A kind of social superstition, to suppose that to be truly friendly one must be saying friendly words all the time, any more than be doing friendly deeds continually.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "True friendliness, like true religion, being in a sort independent of works.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "At length, the good merchant, whose eyes were pensively resting upon the gay tables in the distance, broke the spell by saying that, from the spectacle before them, one would little divine what other quarters of the boat might reveal.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "To such a degree, indeed, that he had no trust in anything, not even in his parchment bonds, which, the better to preserve from the tooth of time, he had packed down and sealed up, like brandy peaches, in a tin case of spirits.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The worthy man proceeded at some length with these dispiriting particulars.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Nor would his cheery companion wholly deny that there might be a point of view from which such a case of extreme want of confidence might, to the humane mind, present features not altogether welcome as wine and olives after dinner.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Still, he was not without compensatory considerations, and, upon the whole, took his companion to task for evincing what, in a good-natured, round about way, he hinted to be a somewhat jaundiced sentimentality.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Nature, he added, in Shakespeare's words, had meal and bran; and, rightly regarded, the bran in its way was not to be condemned.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "The other was not disposed to question the justice of Shakespeare's thought, but would hardly admit the propriety of the application in this instance, much less of the comment.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000005_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "He knew nothing about the cripple, nor had seen him, but ventured to surmise that, could one but get at the real state of his heart, he would be found about as happy as most men, if not, in fact, full as happy as the speaker himself.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "It was improbable, therefore, that a negro, however reduced to his stumps by fortune, could be ever thrown off the legs of a laughing philosophy.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "CHAPTER twelve.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Goneril was young, in person lithe and straight, too straight, indeed, for a woman, a complexion naturally rosy, and which would have been charmingly so, but for a certain hardness and bakedness, like that of the glazed colors on stone ware.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Her hair was of a deep, rich chestnut, but worn in close, short curls all round her head.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000011_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Her Indian figure was not without its impairing effect on her bust, while her mouth would have been pretty but for a trace of moustache.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "It was happy for Goneril that her more striking peculiarities were less of the person than of temper and taste.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "She liked lemons, and the only kind of candy she loved were little dried sticks of blue clay, secretly carried in her pocket.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000003.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Withal she had hard, steady health like a squaw's, with as firm a spirit and resolution.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000005.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Lithe though she was, she loved supineness, but upon occasion could endure like a stoic.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000006.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "She was taciturn, too.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000007.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "From early morning till about three o'clock in the afternoon she would seldom speak-it taking that time to thaw her, by all accounts, into but talking terms with humanity.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000009.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Those who thought they best knew her, often wondered what happiness such a being could take in life, not considering the happiness which is to be had by some natures in the very easy way of simply causing pain to those around them.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000011.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "In a large sense she possessed the virtue of independence of mind.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000014.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Passion is human.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000015.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Like an icicle dagger, Goneril at once stabbed and froze; so at least they said; and when she saw frankness and innocence tyrannized into sad nervousness under her spell, according to the same authority, inly she chewed her blue clay, and you could mark that she chuckled.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000016.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "These peculiarities were strange and unpleasing; but another was alleged, one really incomprehensible.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000012_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000012_000017.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "In company she had a strange way of touching, as by accident, the arm or hand of comely young men, and seemed to reap a secret delight from it, but whether from the humane satisfaction of having given the evil touch, as it is called, or whether it was something else in her, not equally wonderful, but quite as deplorable, remained an enigma.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000002.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "He would shudderingly shun the young gentleman.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000003.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "So that here, to the husband, Goneril's touch had the dread operation of the heathen taboo.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000004.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Now Goneril brooked no chiding.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000005.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "So, at favorable times, he, in a wary manner, and not indelicately, would venture in private interviews gently to make distant allusions to this questionable propensity.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000006.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "She divined him.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000014.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "In vain did his counsel, striving to make out the derangement to be where, in fact, if anywhere, it was, urge that, to hold otherwise, to hold that such a being as Goneril was sane, this was constructively a libel upon womankind.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000015.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "Libel be it.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1492_55449_000013_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1492/55449/1492_55449_000013_000016.wav",
        "speaker_id": "LibriTTS_R-1492",
        "content": "And all ended by the unfortunate man's subsequently getting wind of Goneril's intention to procure him to be permanently committed for a lunatic.",
