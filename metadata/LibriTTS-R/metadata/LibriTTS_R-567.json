        "speaker_id": "LibriTTS_R-567",
        "content": "THE CONTENTS OF THE COFFIN",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
