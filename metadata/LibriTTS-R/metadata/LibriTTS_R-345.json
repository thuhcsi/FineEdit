[
    {
        "item_name": "LibriTTS_R-345_1119_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000006_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Her father had been an attorney in Meryton, and had left her four thousand pounds.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000007_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "She had a sister married to a mr Phillips, who had been a clerk to their father and succeeded him in the business, and a brother settled in London in a respectable line of trade.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000009_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Their visits to mrs Phillips were now productive of the most interesting intelligence.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000011_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"From all that I can collect by your manner of talking, you must be two of the silliest girls in the country.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000011_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I have suspected it some time, but I am now convinced.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000014_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"If my children are silly, I must hope to be always sensible of it.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000020_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "What is it about?",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000020_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "What does he say?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000020_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Well, Jane, make haste and tell us; make haste, my love.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000021_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"It is from Miss Bingley,\" said Jane, and then read it aloud.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000024_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"CAROLINE BINGLEY\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000025_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"With the officers!\" cried Lydia.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000026_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Dining out,\" said mrs Bennet, \"that is very unlucky.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000027_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Can I have the carriage?\" said Jane.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000028_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"No, my dear, you had better go on horseback, because it seems likely to rain; and then you must stay all night.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000029_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"That would be a good scheme,\" said Elizabeth, \"if you were sure that they would not offer to send her home.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000034_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"But if you have got them to day,\" said Elizabeth, \"my mother's purpose will be answered.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000035_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Her hopes were answered; Jane had not been gone long before it rained hard.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000036_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"This was a lucky idea of mine, indeed!\" said mrs Bennet more than once, as if the credit of making it rain were all her own.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000037_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"MY DEAREST LIZZY,--",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000038_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"I find myself very unwell this morning, which, I suppose, is to be imputed to my getting wet through yesterday.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000039_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Well, my dear,\" said mr Bennet, when Elizabeth had read the note aloud, \"if your daughter should have a dangerous fit of illness-if she should die, it would be a comfort to know that it was all in pursuit of mr Bingley, and under your orders.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000040_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Oh!",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000043_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"I shall be very fit to see Jane-which is all I want.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000044_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Is this a hint to me, Lizzy,\" said her father, \"to send for the horses?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000045_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"No, indeed, I do not wish to avoid the walk.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000045_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000045_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I shall be back by dinner.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000047_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"We will go as far as Meryton with you,\" said Catherine and Lydia. Elizabeth accepted their company, and the three young ladies set off together.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000050_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000050_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "She was received, however, very politely by them; and in their brother's manners there was something better than politeness; there was good humour and kindness.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000050_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000050_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "mr Darcy said very little, and mr Hurst nothing at all.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000050_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000050_000004.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "The latter was thinking only of his breakfast.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000051_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000051_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Miss Bennet had slept ill, and though up, was very feverish, and not well enough to leave her room.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000051_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000051_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "She was not equal, however, to much conversation, and when Miss Bingley left them together, could attempt little besides expressions of gratitude for the extraordinary kindness she was treated with.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000051_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000051_000004.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Elizabeth silently attended her.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000052_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000052_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "The advice was followed readily, for the feverish symptoms increased, and her head ached acutely.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1119_000052_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1119/345_1119_000052_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Elizabeth did not quit her room for a moment; nor were the other ladies often absent; the gentlemen being out, they had, in fact, nothing to do elsewhere.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1120_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1120/345_1120_000035_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"I wish it may.\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1120_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1120/345_1120_000042_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"I think she will.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1120_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1120/345_1120_000046_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Yes, all of them, I think.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000001_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Chapter nineteen",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000002_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "The next day opened a new scene at Longbourn.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000002_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Having resolved to do it without loss of time, as his leave of absence extended only to the following Saturday, and having no feelings of diffidence to make it distressing to himself even at the moment, he set about it in a very orderly manner, with all the observances, which he supposed a regular part of the business.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000002_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "On finding mrs Bennet, Elizabeth, and one of the younger girls together, soon after breakfast, he addressed the mother in these words:",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000003_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"May I hope, madam, for your interest with your fair daughter Elizabeth, when I solicit for the honour of a private audience with her in the course of this morning?\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000004_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Before Elizabeth had time for anything but a blush of surprise, mrs Bennet answered instantly, \"Oh dear!--yes-certainly.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000004_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I am sure Lizzy will be very happy-I am sure she can have no objection.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000004_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Come, Kitty, I want you up stairs.\" And, gathering her work together, she was hastening away, when Elizabeth called out:",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000005_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Dear madam, do not go.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000005_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I beg you will not go.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000005_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "mr Collins must excuse me.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000005_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "He can have nothing to say to me that anybody need not hear.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000005_000004.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I am going away myself.\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000007_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Elizabeth would not oppose such an injunction-and a moment's consideration making her also sensible that it would be wisest to get it over as soon and as quietly as possible, she sat down again and tried to conceal, by incessant employment the feelings which were divided between distress and diversion.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000007_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "mrs Bennet and Kitty walked off, and as soon as they were gone, mr Collins began.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000008_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Believe me, my dear Miss Elizabeth, that your modesty, so far from doing you any disservice, rather adds to your other perfections.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000008_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "You can hardly doubt the purport of my discourse, however your natural delicacy may lead you to dissemble; my attentions have been too marked to be mistaken.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000010_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Collins, you must marry.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000010_000005.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "This is my advice.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000010_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000010_000007.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "You will find her manners beyond anything I can describe; and your wit and vivacity, I think, must be acceptable to her, especially when tempered with the silence and respect which her rank will inevitably excite.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000010_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000010_000008.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Thus much for my general intention in favour of matrimony; it remains to be told why my views were directed towards Longbourn instead of my own neighbourhood, where I can assure you there are many amiable young women.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000010_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000010_000011.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "And now nothing remains for me but to assure you in the most animated language of the violence of my affection.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000010_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000010_000013.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "On that head, therefore, I shall be uniformly silent; and you may assure yourself that no ungenerous reproach shall ever pass my lips when we are married.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000012_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"You are too hasty, sir,\" she cried.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000012_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"You forget that I have made no answer.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000012_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Let me do it without further loss of time.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000012_000004.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I am very sensible of the honour of your proposals, but it is impossible for me to do otherwise than to decline them.\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000013_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"I am not now to learn,\" replied mr Collins, with a formal wave of the hand, \"that it is usual with young ladies to reject the addresses of the man whom they secretly mean to accept, when he first applies for their favour; and that sometimes the refusal is repeated a second, or even a third time.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000013_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I am therefore by no means discouraged by what you have just said, and shall hope to lead you to the altar ere long.\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000014_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Upon my word, sir,\" cried Elizabeth, \"your hope is a rather extraordinary one after my declaration.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000014_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I do assure you that I am not one of those young ladies (if such young ladies there are) who are so daring as to risk their happiness on the chance of being asked a second time.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000014_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I am perfectly serious in my refusal.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000014_000004.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Nay, were your friend Lady Catherine to know me, I am persuaded she would find me in every respect ill qualified for the situation.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000015_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "And you may be certain when I have the honour of seeing her again, I shall speak in the very highest terms of your modesty, economy, and other amiable qualification.\"",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000016_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Indeed, mr Collins, all praise of me will be unnecessary.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000016_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "You must give me leave to judge for myself, and pay me the compliment of believing what I say.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000016_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I wish you very happy and very rich, and by refusing your hand, do all in my power to prevent your being otherwise. In making me the offer, you must have satisfied the delicacy of your feelings with regard to my family, and may take possession of Longbourn estate whenever it falls, without any self reproach.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000016_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "This matter may be considered, therefore, as finally settled.\" And rising as she thus spoke, she would have quitted the room, had mr Collins not thus addressed her:",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000018_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"Really, mr Collins,\" cried Elizabeth with some warmth, \"you puzzle me exceedingly.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000019_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"You must give me leave to flatter myself, my dear cousin, that your refusal of my addresses is merely words of course.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000019_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "My reasons for believing it are briefly these: It does not appear to me that my hand is unworthy your acceptance, or that the establishment I can offer would be any other than highly desirable.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000019_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Your portion is unhappily so small that it will in all likelihood undo the effects of your loveliness and amiable qualifications.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000019_000004.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "As I must therefore conclude that you are not serious in your rejection of me, I shall choose to attribute it to your wish of increasing my love by suspense, according to the usual practice of elegant females.\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000020_000001.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I would rather be paid the compliment of being believed sincere.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000020_000002.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "I thank you again and again for the honour you have done me in your proposals, but to accept them is absolutely impossible.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000020_000003.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "My feelings in every respect forbid it.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000020_000004.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Can I speak plainer?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000020_000005.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "Do not consider me now as an elegant female, intending to plague you, but as a rational creature, speaking the truth from her heart.\"",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-345_1129_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/345/1129/345_1129_000021_000000.wav",
        "speaker_id": "LibriTTS_R-345",
        "content": "\"You are uniformly charming!\" cried he, with an air of awkward gallantry; \"and I am persuaded that when sanctioned by the express authority of both your excellent parents, my proposals will not fail of being acceptable.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
