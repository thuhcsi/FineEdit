[
    {
        "item_name": "LibriTTS_R-7208_7768_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000001_000000.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "GENERAL VIEW OF THE REMAINDER OF MY LIFE.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000002_000001.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "I shall, therefore, greatly abridge the chronicle of my subsequent years.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000003_000003.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "From April following to the end of eighteen forty one, my spare time was devoted to a complete rewriting of the book from its commencement.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000003_000004.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "It is in this way that all my books have been composed.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000003_000006.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "I have found great advantages in this system of double redaction.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000003_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000003_000007.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "It combines, better than any other mode of composition, the freshness and vigour of the first conception, with the superior precision and completeness resulting from prolonged thought.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000003_000008.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "In my own case, moreover, I have found that the patience necessary for a careful elaboration of the details of composition and expression, costs much less effort after the entire subject has been once gone through, and the substance of all that I find to say has in some manner, however imperfect, been got upon paper.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000005_000003.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "A treatise, however, on a matter so abstract, could not be expected to be popular; it could only be a book for students, and students on such subjects were not only (at least in England) few, but addicted chiefly to the opposite school of metaphysics, the ontological and \"innate principles\" school.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000005_000004.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "I therefore did not expect that the book would have many readers, or approvers; and looked for little practical effect from it, save that of keeping the tradition unbroken of what I thought a better philosophy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000005_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000005_000009.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "I have never indulged the illusion that the book had made any considerable impression on philosophical opinion.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000005_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000005_000011.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "But the \"System of Logic\" supplies what was much wanted, a text book of the opposite doctrine-that which derives all knowledge from experience, and all moral and intellectual qualities principally from the direction given to the associations.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000005_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000005_000015.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "By the aid of this theory, every inveterate belief and every intense feeling, of which the origin is not remembered, is enabled to dispense with the obligation of justifying itself by reason, and is erected into its own all sufficient voucher and justification.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000005_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000005_000016.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "There never was such an instrument devised for consecrating all deep seated prejudices.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "General society, as now carried on in England, is so insipid an affair, even to the persons who make it what it is, that it is kept up for any reason rather than the pleasure it affords.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000006_000004.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "Those persons of any mental superiority who do otherwise, are, almost without exception, greatly deteriorated by it.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000006_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000006_000007.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "All these circumstances united, made the number very small of those whose society, and still more whose intimacy, I now voluntarily sought.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "Among these, by far the principal was the incomparable friend of whom I have already spoken.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000007_000003.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "For though we did not consider the ordinances of society binding on a subject so entirely personal, we did feel bound that our conduct should be such as in no degree to bring discredit on her husband, nor therefore on herself.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "I had now completely turned back from what there had been of excess in my reaction against Benthamism.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000003.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "I was much more inclined, than I can now approve, to put in abeyance the more decidedly heretical part of my opinions, which I now look upon as almost the only ones, the assertion of which tends in any way to regenerate society.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000008.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "In short, I was a democrat, but not the least of a Socialist.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000011.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "We had not the presumption to suppose that we could already foresee, by what precise form of institutions these objects could most effectually be attained, or at how near or how distant a period they would become practicable.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000012.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "We saw clearly that to render any such social transformation either possible or desirable, an equivalent change of character must take place both in the uncultivated herd who now compose the labouring masses, and in the immense majority of their employers.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000013.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "Both these classes must learn by practice to labour and combine for generous, or at all events for public and social purposes, and not, as hitherto, solely for narrowly interested ones.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000014.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "But the capacity to do this has always existed in mankind, and is not, nor is ever likely to be, extinct.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000016.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "True enough, it is only by slow degrees, and a system of culture prolonged through successive generations, that men in general can be brought up to this point.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000008_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000008_000017.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "But the hindrance is not in the essential constitution of human nature. Interest in the common good is at present so weak a motive in the generality not because it can never be otherwise, but because the mind is not accustomed to dwell on it as it dwells from morning till night on things which tend only to personal advantage.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000009_000002.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "In the first edition the difficulties of Socialism were stated so strongly, that the tone was on the whole that of opposition to it.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "It was commenced in the autumn of eighteen forty five, and was ready for the press before the end of eighteen forty seven.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7768_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7768/7208_7768_000010_000004.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "But the idea was new and strange; there was no English precedent for such a proceeding: and the profound ignorance of English politicians and the English public concerning all social phenomena not generally met with in England (however common elsewhere), made my endeavours an entire failure.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7772_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7772/7208_7772_000008_000005.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "There was much more at stake than only justice to the negroes, imperative as was that consideration.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7772_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7772/7208_7772_000008_000007.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "This question could only be decided by an appeal to the tribunals; and such an appeal the Committee determined to make.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7772_000008_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7772/7208_7772_000008_000011.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "There, however, our success ended, for the Old Bailey Grand jury by throwing out our bill prevented the case from coming to trial.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7208_7772_000008_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7772/7208_7772_000008_000012.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "It was clear that to bring English functionaries to the bar of a criminal court for abuses of power committed against negroes and mulattoes was not a popular proceeding with the English middle classes.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7208_7772_000008_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7208/7772/7208_7772_000008_000014.wav",
        "speaker_id": "LibriTTS_R-7208",
        "content": "We had elicited from the highest criminal judge in the nation an authoritative declaration that the law was what we maintained it to be; and we had given an emphatic warning to those who might be tempted to similar guilt hereafter, that, though they might escape the actual sentence of a criminal tribunal, they were not safe against being put to some trouble and expense in order to avoid it.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    }
]