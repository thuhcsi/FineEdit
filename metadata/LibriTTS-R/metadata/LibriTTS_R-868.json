[
    {
        "item_name": "LibriTTS_R-868_131294_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000002_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Have you heard the Taoist tale of the Taming of the Harp?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000003_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "It reared its head to talk to the stars; its roots struck deep into the earth, mingling their bronzed coils with those of the silver dragon that slept beneath.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000004_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "At last came Peiwoh, the prince of harpists.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000004_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Hark! a tiger roars,--the valley answers again.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000004_000006.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "It is autumn; in the desert night, sharp like a sword gleams the moon upon the frosted grass.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000005_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The forest swayed like an ardent swain deep lost in thought.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000005_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000005_000007.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "I left the harp to choose its theme, and knew not truly whether the harp had been Peiwoh or Peiwoh were the harp.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000006_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "At the magic touch of the beautiful the secret chords of our being are awakened, we vibrate and thrill in response to its call.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000006_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Mind speaks to mind.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000006_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We listen to the unspoken, we gaze upon the unseen.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000006_000006.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The master calls forth notes we know not of. Memories long forgotten all come back to us with a new significance. Hopes stifled by fear, yearnings that we dare not recognise, stand forth in new glory.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000008_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Several of his pupils submitted plays for his approval, but only one of the pieces appealed to him.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000009_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000009_000006.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "In art vanity is equally fatal to sympathetic feeling, whether on the part of the artist or the public.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000010_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "At once he is and is not.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000010_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "He catches a glimpse of Infinity, but words cannot voice his delight, for the eye has no tongue.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000010_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000010_000009.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Rarely was the object exposed to view, and then only to the initiated.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000014_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The name of the artist is more important to them than the quality of the work.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000014_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "As a Chinese critic complained many centuries ago, \"People criticise a picture by their ear.\" It is this lack of genuine appreciation that is responsible for the pseudo classic horrors that to day greet us wherever we turn.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000015_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Another common mistake is that of confusing art with archaeology.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000015_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The mere fact that they have passed unscathed through centuries of criticism and come down to us still covered with glory commands our respect.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000015_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000015_000008.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "A collector is anxious to acquire specimens to illustrate a period or a school, and forgets that a single masterpiece can teach us more than any number of the mediocre products of a given period or school.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000015_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000015_000009.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We classify too much and enjoy too little.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000016_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The art of to day is that which really belongs to us: it is our own reflection.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131294_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131294/868_131294_000016_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "In condemning it we but condemn ourselves.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000001_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Flowers",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000003_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We eat, drink, sing, dance, and flirt with them.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000003_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We dare not die without them.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000003_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We have worshipped with the lily, we have meditated with the lotus, we have charged in battle array with the rose and the chrysanthemum.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000003_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We have even attempted to speak in the language of flowers.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000003_000006.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "How could we live without them?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000003_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000003_000007.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "It frightens one to conceive of a world bereft of their presence.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000003_000008.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "What solace do they not bring to the bedside of the sick, what a light of bliss to the darkness of weary spirits?",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000004_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We devastate nature in order to make sacrifice to him.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000004_000006.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "What atrocities do we not perpetrate in the name of culture and refinement!",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000005_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "To morrow a ruthless hand will close around your throats.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000005_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The wretch, she may be passing fair.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000005_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000005_000006.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Tell me, will this be kindness?",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000006_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "He would call himself a Master of Flowers.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000006_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "He would claim the rights of a doctor and you would instinctively hate him, for you know a doctor always seeks to prolong the troubles of his victims.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000006_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "He would cut, bend, and twist you into those impossible positions which he thinks it proper that you should assume.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000006_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "He would burn you with red hot coals to stop your bleeding, and thrust wires into you to assist your circulation.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000006_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000006_000009.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Would you not have preferred to have been killed at once when you were first captured?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000007_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Beside this utter carelessness of life, the guilt of the Flower Master becomes insignificant.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000007_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "He, at least, respects the economy of nature, selects his victims with careful foresight, and after death does honour to their remains.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000007_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "In the West the display of flowers seems to be a part of the pageantry of wealth,--the fancy of a moment.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000008_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Why were the flowers born so beautiful and yet so hapless?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000008_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Insects can sting, and even the meekest of beasts will fight when brought to bay. The birds whose plumage is sought to deck some bonnet can fly from its pursuer, the furred animal whose coat you covet for your own may hide at your approach.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000008_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The only flower known to have wings is the butterfly; all others stand helpless before the destroyer.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000009_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The man of the pot is far more humane than he of the scissors.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000009_000007.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "In Japan, one of the most popular of the No dances, the Hachinoki, composed during the Ashikaga period, is based upon the story of an impoverished knight, who, on a freezing night, in lack of fuel for a fire, cuts his cherished plants in order to entertain a wandering friar.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "However, let us not be too sentimental.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Let us be less luxurious but more magnificent.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Destruction below and above, destruction behind and before. Change is the only Eternal,--why not as welcome Death as Life?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "They are but counterparts one of the other,--The Night and Day of Brahma.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000006.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We have worshipped Death, the relentless goddess of mercy, under many different names.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000007.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "It was the shadow of the All devouring that the Gheburs greeted in the fire.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000009.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The mystic fire consumes our weakness, the sacred sword cleaves the bondage of desire.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000013_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000013_000010.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "From our ashes springs the phoenix of celestial hope, out of the freedom comes a higher realisation of manhood.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000014_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Why not destroy flowers if thereby we can evolve new forms ennobling the world idea?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000015_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000015_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Here we are apt to see only the flower stems, heads as it were, without body, stuck promiscuously into a vase.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000017_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000017_000008.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Thus Sekishiu ordained that white plum blossoms should not be made use of when snow lay in the garden. \"Noisy\" flowers were relentlessly banished from the tea room.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000020_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The tea master deems his duty ended with the selection of the flowers, and leaves them to tell their own story.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000020_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Again, if you go into a noon tea on some irritatingly hot summer day, you may discover in the darkened coolness of the tokonoma a single lily in a hanging vase; dripping with dew, it seems to smile at the foolishness of life.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000021_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "One of the guests has recorded that he felt in the whole composition the breath of waning autumn.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000022_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Flower stories are endless.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000022_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We shall recount but one more.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000022_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The fame of his convulvuli reached the ear of the Taiko, and he expressed a desire to see them, in consequence of which Rikiu invited him to a morning tea at his house.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131295_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131295/868_131295_000023_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "They are not cowards, like men.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000000_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "seven. Tea Masters",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000001_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "In religion the Future is behind us.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000001_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The cut and color of the dress, the poise of the body, and the manner of walking could all be made expressions of artistic personality.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000001_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000001_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "These were matters not to be lightly ignored, for until one has made himself beautiful he has no right to approach beauty. Thus the tea master strove to be something more than the artist,--art itself.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000001_000008.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Rikiu loved to quote an old poem which says: \"To those who long only for flowers, fain would I show the full blown spring which abides in the toiling buds of snow covered hills.\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000002_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The Seven Kilns of Enshiu are well known to all students of Japanese pottery.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000002_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Many of our textile fabrics bear the names of tea masters who conceived their color or design.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000002_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000002_000007.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "One of the greatest schools of painting owes its origin to the tea master Honnami Koyetsu, famed also as a lacquer artist and potter.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000002_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000002_000009.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The whole Korin school, as it is generally designated, is an expression of Teaism. In the broad lines of this school we seem to find the vitality of nature herself.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000003_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Great as has been the influence of the tea masters in the field of art, it is as nothing compared to that which they have exerted on the conduct of life.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000003_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Many of our delicate dishes, as well as our way of serving food, are their inventions.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000003_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "They have instructed us in the proper spirit in which to approach flowers.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000003_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "They have given emphasis to our natural love of simplicity, and shown us the beauty of humility.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000004_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "We stagger in the attempt to keep our moral equilibrium, and see forerunners of the tempest in every cloud that floats on the horizon.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000005_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "The last moments of the great tea masters were as full of exquisite refinement as had been their lives.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000005_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Seeking always to be in harmony with the great rhythm of the universe, they were ever prepared to enter the unknown. The \"Last Tea of Rikiu\" will stand forth forever as the acme of tragic grandeur.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000006_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Long had been the friendship between Rikiu and the Taiko Hideyoshi, and high the estimation in which the great warrior held the tea master.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000006_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "But the friendship of a despot is ever a dangerous honour.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000006_000004.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Taking advantage of the coldness which had for some time existed between the Taiko and Rikiu, the enemies of the latter accused him of being implicated in a conspiracy to poison the despot.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000006_000005.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "It was whispered to Hideyoshi that the fatal potion was to be administered to him with a cup of the green beverage prepared by the tea master.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000007_000000.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "On the day destined for his self immolation, Rikiu invited his chief disciples to a last tea ceremony.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000007_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000007_000007.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Soon the host enters the room.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000007_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000007_000012.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "\"Never again shall this cup, polluted by the lips of misfortune, be used by man.\" He speaks, and breaks the vessel into fragments.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000008_000001.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "One only, the nearest and dearest, is requested to remain and witness the end.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000008_000002.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Rikiu then removes his tea gown and carefully folds it upon the mat, thereby disclosing the immaculate white death robe which it had hitherto concealed.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-868_131296_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/868/131296/868_131296_000008_000003.wav",
        "speaker_id": "LibriTTS_R-868",
        "content": "Tenderly he gazes on the shining blade of the fatal dagger, and in exquisite verse thus addresses it:",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    }
]