        "speaker_id": "LibriTTS_R-7095",
        "content": "In eighteen seventy seven, an eminent French Catholic physician, dr Constantin james, published an elaborate answer to Darwin's book.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
