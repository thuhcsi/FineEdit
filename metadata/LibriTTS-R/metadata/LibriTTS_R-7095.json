        "speaker_id": "LibriTTS_R-7095",
        "content": "In the middle of the eighteenth century Buffon, in France, produced a thesis attempting to state simple geological truths.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
