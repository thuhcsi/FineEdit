        "speaker_id": "LibriTTS_R-7095",
        "content": "Pope Leo the Great solemnly adjudged it a sin worthy of severe punishment.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
