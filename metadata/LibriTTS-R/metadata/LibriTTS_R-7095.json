        "speaker_id": "LibriTTS_R-7095",
        "content": "The theological faculty of Paris protested against the scientific doctrine as unscriptural, destroyed their treatises, and banished their authors from Paris.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
