        "speaker_id": "LibriTTS_R-7095",
        "content": "dr Duffield, both leading authorities at Princeton University.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
