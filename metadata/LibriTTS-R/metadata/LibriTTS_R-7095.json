        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7095/88489/7095_88489_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7095",
        "content": "dr Max Carl Otto, considering the implications of evolution, calls attention to the following: \"Take the evolution of living forms.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
