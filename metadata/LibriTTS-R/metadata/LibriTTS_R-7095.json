        "speaker_id": "LibriTTS_R-7095",
        "content": "In a purely civil matter, the infallible Church from its inception had displayed a marked hostility to loans at interest.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
