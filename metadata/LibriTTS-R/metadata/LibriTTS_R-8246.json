[
    {
        "item_name": "LibriTTS_R-8246_107993_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "OF REPENTANCE",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000007_000001.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Even constancy itself is no other but a slower and more languishing motion.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000007_000004.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Could my soul once take footing, I would not essay but resolve: but it is always learning and making trial.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000008_000002.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "If the world find fault that I speak too much of myself, I find fault that they do not so much as think of themselves.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000008_000003.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "But is it reason that, being so particular in my way of living, I should pretend to recommend myself to the public knowledge?",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000008_000005.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Is it not to build a wall without stone or brick, or some such thing, to write books without learning and without art?",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000008_000006.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "The fancies of music are carried on by art; mine by chance.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000008_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000008_000009.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "I speak truth, not so much as I would, but as much as I dare; and I dare a little the more, as I grow older; for, methinks, custom allows to age more liberty of prating, and more indiscretion of talking of a man's self.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000008_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000008_000012.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "He who shall judge of it without knowing him, will more wrong himself than me; he who does know him, gives me all the satisfaction I desire.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000009_000001.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "I do not teach; I only relate.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000010_000001.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Malice sucks up the greatest part of its own venom, and poisons itself.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000010_000002.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Vice leaves repentance in the soul, like an ulcer in the flesh, which is always scratching and lacerating itself: for reason effaces all other grief and sorrows, but it begets that of repentance, which is so much the more grievous, by reason it springs within, as the cold and heat of fevers are more sharp than those that only strike upon the outward skin.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000010_000003.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "I hold for vices (but every one according to its proportion), not only those which reason and nature condemn, but those also which the opinion of men, though false and erroneous, have made such, if authorised by law and custom.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "There is likewise no virtue which does not rejoice a well descended nature: there is a kind of, I know not what, congratulation in well doing that gives us an inward satisfaction, and a generous boldness that accompanies a good conscience: a soul daringly vicious may, peradventure, arm itself with security, but it cannot supply itself with this complacency and satisfaction.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000015_000002.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "I have my laws and my judicature to judge of myself, and apply myself more to these than to any other rules: I do, indeed, restrain my actions according to others; but extend them not by any other rule than my own.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000017_000004.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "twenty five.]",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "But the saying that repentance immediately follows the sin seems not to have respect to sin in its high estate, which is lodged in us as in its own proper habitation.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000018_000002.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Repentance is no other but a recanting of the will and an opposition to our fancies, which lead us which way they please.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000018_000003.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "It makes this person disown his former virtue and continency:",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "[\"What my mind is, why was it not the same, when I was a boy?",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000000.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "'tis an exact life that maintains itself in due order in private.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000001.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Every one may juggle his part, and represent an honest man upon the stage: but within, and in his own bosom, where all may do as they list, where all is concealed, to be regular, there's the point.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000002.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "The next degree is to be so in his house, and in his ordinary actions, for which we are accountable to none, and where there is no study nor artifice.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000004.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "In my country of Gascony, they look upon it as a drollery to see me in print; the further off I am read from my own home, the better I am esteemed.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000005.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "I purchase printers in Guienne; elsewhere they purchase me.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000007.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "I had rather have a great deal less in hand, and do not expose myself to the world upon any other account than my present share; when I leave it I quit the rest.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000008.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "See this functionary whom the people escort in state, with wonder and applause, to his very door; he puts off the pageant with his robe, and falls so much the lower by how much he was higher exalted: in himself within, all is tumult and degraded.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000009.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "And though all should be regular there, it will require a vivid and well chosen judgment to perceive it in these low and private actions; to which may be added, that order is a dull, sombre virtue.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000021_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000021_000012.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "The shortest way to arrive at glory, would be to do that for conscience which we do for glory: and the virtue of Alexander appears to me of much less vigour in his great theatre, than that of Socrates in his mean and obscure employment.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000023_000000.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Natural inclinations are much assisted and fortified by education; but they seldom alter and overcome their institution: a thousand natures of my time have escaped towards virtue or vice, through a quite contrary discipline:",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000026_000000.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "these original qualities are not to be rooted out; they may be covered and concealed.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000026_000001.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "The Latin tongue is as it were natural to me; I understand it better than French; but I have not been used to speak it, nor hardly to write it, these forty years.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000026_000002.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Unless upon extreme and sudden emotions which I have fallen into twice or thrice in my life, and once seeing my father in perfect health fall upon me in a swoon, I have always uttered from the bottom of my heart my first words in Latin; nature deafened, and forcibly expressing itself, in spite of so long a discontinuation; and this example is said of many others.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8246_107993_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8246/107993/8246_107993_000027_000001.wav",
        "speaker_id": "LibriTTS_R-8246",
        "content": "Look a little into our experience: there is no man, if he listen to himself, who does not in himself discover a particular and governing form of his own, that jostles his education, and wrestles with the tempest of passions that are contrary to it.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    }
]