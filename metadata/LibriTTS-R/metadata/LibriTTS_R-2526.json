        "speaker_id": "LibriTTS_R-2526",
        "content": "Indeed you would not be in love with him for the world!--Your servant, my dear.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
