        "speaker_id": "LibriTTS_R-2526",
        "content": "MISS HOWE, TO MISS CLARISSA HARLOWE THURSDAY MORNING, march second.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
