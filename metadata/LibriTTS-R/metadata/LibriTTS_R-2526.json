        "speaker_id": "LibriTTS_R-2526",
        "content": "For, I think, with all the advantages of person, fortune, and family, he is not by any means worthy of you.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
