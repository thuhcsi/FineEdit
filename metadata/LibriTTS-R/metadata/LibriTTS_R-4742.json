        "speaker_id": "LibriTTS_R-4742",
        "content": "You see, your rescue party proved a success.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
