        "speaker_id": "LibriTTS_R-4742",
        "content": "Can she get me again?\" she said, turning piteously to mr Bright.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
