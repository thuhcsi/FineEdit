        "speaker_id": "LibriTTS_R-4742",
        "content": "I must leave you now.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
