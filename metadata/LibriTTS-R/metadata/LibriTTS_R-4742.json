        "speaker_id": "LibriTTS_R-4742",
        "content": "Good bye, daughter.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
