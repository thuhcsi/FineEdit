        "speaker_id": "LibriTTS_R-4742",
        "content": "Take good care of Mabel.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4742_41609_000035_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4742/41609/4742_41609_000035_000006.wav",
        "speaker_id": "LibriTTS_R-4742",
        "content": "I'll have to hurry now, or miss my appointment.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4742_41609_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4742/41609/4742_41609_000037_000000.wav",
        "speaker_id": "LibriTTS_R-4742",
        "content": "\"Well, girls,\" said Grace, \"here is my street.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4742_41609_000037_000001",
