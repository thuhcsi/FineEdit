        "speaker_id": "LibriTTS_R-1688",
        "content": "'Have you met with a servant, dear?'",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
