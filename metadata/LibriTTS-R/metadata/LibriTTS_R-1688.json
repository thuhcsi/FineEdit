        "speaker_id": "LibriTTS_R-1688",
        "content": "She must be an uncommon person,' her mother added.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
