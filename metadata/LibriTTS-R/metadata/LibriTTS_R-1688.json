        "speaker_id": "LibriTTS_R-1688",
        "content": "Margaret held her in her arms, and put the weary head to rest upon her bosom.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1688_142285_000043_000000",
