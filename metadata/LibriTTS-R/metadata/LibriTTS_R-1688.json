        "speaker_id": "LibriTTS_R-1688",
        "content": "She was late for tea at home.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1688_142285_000044_000001",
