        "speaker_id": "LibriTTS_R-1688",
        "content": "Now let me try.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1688_142285_000047_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1688/142285/1688_142285_000047_000003.wav",
        "speaker_id": "LibriTTS_R-1688",
        "content": "I may be the Cinderella to put on the slipper after all.'",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1688_142285_000049_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1688/142285/1688_142285_000049_000001.wav",
        "speaker_id": "LibriTTS_R-1688",
        "content": "How would you set about it?'",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
