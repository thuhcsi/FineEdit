        "speaker_id": "LibriTTS_R-1688",
        "content": "'The mother of whom he spoke to us?' said Margaret.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
