        "speaker_id": "LibriTTS_R-1688",
        "content": "But we must first catch our house mother.'",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
