        "speaker_id": "LibriTTS_R-1688",
        "content": "'Everybody else has had their turn at this great difficulty.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
