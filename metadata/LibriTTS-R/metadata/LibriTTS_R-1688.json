        "speaker_id": "LibriTTS_R-1688",
        "content": "'No, mamma; that Anne Buckley would never have done.'",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
