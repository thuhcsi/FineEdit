        "speaker_id": "LibriTTS_R-1688",
        "content": "'You have caught her.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
