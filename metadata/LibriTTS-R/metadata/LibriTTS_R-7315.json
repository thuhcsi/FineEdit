        "speaker_id": "LibriTTS_R-7315",
        "content": "The spectre of Valentine rising before the poisoner would have alarmed her less.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7315_86809_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7315/86809/7315_86809_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7315",
        "content": "\"Who said Valentine was dead?\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
