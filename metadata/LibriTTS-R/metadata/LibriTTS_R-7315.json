        "speaker_id": "LibriTTS_R-7315",
        "content": "\"Doctor, do you hear them call for help?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
