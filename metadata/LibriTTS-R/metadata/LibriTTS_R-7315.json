        "speaker_id": "LibriTTS_R-7315",
        "content": "It was cold and motionless.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
