        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7315/86809/7315_86809_000009_000005.wav",
        "speaker_id": "LibriTTS_R-7315",
        "content": "\"What are you saying, doctor?\" he exclaimed, raising his hands to heaven.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7315_86809_000011_000003",
