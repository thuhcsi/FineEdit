        "speaker_id": "LibriTTS_R-7315",
        "content": "\"Will I be a success, too?\" asked Eric in a faint but hopeful voice.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7315_104382_000014_000000",
