        "speaker_id": "LibriTTS_R-7315",
        "content": "\"You!\" said the harsh woman.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7315_104382_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7315/104382/7315_104382_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7315",
        "content": "That's the fate of most orphans.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
