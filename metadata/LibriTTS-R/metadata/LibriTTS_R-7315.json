        "speaker_id": "LibriTTS_R-7315",
        "content": "The nails, too, were turning blue.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
