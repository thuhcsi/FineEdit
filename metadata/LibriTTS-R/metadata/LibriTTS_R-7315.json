        "speaker_id": "LibriTTS_R-7315",
        "content": "Success indeed!",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7315_104382_000014_000004",
