        "speaker_id": "LibriTTS_R-7315",
        "content": "For it was thought that the old ruined church was haunted, and that fearsome things were to be seen there at night.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
