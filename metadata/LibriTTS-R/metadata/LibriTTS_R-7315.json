        "speaker_id": "LibriTTS_R-7315",
        "content": "The night had been a cold one, and the other two boys in the bed, because they were older and stronger, had managed to keep most of the bedding wrapped tightly around them, while little Eric shivered on the very edge.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
