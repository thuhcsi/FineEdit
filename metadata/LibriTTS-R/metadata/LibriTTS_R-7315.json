        "speaker_id": "LibriTTS_R-7315",
        "content": "Breakfast was served in the kitchen by mrs Freg.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7315_104382_000013_000000",
