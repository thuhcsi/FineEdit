        "speaker_id": "LibriTTS_R-7315",
        "content": "And when its neck was shown, the thundering voice came again and said: \"Do you see this great neck of mine?\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
