        "speaker_id": "LibriTTS_R-7315",
        "content": "And again the mighty voice thundered: \"Do you see this great chest of mine?\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
