        "speaker_id": "LibriTTS_R-7315",
        "content": "The two older boys followed him more slowly, yawning, growling, and quarreling.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
