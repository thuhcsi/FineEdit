        "speaker_id": "LibriTTS_R-7315",
        "content": "\"Good,\" she exclaimed, approaching the table, \"she has taken part of her draught; the glass is three quarters empty.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
