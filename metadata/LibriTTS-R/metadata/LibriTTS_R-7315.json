        "speaker_id": "LibriTTS_R-7315",
        "content": "On a sudden she stepped, or rather bounded, with outstretched arms, towards the table.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
