        "speaker_id": "LibriTTS_R-5789",
        "content": "\"I will leave a card then.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
