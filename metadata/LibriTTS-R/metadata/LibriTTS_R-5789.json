        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5789/57158/5789_57158_000067_000000.wav",
        "speaker_id": "LibriTTS_R-5789",
        "content": "\"I am mr john Morton's cousin.\"",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
