        "speaker_id": "LibriTTS_R-5789",
        "content": "Reginald lifted his hat and assented.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5789_57158_000055_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5789/57158/5789_57158_000055_000006.wav",
        "speaker_id": "LibriTTS_R-5789",
        "content": "\"mr Morton, sir, I think is out with the ladies, taking a drive.\"",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
