        "speaker_id": "LibriTTS_R-5789",
        "content": "That was the name I heard up there.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5789_57158_000065_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5789/57158/5789_57158_000065_000000.wav",
        "speaker_id": "LibriTTS_R-5789",
        "content": "\"My name is Morton.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
