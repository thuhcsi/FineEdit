        "speaker_id": "LibriTTS_R-5789",
        "content": "\"Oh, mr Reginald, is that you?\" said old mrs Hopkins taking the card.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5789_57158_000058_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5789/57158/5789_57158_000058_000001.wav",
        "speaker_id": "LibriTTS_R-5789",
        "content": "\"They are all out,--except herself.\" As he certainly did not wish to see \"herself,\" he greeted the old woman and left his card.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5789_57158_000062_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5789/57158/5789_57158_000062_000001.wav",
        "speaker_id": "LibriTTS_R-5789",
        "content": "Good morning to you.\"",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5789_57158_000064_000001",
