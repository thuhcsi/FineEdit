        "speaker_id": "LibriTTS_R-5789",
        "content": "It was mr Gotobed who had just returned from a visit which he had made, the circumstances of which must be narrated in the next chapter.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
