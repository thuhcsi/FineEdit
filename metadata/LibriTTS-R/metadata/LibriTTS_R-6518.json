        "speaker_id": "LibriTTS_R-6518",
        "content": "To and fro The dull thought surges, as the driven waves fight In gulfy channels.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
