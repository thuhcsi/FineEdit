        "speaker_id": "LibriTTS_R-6518",
        "content": "If we might sit until the darkness go, Possess our souls in patience perhaps we might; But there is always something to be done, And no heart left to do it.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
