        "speaker_id": "LibriTTS_R-6518",
        "content": "In all my wrong, Self love and weakness, laziness and fear, This one thing I can say: I am content To be and have what in thy heart I am meant To be and have.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
