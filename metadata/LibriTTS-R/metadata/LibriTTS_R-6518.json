        "speaker_id": "LibriTTS_R-6518",
        "content": "Wilt thou not one day, Lord?",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
