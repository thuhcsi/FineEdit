        "speaker_id": "LibriTTS_R-6518",
        "content": "\"Wake, thou that sleepest; rise up from the dead, And Christ will give thee light.\" I do not know What sleep is, what is death, or what is light; But I am waked enough to feel a woe, To rise and leave death.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
