        "speaker_id": "LibriTTS_R-6518",
        "content": "Stumbling through the night, To my dim lattice, O calling Christ!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
