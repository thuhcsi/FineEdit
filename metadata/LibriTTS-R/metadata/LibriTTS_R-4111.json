        "speaker_id": "LibriTTS_R-4111",
        "content": "There is one exercise here on page twenty that I hate worst of all.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
