        "speaker_id": "LibriTTS_R-4111",
        "content": "Hereafter I'll get up at the time directed on page three, or maybe earlier.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
