        "speaker_id": "LibriTTS_R-4111",
        "content": "Anyhow, it made me take a resolve.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
