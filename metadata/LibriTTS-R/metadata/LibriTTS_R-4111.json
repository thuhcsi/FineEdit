        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4111/184448/4111_184448_000023_000003.wav",
        "speaker_id": "LibriTTS_R-4111",
        "content": "I've put it away on the top shelf of a cupboard, for it is a torment to look at it.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
