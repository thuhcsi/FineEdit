        "speaker_id": "LibriTTS_R-4111",
        "content": "After breakfast, I went into the kitchen to speak to Jane.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
