        "speaker_id": "LibriTTS_R-4111",
        "content": "I want ten hours to sleep and twelve if I get a good tired start.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
