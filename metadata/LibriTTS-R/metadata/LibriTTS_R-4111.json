        "speaker_id": "LibriTTS_R-4111",
        "content": "\"That was a lovely song you sang about 'Molly darling,' Billy,\" I said. \"Where did you hear it?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
