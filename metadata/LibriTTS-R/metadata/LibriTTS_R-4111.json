        "speaker_id": "LibriTTS_R-4111",
        "content": "\"Nobody taught it to me.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
