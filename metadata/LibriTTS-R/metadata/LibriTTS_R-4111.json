        "speaker_id": "LibriTTS_R-4111",
        "content": "\"Who taught it to you, sugar sweet?\" I persisted as I poured water in on the frog under his direction.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
