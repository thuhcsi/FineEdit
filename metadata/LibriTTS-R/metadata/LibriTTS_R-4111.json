        "speaker_id": "LibriTTS_R-4111",
        "content": "I won't let myself even think \"perfect flower\" and \"scarlet runner.\" If I do, I get warm and happy all over.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
