        "speaker_id": "LibriTTS_R-380",
        "content": "Her thoughts were away in other times as the parson read.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
