        "speaker_id": "LibriTTS_R-380",
        "content": "The Major's visit left old john Sedley in a great state of agitation and excitement.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
