    },
    {
        "item_name": "LibriTTS_R-380_129064_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/380/129064/380_129064_000019_000002.wav",
        "speaker_id": "LibriTTS_R-380",
        "content": "But whether it was the sea air, or the hope which sprung up in him afresh, from the day that the ship spread her canvas and stood out of the roads towards home, our friend began to amend, and he was quite well (though as gaunt as a greyhound) before they reached the Cape.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
