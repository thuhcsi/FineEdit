        "speaker_id": "LibriTTS_R-380",
        "content": "Emmy smiled.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
