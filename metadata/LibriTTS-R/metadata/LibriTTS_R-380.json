        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/380/129064/380_129064_000012_000000.wav",
        "speaker_id": "LibriTTS_R-380",
        "content": "They buried Amelia's mother in the churchyard at Brompton, upon just such a rainy, dark day as Amelia recollected when first she had been there to marry George.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
