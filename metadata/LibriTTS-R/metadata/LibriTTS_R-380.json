        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/380/129064/380_129064_000023_000000.wav",
        "speaker_id": "LibriTTS_R-380",
        "content": "After leaving saint Helena he became very generous, disposing of a great quantity of ship stores, claret, preserved meats, and great casks packed with soda water, brought out for his private delectation.",
        "style_prompt": "F_p-low_s-normal_e-normal",
