        "speaker_id": "LibriTTS_R-380",
        "content": "She strove to think it was right that she should be so punished.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
