        "speaker_id": "LibriTTS_R-380",
        "content": "Amelia found him up very early the next morning, more eager, more hectic, and more shaky than ever.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
