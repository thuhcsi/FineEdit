        "speaker_id": "LibriTTS_R-380",
        "content": "Be gentle with those who are less lucky, if not more deserving.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
