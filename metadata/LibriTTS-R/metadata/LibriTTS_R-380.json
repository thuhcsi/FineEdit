        "speaker_id": "LibriTTS_R-380",
        "content": "\"You don't know anything about business, my dear,\" answered the sire, shaking his head with an important air.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
