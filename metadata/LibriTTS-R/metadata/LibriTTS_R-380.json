        "speaker_id": "LibriTTS_R-380",
        "content": "The idea that he should never see her again depressed him in his lucid hours.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
