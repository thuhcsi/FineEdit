        "speaker_id": "LibriTTS_R-380",
        "content": "Little George visited her captivity sometimes and consoled it with feeble gleams of encouragement.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
