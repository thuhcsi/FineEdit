        "speaker_id": "LibriTTS_R-380",
        "content": "So she determined with all her might and strength to try and make her old father happy.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
