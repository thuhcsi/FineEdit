        "speaker_id": "LibriTTS_R-380",
        "content": "I wish she was alive, to ride in Jos's carriage once again.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-380_129066_000006_000004",
