        "speaker_id": "LibriTTS_R-380",
        "content": "She was quite alone in the world.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-380_129064_000015_000000",
