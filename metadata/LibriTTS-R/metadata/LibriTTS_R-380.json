        "speaker_id": "LibriTTS_R-380",
        "content": "\"I didn't sleep much, Emmy, my dear,\" he said.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-380_129066_000006_000003",
