        "speaker_id": "LibriTTS_R-380",
        "content": "The kindness was too much for the poor epileptic creature.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
