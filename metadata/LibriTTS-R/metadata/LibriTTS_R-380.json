        "speaker_id": "LibriTTS_R-380",
        "content": "Old Sedley grew very fond of his daughter after his wife's death, and Amelia had her consolation in doing her duty by the old man.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
