        "speaker_id": "LibriTTS_R-380",
        "content": "What sad, unsatisfactory thoughts those of the widow were!",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
