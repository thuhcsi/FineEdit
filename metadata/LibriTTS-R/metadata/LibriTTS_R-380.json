        "speaker_id": "LibriTTS_R-380",
        "content": "The children running up and down the slopes and broad paths in the gardens reminded her of George, who was taken from her; the first George was taken from her; her selfish, guilty love, in both instances, had been rebuked and bitterly chastised.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
