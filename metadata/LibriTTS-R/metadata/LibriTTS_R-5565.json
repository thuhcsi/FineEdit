        "speaker_id": "LibriTTS_R-5565",
        "content": "\"Is that so, mother?\" he asked.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
