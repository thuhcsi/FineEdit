        "speaker_id": "LibriTTS_R-5565",
        "content": "\"Of course,\" was the answer: \"he's more than other folks now.\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
