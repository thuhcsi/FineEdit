        "speaker_id": "LibriTTS_R-5565",
        "content": "The young clergyman's mother returned thanks with tearful eyes; she could scarcely speak for joyous weeping.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
