        "speaker_id": "LibriTTS_R-6913",
        "content": "Kirkwood looked about the room with face set in anxious discontent.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
