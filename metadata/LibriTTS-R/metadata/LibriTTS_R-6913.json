        "speaker_id": "LibriTTS_R-6913",
        "content": "Great numbers were still bent over their labour, and would be for hours to come, but the majority had leave to wend stablewards.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
