        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000055_000000.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "'Is it no use, mrs Hewett?' he exclaimed suddenly, turning to her. 'Does she mean it?",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6913_80509_000058_000001",
