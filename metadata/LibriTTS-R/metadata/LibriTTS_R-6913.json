        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000002_000006.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "Public houses began to brighten up, to bestir themselves for the evening's business.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
