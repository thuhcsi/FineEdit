        "speaker_id": "LibriTTS_R-6913",
        "content": "Clara, she's that set on goin', an' her father's that set against it.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
