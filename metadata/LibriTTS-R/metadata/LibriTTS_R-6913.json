        "speaker_id": "LibriTTS_R-6913",
        "content": "Here you may see how men have multiplied toil for toil's sake, have wrought to devise work superfluous, have worn their lives away in imagining new forms of weariness.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
