        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000002_000007.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "Streets that had been hives of activity since early morning were being abandoned to silence and darkness and the sweeping wind.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6913_80509_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000003_000001.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "But of these things Clerkenwell takes no count; here it had been a day like any other, consisting of so many hours, each representing a fraction of the weekly wage.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6913_80509_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000003_000002.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "Go where you may in Clerkenwell, on every hand are multiform evidences of toil, intolerable as a nightmare.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6913_80509_000003_000004",
