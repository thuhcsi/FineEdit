        "speaker_id": "LibriTTS_R-6913",
        "content": "She was rather wrapped up than dressed, and her hair, thin and pale coloured, was tied in a ragged knot.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
