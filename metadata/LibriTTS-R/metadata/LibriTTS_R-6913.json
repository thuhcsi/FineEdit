        "speaker_id": "LibriTTS_R-6913",
        "content": "You'll only make trouble, Sidney.'",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
