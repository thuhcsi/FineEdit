        "speaker_id": "LibriTTS_R-6913",
        "content": "There was, however, another reason why she sped eagerly on her present mission.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
