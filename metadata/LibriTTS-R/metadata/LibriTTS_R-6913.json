        "speaker_id": "LibriTTS_R-6913",
        "content": "'You know your way upstairs, I b'lieve,' said Clem, as if he were all but a stranger.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
