        "speaker_id": "LibriTTS_R-6913",
        "content": "The energy, the ingenuity daily put forth in these grimy burrows task the brain's power of wondering.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
