        "speaker_id": "LibriTTS_R-6913",
        "content": "She cried pitifully for a few moments.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
