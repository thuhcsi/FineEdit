        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000059_000009.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "He's got his fancies, but they've never made him selfish to others, as well you know, Sidney.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
