        "speaker_id": "LibriTTS_R-6913",
        "content": "In Clerkenwell the demand is not so much for rude strength as for the cunning fingers and the contriving brain.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
