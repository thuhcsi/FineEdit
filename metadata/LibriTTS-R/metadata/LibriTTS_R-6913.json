        "speaker_id": "LibriTTS_R-6913",
        "content": "He took it without speaking, and threw it over his arm.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
