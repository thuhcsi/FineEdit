        "speaker_id": "LibriTTS_R-6913",
        "content": "The baby at her bosom moaned in the act of sucking; one knew not how the poor woman could supply sustenance to another being.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
