        "speaker_id": "LibriTTS_R-6913",
        "content": "mrs Hewett sat on the bed, and bent forward in an attitude of physical weakness.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
