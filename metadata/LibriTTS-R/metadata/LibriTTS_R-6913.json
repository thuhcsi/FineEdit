        "speaker_id": "LibriTTS_R-6913",
        "content": "That woman mrs Tubbs has been here to see me, talkin' an' talkin'.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
