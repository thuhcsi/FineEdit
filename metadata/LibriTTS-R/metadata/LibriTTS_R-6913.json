        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000007_000003.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "Jane's eagerness impelled her to address one of them.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
