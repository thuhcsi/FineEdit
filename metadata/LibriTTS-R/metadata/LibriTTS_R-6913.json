        "speaker_id": "LibriTTS_R-6913",
        "content": "A woman's voice bade him enter.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
