        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6913/80509/6913_80509_000053_000001.wav",
        "speaker_id": "LibriTTS_R-6913",
        "content": "But see, I want to speak about Clara.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
