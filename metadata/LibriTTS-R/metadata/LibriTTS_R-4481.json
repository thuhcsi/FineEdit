        "speaker_id": "LibriTTS_R-4481",
        "content": "\"I've only been thinking.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
