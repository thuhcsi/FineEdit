        "speaker_id": "LibriTTS_R-3781",
        "content": "With every law, as Austin says, must go a penalty.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
