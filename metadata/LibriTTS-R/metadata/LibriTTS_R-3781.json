        "speaker_id": "LibriTTS_R-3781",
        "content": "Each separate group has its totem, its general rules with reference to the marriage relation, to hunting and fishing, to shelter and protection.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
