        "speaker_id": "LibriTTS_R-3781",
        "content": "Among them the less disciplined, the less intelligently directed groups perish.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
