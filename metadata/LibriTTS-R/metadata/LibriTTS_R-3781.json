        "speaker_id": "LibriTTS_R-3781",
        "content": "They are largely negative.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
