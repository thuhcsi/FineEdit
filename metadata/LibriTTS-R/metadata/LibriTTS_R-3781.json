        "speaker_id": "LibriTTS_R-3781",
        "content": "Later, as the tribe enters the pastoral state, private property is established and laws for its care are made.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
