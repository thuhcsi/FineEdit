        "speaker_id": "LibriTTS_R-3781",
        "content": "Arise, O Jehovah, And let thine enemies be scattered, And let those who hate thee flee before thee.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
