        "speaker_id": "LibriTTS_R-1779",
        "content": "THE MIND HAS AN INCOMPLETE LIFE",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
