        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000008_000011.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "Can it survive the death of the brain?",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1779_142733_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "The second question is that of knowing what is the role, the utility, and the efficacity of the psychical phenomenon.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
