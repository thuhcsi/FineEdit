        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000008_000006.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "This is thought, consciousness, emotion.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1779_142733_000008_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000008_000008.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "What is the nature of the link between them?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1779_142733_000008_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000008_000009.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "Is it a relation of cause to effect, of genesis? or a coincidence? or the interaction of two distinct forces? Is this relation constant or necessary?",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
