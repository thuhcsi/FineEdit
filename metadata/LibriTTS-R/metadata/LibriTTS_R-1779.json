    {
        "item_name": "LibriTTS_R-1779_142733_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "The problem of the union of the mind and the body is not one of those which present themselves in pure speculation; it has its roots in experimental facts, and is forced upon us by the necessity of explaining observations such as those we are about to quote.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1779_142733_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "This is daily demonstrated by thousands upon thousands of observations.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1779_142733_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "The question is to know how this union of the body with the consciousness is to be explained, it being assumed that the two terms of this union present a great difference in their nature.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1779_142733_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "The easier it seems to demonstrate that this union exists, the more difficult it appears to explain how it is realised; and the proof of this difficulty is the number of divergent interpretations given to it. Were it a simple question of fact, the perpetual discussions and controversies upon it would not arise.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
