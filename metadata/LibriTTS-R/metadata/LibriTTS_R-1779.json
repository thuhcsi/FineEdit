        "speaker_id": "LibriTTS_R-1779",
        "content": "Can the mind enjoy an existence independent of the brain?",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
