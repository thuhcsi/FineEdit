        "speaker_id": "LibriTTS_R-1779",
        "content": "Then at a given moment, after this mechanical process, a quite different phenomenon emerges.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
