        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1779/142733/1779_142733_000009_000004.wav",
        "speaker_id": "LibriTTS_R-1779",
        "content": "Does it exercise any action on these intra cerebral functions?",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
