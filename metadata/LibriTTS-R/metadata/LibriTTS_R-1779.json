        "speaker_id": "LibriTTS_R-1779",
        "content": "All this is physical or chemical, and therefore material.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
