        "speaker_id": "LibriTTS_R-3536",
        "content": "Bozzle paused a moment before he replied, and then smiled as he spoke.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
