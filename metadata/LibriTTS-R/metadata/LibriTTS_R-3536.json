        "speaker_id": "LibriTTS_R-3536",
        "content": "And he knew it all.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
