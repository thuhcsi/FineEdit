        "speaker_id": "LibriTTS_R-3536",
        "content": "He have been up all this month, sir.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
