        "speaker_id": "LibriTTS_R-3536",
        "content": "\"I do.\"",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
