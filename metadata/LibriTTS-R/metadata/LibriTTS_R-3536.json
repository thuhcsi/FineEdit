        "speaker_id": "LibriTTS_R-3536",
        "content": "\"You mean the Colonel, sir.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
