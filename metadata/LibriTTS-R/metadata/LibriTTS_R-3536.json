        "speaker_id": "LibriTTS_R-3536",
        "content": "\"I mistook-for I had before given my word that I should pass it abroad.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
