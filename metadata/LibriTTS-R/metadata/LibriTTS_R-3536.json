        "speaker_id": "LibriTTS_R-3536",
        "content": "\"Why not?\" Trevelyan could perceive at once that the authority which he had once respected had gone from the man.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
