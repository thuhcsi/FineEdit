        "speaker_id": "LibriTTS_R-3536",
        "content": "And all work had ceased with him.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
