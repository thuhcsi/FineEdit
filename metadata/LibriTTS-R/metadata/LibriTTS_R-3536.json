        "speaker_id": "LibriTTS_R-3536",
        "content": "He looked up for a moment at Bozzle, and then asked him a question.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
