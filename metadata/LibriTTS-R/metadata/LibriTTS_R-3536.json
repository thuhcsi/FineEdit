        "speaker_id": "LibriTTS_R-3536",
        "content": "Her guardian looked astonished.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
