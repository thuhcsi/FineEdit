        "speaker_id": "LibriTTS_R-3536",
        "content": "\"They haven't met?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
