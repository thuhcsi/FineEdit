        "speaker_id": "LibriTTS_R-3536",
        "content": "But he had been found with his coat off, and a baby in his arms, and he could not recover himself.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
