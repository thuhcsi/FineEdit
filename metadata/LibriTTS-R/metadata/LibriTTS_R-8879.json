[
    {
        "item_name": "LibriTTS_R-8879_300234_000007_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000007_000006.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "This brings the exploration of the Pacific down to eighteen o six.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000008_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Take a look at the map!",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000008_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Mackenzie had crossed overland from the Peace river to Bella Coola.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000008_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "He had ascended that same Parsnip river, which Mackenzie had found so appalling, to a little emerald lake set like a jewel in the mountains.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000009_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "john Stuart accompanied Fraser as lieutenant.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000009_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "They thought the white men in smoking were emitting spirits with each breath.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000009_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000009_000006.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "When the traders offered soap to the squaws, the women at once began to devour it.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000009_000008.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "History does not record whether the women became as addicted to soap as the men to the fragrant weed.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000010_000004.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "It was four or five miles wide, and was gemmed with green islets; and all round, appearing through the clouds in jagged outline, were the opal summits of the snowy peaks.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000010_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "No wonder the two Scotsmen named the new inland empire New Caledonia-after their native land.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000011_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "This was forty miles south of Stuart Lake, at the headwaters of the Nechaco, the north fork of the Fraser.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000011_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Again a fort was erected and named Fort Fraser, making three forts in the interior of New Caledonia.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000012_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Fraser had sent a request to the directors of the north-west Company to be permitted to fit out an expedition down the great river, which he thought was the Columbia; and in the spring of eighteen o seven two canoes under Jules Quesnel were sent out with goods.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000012_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Fraser went down the river and strengthened British possession by building a fourth fort-Fort George at the mouth of the Nechaco.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000014_000002.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "On the third day they passed Mackenzie's farthest south-the site of the present Alexandria.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000014_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Below this the river was unexplored and unknown.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000014_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "In sublime unconsciousness of heroism Fraser records:",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000015_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "I ordered the five best men of the crews into a canoe lightly loaded; and in a moment it was under way.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000015_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000015_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "To continue by water would be certain destruction.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000015_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000015_000007.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The bank was high and steep.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000015_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000015_000010.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "However, we cleared the bank before dark.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000016_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Indians warned the white men to desist from their undertaking.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000016_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Better, they advised, go overland eastward to a great peaceful river and descend that to the sea.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000016_000002.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Fraser, of course, did not know that the peaceful river they spoke of was really the Columbia.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000016_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "He thought the river he was following was the Columbia.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000016_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000016_000007.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Beyond it several minor rapids were passed without difficulty; and then they came upon a series of great whirlpools which seemed impassable.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000016_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000016_000008.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "But the men unloaded the canoes and-'a desperate undertaking'--ran them down the rapids with light ballast.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000016_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000016_000009.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "They then came back overland for the packs.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000017_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "This task [says Fraser] was as dangerous as going by water.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000017_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The men passed and repassed a declivity, on loose stones and gravel, which constantly gave way under foot.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000017_000002.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "One man, who lost the path, got in a most intricate and perilous position.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000017_000004.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "I crawled, not without great risk, to his assistance, and saved his life by cutting his pack so [that] it dropped back in the river.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000019_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Thus skimming along as fast as lightning, the crews, cool and determined, followed each other in awful silence; and when we arrived at the end, we stood gazing at each other in silent congratulation on our narrow escape from total destruction.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The natives here warned Fraser that it would be madness to go forward. At the same time they furnished him with a guide.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000020_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The Indians declared that the sea lay only ten 'sleeps' distant.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000020_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000020_000006.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "One of the chiefs said that he had himself seen white men, who were great 'tyees,' because 'they were well dressed and very proud and went about this way'--clapping his hands to his hips and strutting about with an air of vast importance. The Indians told Fraser of another great river that came in from the east and joined this one some distance below.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000020_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000020_000011.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The voyageurs again embarked, and swept down the narrow bends of the turbulent floods at what are now Lytton, Yale, and Hope.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000022_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The return journey was fraught with danger.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300234_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300234/8879_300234_000022_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Then he forced each voyageur to swear on the Cross: 'I do solemnly swear that I will sooner perish than forsake in distress any of our crew during the present voyage.' With renewed self respect they then paddled off, singing voyageurs' songs to keep up their courage. Imagine, for a moment, the scene!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000000_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Strange that the Spaniards should look on complaisantly while English traders from China-Meares and Hanna and Barkley and Douglas-were taking possession of Nootka.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000000_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000000_000004.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The answer came unexpectedly.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000002_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Some of the names, however, were afterwards changed.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000002_000002.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "What is to day known as Esquimalt, Quimper called Valdes, and Victoria he named Cordoba.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000003_000004.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Loop holes punctured the palisades of the fort, and cannon were above the gates.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000003_000008.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "On the morning of the twentieth the woods were seen to be alive with Indians.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000004_000002.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Let us leave him for the present stealing furtively along the coast from Cape Flattery to Cape Disappointment.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000005_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "It was the spring of seventeen ninety two.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000005_000004.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "It was a new river, with wonderful purple water-the purple of river silt blending with ocean blue.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000005_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000005_000010.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The ragged starveling crew of Pilot Narvaez had found what are now known as Burrard Inlet, Vancouver City, Point Grey, Shaughnessy Heights, and the Fraser River.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000005_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000005_000013.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Narvaez himself lay almost unconscious in his berth.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000006_000004.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Yet they sang as they sailed their rickety death traps, and they laughed as they rowed; and when the tide rip caught them, they sank without a cry to any but the Virgin.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000006_000006.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "First were the Spaniards at every harbour gate; and yet to day, of all their deep-sea findings on that coast, not a rod, not a foot, does Spain own.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000006_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000006_000008.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "But if actual accomplishments count, these pilots with their ragged peon crews, half bloods of Aztec woman and Spanish adventurer, deserve higher rank in the roll of Pacific coast exploration than history has yet accorded them.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "England, it may be believed, did not calmly submit to seeing the ships and forts of her traders seized at Nootka.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000004.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "And as mistress of the seas, she could not tolerate as much as the seizure of a fishing smack.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000005.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "For some time there were mutterings of war, but at length diplomacy prevailed. England demanded, among other things, the restoration of the buildings and the land, and full reparation for all losses.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000008.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "This expedition was commanded by Captain George Vancouver, who had been on the Pacific with Cook.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000013.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "The American told an astounding story.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000014.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "He had found Bruno Heceta's River of the West.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000015.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Vancouver refused to credit the news; yet there was the ship's log; there were the details-landmarks, soundings, anchorages for twenty miles up the Columbia from its mouth.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000007_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000007_000016.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Gray had, indeed, been up the river, and had crossed the bar and come out on the Pacific again.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000008_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "In June the explorers passed up the Strait of Georgia.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000010_000002.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Vancouver found the Spaniards occupying a fort on an island at the mouth of the harbour. On the main shore stood the Indian village of Chief Maquinna.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000010_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000010_000006.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Spanish cannon thundered a welcome that shook the hills, and English guns made answer.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000010_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000010_000012.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Don Quadra held that he had been instructed to relinquish only the land on which the fort stood-according to Vancouver, 'but little more than one hundred yards in extent any way.' No understanding could be arrived at, and Quadra at the end of September took his departure for Monterey, leaving Vancouver to follow a few days later.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Vancouver was anxious to be off on further exploration.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000011_000002.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "He spent most of October exploring this river.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000011_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Explorers in that day, as in this, were not fair judges of each other's feats.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000012_000000.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Vancouver then visited the presidio at San Francisco, and thence proceeded to Monterey, where Quadra awaited him.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000012_000001.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "His lieutenant, Broughton, who had been in charge of the boats that explored the Columbia, here left him and accompanied Quadra to San Blas, whence he went overland to the Atlantic and sailed for England, bearing dispatches to the government.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8879_300343_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8879/300343/8879_300343_000012_000003.wav",
        "speaker_id": "LibriTTS_R-8879",
        "content": "Portland Canal, Jervis Inlet, Cook Inlet, Prince William Sound, Lynn Canal-all were traced to head waters by Vancouver.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    }
]