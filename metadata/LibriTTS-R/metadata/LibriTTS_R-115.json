        "speaker_id": "LibriTTS_R-115",
        "content": "With this in mind, the author has prepared \"The Foolish Dictionary,\" not in serious emulation of the worthier-and wordier-works of Webster and Worcester, but rather in the playful spirit of the parodist, who would gladly direct the faint rays from his flickering candle of fun to the shrine of their great memories.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
