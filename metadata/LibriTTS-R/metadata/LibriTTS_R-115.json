        "speaker_id": "LibriTTS_R-115",
        "content": "With half a million English words to choose from, modesty has been the watchword, and the author has confined himself to the treatment of only about half a thousand.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
