        "speaker_id": "LibriTTS_R-3654",
        "content": "Yet did the disturbance that was in his soul plainly appear by the solicitude he was in [how to recover his affairs again].",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
