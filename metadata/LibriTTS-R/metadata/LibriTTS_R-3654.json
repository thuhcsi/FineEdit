        "speaker_id": "LibriTTS_R-3654",
        "content": "CHAPTER two.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3654_171137_000012_000000",
