        "speaker_id": "LibriTTS_R-6288",
        "content": "Even one man counted there-counted for, oh, so much!--for at the last there was just one man left----john McGuire.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
