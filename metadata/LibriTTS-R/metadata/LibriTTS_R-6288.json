        "speaker_id": "LibriTTS_R-6288",
        "content": "\"Listen!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6288_63111_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6288/63111/6288_63111_000019_000002.wav",
        "speaker_id": "LibriTTS_R-6288",
        "content": "You want others to hear it-what you heard-don't you?\"",
