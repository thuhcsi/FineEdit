        "speaker_id": "LibriTTS_R-6288",
        "content": "\"Susan, I can't! I can't-stand it,\" he moaned.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
