        "speaker_id": "LibriTTS_R-6288",
        "content": "\"john McGuire.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
