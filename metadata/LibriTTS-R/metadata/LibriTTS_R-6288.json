        "speaker_id": "LibriTTS_R-6288",
        "content": "And there it was, wasted, WASTED, worse than wasted on-me!\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
