        "speaker_id": "LibriTTS_R-6288",
        "content": "Why, Susan, I could see it-SEE it, I tell you, and, oh, I did so want to be there to help.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
