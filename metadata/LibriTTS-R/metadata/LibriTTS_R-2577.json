        "speaker_id": "LibriTTS_R-2577",
        "content": "'Little girl, don't be rude,' said Mrs Biddle, flushing violet.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
