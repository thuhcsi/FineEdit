        "speaker_id": "LibriTTS_R-2577",
        "content": "It took some time to arrange the things on the stall.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
