        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2577/157236/2577_157236_000164_000001.wav",
        "speaker_id": "LibriTTS_R-2577",
