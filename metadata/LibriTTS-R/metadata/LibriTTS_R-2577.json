        "speaker_id": "LibriTTS_R-2577",
        "content": "'I don't understand about that blue paper,' said Mrs Biddle. 'It looks to me like the work of a lunatic.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
