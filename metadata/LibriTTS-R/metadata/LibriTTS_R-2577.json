        "speaker_id": "LibriTTS_R-2577",
        "content": "'There's nothing to go back for,' said Miss Peasmarsh gaily; 'thanks to you dear children we've sold everything.'",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
