[
    {
        "item_name": "LibriTTS_R-7559_96246_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000005_000002.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "It is not an original gratification coming to us of itself, but must always be the satisfaction of a wish.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000005_000004.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "But with the satisfaction the wish and therefore the pleasure cease.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000005_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000005_000006.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "It is, however, so hard to attain or achieve anything; difficulties and troubles without end are opposed to every purpose, and at every step hindrances accumulate.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000005_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000005_000009.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Only when we have lost them do we become sensible of their value; for the want, the privation, the sorrow, is the positive, communicating itself directly to us.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Because a genuine enduring happiness is not possible, it cannot be the subject of art.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000008_000005.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "What we see in poetry we find again in music; in the melodies of which we have recognised the universal expression of the inmost history of the self conscious will, the most secret life, longing, suffering, and delight; the ebb and flow of the human heart.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000009_000003.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "First, the powerful will, the strong passions (Radscha Guna).",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000009_000004.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "It appears in great historical characters; it is described in the epic and the drama.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000009_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000009_000014.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "This is why the sight of a corpse makes us suddenly so serious.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "The life of every individual, if we survey it as a whole and in general, and only lay stress upon its most significant features, is really always a tragedy, but gone through in detail, it has the character of a comedy.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000011_000005.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Every event of life is regarded as the work of these beings; the intercourse with them occupies half the time of life, constantly sustains hope, and by the charm of illusion often becomes more interesting than intercourse with real beings.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000002.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "But the chapter would have no end, and would carry us far from the standpoint of the universal, which is essential to philosophy; and, moreover, such a description might easily be taken for a mere declamation on human misery, such as has often been given, and, as such, might be charged with one sidedness, because it started from particular facts.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000010.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "The essential content of the famous soliloquy in \"Hamlet\" is briefly this: Our state is so wretched that absolute annihilation would be decidedly preferable.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000013.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "According to this, the brevity of life, which is so constantly lamented, may be the best quality it possesses.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000015.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "And yet he made a very proper hell of it.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000017.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "But from this it is sufficiently clear what manner of world it is.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000023",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000023.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "As little as an external power can change or suppress this will, so little can a foreign power deliver it from the miseries which proceed from the life which is the phenomenal appearance of that will.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000026",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000026.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "It is and remains the will of man upon which everything depends for him.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96246_000012_000028",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96246/7559_96246_000012_000028.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "But I do not wish to anticipate the later exposition.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000000_000002.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Therefore we can now proceed to bring out more clearly the nature of this assertion and denial itself, which was referred to and explained in a merely general way above.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000000_000003.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "This we shall do by exhibiting the conduct in which alone it finds its expression, and considering it in its inner significance.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000001_000004.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "But indirectly the most different kinds of motives obtain in this way power over the will, and bring about the most multifarious acts of will.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000001_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000001_000005.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Each of these is only an example, an instance, of the will which here manifests itself generally.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000001_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000001_000006.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Of what nature this example may be, what form the motive may have and impart to it, is not essential; the important point here is that something is willed in general and the degree of intensity with which it is so willed.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000001_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000001_000007.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "The will can only become visible in the motives, as the eye only manifests its power of seeing in the light.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000001_000008.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "The motive in general stands before the will in protean forms.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000001_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000001_000009.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "It constantly promises complete satisfaction, the quenching of the thirst of will.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000002_000000.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "From the first appearance of consciousness, a man finds himself a willing being, and as a rule, his knowledge remains in constant relation to his will.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000002_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000002_000005.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "They press forward with much earnestness, and indeed with an air of importance; thus children also pursue their play.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000002_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000002_000006.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "It is always an exception if such a life suffers interruption from the fact that either the aesthetic demand for contemplation or the ethical demand for renunciation proceed from a knowledge which is independent of the service of the will, and directed to the nature of the world in general.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000002_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000002_000007.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Most men are pursued by want all through life, without ever being allowed to come to their senses.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000003_000002.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Nature, always true and consistent, here even naive, exhibits to us openly the inner significance of the act of generation.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000003_000008.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "Here lies the profound reason of the shame connected with the process of generation. This view is mythically expressed in the dogma of Christian theology that we are all partakers in Adam's first transgression (which is clearly just the satisfaction of sexual passion), and through it are guilty of suffering and death.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7559_96247_000003_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7559/96247/7559_96247_000003_000009.wav",
        "speaker_id": "LibriTTS_R-7559",
        "content": "In this theology goes beyond the consideration of things according to the principle of sufficient reason, and recognises the Idea of man, the unity of which is re-established out of its dispersion into innumerable individuals through the bond of generation which holds them all together.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    }
]