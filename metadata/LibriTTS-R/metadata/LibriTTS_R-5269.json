        "speaker_id": "LibriTTS_R-5269",
        "content": "The goat promptly accepted the invitation and at the appointed day they started on their journey to the house of the tiger's friend.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
