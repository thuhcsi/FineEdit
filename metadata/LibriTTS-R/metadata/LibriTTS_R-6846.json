[
    {
        "item_name": "LibriTTS_R-6846_76681_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000003_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "CHAPTER ten-SHY NEIGHBOURHOODS",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000004_000002.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The road was so lonely in the night, that I fell asleep to the monotonous sound of my own feet, doing their regular four miles an hour.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000004_000004.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "It was only when I made a stumble like a drunken man, or struck out into the road to avoid a horseman close upon me on the path-who had no existence-that I came to myself and looked about.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000004_000005.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The day broke mistily (it was autumn time), and I could not disembarrass myself of the idea that I had to climb those heights and banks of cloud, and that there was an Alpine Convent somewhere behind the sun, where I was going to breakfast.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000004_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000004_000007.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "It is a curiosity of broken sleep that I made immense quantities of verses on that pedestrian occasion (of course I never make any when I am in my right senses), and that I spoke a certain language once pretty familiar to me, but which I have nearly forgotten from disuse, with fluency.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000004_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000004_000009.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The readiness is not imaginary, because I often recall long strings of the verses, and many turns of the fluent speech, after I am broad awake.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "My walking is of two kinds: one, straight on end to a definite goal at a round pace; one, objectless, loitering, and purely vagabond.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000006_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "These illustrious men are highly coloured in fighting trim, and fighting attitude.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000006_000002.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "To suggest the pastoral and meditative nature of their peaceful calling, mr Heenan is represented on emerald sward, with primroses and other modest flowers springing up under the heels of his half boots; while mr Sayers is impelled to the administration of his favourite blow, the Auctioneer, by the silent eloquence of a village church.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000006_000003.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The humble homes of England, with their domestic virtues and honeysuckle porches, urge both heroes to go in and win; and the lark and other singing birds are observable in the upper air, ecstatically carolling their thanks to Heaven for a fight.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000006_000004.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "On the whole, the associations entwined with the pugilistic art by this artist are much in the manner of Izaak Walton.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000007_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "For human notes we may return to such neighbourhoods when leisure and opportunity serve.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Nothing in shy neighbourhoods perplexes my mind more, than the bad company birds keep.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Foreign birds often get into good society, but British birds are inseparable from low associates.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000004.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Why is this?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000005.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Also, they will do things for people in short skirted velveteen coats with bone buttons, or in sleeved waistcoats and fur caps, which they cannot be persuaded by the respectable orders of society to undertake.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000006.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "In a dirty court in Spitalfields, once, I found a goldfinch drawing his own water, and drawing as much of it as if he were in a consuming fever.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000007.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "That goldfinch lived at a bird shop, and offered, in writing, to barter himself against old clothes, empty bottles, or even kitchen stuff. Surely a low thing and a depraved taste in any finch!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000008.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I bought that goldfinch for money.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000009.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He was sent home, and hung upon a nail over against my table.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000010.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He lived outside a counterfeit dwelling house, supposed (as I argued) to be a dyer's; otherwise it would have been impossible to account for his perch sticking out of the garret window.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000012.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He drew no water but by stealth and under the cloak of night.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000013.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "After an interval of futile and at length hopeless expectation, the merchant who had educated him was appealed to. The merchant was a bow legged character, with a flat and cushiony nose, like the last new strawberry.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000008_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000008_000014.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He wore a fur cap, and shorts, and was of the velveteen race, velveteeny.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Donkeys again.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000002.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Gentility, nobility, Royalty, would appeal to that donkey in vain to do what he does for a costermonger.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000003.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Feed him with oats at the highest price, put an infant prince and princess in a pair of panniers on his back, adjust his delicate trappings to a nicety, take him to the softest slopes at Windsor, and try what pace you can get out of him.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000004.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Then, starve him, harness him anyhow to a truck with a flat tray on it, and see him bowl from Whitechapel to Bayswater.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000006.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I have known a donkey-by sight; we were not on speaking terms-who lived over on the Surrey side of London bridge, among the fastnesses of Jacob's Island and Dockhead.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000007.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "It was the habit of that animal, when his services were not in immediate requisition, to go out alone, idling.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000008.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I have met him a mile from his place of residence, loitering about the streets; and the expression of his countenance at such times was most degraded.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000010.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The last time I ever saw him (about five years ago) he was in circumstances of difficulty, caused by this failing.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000011.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Having been left alone with the cart of periwinkles, and forgotten, he went off idling.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000012.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He prowled among his usual low haunts for some time, gratifying his depraved tastes, until, not taking the cart into his calculations, he endeavoured to turn up a narrow alley, and became greatly involved.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000013.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He was taken into custody by the police, and, the Green Yard of the district being near at hand, was backed into that place of durance.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000014.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "At that crisis, I encountered him; the stubborn sense he evinced of being-not to compromise the expression-a blackguard, I never saw exceeded in the human subject.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000015.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "A flaring candle in a paper shade, stuck in among his periwinkles, showed him, with his ragged harness broken and his cart extensively shattered, twitching his mouth and shaking his hanging head, a picture of disgrace and obduracy.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000009_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000009_000016.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I have seen boys being taken to station houses, who were as like him as his own brother.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The dogs of shy neighbourhoods, I observe to avoid play, and to be conscious of poverty.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "They avoid work, too, if they can, of course; that is in the nature of all animals.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000005.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He is a dog of the Newfoundland breed, for whose honesty I would be bail to any amount; but whose intellectual qualities in association with dramatic fiction, I cannot rate high.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000006.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Indeed, he is too honest for the profession he has entered.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000008.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "His first scene was eminently successful; but, as it occupied a second in its representation (and five lines in the bill), it scarcely afforded ground for a cool and deliberate judgment of his powers.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000009.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He had merely to bark, run on, and jump through an inn window, after a comic fugitive.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000011.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "But it was in his greatest scene of all, that his honesty got the better of him.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000012.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He had to enter a dense and trackless forest, on the trail of the murderer, and there to fly at the murderer when he found him resting at the foot of a tree, with his victim bound ready for slaughter.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000010_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000010_000015.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "It happened through these means, that when he was in course of time persuaded to trot up and rend the murderer limb from limb, he made it (for dramatic purposes) a little too obvious that he worked out that awful retribution by licking butter off his blood stained hands.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I may venture to say that I am on terms of intimacy with both, and that I never saw either guilty of the falsehood of failing to look down at the man inside the show, during the whole performance.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000002.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The difficulty other dogs have in satisfying their minds about these dogs, appears to be never overcome by time.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000003.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The same dogs must encounter them over and over again, as they trudge along in their off minutes behind the legs of the show and beside the drum; but all dogs seem to suspect their frills and jackets, and to sniff at them as if they thought those articles of personal adornment, an eruption-a something in the nature of mange, perhaps.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000004.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "From this Covent garden window of mine I noticed a country dog, only the other day, who had come up to Covent garden Market under a cart, and had broken his cord, an end of which he still trailed along with him.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000005.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He loitered about the corners of the four streets commanded by my window; and bad London dogs came up, and told him lies that he didn't believe; and worse London dogs came up, and made proposals to him to go and steal in the market, which his principles rejected; and the ways of the town confused him, and he crept aside and lay down in a doorway.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000006.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He had scarcely got a wink of sleep, when up comes Punch with Toby.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000008.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "The show was pitched, Toby retired behind the drapery, the audience formed, the drum and pipes struck up.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000009.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "My country dog remained immovable, intently staring at these strange appearances, until Toby opened the drama by appearing on his ledge, and to him entered Punch, who put a tobacco pipe into Toby's mouth.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000011_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000011_000010.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "At this spectacle, the country dog threw up his head, gave one terrible howl, and fled due west.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000012_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "We talk of men keeping dogs, but we might often talk more expressively of dogs keeping men.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000012_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I know a bull dog in a shy corner of Hammersmith who keeps a man.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000012_000005.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "This, however, was not in a shy neighbourhood, and is a digression consequently.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "There are a great many dogs in shy neighbourhoods, who keep boys. I have my eye on a mongrel in Somerstown who keeps three boys.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He feigns that he can bring down sparrows, and unburrow rats (he can do neither), and he takes the boys out on sporting pretences into all sorts of suburban fields.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000008.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "They sit (very uncomfortably) on a sloping stone there, and compare notes.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000009.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Their dogs may always be observed at the same time, openly disparaging the men they keep, to one another, and settling where they shall respectively take their men when they begin to move again.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000010.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "At a small butcher's, in a shy neighbourhood (there is no reason for suppressing the name; it is by Notting hill, and gives upon the district called the Potteries), I know a shaggy black and white dog who keeps a drover.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000011.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He is a dog of an easy disposition, and too frequently allows this drover to get drunk.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000012.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "On these occasions, it is the dog's custom to sit outside the public house, keeping his eye on a few sheep, and thinking.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000015.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "A light has gradually broken on him, he has remembered at what butcher's he left them, and in a burst of grave satisfaction has caught a fly off his nose, and shown himself much relieved.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000016.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "If I could at any time have doubted the fact that it was he who kept the drover, and not the drover who kept him, it would have been abundantly proved by his way of taking undivided charge of the six sheep, when the drover came out besmeared with red ochre and beer, and gave him wrong directions, which he calmly disregarded.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000013_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000013_000017.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "He has taken the sheep entirely into his own hands, has merely remarked with respectful firmness, 'That instruction would place them under an omnibus; you had better confine your attention to yourself-you will want it all;' and has driven his charge away, with an intelligence of ears and tail, and a knowledge of business, that has left his lout of a man very, very far behind.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000014_000000.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "As the dogs of shy neighbourhoods usually betray a slinking consciousness of being in poor circumstances-for the most part manifested in an aspect of anxiety, an awkwardness in their play, and a misgiving that somebody is going to harness them to something, to pick up a living-so the cats of shy neighbourhoods exhibit a strong tendency to relapse into barbarism.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000014_000003.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I am on terms of recognition with several small streets of cats, about the Obelisk in Saint George's Fields, and also in the vicinity of Clerkenwell green, and also in the back settlements of Drury lane.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000014_000004.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "In appearance, they are very like the women among whom they live. They seem to turn out of their unwholesome beds into the street, without any preparation.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000014_000005.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "They leave their young families to stagger about the gutters, unassisted, while they frouzily quarrel and swear and scratch and spit, at street corners.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000014_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000014_000006.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "In particular, I remark that when they are about to increase their families (an event of frequent recurrence) the resemblance is strongly expressed in a certain dusty dowdiness, down at heel self neglect, and general giving up of things.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000014_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000014_000007.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I cannot honestly report that I have ever seen a feline matron of this class washing her face when in an interesting condition.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000016_000001.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I wonder at nothing concerning them, and take them as they are.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000016_000002.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I accept as products of Nature and things of course, a reduced Bantam family of my acquaintance in the Hackney road, who are incessantly at the pawnbroker's.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000016_000003.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "I cannot say that they enjoy themselves, for they are of a melancholy temperament; but what enjoyment they are capable of, they derive from crowding together in the pawnbroker's side entry.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000016_000004.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Here, they are always to be found in a feeble flutter, as if they were newly come down in the world, and were afraid of being identified.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000016_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000016_000008.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "Their abstraction from the objects among which they live, or rather their conviction that those objects have all come into existence in express subservience to fowls, has so enchanted me, that I have made them the subject of many journeys at divers hours.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6846_76681_000016_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6846/76681/6846_76681_000016_000010.wav",
        "speaker_id": "LibriTTS_R-6846",
        "content": "They look upon old shoes, wrecks of kettles and saucepans, and fragments of bonnets, as a kind of meteoric discharge, for fowls to peck at.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    }
]