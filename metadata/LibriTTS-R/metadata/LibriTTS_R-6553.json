[
    {
        "item_name": "LibriTTS_R-6553_82558_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/82558/6553_82558_000004_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "At that time, Moreover, the first storm was overblown, And the strong hand of outward violence Locked up in quiet.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_82558_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/82558/6553_82558_000005_000003.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "'twas in truth an hour Of universal ferment; mildest men Were agitated; and commotions, strife Of passion and opinion, filled the walls Of peaceful houses with unquiet sounds.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_82558_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/82558/6553_82558_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Such was the state of things.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_82558_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/82558/6553_82558_000010_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "A meeker man Than this lived never, nor a more benign, Meek though enthusiastic.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_82558_000014_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/82558/6553_82558_000014_000006.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "But, these things set apart, Was not this single confidence enough To animate the mind that ever turned A thought to human welfare?",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_82558_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/82558/6553_82558_000015_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Oh, happy time of youthful lovers, (thus The story might begin).",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000001_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "The Story of Deirdre",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000003_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "The man was a right good man, and he had a goodly share of this world's goods. He had a wife, but no family.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000003_000003.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Whether it was that he was invited or that he came of himself, the soothsayer came to the house of Malcolm.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Yes, I am doing a little.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Well, I do not mind taking soothsaying from you, if you had soothsaying for me, and you would be willing to do it.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000009_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Well, I am going out, and when I return I will tell you.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000011_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "And the three most famous heroes that ever were found will lose their heads on her account.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000012_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "He did not allow a living being to come to his house, only himself and the nurse.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000012_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "He asked this woman, \"Will you yourself bring up the child to keep her in hiding far away where eye will not see a sight of her nor ear hear a word about her?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "He caused there a hillock, round and green, to be dug out of the middle, and the hole thus made to be covered carefully over, so that a little company could dwell there together.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000013_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "This was done.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000014_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Deirdre and her foster mother dwelt in the bothy mid the hills without the knowledge or the suspicion of any living person about them and without anything occurring, until Deirdre was sixteen years of age. Deirdre grew like the white sapling, straight and trim as the rash on the moss.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000015_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "The woman that had charge of her gave Deirdre every information and skill of which she herself had knowledge and skill.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000015_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "There was not a blade of grass growing from root, nor a bird singing in the wood, nor a star shining from heaven but Deirdre had a name for it.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000015_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "But one thing, she did not wish her to have either part or parley with any single living man of the rest of the world.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000015_000003.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "But on a gloomy winter night, with black, scowling clouds, a hunter of game was wearily travelling the hills, and what happened but that he missed the trail of the hunt, and lost his course and companions.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000015_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000015_000009.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "There is no shelter or house for them here.\" \"O foster mother, the bird asked to get inside for the sake of the God of the Elements, and you yourself tell me that anything that is asked in His name we ought to do.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000015_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000015_000010.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "If you will not allow the bird that is being benumbed with cold, and done to death with hunger, to be let in, I do not think much of your language or your faith.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000015_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000015_000012.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "She placed a seat in the place for sitting, food in the place for eating, and drink in the place for drinking for the man who came to the house.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000016_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"What men are these you refer to?\" said Deirdre.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000026_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Well, I did see her,\" said the hunter.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000026_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"But, if I did, no man else can see her unless he get directions from me as to where she is dwelling.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000027_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"And will you direct me to where she dwells? and the reward of your directing me will be as good as the reward of your message,\" said the king.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000028_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Well, I will direct you, O king, although it is likely that this will not be what they want,\" said the hunter.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000029_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Connachar, king of Ulster, sent for his nearest kinsmen, and he told them of his intent.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000030_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Connachar with his band of kinsfolk went down to the green knoll where Deirdre dwelt and he knocked at the door of the bothy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000030_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "The nurse replied, \"No less than a king's command and a king's army could put me out of my bothy to night.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000030_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "And I should be obliged to you, were you to tell who it is that wants me to open my bothy door.\" \"It is I, Connachar, king of Ulster.\" When the poor woman heard who was at the door, she rose with haste and let in the king and all that could get in of his retinue.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000031_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "When the king saw the woman that was before him that he had been in quest of, he thought he never saw in the course of the day nor in the dream of night a creature so fair as Deirdre and he gave his full heart's weight of love to her.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000031_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Deirdre was raised on the topmost of the heroes' shoulders and she and her foster mother were brought to the Court of King Connachar of Ulster.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000032_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "With the love that Connachar had for her, he wanted to marry Deirdre right off there and then, will she nill she marry him.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000032_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000032_000003.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Deirdre was clever in maidenly duties and wifely understanding, and Connachar thought he never saw with bodily eye a creature that pleased him more.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000032_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000032_000006.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Deirdre was looking at the men that were coming, and wondering at them.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000032_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000032_000010.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "She girded up her raiment and went after the men that went past the base of the knoll, leaving her women attendants there.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000032_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000032_000012.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "They perceived the woman coming, and called on one another to hasten their step as they had a long distance to travel, and the dusk of night was coming on. They did so.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000032_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000032_000014.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"It isn't anything else but the wail of the wave swans of Connachar,\" said his brothers.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000032_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000032_000017.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "With the confusion that she was in, Deirdre went into a crimson blaze of fire, and her colour came and went as rapidly as the movement of the aspen by the stream side.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000033_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "He reached the side of Loch Ness and made his habitation there.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000034_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "By this time the end of the period came at which Deirdre had to marry Connachar, king of Ulster.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000034_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000034_000003.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "He sent word far and wide through Erin to all his kinspeople to come to the feast.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000041_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "There came three white doves out of the South Flying over the sea, And drops of honey were in their mouth From the hive of the honey bee.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000043_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "I saw three grey hawks out of the South Come flying over the sea, And the red drops they bare in their mouth They were dearer than life to me.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000045_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "It is nought but the fear of woman's heart, And a dream of the night, Deirdre.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000046_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"The day that Connachar sent the invitation to his feast will be unlucky for us if we don't go, O Deirdre.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000050_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000050_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Deirdre wept tears in showers and she sang:",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000054_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000054_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "But there is a house down yonder where I keep strangers, and let them go down to it to day, and my house will be ready before them to morrow.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000055_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000055_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "But he that was up in the palace felt it long that he was not getting word as to how matters were going on for those down in the house of the strangers.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000055_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000055_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Go you, Gelban Grednach, son of Lochlin's King, go you down and bring me information as to whether her former hue and complexion are on Deirdre.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000056_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000056_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Now she that he gazed upon used to go into a crimson blaze of blushes when any one looked at her.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000060_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Connachar ordered three hundred active heroes to go down to the abode of the strangers, and to take Deirdre up with them and kill the rest. \"The pursuit is coming,\" said Deirdre.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000066_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000066_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Well, Connachar, we will not accept that offer from you, nor thank you for it.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000066_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000066_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Greater by far do we prefer to go home to our father and tell the deeds of heroism we have done, than accept anything on these terms from you.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000067_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000067_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Word came to the king that the company he was in pursuit of were gone.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000069_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000069_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"What is the good of that?",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000069_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000069_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "that will not do yet,\" said Connachar. \"They are off without bending of their feet or stopping of their step, without heed or respect to me, and I am without power to keep up to them, or opportunity to turn them back this night.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000070_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000070_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"I will try another plan on them,\" said the druid; and he placed before them a grey sea instead of a green plain.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000072_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000072_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Though that be good, O Duanan, it will not make the heroes return,\" said Connachar; \"they are gone without regard for me, and without honor to me, and without power on my part to pursue them, or to force them to return this night.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000074_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000074_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"We shall try another method on them, since yon one did not stop them,\" said the druid.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000074_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000074_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Then Arden cried that he was getting tired, and nearly giving over.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000074_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000074_000005.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Allen then cried out that he was getting faint and well nigh giving up.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000075_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000075_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"They are gone,\" said Duanan Gacha Druid to the king, \"and I have done what you desired me.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000076_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000076_000000.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "\"Blessings for that upon you and may the good results accrue to me, Duanan.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000076_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000076_000001.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "I count it no loss what I spent in the schooling and teaching of you.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6553_86683_000076_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6553/86683/6553_86683_000076_000002.wav",
        "speaker_id": "LibriTTS_R-6553",
        "content": "Now dry up the flood and let me see if I can behold Deirdre,\" said Connachar.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    }
]