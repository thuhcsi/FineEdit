        "speaker_id": "LibriTTS_R-3729",
        "content": "\"Quite the reverse, for it was a cunning artifice on her part.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
