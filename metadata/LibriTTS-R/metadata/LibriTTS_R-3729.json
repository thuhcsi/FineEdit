        "speaker_id": "LibriTTS_R-3729",
        "content": "\"You are mad, she has given birth to a princess.\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
