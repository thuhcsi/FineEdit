        "speaker_id": "LibriTTS_R-3729",
        "content": "My new friend was a poet as I was; he was an admirer of Italian literature, while I admired the French.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
