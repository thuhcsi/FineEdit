        "speaker_id": "LibriTTS_R-3729",
        "content": "I address him in Italian, and he answers very wittily, but his way of speaking makes me smile, and I tell him why.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
