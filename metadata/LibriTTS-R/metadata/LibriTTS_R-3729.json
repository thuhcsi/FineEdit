        "speaker_id": "LibriTTS_R-3729",
        "content": "I laugh heartily.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
