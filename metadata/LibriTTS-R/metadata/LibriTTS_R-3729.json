        "speaker_id": "LibriTTS_R-3729",
        "content": "She held her tongue, but from that time she told everybody that I was an impostor.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
