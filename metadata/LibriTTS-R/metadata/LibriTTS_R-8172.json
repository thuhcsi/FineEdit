        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8172/281515/8172_281515_000037_000002.wav",
        "speaker_id": "LibriTTS_R-8172",
        "content": "Did the Conquerors heap Their spoils here?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
