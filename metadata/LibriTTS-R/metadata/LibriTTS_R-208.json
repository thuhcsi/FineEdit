        "speaker_id": "LibriTTS_R-208",
        "content": "So long as the hens lay eggs and the cow gives milk we can have omelettes and junket.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
