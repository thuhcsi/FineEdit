        "speaker_id": "LibriTTS_R-208",
        "content": "The Winter is still a long way off.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
