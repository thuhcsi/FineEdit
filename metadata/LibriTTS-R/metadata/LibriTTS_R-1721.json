        "speaker_id": "LibriTTS_R-1721",
        "content": "'Oh! let us go.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000052_000001",
