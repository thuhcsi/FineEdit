        "speaker_id": "LibriTTS_R-1721",
        "content": "But none in his household saw mr Thornton again that day.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
