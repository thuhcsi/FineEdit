[
    {
        "item_name": "LibriTTS_R-1721_142317_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "It was noisy, and smoky, and the poor people whom she saw in the streets were dirty, and the rich ladies over dressed, and not a man that she saw, high or low, had his clothes made to fit him.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "She was sure Margaret would never regain her lost strength while she stayed in Milton; and she herself was afraid of one of her old attacks of the nerves.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000003_000003.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Margaret must return with her, and that quickly.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Captain Lennox and mr Thornton are here.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "However, that Dixon of yours is trusty; and can hold her, or your own, till I come.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000007.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Or you can send a list afterwards.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000008.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Now two things more, and I have done.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000009.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "You know, or if you don't, your poor father did, that you are to have my money and goods when I die.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000011.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "These Lennoxes seem very fond of you now; and perhaps may continue to be; perhaps not.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000015.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "I make no doubt you have.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000016.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Yet the old man has a right.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000004_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000004_000018.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Write by return, if only two lines, to tell me your answer.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Margaret took up a pen and scrawled with trembling hand, 'Margaret Hale is not the girl to say him nay.' In her weak state she could not think of any other words, and yet she was vexed to use these.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000005_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "She was obliged to lie down again, and try not to think.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Has that letter vexed or troubled you?'",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'I shall be better when to morrow is over.'",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'I feel sure, darling, you won't be better till I get you out of this horrid air.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000008_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "How you can have borne it this two years I can't imagine.'",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'Where could I go to?",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'Well! don't distress yourself, my dear.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "I dare say it was all for the best, only I had no conception of how you were living.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Our butler's wife lives in a better house than this.'",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'It is sometimes very pretty-in summer; you can't judge by what it is now.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "I have been very happy here,' and Margaret closed her eyes by way of stopping the conversation.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "The house teemed with comfort now, compared to what it had done.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000012_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "The evenings were chilly, and by mrs Shaw's directions fires were lighted in every bedroom.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000012_000004.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "She was restless, though so weak.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000012_000005.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "All the day long, she kept herself from thinking of the ceremony which was going on at Oxford, by wandering from room to room, and languidly setting aside such articles as she wished to retain.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000012_000006.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Dixon followed her by mrs Shaw's desire, ostensibly to receive instructions, but with a private injunction to soothe her into repose as soon as might be.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'These books, Dixon, I will keep.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "All the rest will you send to mr Bell?",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000013_000003.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "This---- I should like you to take this to mr Thornton, after I am gone.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'DEAR SIR,--The accompanying book I am sure will be valued by you for the sake of my father, to whom it belonged.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000018_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "mrs Shaw objected:",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'But to day is my only day; if Captain Lennox comes this afternoon, and if we must-if I must really go to morrow---- '",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000021_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "No; if you must pay these calls, I will go with you. Dixon can get us a coach, I suppose?'",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Margaret's face was too sad to lighten up into a smile at all this preparation for paying two visits, that she had often made by herself at all hours of the day.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000024_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Margaret was vexed with herself for not having timed her visit better.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000026_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'I should like to have some little thing to remind me of Bessy.'",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000027_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Instantly Mary's generosity was keenly alive.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000027_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "What could they give?",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000029_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'That will do, thank you,' said Margaret; and she went quickly away, while the light caused by the pleasure of having something to give yet lingered on Mary's face.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000032_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'What an icy room!' she said.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000033_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "They had to wait for some time before mrs Thornton entered.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000033_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "She remembered her spirit, as shown at various times and places even more than the patience with which she had endured long and wearing cares.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000033_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000033_000003.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Her countenance was blander than usual, as she greeted her; there was even a shade of tenderness in her manner, as she noticed the white, tear swollen face, and the quiver in the voice which Margaret tried to make so steady.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000035_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Thanks for kindness! and apologies for failure in good manners!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000035_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "But mrs Thornton replied:",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000036_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'Miss Hale, I am glad you do me justice.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000036_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "I have always desired to act the part of a friend to you.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000036_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000036_000003.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "I am glad you do me justice.'",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000037_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'And,' said Margaret, blushing excessively as she spoke, 'will you do me justice, and believe that though I cannot-I do not choose-to give explanations of my conduct, I have not acted in the unbecoming way you apprehended?'",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000039_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'Yes, I do believe you.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000039_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Let us say no more about it.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000039_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000039_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Where are you going to reside, Miss Hale?",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000039_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000039_000003.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "I understood from mr Bell that you were going to leave Milton.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000039_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000039_000004.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "You never liked Milton, you know,' said mrs Thornton, with a sort of grim smile; 'but for all that, you must not expect me to congratulate you on quitting it.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000039_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000039_000005.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Where shall you live?'",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000041_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'My niece will reside with me in Harley Street.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000041_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "If you and your husband ever come to town, my son and daughter, Captain and mrs Lennox, will, I am sure, join with me in wishing to do anything in our power to show you attention.'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000042_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "mrs Thornton thought in her own mind, that Margaret had not taken much care to enlighten her aunt as to the relationship between the mr and mrs Thornton, towards whom the fine lady aunt was extending her soft patronage; so she answered shortly,",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000043_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'My husband is dead.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000043_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "mr Thornton is my son.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000043_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000043_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "I never go to London; so I am not likely to be able to avail myself of your polite offers.'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000044_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "At this instant mr Thornton entered the room; he had only just returned from Oxford.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000044_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "His mourning suit spoke of the reason that had called him there.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000046_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'You are going then!' said he, in a low voice.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000047_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'Yes,' said Margaret. 'We leave to morrow.'",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000048_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "'My son in law comes this evening to escort us,' said mrs Shaw.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000049_000000.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "mr Thornton turned away.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000049_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000049_000001.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "He had not sat down, and now he seemed to be examining something on the table, almost as if he had discovered an unopened letter, which had made him forget the present company.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000049_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000049_000002.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "He did not even seem to be aware when they got up to take leave.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000049_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000049_000003.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "He started forwards, however, to hand mrs Shaw down to the carriage.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000049_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000049_000004.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "As it drove up, he and Margaret stood close together on the door step, and it was impossible but that the recollection of the day of the riot should force itself into both their minds.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000049_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000049_000006.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "And at the remembrance of her taunting words, his brow grew stern, though his heart beat thick with longing love. 'No!' said he, 'I put it to the touch once, and I lost it all.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1721_142317_000049_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1721/142317/1721_142317_000049_000007.wav",
        "speaker_id": "LibriTTS_R-1721",
        "content": "Let her go,--with her stony heart, and her beauty;--how set and terrible her look is now, for all her loveliness of feature!",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
