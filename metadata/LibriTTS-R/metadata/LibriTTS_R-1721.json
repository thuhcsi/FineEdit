        "speaker_id": "LibriTTS_R-1721",
        "content": "Beauty and heiress as she may be, she will find it hard to meet with a truer heart than mine.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
