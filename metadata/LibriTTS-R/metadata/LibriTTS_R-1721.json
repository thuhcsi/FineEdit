        "speaker_id": "LibriTTS_R-1721",
        "content": "I shall not get well here.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
