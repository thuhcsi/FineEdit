        "speaker_id": "LibriTTS_R-1721",
        "content": "He was busily engaged; or so he said.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
