        "speaker_id": "LibriTTS_R-836",
        "content": "Even so, ten o'clock was about to strike.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
