        "speaker_id": "LibriTTS_R-836",
        "content": "\"Maelstrom!",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
