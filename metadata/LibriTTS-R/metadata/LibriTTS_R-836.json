        "speaker_id": "LibriTTS_R-836",
        "content": "\"Then we'll die together, Ned my friend.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
