        "speaker_id": "LibriTTS_R-836",
        "content": "\"Yes.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
