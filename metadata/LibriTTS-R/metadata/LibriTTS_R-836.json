        "speaker_id": "LibriTTS_R-836",
        "content": "\"Yes,\" I muttered, \"we know how to die!\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
