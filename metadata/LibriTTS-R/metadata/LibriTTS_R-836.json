        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/836/130900/836_130900_000057_000000.wav",
        "speaker_id": "LibriTTS_R-836",
        "content": "The Canadian paused in his work.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
