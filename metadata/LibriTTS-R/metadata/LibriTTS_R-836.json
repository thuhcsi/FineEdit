        "speaker_id": "LibriTTS_R-836",
        "content": "Maelstrom!\" they were shouting.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
