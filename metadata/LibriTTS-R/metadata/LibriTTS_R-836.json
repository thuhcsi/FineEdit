        "speaker_id": "LibriTTS_R-836",
        "content": "We'll escape tonight even if the sea swallows us up!\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
