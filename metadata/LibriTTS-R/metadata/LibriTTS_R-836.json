        "speaker_id": "LibriTTS_R-836",
        "content": "It was best not to meet him face to face! Best to try and forget him!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
