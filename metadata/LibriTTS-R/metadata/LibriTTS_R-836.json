    {
        "item_name": "LibriTTS_R-836_130900_000055_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/836/130900/836_130900_000055_000001.wav",
        "speaker_id": "LibriTTS_R-836",
        "content": "What was it? Had they spotted our escape?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
