        "speaker_id": "LibriTTS_R-836",
        "content": "Captain Nemo had left his stateroom. He was in the same lounge I had to cross in order to escape. There I would encounter him one last time.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
