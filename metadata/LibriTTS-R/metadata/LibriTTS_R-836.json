        "speaker_id": "LibriTTS_R-836",
        "content": "I opened it gently. The lounge was plunged in profound darkness.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
