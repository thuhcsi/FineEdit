        "speaker_id": "LibriTTS_R-836",
        "content": "I no longer wanted to think. A half hour still to wait!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
