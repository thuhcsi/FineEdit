        "speaker_id": "LibriTTS_R-836",
        "content": "What was he doing just then?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
