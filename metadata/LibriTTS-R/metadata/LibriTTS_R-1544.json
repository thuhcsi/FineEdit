        "speaker_id": "LibriTTS_R-1544",
        "content": "That must not be.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
