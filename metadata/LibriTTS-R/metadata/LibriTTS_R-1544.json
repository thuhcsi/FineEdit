        "speaker_id": "LibriTTS_R-1544",
        "content": "\"Why, Kostya, you here too!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
