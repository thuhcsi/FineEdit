        "speaker_id": "LibriTTS_R-1544",
        "content": "Many had come only for that day.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
