        "speaker_id": "LibriTTS_R-1544",
        "content": "And listening to the conversation, he supported Sviazhsky's contention.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
