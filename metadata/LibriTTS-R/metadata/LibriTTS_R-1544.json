        "speaker_id": "LibriTTS_R-1544",
        "content": "\"She writes; and I call her stuck up.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
