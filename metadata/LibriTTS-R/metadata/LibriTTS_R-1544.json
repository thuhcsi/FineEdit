        "speaker_id": "LibriTTS_R-1544",
        "content": "There was much discussion around the governor's table under the portrait of the Tsar.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
