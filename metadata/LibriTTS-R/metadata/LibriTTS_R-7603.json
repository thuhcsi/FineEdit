        "speaker_id": "LibriTTS_R-7603",
        "content": "As I entered the chamber, I looked about, of course, for the occupant, but did not immediately perceive him.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
