        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7603/274560/7603_274560_000044_000000.wav",
        "speaker_id": "LibriTTS_R-7603",
        "content": "I fairly shouted with terror, and made off, at a tangent, into the farthest extremity of the room.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
