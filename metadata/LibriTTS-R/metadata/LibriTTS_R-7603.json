        "speaker_id": "LibriTTS_R-7603",
        "content": "I would be plain, positive, peremptory-as short as pie crust-as concise as Tacitus or Montesquieu.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
