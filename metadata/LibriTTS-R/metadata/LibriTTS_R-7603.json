        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7603/274560/7603_274560_000034_000000.wav",
        "speaker_id": "LibriTTS_R-7603",
        "content": "\"Smith?\" said he, in his well-known peculiar way of drawling out his syllables; \"Smith?--why, not General john a b c?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
