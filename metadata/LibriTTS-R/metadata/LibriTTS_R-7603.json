        "speaker_id": "LibriTTS_R-7603",
        "content": "There was no chance of hearing anything farther that evening in regard to Brevet Brigadier General john a b c Smith.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
