        "speaker_id": "LibriTTS_R-7603",
        "content": "In the meantime, however, I had no notion of being thwarted touching the information I desired.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
