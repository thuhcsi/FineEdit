        "speaker_id": "LibriTTS_R-7603",
        "content": "Yes! mrs O'Trump, she went on, and I-I went off.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
