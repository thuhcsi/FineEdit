        "speaker_id": "LibriTTS_R-7603",
        "content": "\"Madam!\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
