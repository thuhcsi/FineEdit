        "speaker_id": "LibriTTS_R-7603",
        "content": "\"Did ever anybody hear the like?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
