[
    {
        "item_name": "LibriTTS_R-1795_142410_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000000_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"EXIT TYRANNUS\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000001_000002.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "The time that remained had been taken up by the planning of practical expressions of the popular sentiment.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "I was awakened by Harold digging me in the ribs, and \"She's going to day!\" was the morning hymn that scattered the clouds of sleep.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Strange to say, it was with no corresponding jubilation of spirits that I slowly realised the momentous fact.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Harold was evidently feeling it too, for after repeating \"She's going to day!\" in a tone more befitting the Litany, he looked hard in my face for direction as to how the situation was to be taken.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Down at last and out in the sun, we found Edward before us, swinging on a gate, and chanting a farm yard ditty in which all the beasts appear in due order, jargoning in their several tongues, and every verse begins with the couplet-",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"Now, my lads, come with me, Out in the morning early!\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"She's going to day!\" I said.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Edward's carol subsided like a water tap turned off.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "At breakfast Miss Smedley behaved in a most mean and uncalled for manner.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "The right divine of governesses to govern wrong includes no right to cry.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "In thus usurping the prerogative of their victims, they ignore the rules of the ring, and hit below the belt.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000007_000003.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Charlotte was crying, of course; but that counted for nothing.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000007_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000007_000007.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "History has not even considered the possibility.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000007_000008.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Rules and precedents should be strictly observed on both sides; when they are violated, the other party is justified in feeling injured.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "There were no lessons that morning, naturally-another grievance!",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "It was a wrong system altogether, I thought, this going of people one had got used to.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Things ought always to continue as they had been.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000009_000003.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Change there must be, of course; pigs, for instance, came and went with disturbing frequency-",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"Fired their ringing shot and passed, Hotly charged and sank at last,\"--",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "but Nature had ordered it so, and in requital had provided for rapid successors.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"Grand fun!\" I replied, dolorously; and conversation flagged.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Edward gazed around him dubiously.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000016_000003.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "P'raps I won't run it up at all.\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Harold came round the corner like a bison pursued by Indians.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"You leave 'em alone,\" said Edward, severely, \"or you'll be blowing yourself up\" (consideration for others was not usually Edward's strong point).",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000018_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"Don't touch the gunpowder till you're told, or you'll get your head smacked.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Harold fell behind, limp, squashed, obedient.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000019_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"She wants me to write to her,\" he began, presently.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1795_142410_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142410/1795_142410_000019_000003.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Fancy her saying that!\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000000_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "If he would only make it up, she would have done the apologising part herself.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000000_000002.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "But that was not a boy's way.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000000_000003.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Something solid, Harold felt, was due from him; and until that was achieved, making up must not be thought of, in order that the final effect might not be spoilt.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "\"I know what she wants most,\" said Harold.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000001_000002.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "But it costs five shillings!\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "The result worked out as follows:--",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "The rest promised to be easy.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1795/142412/1795_142412_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1795",
        "content": "Selina had a tea party at five on the morrow, with the chipped old wooden tea things that had served her successive dolls from babyhood.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1795_142412_000009_000002",
