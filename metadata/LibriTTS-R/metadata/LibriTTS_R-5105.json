[
    {
        "item_name": "LibriTTS_R-5105_28233_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000001_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "CHAPTER two.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000010_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Hector Servadac was thirty years of age, an orphan without lineage and almost without means.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000010_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Thirsting for glory rather than for gold, slightly scatter brained, but warm hearted, generous, and brave, he was eminently formed to be the protege of the god of battles.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000013_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "They came to a place where the side work of the trench had been so riddled by shell that a portion of it had actually fallen in, leaving an aperture quite unsheltered from the grape shot that was pouring in thick and fast.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000013_000003.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The men hesitated.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000013_000004.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "In an instant Servadac mounted the side work, laid himself down in the gap, and thus filling up the breach by his own body, shouted, \"March on!\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000014_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "And through a storm of shot, not one of which touched the prostrate officer, the troop passed in safety.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000016_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "She was a colonel's widow, young and handsome, very reserved, not to say haughty in her manner, and either indifferent or impervious to the admiration which she inspired. Captain Servadac had not yet ventured to declare his attachment; of rivals he was well aware he had not a few, and amongst these not the least formidable was the Russian Count Timascheff.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000017_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Ben Zoof was devoted, body and soul, to his superior officer.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000018_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "To crown all, Montmartre boasted a mountain-a veritable mountain; envious tongues indeed might pronounce it little more than a hill; but Ben Zoof would have allowed himself to be hewn in pieces rather than admit that it was anything less than fifteen thousand feet in height.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000019_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Ben Zoof, however, did not despair of ultimately converting the captain, and meanwhile had resolved never to leave him.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000019_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "When a private in the eighth Cavalry, he had been on the point of quitting the army at twenty eight years of age, but unexpectedly he had been appointed orderly to Captain Servadac.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000019_000003.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Side by side they fought in two campaigns.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000019_000004.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Servadac had saved Ben Zoof's life in Japan; Ben Zoof had rendered his master a like service in the Soudan.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000019_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000019_000005.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The bond of union thus effected could never be severed; and although Ben Zoof's achievements had fairly earned him the right of retirement, he firmly declined all honors or any pension that might part him from his superior officer.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28233_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28233/5105_28233_000022_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Ben Zoof's eyes glistened with delight; and from that moment Hector Servadac and Montmartre held equal places in his affection.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28240_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28240/5105_28240_000003_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "CHAPTER nine.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28240_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28240/5105_28240_000013_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "After rounding the peak, she steered direct for the channel to which Servadac by his gestures was pointing her, and was not long in entering the creek.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28240_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28240/5105_28240_000013_000005.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Captain Servadac hastened towards him.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28240_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28240/5105_28240_000017_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"I am quite aware of it.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28240_000024_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28240/5105_28240_000024_000005.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Was he aware, in short, that the entire motions of the terrestrial sphere had undergone a complete modification? To all these inquiries, the count responded in the affirmative.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28240_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28240/5105_28240_000030_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The count shook his head.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5105_28240_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28240/5105_28240_000031_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"I am not sure,\" said he, \"but what the tour of the Mediterranean will prove to be the tour of the world.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000002_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "CHAPTER ten A SEARCH FOR ALGERIA",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000003_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Her sea going qualities were excellent, and would have amply sufficed for a circumnavigation of the globe.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000003_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Count Timascheff was himself no sailor, but had the greatest confidence in leaving the command of his yacht in the hands of Lieutenant Procope, a man of about thirty years of age, and an excellent seaman.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000003_000004.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "After an apprenticeship on a merchant ship he had entered the imperial navy, and had already reached the rank of lieutenant when the count appointed him to the charge of his own private yacht, in which he was accustomed to spend by far the greater part of his time, throughout the winter generally cruising in the Mediterranean, whilst in the summer he visited more northern waters.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000004_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The ship could not have been in better hands.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000004_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The lieutenant was well informed in many matters outside the pale of his profession, and his attainments were alike creditable to himself and to the liberal friend who had given him his education.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000004_000004.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The late astounding events, however, had rendered Procope manifestly uneasy, and not the less so from his consciousness that the count secretly partook of his own anxiety.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000005_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Steam up and canvas spread, the schooner started eastwards.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000005_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "With a favorable wind she would certainly have made eleven knots an hour had not the high waves somewhat impeded her progress.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000005_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Although only a moderate breeze was blowing, the sea was rough, a circumstance to be accounted for only by the diminution in the force of the earth's attraction rendering the liquid particles so buoyant, that by the mere effect of oscillation they were carried to a height that was quite unprecedented.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000005_000004.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Nor did these waves in the usual way partially unfurl themselves and rebound against the sides of the vessel; they might rather be described as long undulations carrying the schooner (its weight diminished from the same cause as that of the water) alternately to such heights and depths, that if Captain Servadac had been subject to seasickness he must have found himself in sorry plight.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000006_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "For a few miles she followed the line hitherto presumably occupied by the coast of Algeria; but no land appeared to the south.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000007_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Happily the recent phenomena had no effect upon the compass; the magnetic needle, which in these regions had pointed about twenty two degrees from the north pole, had never deviated in the least-a proof that, although east and west had apparently changed places, north and south continued to retain their normal position as cardinal points.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000008_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "On the first morning of the cruise Lieutenant Procope, who, like most Russians, spoke French fluently, was explaining these peculiarities to Captain Servadac; the count was present, and the conversation perpetually recurred, as naturally it would, to the phenomena which remained so inexplicable to them all.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000009_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"It is very evident,\" said the lieutenant, \"that ever since the first of January the earth has been moving in a new orbit, and from some unknown cause has drawn nearer to the sun\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000010_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"No doubt about that,\" said Servadac; \"and I suppose that, having crossed the orbit of Venus, we have a good chance of running into the orbit of Mercury.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000011_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"And finish up by a collision with the sun!\" added the count.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000012_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"There is no fear of that, sir.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000012_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The earth has undoubtedly entered upon a new orbit, but she is not incurring any probable risk of being precipitated onto the sun\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000013_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"Can you satisfy us of that?\" asked the count.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000014_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"I can, sir.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000014_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "I can give you a proof which I think you will own is conclusive.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000015_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"And what demonstration do you offer,\" asked Servadac eagerly, \"that it will not happen?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000016_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"Simply this, captain: that since the earth entered her new orbit half the sixty four days has already elapsed, and yet it is only just recently that she has crossed the orbit of Venus, hardly one third of the distance to be traversed to reach the sun\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000017_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The lieutenant paused to allow time for reflection, and added: \"Moreover, I have every reason to believe that we are not so near the sun as we have been.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000017_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "At the same time, we have the problem still unsolved that the Mediterranean has evidently been transported to the equatorial zone.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000018_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Both the count and the captain expressed themselves reassured by his representations, and observed that they must now do all in their power to discover what had become of the vast continent of Africa, of which, they were hitherto failing so completely to find a vestige.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000019_000004.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "But Algiers, like all the other coast towns, had apparently been absorbed into the bowels of the earth.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000020_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Captain Servadac, with clenched teeth and knitted brow, stood sternly, almost fiercely, regarding the boundless waste of water.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000020_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "His pulse beat fast as he recalled the friends and comrades with whom he had spent the last few years in that vanished city.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000020_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "All the images of his past life floated upon his memory; his thoughts sped away to his native France, only to return again to wonder whether the depths of ocean would reveal any traces of the Algerian metropolis.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000021_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"Is it not impossible,\" he murmured aloud, \"that any city should disappear so completely?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000021_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Would not the loftiest eminences of the city at least be visible?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000021_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Surely some portion of the Casbah must still rise above the waves?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000021_000003.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The imperial fort, too, was built upon an elevation of seven hundred fifty feet; it is incredible that it should be so totally submerged. Unless some vestiges of these are found, I shall begin to suspect that the whole of Africa has been swallowed in some vast abyss.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000022_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Another circumstance was most remarkable.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000022_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Not a material object of any kind was to be noticed floating on the surface of the water; not one branch of a tree had been seen drifting by, nor one spar belonging to one of the numerous vessels that a month previously had been moored in the magnificent bay which stretched twelve miles across from Cape Matafuz to Point Pexade.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000022_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Perhaps the depths might disclose what the surface failed to reveal, and Count Timascheff, anxious that Servadac should have every facility afforded him for solving his doubts, called for the sounding line.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000024_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "\"You must see, lieutenant, I should think, that we are not so near the coast of Algeria as you imagined.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000025_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "The lieutenant shook his head.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000025_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "After pondering awhile, he said: \"If we were farther away I should expect to find a depth of two or three hundred fathoms instead of five fathoms.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000025_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Five fathoms!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000025_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000025_000003.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "I confess I am puzzled.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000026_000000.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "For the next thirty six hours, until the fourth of February, the sea was examined and explored with the most unflagging perseverance.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000026_000001.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Its depth remained invariable, still four, or at most five, fathoms; and although its bottom was assiduously dredged, it was only to prove it barren of marine production of any type.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5105_28241_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5105/28241/5105_28241_000027_000002.wav",
        "speaker_id": "LibriTTS_R-5105",
        "content": "Nothing was to be done but to put about, and return in disappointment towards the north.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    }
]