        "speaker_id": "LibriTTS_R-5977",
        "content": "Little now remains to be told.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5977_46900_000060_000002",
