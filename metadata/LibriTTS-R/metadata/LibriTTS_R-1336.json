        "speaker_id": "LibriTTS_R-1336",
        "content": "\"I declare, Hubbard, you're tanned like an aboriginal, and you look like one, too,\" laughed Maloney.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
