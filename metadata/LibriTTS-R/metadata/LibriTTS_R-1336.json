        "speaker_id": "LibriTTS_R-1336",
        "content": "He asked the question with his eyes straight on the other's face.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
