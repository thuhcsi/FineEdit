        "speaker_id": "LibriTTS_R-1336",
        "content": "\"But what makes you think the creature is starved?\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
