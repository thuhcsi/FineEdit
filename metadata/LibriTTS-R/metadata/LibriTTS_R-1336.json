        "speaker_id": "LibriTTS_R-1336",
        "content": "I propose a swim and then bed.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
