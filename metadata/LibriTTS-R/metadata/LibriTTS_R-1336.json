        "speaker_id": "LibriTTS_R-1336",
        "content": "\"We'll have the first decent breakfast we've had this year.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
