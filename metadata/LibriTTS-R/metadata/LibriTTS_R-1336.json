        "speaker_id": "LibriTTS_R-1336",
        "content": "The mind, like the body, grows quickly hard, simple, uncomplex.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
