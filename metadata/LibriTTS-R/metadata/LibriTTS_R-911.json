        "speaker_id": "LibriTTS_R-911",
        "content": "Thoughts, we all naturally think, are made of one kind of substance, and things of another.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
