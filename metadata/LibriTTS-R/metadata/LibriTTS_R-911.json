        "speaker_id": "LibriTTS_R-911",
        "content": "Common sense and popular philosophy are as dualistic as it is possible to be.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
