        "speaker_id": "LibriTTS_R-7892",
        "content": "Just before the warm sun dropped behind the tops of the walnut grove beyond the river the work was done, and a great pile of rockets lay on the grass.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7892_294520_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7892/294520/7892_294520_000009_000002.wav",
        "speaker_id": "LibriTTS_R-7892",
        "content": "They had all been born and brought up near the winding Conestoga, and had fished in it and swam in it ever since they could remember.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7892_294520_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7892/294520/7892_294520_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7892",
        "content": "The next evening the boys of Lancaster sprang a surprise on that quiet but patriotic town.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
