        "speaker_id": "LibriTTS_R-7892",
        "content": "But at dusk all the boys gathered at Rob Fulton's house, just outside town, and as soon as it was really dark proceeded to the town square, their arms full of mysterious packages.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7892_294520_000011_000003",
