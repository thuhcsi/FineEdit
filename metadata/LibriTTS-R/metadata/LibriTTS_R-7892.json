        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7892/294520/7892_294520_000012_000000.wav",
        "speaker_id": "LibriTTS_R-7892",
        "content": "\"What are they?",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7892_294520_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7892/294520/7892_294520_000012_000001.wav",
        "speaker_id": "LibriTTS_R-7892",
        "content": "Where did they come from?",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7892_294520_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7892/294520/7892_294520_000012_000003.wav",
        "speaker_id": "LibriTTS_R-7892",
        "content": "He read about making them in some book.\"",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7892_294520_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7892/294520/7892_294520_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7892",
        "content": "His schoolmaster told me the other day that when he was only ten he made his own lead pencils, picking up any bits of sheet lead which happened to come his way, and hammering the lead out of them and making pencils that were as good as any in the school.\"",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
