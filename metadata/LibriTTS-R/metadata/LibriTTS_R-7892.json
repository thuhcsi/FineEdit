        "speaker_id": "LibriTTS_R-7892",
        "content": "This was indeed a great surprise.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
