        "speaker_id": "LibriTTS_R-7892",
        "content": "For a day or two Rob Fulton was an important personage, then he dropped back into the ranks with his schoolmates.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
