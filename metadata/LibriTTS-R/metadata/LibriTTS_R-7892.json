        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7892/294520/7892_294520_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7892",
        "content": "They'll be much grander than last year's candle parade.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
