[
    {
        "item_name": "LibriTTS_R-8544_281189_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000000_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "He was disobedient to his father and mother, and would go out early in the morning and stay out all day, playing in the streets and public places with idle children of his own age.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000001_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Mustapha chastised him; but Aladdin was incorrigible, and his father, to his great grief, was forced to abandon him to his idleness, and was so much troubled about him that he fell sick and died in a few months.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000002_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "This course he followed till he was fifteen years old, without giving his mind to any useful pursuit, or the least reflection on what would become of him.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000002_000002.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "As he was one day playing, according to custom, in the street with his evil associates, a stranger passing by stood to observe him.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000005_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Your worthy father was my own brother.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin ran to his mother, overjoyed at the money his uncle had given him.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000006_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "\"Mother,\" said he, \"have I an uncle?\" \"No, child,\" replied his mother, \"you have no uncle by your father's side or mine.\" \"I am just now come,\" said Aladdin, \"from a man who says he is my uncle and my father's brother.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000008_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "She spent the whole day in preparing the supper; and at night, when it was ready, said to her son, \"Perhaps the stranger knows not how to find our house; go and bring him, if you meet with him.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "When the magician had made choice of a place, and sat down, he began to enter into discourse with Aladdin's mother.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000011_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "\"My good sister,\" said he, \"do not be surprised at your never having seen me all the time you have been married to my brother Mustapha of happy memory.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000011_000005.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "But God be praised for all things!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000013_000002.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "For my part, I am resolved, one of these days, to turn him out of doors, and let him provide for himself.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "After these words Aladdin's mother burst into tears; and the magician said, \"This is not well, nephew; you must think of helping yourself, and getting your livelihood.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000014_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "There are many sorts of trades.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000014_000002.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Perhaps you do not like your father's, and would prefer another; I will endeavor to help you.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000014_000004.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Tell me freely what you think of my proposal; you shall always find me ready to keep my word.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000015_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "This plan just suited Aladdin, who hated work.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000016_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "The widow, after his promises of kindness to her son, no longer doubted that the magician was her husband's brother.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Early the next morning, the magician called again for Aladdin, and said he would take him to spend that day in the country, and on the next he would purchase the shop.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000022_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "\"We will go no further now,\" said he to Aladdin; \"I will show you here some extraordinary things, which, when you have seen, you will thank me for; but while I strike a light, gather up all the loose dry sticks you can see, to kindle a fire with.\"",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000023_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin found so many dried sticks that he soon collected a great heap.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000025_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Command me, I am ready to obey.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000025_000002.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "\"I am overjoyed, child,\" said the African magician, embracing him.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000025_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000025_000004.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Take hold of the ring and lift it up; you will find it will come easily.\" Aladdin did as the magician bade him, raised the stone with ease, and laid it on one side.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000026_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "When the stone was pulled up, there appeared a staircase about three or four feet deep, leading to a door.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000026_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000026_000008.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Take the lamp down, and put it out.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000027_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "After these words the magician drew a ring off his finger, and put it on one of Aladdin's, saying: \"It is a talisman against all evil, so long as you obey me.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000027_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Go, therefore, boldly, and we shall both be rich all our lives.\"",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000028_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin descended the steps, and, opening the door, found the three halls just as the African magician had described.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000028_000002.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "But as he came down from the terrace, seeing it was perfectly dry, he stopped in the garden to observe the trees, which were loaded with extraordinary fruit, of different colors on each tree.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000028_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000028_000003.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Some bore fruit entirely white, and some clear and transparent as crystal; some pale red, and others deeper; some green, blue, and purple, and others yellow; in short, there was fruit of all colors.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000030_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000030_000004.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin being suddenly enveloped in darkness, cried, and called out to his uncle to tell him he was ready to give him the lamp; but in vain, since his cries could not be heard.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000030_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000030_000007.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "In this great emergency he said, \"There is no strength or power but in the great and high God\"; and in joining his hands to pray he rubbed the ring which the magician had put on his finger.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000030_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000030_000008.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Immediately a genie of frightful aspect appeared, and said, \"What wouldst thou have?",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000030_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000030_000009.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "I am ready to obey thee.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000031_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Returning God thanks to find himself once more in the world, he made the best of his way home.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000034_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "I am ready to obey thee as thy slave, and the slave of all those who have that lamp in their hands; I and the other slaves of the lamp.\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000035_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "All these he placed upon a carpet, and disappeared; this was done before Aladdin's mother recovered from her swoon.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000036_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin had fetched some water, and sprinkled it in her face to recover her.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000036_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Whether that or the smell of the meat effected her cure, it was not long before she came to herself.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000037_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000037_000003.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "\"It is no matter, mother,\" said Aladdin, \"let us sit down and eat; for you have almost as much need of a good breakfast as myself; when we have done, I will tell you.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000038_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Accordingly, both mother and son sat down, and ate with the better relish as the table was so well furnished.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000041_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "She was in as great amazement at what her son told her as at the appearance of the genie; and said to him, \"But, son, what have we to do with genies?",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000041_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "I never heard that any of my acquaintance had ever seen one.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000041_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000041_000003.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "If you remember, he that I first saw called himself the slave of the ring on my finger; and this you saw called himself the slave of the lamp you had in your hand; but I believe you did not hear him, for I think you fainted as soon as he began to speak.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000043_000001.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "And since we have honestly come by it, let us make a profitable use of it, without making any great show, and exciting the envy and jealousy of our neighbors.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000043_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000043_000003.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "The ring I cannot resolve to part with; for without that you had never seen me again; and though I am alive now, perhaps, if it were gone, I might not be so some moments hence; therefore, I hope you will give me leave to keep it, and to wear it always on my finger.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000044_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin's mother replied that he might do what he pleased; for her part she would have nothing to do with genies, and never say anything more about them.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000045_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000045_000002.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin, who had never been used to such traffic, told him he would trust to his judgment and honor.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000045_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000045_000004.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Aladdin, taking the money very eagerly, retired with so much haste that the Jew, not content with the exorbitancy of his profit, was vexed he had not penetrated into his ignorance, and was going to run after him, to endeavor to get some change out of the piece of gold; but he ran so fast, and had got so far, that it would have been impossible for him to overtake him.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000046_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "Before Aladdin went home he called at a baker's, bought some cakes of bread, changed his money, and on his return gave the rest to his mother, who went and purchased provisions enough to last them some time.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8544_281189_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8544/281189/8544_281189_000047_000000.wav",
        "speaker_id": "LibriTTS_R-8544",
        "content": "When all the money was spent, Aladdin had recourse again to the lamp.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    }
