        "speaker_id": "LibriTTS_R-173",
        "content": "\"A general deficiency of subject, a total inattention to stops, and a very frequent ignorance of grammar.\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-173_200_000031_000000",
