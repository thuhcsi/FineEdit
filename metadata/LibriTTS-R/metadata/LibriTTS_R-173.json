        "speaker_id": "LibriTTS_R-173",
        "content": "I need not have been afraid of disclaiming the compliment.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
