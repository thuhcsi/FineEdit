        "speaker_id": "LibriTTS_R-173",
        "content": "\"Upon my word!",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
