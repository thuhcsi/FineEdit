        "speaker_id": "LibriTTS_R-173",
        "content": "\"Bath is a charming place, sir; there are so many good shops here.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
    },
    {
