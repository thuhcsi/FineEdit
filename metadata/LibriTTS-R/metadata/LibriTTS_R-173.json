        "speaker_id": "LibriTTS_R-173",
        "content": "\"And what are they?\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-173_200_000030_000000",
