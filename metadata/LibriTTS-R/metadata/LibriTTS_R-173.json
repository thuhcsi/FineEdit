        "speaker_id": "LibriTTS_R-173",
        "content": "Now, here one can step out of doors and get a thing in five minutes.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
