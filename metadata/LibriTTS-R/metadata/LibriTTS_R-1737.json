        "speaker_id": "LibriTTS_R-1737",
        "content": "Teddy stood on his head literally, and tore about the neighbourhood on Octoo, like a second Paul Revere-only his tidings were good.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1737_148989_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1737/148989/1737_148989_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1737",
        "content": "There was great scrubbing and dusting among the matrons as they set their houses in order not only for Class Day, but to receive the bride and groom, who were to come to them for the honeymoon trip.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
