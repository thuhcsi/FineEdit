        "speaker_id": "LibriTTS_R-1737",
        "content": "Mrs Jo refused to believe it, stoutly insisting that Emil would outlive any storm and yet turn up safe and gay.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
