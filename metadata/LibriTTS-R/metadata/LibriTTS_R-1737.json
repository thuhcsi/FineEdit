        "speaker_id": "LibriTTS_R-1737",
        "content": "Yet his success was far greater than Nat's, though only God and one good man saw it.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
