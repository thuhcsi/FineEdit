        "speaker_id": "LibriTTS_R-1737",
        "content": "Tidings had been sent to the shipowners at Hamburg by some of the survivors, and telegraphed at once by Franz to his uncle.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
