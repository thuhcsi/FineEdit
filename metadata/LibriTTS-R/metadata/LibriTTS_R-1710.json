[
    {
        "item_name": "LibriTTS_R-1710_133294_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The Present And Probable Future Condition Of The Three Races Which Inhabit The Territory Of The United States",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The principal part of the task which I had imposed upon myself is now performed.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "Here I might stop; but the reader would perhaps feel that I had not satisfied his expectations.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The absolute supremacy of democracy is not all that we meet with in America; the inhabitants of the New World may be considered from more than one point of view.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "I have mentioned in what spirit, and according to what laws, the Anglo American Union was formed; but I could only glance at the dangers which menace that confederation, whilst it was equally impossible for me to give a detailed account of its chances of duration, independently of its laws and manners.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The territory now occupied or claimed by the American Union spreads from the shores of the Atlantic to those of the Pacific Ocean.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "On the east and west its limits are those of the continent itself.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "These two unhappy races have nothing in common; neither birth, nor features, nor language, nor habits.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "Their only resemblance lies in their misfortunes.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "But he remains half way between the two communities; sold by the one, repulsed by the other; finding not a spot in the universe to call by the name of country, except the faint image of a home which the shelter of his master's roof affords.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "If he becomes free, independence is often felt by him to be a heavier burden than slavery; for having learned, in the course of his life, to submit to everything except reason, he is too much unacquainted with her dictates to obey them.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000009_000004.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "In short, he sinks to such a depth of wretchedness, that while servitude brutalizes, liberty destroys him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The Europeans, having dispersed the Indian tribes and driven them into the deserts, condemned them to a wandering life full of inexpressible sufferings.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "Savage nations are only controlled by opinion and by custom.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "To be free, with him, signifies to escape from all the shackles of society.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The negro makes a thousand fruitless efforts to insinuate himself amongst men who repulse him; he conforms to the tastes of his oppressors, adopts their opinions, and hopes by imitating them to form a part of their community.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "Having been told from infancy that his race is naturally inferior to that of the whites, he assents to the proposition and is ashamed of his own nature.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The Indian, on the contrary, has his imagination inflated with the pretended nobility of his origin, and lives and dies in the midst of these dreams of pride.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "I remember that while I was travelling through the forests which still cover the State of Alabama, I arrived one day at the log house of a pioneer.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "The Present And Probable Future Condition Of The Indian Tribes Which Inhabit The Territory Possessed By The Union",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000021_000004.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "There is no instance upon record of so prodigious a growth, or so rapid a destruction: the manner in which the latter change takes place is not difficult to describe.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1710_133294_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133294/1710_133294_000023_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "When the Indians were the sole inhabitants of the wilds from whence they have since been expelled, their wants were few.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1710_133295_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133295/1710_133295_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "These are great evils; and it must be added that they appear to me to be irremediable.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133295_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133295/1710_133295_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "It is easy to foresee that the Indians will never conform to civilization; or that it will be too late, whenever they may be inclined to make the experiment.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1710_133295_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133295/1710_133295_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "Civilization is the result of a long social process which takes place in the same spot, and is handed down from one generation to another, each one profiting by the experience of the last.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133295_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133295/1710_133295_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "Civilization began in the cabin, but it soon retired to expire in the woods.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133295_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133295/1710_133295_000007_000003.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "But not only are they destitute of this indispensable preliminary to civilization, they would even have great difficulty in acquiring it.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1710_133295_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133295/1710_133295_000015_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "These tribes have not been driven from place to place, like their Northern brethren; but they have been gradually enclosed within narrow limits, like the game within the thicket, before the huntsmen plunge into the interior.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1710_133295_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1710/133295/1710_133295_000019_000002.wav",
        "speaker_id": "LibriTTS_R-1710",
        "content": "Wherever this race has multiplied the savage state has become modified, and a great change has taken place in the manners of the people.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    }
]