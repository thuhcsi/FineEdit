        "speaker_id": "LibriTTS_R-4853",
        "content": "If I hadn't kept my temper, I might have killed him.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
