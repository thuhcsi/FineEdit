        "speaker_id": "LibriTTS_R-4853",
        "content": "\"And when you looked at Miss Cristel, and she was too busy with her brooch to notice you, was that another signal?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
