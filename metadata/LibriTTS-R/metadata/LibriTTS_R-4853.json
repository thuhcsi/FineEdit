        "speaker_id": "LibriTTS_R-4853",
        "content": "\"Then sit down, Gloody, and make a clean breast of it.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
