        "speaker_id": "LibriTTS_R-4853",
        "content": "I can't look you in the face, and tell you of it.\" He walked away to the window.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
