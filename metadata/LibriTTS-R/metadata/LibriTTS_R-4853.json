        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4853/29413/4853_29413_000045_000003.wav",
        "speaker_id": "LibriTTS_R-4853",
        "content": "Had we any proof to justify us?",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
