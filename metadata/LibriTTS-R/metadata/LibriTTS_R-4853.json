        "speaker_id": "LibriTTS_R-4853",
        "content": "The one way of putting a stop to murdering mischief (if murdering mischief it might be) was to trust Miss Cristel.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
