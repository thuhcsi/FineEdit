        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4853/29413/4853_29413_000038_000003.wav",
        "speaker_id": "LibriTTS_R-4853",
        "content": "He turned pale when he felt the floor shaken by your fall.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
