        "speaker_id": "LibriTTS_R-4853",
        "content": "mr Roylake, he kicked me.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
