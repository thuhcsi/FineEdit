        "speaker_id": "LibriTTS_R-4853",
        "content": "\"Flew into a furious rage.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4853_29413_000017_000003",
