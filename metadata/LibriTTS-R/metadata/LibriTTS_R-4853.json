        "speaker_id": "LibriTTS_R-4853",
        "content": "\"I didn't dare speak to you about it; you wouldn't have believed me.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
