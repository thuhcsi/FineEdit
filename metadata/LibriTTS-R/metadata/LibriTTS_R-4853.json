        "speaker_id": "LibriTTS_R-4853",
        "content": "\"Do you think he saw through it?",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
