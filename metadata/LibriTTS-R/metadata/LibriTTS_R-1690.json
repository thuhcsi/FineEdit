        "speaker_id": "LibriTTS_R-1690",
        "content": "I can tell it in the touch of your hand, as well as in what you're saying.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
