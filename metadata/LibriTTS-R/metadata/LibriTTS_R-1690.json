        "speaker_id": "LibriTTS_R-1690",
        "content": "'And do they think the strike will mend this?' asked Margaret.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
