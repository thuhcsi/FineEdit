        "speaker_id": "LibriTTS_R-1690",
        "content": "'Good bye!' said Margaret, hastily.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
