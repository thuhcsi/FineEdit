        "speaker_id": "LibriTTS_R-1690",
        "content": "I shall look to see you on the twenty first, if you're well enough.'",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1690_142293_000053_000000",
