        "speaker_id": "LibriTTS_R-1690",
        "content": "He caught his daughter's last words.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
