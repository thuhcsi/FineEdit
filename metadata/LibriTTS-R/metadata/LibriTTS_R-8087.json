        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000010_000000.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "The next morning they saw a dignified, elderly gentleman with ten unarmed followers coming down towards the shore.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
