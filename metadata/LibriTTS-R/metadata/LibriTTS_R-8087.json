[
    {
        "item_name": "LibriTTS_R-8087_118165_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118165/8087_118165_000002_000000.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "THE CRUELTIES OF THE Spaniards Committed in AMERICA.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118165_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118165/8087_118165_000005_000002.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "They go naked, having no other Covering but what conceals their Pudends from publick sight.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8087_118165_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118165/8087_118165_000005_000005.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "The Men are pregnant and docible.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118165_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118165/8087_118165_000008_000001.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "The first whereof was raising an unjust, sanguinolent, cruel War.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000003_000003.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "Nay they threw into them Women with Child, and as many Aged Men as they laid hold of, till they were all fill'd up with Carkasses.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000003_000004.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "It was a sight deserving Commiseration, to behold Women and Children gauncht or run through with these Posts, some were taken off by Spears and Swords, and the remainder expos'd to hungry Dogs, kept short of food for that purpose, to be devour'd by them and torn in pieces.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000003_000006.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "All which Butcheries continued Seven Years, from fifteen twenty four, to fifteen thirty one.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000003_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000003_000007.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "I leave the Reader to judge how many might be Massacred during that time.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000004_000000.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "Among the Innumerable Flagitious Acts done by this Tyrant and his Co partners (for they were as Barbarous as their Principal) in this Kingdom, this also occurs worthy of an Afterism in the Margin.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000004_000006.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "Let that Nation that is without Gold be accursed to the Pit of Hell.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000004_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000004_000008.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "I my self saw the Impression made on the Son of the Chiefest Person in the City.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000005_000001.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "They butcher'd the Men for their Feet and Hands only; for these Members were accounted by them Dainties, most delicious Food.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000006_000002.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "He had two Companies of Soldiers who hackt and tore them in pieces, like Thunder from Heaven speedily.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000006_000003.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "O how many Parents has he robb'd of their Children, how many Wives of their Husbands, and Children of their Parents?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000006_000004.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "How many Adulteries, Rapes, and what Libidinous Acts hath he been guilty of?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118174_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118174/8087_118174_000006_000006.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "How many Tears, Sighs and Groans hath he occasion'd?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8087_118180_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118180/8087_118180_000007_000000.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "These incarnate Devils laid waste and desolate Four Hundred miles of most Fertile Land, containing vast and wonderful Provinces, most spatious and large Valleys surrounded with Hills, forty Miles in Length, and many Towns richly abounding in Gold and Silver.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118180_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118180/8087_118180_000007_000002.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "I judge that they by new invented and unusual Torments ruinated four or five Millions of Souls and sent them all to Hell.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118180_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118180/8087_118180_000007_000003.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "I will give a taste of two or three of their Transactions, that hereby you may guess at the rest.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118180_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118180/8087_118180_000008_000000.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "They made the supream Lord of the Province a Slave, to squeeze his Gold from him, racking him to extort his confession who escaping fled into the Mountains, their common Sanctuary, and his Subjects lying absconded in the Thickets of the Woods, were stir'd up to Sedition and Tumult or Mutiny.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8087_118180_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118180/8087_118180_000009_000001.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "The German Captain and Tyrant caused several of them to be clapt into a Thatcht House, and there cut in pieces; but some of them to avoid falling by their bloody and merciless Swords, climb'd up to the beams and Rafters of the House, and the Governour, hearing it (O cruel Brute?) commanded Fire to be put to it and burnt them all alive, leaving the Region desert and desolate.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118180_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118180/8087_118180_000010_000001.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "Several of them sent home to discharge the demanded price of their Redemption, and procur'd their Freedom, as well as they could by one means or other, that so they might return to their Livelihood and profession, but not long after he sent other Rogues and Robbers among them to enslave those that were Redeemed.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118180_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118180/8087_118180_000013_000003.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "And these are the Temporal Dammages the King suffers.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000003_000000.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "thirteen",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000005_000005.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "All this was more than two hundred years ago.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "He naturally went up to The Gregory at this hour, because it was then that he met the other boys, and caught puffins by being lowered over the cliff.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000006_000001.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "The agent of the island employed the boys, and paid them a sixpence for every dozen birds, that he might sell the feathers.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000006_000003.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "He took in this way twenty or thirty score of the birds, besides quantities of their large eggs, which were found in deep clefts in the rock; and these he carried with him when his friends came in the morning to haul him up.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000006_000004.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "It was a good school of courage, for sometimes boys missed their footing and were dashed to pieces.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000006_000005.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "At other times he fished in his father's boat, or drove calves for sale on the mainland, or cured salt after high tide in the caverns, or collected kelp for the farmers.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000007_000001.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "His companion in the boat-or dory mate, as it would be called in New England-had gone to cut bait on board another boat, but Kirwan could manage the boat well enough alone.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000007_000003.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "At last the fog lifted, and he found himself alone upon the ocean.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000007_000004.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "He had lost his bearings and could not tell the points of the compass.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000007_000005.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "Presently out of a heavy bank of fog which rose against the horizon he saw what seemed land.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000007_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000007_000007.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "Growing weaker and weaker, he did not clearly know what he was doing.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8087/118726/8087_118726_000007_000008.wav",
        "speaker_id": "LibriTTS_R-8087",
        "content": "Suddenly he started up, for a voice hailed him from above his head.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000007_000009",
