        "speaker_id": "LibriTTS_R-8087",
        "content": "They took swords and pistols.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
