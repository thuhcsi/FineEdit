        "speaker_id": "LibriTTS_R-8087",
        "content": "He saw above him the high stern of a small vessel, and with the aid of a sailor he was helped on board.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
