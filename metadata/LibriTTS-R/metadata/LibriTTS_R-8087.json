        "speaker_id": "LibriTTS_R-8087",
        "content": "After this the whole ship's company went ashore, except one left in charge, and they wandered about for hours, yet saw nothing more.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8087_118726_000009_000007",
