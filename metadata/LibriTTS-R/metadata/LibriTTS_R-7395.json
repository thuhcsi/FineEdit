        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7395/89880/7395_89880_000020_000000.wav",
        "speaker_id": "LibriTTS_R-7395",
        "content": "Justus, bishop of the church of Rochester, immediately succeeded Mellitus in the archbishopric.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
