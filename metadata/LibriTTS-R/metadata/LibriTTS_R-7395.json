        "speaker_id": "LibriTTS_R-7395",
        "content": "But he and his nation, after his conversion to the Lord, sought to obey the commandments of God.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
