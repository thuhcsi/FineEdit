        "speaker_id": "LibriTTS_R-7395",
        "content": "Which letter we have also thought fit to insert in this our history:",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
