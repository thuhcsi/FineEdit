        "speaker_id": "LibriTTS_R-7395",
        "content": "How Pope Boniface sent the Pall and a letter to Justus, successor to Mellitus. [six twenty four a d]",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
