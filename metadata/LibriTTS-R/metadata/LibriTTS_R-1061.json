        "speaker_id": "LibriTTS_R-1061",
        "content": "\"What!\" said mr Bird, coming in softly and closing the door behind him.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
