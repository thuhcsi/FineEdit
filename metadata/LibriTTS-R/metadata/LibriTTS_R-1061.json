        "speaker_id": "LibriTTS_R-1061",
        "content": "It was the boy choir singing Christmas anthems. Higher and higher rose the clear, fresh voices, full of hope and cheer, as children's voices always are.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
