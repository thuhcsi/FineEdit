        "speaker_id": "LibriTTS_R-1061",
        "content": "Nurse was making gruel in the kitchen, and the room was dim and quiet.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
