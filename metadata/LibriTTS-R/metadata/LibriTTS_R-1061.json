        "speaker_id": "LibriTTS_R-1061",
        "content": "She opened her eyes and drew the baby closer.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
