        "speaker_id": "LibriTTS_R-1061",
        "content": "Fuller and fuller grew the burst of melody as one glad strain fell upon another in joyful harmony:",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
