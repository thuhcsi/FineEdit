        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1061/146197/1061_146197_000032_000001.wav",
        "speaker_id": "LibriTTS_R-1061",
        "content": "You are a little Christmas child, and we will name you 'Carol'--mother's little Christmas Carol!\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
