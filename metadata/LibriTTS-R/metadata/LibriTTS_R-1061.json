        "speaker_id": "LibriTTS_R-1061",
        "content": "\"Why, my baby,\" whispered mrs Bird in soft surprise, \"I had forgotten what day it was.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
