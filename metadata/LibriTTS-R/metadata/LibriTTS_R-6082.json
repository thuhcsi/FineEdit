        "speaker_id": "LibriTTS_R-6082",
        "content": "To older people she seemed an especially well mannered girl, with a delightful vein of thoughtfulness that was not too often met in young girls.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
