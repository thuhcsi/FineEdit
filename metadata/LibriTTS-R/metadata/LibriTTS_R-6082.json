        "speaker_id": "LibriTTS_R-6082",
        "content": "For Edith had an uncomfortable habit of forgetting just what was to be kept secret, and though Philip had no very dark secrets, there were still little things that he preferred not to have told.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
