        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6082/56175/6082_56175_000018_000010.wav",
        "speaker_id": "LibriTTS_R-6082",
        "content": "This when she opened proved to contain a delicately chased little envelope opener, shaped like a tiny scimitar.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6082_56175_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6082/56175/6082_56175_000019_000004.wav",
        "speaker_id": "LibriTTS_R-6082",
        "content": "How did it strike you, Julia?\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6082_56175_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6082/56175/6082_56175_000020_000000.wav",
        "speaker_id": "LibriTTS_R-6082",
        "content": "\"Not that way, uncle, at all, not at all, though she seemed very sad.\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
