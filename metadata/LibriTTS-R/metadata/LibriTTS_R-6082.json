        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6082/56175/6082_56175_000021_000000.wav",
        "speaker_id": "LibriTTS_R-6082",
        "content": "\"Perhaps she's repenting for the way she has neglected her grandchildren,\" interposed Brenda.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
