        "speaker_id": "LibriTTS_R-6082",
        "content": "Other persons did not find Julia peculiar.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
