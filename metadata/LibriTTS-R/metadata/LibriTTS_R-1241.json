        "speaker_id": "LibriTTS_R-1241",
        "content": "How does this misfortune affect you?",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
