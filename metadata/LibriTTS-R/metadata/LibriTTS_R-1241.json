        "speaker_id": "LibriTTS_R-1241",
        "content": "I rely on your friendship to assist me, Beauchamp, if contempt has not banished it from your heart.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
