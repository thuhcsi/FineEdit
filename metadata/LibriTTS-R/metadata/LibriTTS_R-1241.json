        "speaker_id": "LibriTTS_R-1241",
        "content": "He cherished the thought of the duel, hoping to conceal its true cause even from his seconds.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
