        "speaker_id": "LibriTTS_R-1241",
        "content": "\"I will facilitate it by repeating the question, 'Will you, or will you not, retract?'\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
