        "speaker_id": "LibriTTS_R-1241",
        "content": "He found Beauchamp pacing the room; on perceiving him Beauchamp stopped.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
