        "speaker_id": "LibriTTS_R-1241",
        "content": "I took a week to go, another to return, four days of quarantine, and forty eight hours to stay there; that makes three weeks.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
