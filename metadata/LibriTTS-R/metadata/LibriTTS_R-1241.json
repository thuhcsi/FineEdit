        "speaker_id": "LibriTTS_R-1241",
        "content": "Oh, Beauchamp, Beauchamp, how shall I now approach mine?",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
