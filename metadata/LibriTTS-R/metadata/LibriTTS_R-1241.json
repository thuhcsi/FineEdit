        "speaker_id": "LibriTTS_R-1241",
        "content": "\"You hesitate?\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
