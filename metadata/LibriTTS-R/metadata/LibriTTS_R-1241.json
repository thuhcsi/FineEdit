        "speaker_id": "LibriTTS_R-1241",
        "content": "\"Contempt, my friend?",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
