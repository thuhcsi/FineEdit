        "speaker_id": "LibriTTS_R-1241",
        "content": "Acknowledge it, Beauchamp; your courage cannot be doubted.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
