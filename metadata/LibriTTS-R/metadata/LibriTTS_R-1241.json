        "speaker_id": "LibriTTS_R-1241",
        "content": "\"Then,\" continued Beauchamp, \"I took advantage of the silence and the darkness to leave the house without being seen.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1241_121106_000002_000006",
