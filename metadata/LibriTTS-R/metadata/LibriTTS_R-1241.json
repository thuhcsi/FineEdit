    {
        "item_name": "LibriTTS_R-1241_121106_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1241/121106/1241_121106_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1241",
        "content": "\"'How, and why?'",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1241_121106_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1241/121106/1241_121106_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1241",
        "content": "\"'Because a fortnight since I was questioned on the same subject.'",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
