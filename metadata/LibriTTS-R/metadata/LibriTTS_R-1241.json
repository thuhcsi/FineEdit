        "speaker_id": "LibriTTS_R-1241",
        "content": "Albert turned frightfully pale; he endeavored to speak, but the words died on his lips.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
