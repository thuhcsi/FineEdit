        "speaker_id": "LibriTTS_R-103",
        "content": "Maybe they were out of boys of the brand you wanted.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
