        "speaker_id": "LibriTTS_R-103",
        "content": "\"But there was a passenger dropped off for you-a little girl.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
