        "speaker_id": "LibriTTS_R-103",
        "content": "\"I suppose you are mr matthew Cuthbert of Green Gables?\" she said in a peculiarly clear, sweet voice.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
