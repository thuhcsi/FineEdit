        "speaker_id": "LibriTTS_R-103",
        "content": "\"It's a boy I've come for.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
