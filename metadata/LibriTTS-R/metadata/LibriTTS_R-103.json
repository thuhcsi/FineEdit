        "speaker_id": "LibriTTS_R-103",
        "content": "\"Oh, I can carry it,\" the child responded cheerfully.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
