        "speaker_id": "LibriTTS_R-103",
        "content": "\"I'm very glad to see you.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-103_1241_000020_000000",
