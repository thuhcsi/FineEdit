        "speaker_id": "LibriTTS_R-103",
        "content": "They were good, you know-the asylum people.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
