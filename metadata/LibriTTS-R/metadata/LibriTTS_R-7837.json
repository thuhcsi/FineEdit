[
    {
        "item_name": "LibriTTS_R-7837_109173_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000002_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Clear running water filled the ditch, but the bottom was dull black, powdery mud.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000002_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "It lay inches deep, layer upon layer of one tiny particle upon another, and so loose and light that a thick, opaque, smoke like column ascended at the slightest touch.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "The entire monster measured scarcely a finger's length.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000005_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Her reddish brown colour with the tiger like transverse stripes made an excellent disguise.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000005_000003.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Even the sharp eyed heron, which had dropped down unnoticed about a dozen yards off, and was now noiselessly, with slow, cautious steps, wading nearer and nearer, took her at the first glance for a stick.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "The young pike peered upwards, and saw in the shelter of a tuft of rushes a collection of black, boat shaped whirligigs, showing like dots against the shining surface.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000009_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "There was never any peace around her.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000009_000005.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Air bubbles, too, were set free, and ascended quickly with a rotary motion.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Here two large tiger beetles were fighting with a poor water bug.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000010_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "It must have been almost a pleasure to find oneself so neatly despatched!",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000012_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "It was tired now, and had just stretched itself out for a moment's rest, when the supposed pieces of stick upon which it lay seized it, and voracious heads with sharp jaws attacked its flesh.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000012_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "It was within an ace of being made captive for ever, but at last succeeded in making its escape and pushing off, with two of its tormentors after it.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000013_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "The young pike watched attentively the flight of the black leech.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "It was not long before she had forgotten her recent peril, and once more became filled with the cruel passion of the hunter.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "This was a very favourite lurking place; she could lie there with her back right up against the under surface of the leaf, and her snout on the very border of its shadow, ready to strike.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000016_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "The silvery flash of small fish twinkled around her, and myriads of tiny shining crustaceans whisked about so close to her nose that at any moment she could have snapped them up by the score into her voracious mouth.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "It was especially things that moved that had a magic attraction for Grim.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000020_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "----Meanwhile, the keen eyed heron, wading up to its breast in the water, comes softly and silently trawling through the ditch.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Sedately it goes about its business, stalking along with slow, measured steps.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000023_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Sea crows and terns scream around it, and from time to time three or four of them unite in harrying their great rival.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000023_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Just as the heron has brought its beak close to the surface of the water, ready to seize its prey, the gulls dash upon it from behind.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000023_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "With a hiss it curves its neck and turns the foil upwards, snapping and biting at its tormentors.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000024_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "An irritating little flock of gulls may go on thus for a long time; and when at last, screaming and mocking, they take their departure, they have spoilt many a chance and wasted many precious minutes of the big, silent, patient fisher's time.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000025_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "The gulls once gone, the heron applies itself with redoubled zeal to its business.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000025_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "From various attacking positions its beak darts down into the water, but often without result, and it has to go farther afield; then at last it captures a little eel.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000026_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "The eel twists, and refuses to be swallowed; so the bird has to reduce its liveliness by rolling up and down in its sharp edged beak.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000026_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Then it glides down.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000027_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "This time, too, fortune is disposed to favour the young pike.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000027_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "The heron, coming up behind her, cautiously bends its neck over the drifting piece of reed.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000027_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "It sees there is something suspicious about it, but thinks it is mistaken, and is about to take another step forward. When only half-way, it pauses with its foot in the air; and the next moment the blow falls.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000028_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Grim only once moved her tail.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000028_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Then she was seized, something hard and sharp and strong held her fast, and she passed head foremost down into a warm, narrow channel.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000029_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "There was a fearful crush of fish in the channel, and much elbowing with fins and twisting of tails.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000031_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Out on the lake lay a boat in which a man sat fishing.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000031_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Experience told the bird it was a fisherman, but here the bird was wrong.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000032_000000.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "Grim was among the fortunate ones.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7837_109173_000032_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109173/7837_109173_000032_000002.wav",
        "speaker_id": "LibriTTS_R-7837",
        "content": "A little later the stream gathered furious pace and carried her with it; she saw light and felt space round her; she was able to move her fins.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7837_109174_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7837/109174/7837_109174_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7837",
