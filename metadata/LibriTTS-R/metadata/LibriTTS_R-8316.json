        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8316/279798/8316_279798_000023_000000.wav",
        "speaker_id": "LibriTTS_R-8316",
        "content": "The mother brought a great big dish of black soup, and Margery cried and cried without ceasing.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
