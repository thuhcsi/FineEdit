        "speaker_id": "LibriTTS_R-8316",
        "content": "Then Margery went, and said, \"Brother, give me the apple.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8316_279798_000018_000000",
