        "speaker_id": "LibriTTS_R-8316",
        "content": "Then the father said again, \"Where is my son?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
