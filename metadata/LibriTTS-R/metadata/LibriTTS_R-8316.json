        "speaker_id": "LibriTTS_R-8316",
        "content": "The fifth month passed, and she stood under the Juniper tree, and it smelt so beautiful, and her heart leaped with joy.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
