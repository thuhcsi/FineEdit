        "speaker_id": "LibriTTS_R-5940",
        "content": "\"Help!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5940_54016_000049_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5940/54016/5940_54016_000049_000002.wav",
        "speaker_id": "LibriTTS_R-5940",
        "content": "Murder!\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5940_54016_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5940/54016/5940_54016_000051_000000.wav",
        "speaker_id": "LibriTTS_R-5940",
        "content": "\"Stop, friend,\" said he to the smith, \"let the simpleton go; this is not past mending yet.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
