        "speaker_id": "LibriTTS_R-5940",
        "content": "\"Not I,\" said Babo; \"I will carry no stone with me.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
