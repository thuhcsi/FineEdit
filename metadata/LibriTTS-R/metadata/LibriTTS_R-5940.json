        "speaker_id": "LibriTTS_R-5940",
        "content": "\"Help!\" bawled Babo.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5940_54016_000049_000001",
