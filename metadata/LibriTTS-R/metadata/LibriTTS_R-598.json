        "speaker_id": "LibriTTS_R-598",
        "content": "Two Day Excursions",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-598_127703_000023_000002",
