        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/598/127703/598_127703_000020_000000.wav",
        "speaker_id": "LibriTTS_R-598",
        "content": "With your heart aglow, spangling Lake Tenaya and Lake May will beckon you away for walks on their ice burnished shores.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
