        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/598/127703/598_127703_000013_000001.wav",
        "speaker_id": "LibriTTS_R-598",
        "content": "From the foot of the Fall the trail zigzags up a narrow canyon between the fall and a plain mural cliff that is burnished here and there by glacial action.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-598_127703_000014_000000",
