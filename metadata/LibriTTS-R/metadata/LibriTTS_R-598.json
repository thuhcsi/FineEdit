        "speaker_id": "LibriTTS_R-598",
        "content": "A Three Day Excursion",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-598_127703_000027_000000",
