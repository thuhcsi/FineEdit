        "speaker_id": "LibriTTS_R-598",
        "content": "We come now to the grandest of all the Yosemite excursions, one that requires at least two or three weeks.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
