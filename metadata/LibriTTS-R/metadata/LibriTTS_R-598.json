        "speaker_id": "LibriTTS_R-598",
        "content": "There instead of returning to the Valley, follow the Tioga road around the northwest side of the lake, over to the Tuolumne Meadows and up to the west base of Mount Dana.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
