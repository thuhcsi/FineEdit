        "speaker_id": "LibriTTS_R-598",
        "content": "Early next morning visit the small glacier on the north side of Merced Peak, the first of the sixty five that I discovered in the Sierra.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
