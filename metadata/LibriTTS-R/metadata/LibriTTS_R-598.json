        "speaker_id": "LibriTTS_R-598",
        "content": "The walking is good and almost level and from the west end of Clouds' Rest take the Clouds' Rest Trail which will lead direct to the Valley by the Nevada and Vernal Falls.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
