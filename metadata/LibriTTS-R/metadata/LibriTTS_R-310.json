        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/310/129055/310_129055_000023_000001.wav",
        "speaker_id": "LibriTTS_R-310",
        "content": "The dazzled eyes close before that Magnificent Idea.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-310_129055_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/310/129055/310_129055_000023_000002.wav",
        "speaker_id": "LibriTTS_R-310",
        "content": "Loyal respect and decency tell even the imagination not to look too keenly and audaciously about the sacred audience chamber, but to back away rapidly, silently, and respectfully, making profound bows out of the August Presence.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-310_129055_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/310/129055/310_129055_000024_000000.wav",
        "speaker_id": "LibriTTS_R-310",
        "content": "This may be said, that in all London there was no more loyal heart than Becky's after this interview.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-310_129055_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/310/129055/310_129055_000024_000001.wav",
        "speaker_id": "LibriTTS_R-310",
        "content": "The name of her king was always on her lips, and he was proclaimed by her to be the most charming of men.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
