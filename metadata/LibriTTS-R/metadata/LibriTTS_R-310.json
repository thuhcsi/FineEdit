        "speaker_id": "LibriTTS_R-310",
        "content": "Fate cannot deprive us of THAT.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
