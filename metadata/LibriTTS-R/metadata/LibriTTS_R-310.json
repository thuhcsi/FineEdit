        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/310/129055/310_129055_000024_000002.wav",
        "speaker_id": "LibriTTS_R-310",
        "content": "She went to Colnaghi's and ordered the finest portrait of him that art had produced, and credit could supply.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
