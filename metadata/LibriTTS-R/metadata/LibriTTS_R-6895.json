        "speaker_id": "LibriTTS_R-6895",
        "content": "In the clarid gold of the platform I saw her fez and corals reflected as an elongated blotch of florid red.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
