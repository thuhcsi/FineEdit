        "speaker_id": "LibriTTS_R-6895",
        "content": "'I am not going to argue the matter,' I said.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
