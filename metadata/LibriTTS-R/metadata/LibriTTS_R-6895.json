        "speaker_id": "LibriTTS_R-6895",
        "content": "'I do not complehend!'",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
