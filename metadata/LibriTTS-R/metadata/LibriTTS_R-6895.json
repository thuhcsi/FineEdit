        "speaker_id": "LibriTTS_R-6895",
        "content": "But how did Abel feel when he was killed?",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
