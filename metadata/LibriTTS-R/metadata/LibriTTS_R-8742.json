[
    {
        "item_name": "LibriTTS_R-8742_245707_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000002_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "THE PRODUCTION OF THE WOMAN (In Four Articles)",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000003_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "We must next consider the production of the woman.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000003_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Under this head there are four points of inquiry:",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000004_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "(one) Whether the woman should have been made in that first production of things?",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000005_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "(two) Whether the woman should have been made from man?",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "(three) Whether of man's rib?",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000009_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Whether the Woman Should Have Been Made in the First Production of Things?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000010_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the woman should not have been made in the first production of things.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000012_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But God foresaw that the woman would be an occasion of sin to man.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000014_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Among perfect animals the active power of generation belongs to the male sex, and the passive power to the female.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000014_000005.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But man is yet further ordered to a still nobler vital action, and that is intellectual operation. Therefore there was greater reason for the distinction of these two forces in man; so that the female should be produced separately from the male; although they are carnally united for generation.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000015_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "On the other hand, as regards human nature in general, woman is not misbegotten, but is included in nature's intention as directed to the work of generation.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000015_000004.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Now the general intention of nature depends on God, Who is the universal Author of nature.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000015_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000015_000005.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore, in producing nature, God formed not only the male but also the female.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000016_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "One is servile, by virtue of which a superior makes use of a subject for his own benefit; and this kind of subjection began after sin.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000016_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "There is another kind of subjection which is called economic or civil, whereby the superior makes use of his subjects for their own benefit and good; and this kind of subjection existed even before sin.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000020_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "For sex belongs both to man and animals.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000020_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But in the other animals the female was not made from the male.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000020_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore neither should it have been so with man.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000024_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Secondly, that man might love woman all the more, and cleave to her more closely, knowing her to be fashioned from himself.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000024_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000024_000006.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Wherefore it was suitable for the woman to be made out of man, as out of her principle.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000024_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000024_000007.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Fourthly, there is a sacramental reason for this.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000024_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000024_000008.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "For by this is signified that the Church takes her origin from Christ.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000024_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000024_000010.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "five thirty two): \"This is a great sacrament; but I speak in Christ and in the Church.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000026_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "On the other hand, the Divine Power, being infinite, can produce things of the same species out of any matter, such as a man from the slime of the earth, and a woman from out of man.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000030_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the woman should not have been formed from the rib of man.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000031_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore a rib of Adam belonged to the integrity of his body.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000031_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "So, if a rib was removed, his body remained imperfect; which is unreasonable to suppose.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000032_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But there was no pain before sin.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000035_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But this is quite impossible.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000035_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "For such an increase of matter would either be by a change of the very substance of the matter itself, or by a change of its dimensions.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000035_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000035_000004.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Wherefore multiplication of matter is quite unintelligible, as long as the matter itself remains the same without anything added to it; unless it receives greater dimensions.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000036_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Wherefore, as no rarefaction is apparent in such multiplication of matter, we must admit an addition of matter: either by creation, or which is more probable, by conversion.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000037_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Much more, therefore, was it possible that by the Divine power the body of the woman should be produced from the man's rib.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000041_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the woman was not formed immediately by God.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000041_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000041_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore she was not made immediately by God.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000042_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000042_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But the woman's body was formed from corporeal matter.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8742_245707_000045_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245707/8742_245707_000045_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Now God alone, the Author of nature, can produce an effect into existence outside the ordinary course of nature.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000004_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "QUESTION ninety three",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000008_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "(two) Whether the image of God is in irrational creatures?",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000010_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "(four) Whether the image of God is in every man?",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "(five) Whether the image of God is in man by comparison with the Essence, or with all the Divine Persons, or with one of them?",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000012_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "(six) Whether the image of God is in man, as to his mind only?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the image of God is not in man.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000022_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "seventy four): \"Where an image exists, there forthwith is likeness; but where there is likeness, there is not necessarily an image.\" Hence it is clear that likeness is essential to an image; and that an image adds something to likeness-namely, that it is copied from something else.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000022_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "For an \"image\" is so called because it is produced as an imitation of something else; wherefore, for instance, an egg, however much like and equal to another egg, is not called an image of the other egg, because it is not copied from it.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000023_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "seventy four): \"Where there is an image there is not necessarily equality,\" as we see in a person's image reflected in a glass.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000023_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Yet this is of the essence of a perfect image; for in a perfect image nothing is wanting that is to be found in that of which it is a copy.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000023_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Now it is manifest that in man there is some likeness to God, copied from God as from an exemplar; yet this likeness is not one of equality, for such an exemplar infinitely excels its copy. Therefore there is in man a likeness to God; not, indeed, a perfect likeness, but imperfect.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000023_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000023_000004.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "And Scripture implies the same when it says that man was made \"to\" God's likeness; for the preposition \"to\" signifies a certain approach, as of something at a distance.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000026_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Now a thing is said to be one not only numerically, specifically, or generically, but also according to a certain analogy or proportion.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000029_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the image of God is to be found in irrational creatures.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000031_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore the whole universe is to the image of God, and not only man.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000034_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "For instance, a worm, though from man it may originate, cannot be called man's image, merely because of the generic likeness.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000034_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000034_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Nor, if anything is made white like something else, can we say that it is the image of that thing; for whiteness is an accident belonging to many species.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000034_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000034_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But the nature of an image requires likeness in species; thus the image of the king exists in his son: or, at least, in some specific accident, and chiefly in the shape; thus, we speak of a man's image in copper. Whence Hilary says pointedly that \"an image is of the same species.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000035_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Now it is manifest that specific likeness follows the ultimate difference.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000035_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "fifty one) \"approach so near to God in likeness, that among all creatures nothing comes nearer to Him.\" It is clear, therefore, that intellectual creatures alone, properly speaking, are made to God's image.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000036_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore even what falls short of the nature of an image, so far as it possesses any sort of likeness to God, participates in some degree the nature of an image.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000038_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Or else we may say that a part is not rightly divided against the whole, but only against another part.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000039_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Thus every creature is an image of the exemplar type thereof in the Divine mind.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000042_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the angels are not more to the image of God than man is.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000043_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "fifty one), \"man is so much to God's image that God did not make any creature to be between Him and man: and therefore nothing is more akin to Him.\" But a creature is called God's image so far as it is akin to God.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000044_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But the intellectual nature does not admit of intensity or remissness; for it is not an accidental thing, since it is a substance.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000046_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "First, we may consider in it that in which the image chiefly consists, that is, the intellectual nature.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000046_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000046_000004.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Secondly, we may consider the image of God in man as regards its accidental qualities, so far as to observe in man a certain imitation of God, consisting in the fact that man proceeds from man, as God from God; and also in the fact that the whole human soul is in the whole body, and again, in every part, as God is in regard to the whole world.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000046_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000046_000006.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But these do not of themselves belong to the nature of the Divine image in man, unless we presuppose the first likeness, which is in the intellectual nature; otherwise even brute animals would be to God's image.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000046_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000046_000007.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore, as in their intellectual nature, the angels are more to the image of God than man is, we must grant that, absolutely speaking, the angels are more to the image of God than man is, but that in some respects man is more like to God.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000052_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000052_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the image of God is not found in every man.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000052_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000052_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore, as woman is an individual of the human species, it is clear that every individual is not an image of God.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000053_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000053_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Therefore all men have not the conformity of image.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000054_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000054_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But by sin man becomes unlike God.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000056_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000056_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Now the intellectual nature imitates God chiefly in this, that God understands and loves Himself.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000056_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000056_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "First, inasmuch as man possesses a natural aptitude for understanding and loving God; and this aptitude consists in the very nature of the mind, which is common to all men.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000056_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000056_000004.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Secondly, inasmuch as man actually and habitually knows and loves God, though imperfectly; and this image consists in the conformity of grace.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000057_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000057_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "But in a secondary sense the image of God is found in man, and not in woman: for man is the beginning and end of woman; as God is the beginning and end of every creature.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000057_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000057_000004.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "So when the Apostle had said that \"man is the image and glory of God, but woman is the glory of man,\" he adds his reason for saying this: \"For man is not of woman, but woman of man; and man was not created for woman, but woman for man.\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000059_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000059_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "five]",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000060_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Whether the Image of God Is in Man According to the Trinity of Persons?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000061_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000061_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Objection one: It would seem that the image of God does not exist in man as to the Trinity of Persons.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000066_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000066_000001.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Now the mode of origin is not the same in all things, but in each thing is adapted to the nature thereof; animated things being produced in one way, and inanimate in another; animals in one way, and plants in another.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000066_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000066_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Wherefore it is manifest that the distinction of the Divine Persons is suitable to the Divine Nature; and therefore to be to the image of God by imitation of the Divine Nature does not exclude being to the same image by the representation of the Divine Persons: but rather one follows from the other.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000066_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000066_000003.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "We must, therefore, say that in man there exists the image of God, both as regards the Divine Nature and as regards the Trinity of Persons; for also in God Himself there is one Nature in Three Persons.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000067_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000067_000000.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "Thus it is clear how to solve the first two objections.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8742_245708_000069_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8742/245708/8742_245708_000069_000002.wav",
        "speaker_id": "LibriTTS_R-8742",
        "content": "First, because as the Son is like to the Father by a likeness of essence, it would follow of necessity if man were made in likeness to the Son, that he is made to the likeness of the Father.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    }
]