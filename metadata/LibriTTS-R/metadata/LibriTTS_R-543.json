        "speaker_id": "LibriTTS_R-543",
        "content": "The palace was beautifully built.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
