        "speaker_id": "LibriTTS_R-543",
        "content": "They sat down to table, and after an excellent dinner they went into the library.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-543_133212_000030_000004",
