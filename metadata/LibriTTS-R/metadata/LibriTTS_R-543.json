        "speaker_id": "LibriTTS_R-543",
        "content": "Music, to day, is only the art of executing difficult things, and that which is only difficult cannot please long.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
