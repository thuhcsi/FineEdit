        "speaker_id": "LibriTTS_R-1547",
        "content": "She gave him entire confidence, he gave her the help she needed, and both found consolation in the act.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
