        "speaker_id": "LibriTTS_R-1547",
        "content": "You are like a chestnut burr, prickly outside, but silky soft within, and a sweet kernal, if one can only get at it.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
