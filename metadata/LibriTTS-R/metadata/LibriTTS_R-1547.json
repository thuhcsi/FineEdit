        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1547/130184/1547_130184_000016_000001.wav",
        "speaker_id": "LibriTTS_R-1547",
        "content": "A little more sunshine to ripen the nut, then, not a boy's impatient shake, but a man's hand reached up to pick it gently from the burr, and find the kernal sound and sweet.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
