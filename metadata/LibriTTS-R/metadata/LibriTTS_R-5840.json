        "speaker_id": "LibriTTS_R-5840",
        "content": "WITH PADEREWSKI-A MODERN PIANIST ON TOUR",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
