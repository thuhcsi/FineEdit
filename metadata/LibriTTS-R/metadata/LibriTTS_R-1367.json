        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1367/291931/1367_291931_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1367",
        "content": "And if this be true of even mediocre poetry, for how much more are we indebted to the best!",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
