        "speaker_id": "LibriTTS_R-1367",
        "content": "Through what power Even for the least division of an hour Have I been so beguiled as to be blind",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
