        "speaker_id": "LibriTTS_R-2652",
        "content": "There is direct evidence, too, besides the story in the first paragraph of this chapter, that women disliked the prevalence of smoking.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
