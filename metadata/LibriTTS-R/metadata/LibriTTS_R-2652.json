        "speaker_id": "LibriTTS_R-2652",
        "content": "On this occasion the passage though stormy was very quick, for it lasted only thirty four days.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
