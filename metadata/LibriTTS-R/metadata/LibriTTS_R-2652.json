        "speaker_id": "LibriTTS_R-2652",
        "content": "Nor has the practice by any means yet died out.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
