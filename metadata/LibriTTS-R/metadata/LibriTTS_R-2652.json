        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2652/157644/2652_157644_000038_000012.wav",
        "speaker_id": "LibriTTS_R-2652",
        "content": "But even this was not all.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
