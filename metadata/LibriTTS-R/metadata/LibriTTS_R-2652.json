        "speaker_id": "LibriTTS_R-2652",
        "content": "She had burned herself more than once before in performing the same operation; but her pipe she was bound to have, and so met her end.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
