        "speaker_id": "LibriTTS_R-2652",
        "content": "The younger lady's conversation would have shocked the prim maids and matrons of that day.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
