        "speaker_id": "LibriTTS_R-2652",
        "content": "Possibly she was not a smoker at all, but needed the tobacco for some medicinal purpose.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
