        "speaker_id": "LibriTTS_R-2652",
        "content": "\"George Thresher kept a shoppe in Romford and sold tobacco there.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
