        "speaker_id": "LibriTTS_R-2652",
        "content": "The woman is plainly a convivial soul; but there is no pipe for her, and such provision was no doubt unusual.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
