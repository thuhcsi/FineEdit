        "speaker_id": "LibriTTS_R-2652",
        "content": "Her death was caused by the accidental ignition of her clothes as she was lighting her pipe at the fire.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
