        "speaker_id": "LibriTTS_R-594",
        "content": "\"That is what you are not to ask me.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-594_128329_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/594/128329/594_128329_000038_000001.wav",
        "speaker_id": "LibriTTS_R-594",
        "content": "I would ask you to believe that he has a heart he very, very seldom reveals, and that there are deep wounds in it.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
