        "speaker_id": "LibriTTS_R-475",
        "content": "A good life is infinitely preferable to good looks.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
