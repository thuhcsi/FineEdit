        "speaker_id": "LibriTTS_R-475",
        "content": "Quite a charming woman; separated from her husband\"--",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
