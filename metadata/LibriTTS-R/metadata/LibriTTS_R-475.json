        "speaker_id": "LibriTTS_R-475",
        "content": "\"Scandal, my dear Irene-I may call you Irene, mayn't I?\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-475_125002_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/475/125002/475_125002_000013_000000.wav",
        "speaker_id": "LibriTTS_R-475",
        "content": "\"I don't know that you have known me long enough for that.\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-475_125002_000014_000003",
