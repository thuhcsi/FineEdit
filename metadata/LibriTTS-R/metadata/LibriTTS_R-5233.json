        "speaker_id": "LibriTTS_R-5233",
        "content": "Almost all the travellers who have visited Italy, agree in describing it as the most abandoned of all the countries of Europe.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
