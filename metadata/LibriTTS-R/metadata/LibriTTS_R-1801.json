        "speaker_id": "LibriTTS_R-1801",
        "content": "I call her peerless because she has no peer, whether it be in bodily stature or in the supremacy of rank and beauty.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
