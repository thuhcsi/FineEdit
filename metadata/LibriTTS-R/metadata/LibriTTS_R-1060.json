        "speaker_id": "LibriTTS_R-1060",
        "content": "During the day she was happy, but when night came on she began to grow restless.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
