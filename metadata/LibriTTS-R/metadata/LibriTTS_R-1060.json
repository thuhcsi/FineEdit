        "speaker_id": "LibriTTS_R-1060",
        "content": "At the Fair she was glad to be seen in his company as he was well dressed and a stranger.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
