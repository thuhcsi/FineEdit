        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1060/134451/1060_134451_000005_000006.wav",
        "speaker_id": "LibriTTS_R-1060",
        "content": "From being quite sure of himself and his future he becomes not at all sure.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
