    },
    {
        "item_name": "LibriTTS_R-1060_134451_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1060/134451/1060_134451_000007_000003.wav",
        "speaker_id": "LibriTTS_R-1060",
        "content": "She had come home from Cleveland, where she was attending college, to spend a day at the Fair.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
