        "speaker_id": "LibriTTS_R-1060",
        "content": "He wanted to tell her of the new impulses that had come to him.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
