        "speaker_id": "LibriTTS_R-1060",
        "content": "She was no longer a girl and hungered to reach into the grace and beauty of womanhood.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
