        "speaker_id": "LibriTTS_R-1060",
        "content": "He felt old and a little tired.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
