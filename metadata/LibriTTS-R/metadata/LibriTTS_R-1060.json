        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1060/134451/1060_134451_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1060",
        "content": "As for Helen White, she also had come to a period of change.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
