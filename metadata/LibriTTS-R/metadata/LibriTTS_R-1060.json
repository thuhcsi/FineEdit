        "speaker_id": "LibriTTS_R-1060",
        "content": "She knew that the fact of his presence would create an impression.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
