        "speaker_id": "LibriTTS_R-1060",
        "content": "The mood that had taken possession of him was a thing known to men and unknown to boys.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
