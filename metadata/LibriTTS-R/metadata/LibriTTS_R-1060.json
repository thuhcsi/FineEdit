        "speaker_id": "LibriTTS_R-1060",
        "content": "To his mind his new sense of maturity set him apart, made of him a half tragic figure.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
