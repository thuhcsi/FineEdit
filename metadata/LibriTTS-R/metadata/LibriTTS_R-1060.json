        "speaker_id": "LibriTTS_R-1060",
        "content": "George Willard, the Ohio village boy, was fast growing into manhood and new thoughts had been coming into his mind.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
