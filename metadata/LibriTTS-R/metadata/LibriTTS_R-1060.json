        "speaker_id": "LibriTTS_R-1060",
        "content": "\"A scholar needs money. I should marry a woman with money,\" he mused.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
