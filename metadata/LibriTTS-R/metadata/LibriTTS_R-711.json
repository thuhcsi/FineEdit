[
    {
        "item_name": "LibriTTS_R-711_187464_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187464/711_187464_000035_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "This was tapped, and served regularly to all hands, which was much preferable to spirits, as it gave them strength without intoxication.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000003_000000.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The exclusive trade of sandlewood was valuable and convenient to the Dutch; but, from the vast extent of territory lately acquired in India, we have plenty of that commodity without going to the Dutch market.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000003_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "Close to the Dutch town is a Chinese town and temple.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000003_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "They have a governor of their own nation, but pay large tribute to the Dutch.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000004_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "One of the petty princes, in settling his account with a merchant of this place, was some dollars short of cash.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000004_000004.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "He went passenger in the ship with us to Batavia.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000006_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "I could dwell with pleasure for an age in praise of this honest Dutchman; it is the tribute of a grateful heart, and his due.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000006_000003.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "This is the third time he has had an opportunity of extending his hospitality to shipwrecked Englishmen.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000007_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "They drew bills on the British government, and were supplied with every necessary they stood in need of.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000008_000005.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "They had been supplied with a quadrant, a compass, a chart, and some small arms and ammunition, from a Dutch ship that lay there; and the expedition was conducted by the Governor's fisherman, whose time of transportation was expired.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000008_000007.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "They dragged along the coast of New South Wales; and as often as the hostile nature of the savage natives would permit, hauled their boat up at night, and slept on shore.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000008_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000008_000009.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "In many places of the coast of South Wales, they found very good coal; a circumstance that was not before known.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000008_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000008_000010.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "Our men were now beginning to regain their strength; and Captain Dadleberg of the Rembang Indiaman was making every possible dispatch with his ship to carry us to Batavia.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000009_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The Governor, Lieutenant Governor, and all the Europeans were invited.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000009_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "Six months had been spent in preparations for this fete, at which an emperor and twenty five kings assisted and attended in person with all their body guards, standards, and standard bearers, were present.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000010_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The first toast after dinner was the dead king's health.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000011_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "As he was preceded by music, and colours flying, every one turned out to see him. Amongst the rest was a captive king in chains, who was employed blowing the bellows to our armourer, whilst he was forging bolts and fetters for our prisoners and convicts.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000012_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "That domestic strife serves likewise amply to supply the slave trade from the prisoners of both parties.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000013_000006.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "At stated periods it makes a noise exactly like a cuckoo clock.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000014_000000.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The Governor, Mynheer Vanion, relates a circumstance that happened to him while hunting.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000014_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "In crossing a shallow part of the river, his black boy was snapped up by an alligator; but the Governor immediately dismounted, rescued the boy out of his mouth, and slew him.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000016_000000.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "On the sixth of October, we embarked on board the Rembang Dutch Indiaman, taking with us the prisoners and convicts.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000016_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000016_000006.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The Dutch seamen were struck with horror, and went below; and the ship was preserved from destruction by the manly exertion of our English tars, whose souls seemed to catch redoubled ardour from the tempest's rage.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000019_000000.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "On the twenty sixth, saw the island of Java; and on the thirtieth, anchored at Samarang.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000020_000000.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "Immediately on our coming to anchor, we were agreeably surprised to find our tender here which we had so long given up for lost.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000021_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "Our seven barrelled pieces made great havoc amongst them.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000024_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The alternative was dreadful, as famine presented them on the one hand, and shipwreck on the other.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000028_000000.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The town is regular and beautiful, and the houses are built in a style of architecture, which has given loose to the most sportive fancy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000030_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "Some dead bodies floating down the canal struck our boat, which had a very disagreeable effect on the minds of our brave fellows, whose nerves were reduced to a very weak state from sickness.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000033_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000033_000003.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The compass of my work will not allow me to be particular; but I must instance one among many others.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000034_000000.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "In our passage from this to the Cape, before we left Java, one of the convicts had jumped over board in the night, and swam to the Dutch arsenal at Honroost.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000034_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000034_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "We met nothing particular in passing the island of Sumatra, but experienced great death and sickness in going through the Straits of Sunda; and after a tedious passage, arrived at the Cape of Good Hope.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000037_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "But should the piquet be negligent in their duty, and suffer the main body to be surprised, the delinquents are severely punished.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000038_000001.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "They have even contrived to carry canals to the top of a mountain.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-711_187466_000038_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/711/187466/711_187466_000038_000002.wav",
        "speaker_id": "LibriTTS_R-711",
        "content": "The boors, or country farmers, are a species of the human race, so gigantic and superior to the rest of mankind, in point of size and constitution, that they may be called nondescripts.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    }
]