[
    {
        "item_name": "LibriTTS_R-4734_220951_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000001_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "one: NATURE IS GOVERNED BY ONE UNIVERSAL LAW",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000002_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Nature is that condition, that reality, which in appearance consists in life and death, or, in other words, in the composition and decomposition of all things.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000004_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "But when you look at Nature itself, you see that it has no intelligence, no will.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000004_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "For instance, the nature of fire is to burn; it burns without will or intelligence.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000004_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "The nature of water is fluidity; it flows without will or intelligence.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000004_000003.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "The nature of the sun is radiance; it shines without will or intelligence.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000004_000004.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "The nature of vapor is to ascend; it ascends without will or intelligence.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000004_000005.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Thus it is clear that the natural movements of all things are compelled; there are no voluntary movements except those of animals and, above all, those of man.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000004_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000004_000007.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "For example, he invented the telegraph, which is the means of communication between the East and the West.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000005_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Now, when you behold in existence such organizations, arrangements and laws, can you say that all these are the effect of Nature, though Nature has neither intelligence nor perception?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000005_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "If not, it becomes evident that this Nature, which has neither perception nor intelligence, is in the grasp of Almighty God, Who is the Ruler of the world of Nature; whatever He wishes, He causes Nature to manifest.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000006_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "One of the things which has appeared in the world of existence, and which is one of the requirements of Nature, is human life.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000006_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Considered from this point of view man is the branch; nature is the root.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000008_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "two: PROOFS AND EVIDENCES OF THE EXISTENCE OF GOD",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000009_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "One of the proofs and demonstrations of the existence of God is the fact that man did not create himself: nay, his creator and designer is another than himself.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000010_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "It is certain and indisputable that the creator of man is not like man because a powerless creature cannot create another being.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000010_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "The maker, the creator, has to possess all perfections in order that he may create.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000011_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Can the creation be perfect and the creator imperfect?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000011_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Can a picture be a masterpiece and the painter imperfect in his art?",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000011_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "For it is his art and his creation.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000011_000003.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Moreover, the picture cannot be like the painter; otherwise, the painting would have created itself.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000011_000004.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "However perfect the picture may be, in comparison with the painter it is in the utmost degree of imperfection.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000012_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "The imperfections of the contingent world are in themselves a proof of the perfections of God.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000013_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "For example, when you look at man, you see that he is weak.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000013_000004.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "In the contingent world there is ignorance; necessarily knowledge exists, because ignorance is found; for if there were no knowledge, neither would there be ignorance.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000014_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Because a characteristic of contingent beings is dependency, and this dependency is an essential necessity, therefore, there must be an independent being whose independence is essential.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000017_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Throughout the world of existence it is the same; the smallest created thing proves that there is a creator.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000017_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "For instance, this piece of bread proves that it has a maker.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000018_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Praise be to God! the least change produced in the form of the smallest thing proves the existence of a creator: then can this great universe, which is endless, be self created and come into existence from the action of matter and the elements?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000019_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "These obvious arguments are adduced for weak souls; but if the inner perception be open, a hundred thousand clear proofs become visible.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000020_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "three: THE NEED OF AN EDUCATOR",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000021_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "When we consider existence, we see that the mineral, vegetable, animal and human worlds are all in need of an educator.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000022_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "If the earth is not cultivated, it becomes a jungle where useless weeds grow; but if a cultivator comes and tills the ground, it produces crops which nourish living creatures.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000022_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "It is evident, therefore, that the soil needs the cultivation of the farmer.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000022_000003.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "These are rational proofs; in this age the peoples of the world need the arguments of reason.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000024_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "If a man be left alone in a wilderness where he sees none of his own kind, he will undoubtedly become a mere brute; it is then clear that an educator is needed.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000025_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "But education is of three kinds: material, human and spiritual.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000028_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Now we need an educator who will be at the same time a material, human and spiritual educator, and whose authority will be effective in all conditions.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000030_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "He must also impart spiritual education, so that intelligence and comprehension may penetrate the metaphysical world, and may receive benefit from the sanctifying breeze of the Holy Spirit, and may enter into relationship with the Supreme Concourse.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000031_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "How can one solitary person without help and without support lay the foundations of such a noble construction?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000031_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000031_000003.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Certainly nothing short of a divine power could accomplish so great a work.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000031_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000031_000004.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "We ought to consider this with justice, for this is the office of justice.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000032_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "A Cause which all the governments and peoples of the world, with all their powers and armies, cannot promulgate and spread, one Holy Soul can promote without help or support!",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000032_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Can this be done by human power?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000032_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000032_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "No, in the name of God!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000033_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "If He does not show forth such a holy power, He will not be able to educate, for if He be imperfect, how can He give a perfect education?",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000033_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "If He be ignorant, how can He make others wise?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000033_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000033_000003.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "If He be unjust, how can He make others just?",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000033_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000033_000004.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "If He be earthly, how can He make others heavenly?",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220951_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220951/4734_220951_000035_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Therefore, it must be our task to prove to the thoughtful by reasonable arguments the prophethood of Moses, of Christ and of the other Divine Manifestations.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000001_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "four: ABRAHAM",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000002_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "He opposed His own nation and people, and even His own family, by rejecting all their gods.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000002_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Alone and without help He resisted a powerful tribe, a task which is neither simple nor easy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000003_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "These people believed not in one God but in many gods, to whom they ascribed miracles; therefore, they all arose against Him, and no one supported Him except Lot, His brother's son, and one or two other people of no importance.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000003_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "In reality they banished Him in order that He might be crushed and destroyed, and that no trace of Him might be left.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000004_000003.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "As a result the teachings of Abraham were spread abroad, a Jacob appeared among His posterity, and a Joseph who became ruler in Egypt.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000004_000004.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "In consequence of His exile a Moses and a being like Christ were manifested from His posterity, and Hagar was found from whom Ishmael was born, one of whose descendants was Muhammad.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000004_000006.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "And so it will continue for ever and ever.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000004_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000004_000008.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "See what a power it is that enabled a Man Who was a fugitive from His country to found such a family, to establish such a faith, and to promulgate such teachings.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000004_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000004_000010.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "We must be just: was this Man an Educator or not?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000007_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "five: MOSES",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000008_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Moses was for a long time a shepherd in the wilderness.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000009_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "It was such a Man as this that freed a great nation from the chains of captivity, made them contented, brought them out from Egypt, and led them to the Holy Land.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000010_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "This people from the depths of degradation were lifted up to the height of glory.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000010_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "They were captive; they became free.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000010_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "They were the most ignorant of peoples; they became the most wise.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000011_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Later the people of Greece rose in opposition to him, accused him of impiety, arraigned him before the Areopagus, and condemned him to death by poison.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000012_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Now, how could a Man Who was a stammerer, Who had been brought up in the house of Pharaoh, Who was known among men as a murderer, Who through fear had for a long time remained in concealment, and Who had become a shepherd, establish so great a Cause, when the wisest philosophers on earth have not displayed one thousandth part of this influence?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000012_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "This is indeed a prodigy.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000013_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "A Man Who had a stammering tongue, Who could not even converse correctly, succeeded in sustaining this great Cause!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000013_000004.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "How is it that a shepherd could acquire all of this knowledge?",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000013_000005.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "It is beyond doubt that He must have been assisted by an omnipotent power.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000014_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Consider also what trials and difficulties arise for people.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000014_000001.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "To prevent an act of cruelty, Moses struck down an Egyptian and afterward became known among men as a murderer, more notably because the man He had killed was of the ruling nation.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000014_000002.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "Then He fled, and it was after that that He was raised to the rank of a Prophet!",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4734_220952_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000016_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "six: CHRIST",
        "style_prompt": "M_p-low_s-slow_e-low",
