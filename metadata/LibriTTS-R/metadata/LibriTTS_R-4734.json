        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4734/220952/4734_220952_000019_000000.wav",
        "speaker_id": "LibriTTS_R-4734",
        "content": "This young Man, Christ, by the help of a supernatural power, abrogated the ancient Mosaic Law, reformed the general morals, and once again laid the foundation of eternal glory for the Israelites.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
