        "speaker_id": "LibriTTS_R-4734",
        "content": "To all outward appearances they overcame Him and brought Him into direst distress.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
