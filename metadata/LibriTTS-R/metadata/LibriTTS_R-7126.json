        "speaker_id": "LibriTTS_R-7126",
        "content": "We call him charming as Pater called Athens charming.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
