        "speaker_id": "LibriTTS_R-7126",
        "content": "He is one of those authors whose books we love because they reveal a personality sensitive, affectionate, pitiful.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
