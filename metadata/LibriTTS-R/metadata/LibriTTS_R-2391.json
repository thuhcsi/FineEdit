        "speaker_id": "LibriTTS_R-2391",
        "content": "The patten now supports each frugal dame, Which from the blue eyed Patty takes the name.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
