        "speaker_id": "LibriTTS_R-2391",
        "content": "This defence against wet and dirt is now seldom seen.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2391_145015_000036_000000",
