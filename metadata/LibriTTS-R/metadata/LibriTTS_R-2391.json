        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2391/145015/2391_145015_000041_000006.wav",
        "speaker_id": "LibriTTS_R-2391",
        "content": "I remember two such elegant little wheels in our own family.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
