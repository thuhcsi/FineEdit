        "speaker_id": "LibriTTS_R-2391",
        "content": "It may be observed that this hand spinning is the most primitive of female accomplishments, and can be traced back to the earliest times. Ballad poetry and fairy tales are full of allusions to it.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
