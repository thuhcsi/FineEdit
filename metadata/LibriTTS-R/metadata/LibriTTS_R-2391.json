        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2391/145015/2391_145015_000038_000000.wav",
        "speaker_id": "LibriTTS_R-2391",
        "content": "As an illustration of the purposes which a patten was intended to serve, I add the following epigram, written by Jane Austen's uncle, mr Leigh Perrot, on reading in a newspaper the marriage of Captain Foote to Miss Patten:--",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2391_145015_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2391/145015/2391_145015_000041_000000.wav",
        "speaker_id": "LibriTTS_R-2391",
        "content": "Up to the beginning of the present century, poor women found profitable employment in spinning flax or wool.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2391_145015_000041_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2391/145015/2391_145015_000041_000004.wav",
        "speaker_id": "LibriTTS_R-2391",
        "content": "The outstretched arms, the advanced foot, the sway of the whole figure backwards and forwards, produced picturesque attitudes, and displayed whatever of grace or beauty the work woman might possess.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
