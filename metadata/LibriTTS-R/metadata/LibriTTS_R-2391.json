        "speaker_id": "LibriTTS_R-2391",
        "content": "If all this is true, the future admiral of the British Fleet must have cut a conspicuous figure in the hunting field.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
