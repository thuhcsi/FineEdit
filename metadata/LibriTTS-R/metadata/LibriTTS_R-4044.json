        "speaker_id": "LibriTTS_R-4044",
        "content": "'Don't look so cross at me, Prince Wulf; I'm sure it's not my fault; I could only say what the monk told me,' whispered poor Pelagia.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
