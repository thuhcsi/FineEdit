[
    {
        "item_name": "LibriTTS_R-2288_139949_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "These fans of leaves from Indian trees- These crimson shells, from Indian seas- These tiny portraits, set in rings- Once, doubtless, deemed such precious things; Keepsakes bestowed by Love on Faith, And worn till the receiver's death, Now stored with cameos, china, shells, In this old closet's dusty cells.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000003_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "I scarcely think, for ten long years, A hand has touched these relics old; And, coating each, slow formed, appears The growth of green and antique mould.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000006_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "And outside all is ivy, clinging To chimney, lattice, gable grey; Scarcely one little red rose springing Through the green moss can force its way.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000009_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "I fear to see the very faces, Familiar thirty years ago, Even in the old accustomed places Which look so cold and gloomy now,",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000010_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "I've come, to close the window, hither, At twilight, when the sun was down, And Fear my very soul would wither, Lest something should be dimly shown,",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Hers was this chamber; in her time It seemed to me a pleasant room, For then no cloud of grief or crime Had cursed it with a settled gloom;",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "She bore in silence-but when passion Surged in her soul with ceaseless foam, The storm at last brought desolation, And drove her exiled from her home.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Fain would I know if, henceforth, ever, These eyes shall read in hers again, That light of love which faded never, Though dimmed so long with secret pain.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000027_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "So speaks experience, sage and hoary; I see it plainly, know it well, Like one who, having read a story, Each incident therein can tell.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000028_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Touch not that ring; 'twas his, the sire Of that forsaken child; And nought his relics can inspire Save memories, sin defiled.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139949_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139949/2288_139949_000030_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "And heaven did curse-they found him laid, When crime for wrath was rife, Cold-with the suicidal blade Clutched in his desperate gripe.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "There was an alcove in that shade, Screening a rustic seat and stand; Weary she sat her down, and laid Her hot brow on her burning hand.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000009_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "To solitude and to the night, Some words she now, in murmurs, said; And trickling through her fingers white, Some tears of misery she shed.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Who can for ever crush the heart, Restrain its throbbing, curb its life? Dissemble truth with ceaseless art, With outward calm mask inward strife?\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000015_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"My love awakes no love again, My tears collect, and fall unfelt; My sorrow touches none with pain, My humble hopes to nothing melt.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"That mind my own.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000019_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Must it be so?",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000022_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Oh! leaving disappointment here, Will man find hope on yonder coast? Hope, which, on earth, shines never clear, And oft in clouds is wholly lost.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000023_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Will he hope's source of light behold, Fruition's spring, where doubts expire, And drink, in waves of living gold, Contentment, full, for long desire?",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000025_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Will he find love without lust's leaven, Love fearless, tearless, perfect, pure, To all with equal bounty given; In all, unfeigned, unfailing, sure?",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000026_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Will he, from penal sufferings free, Released from shroud and wormy clod, All calm and glorious, rise and see Creation's Sire-Existence' God?",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000028_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"If so, endure, my weary frame; And when thy anguish strikes too deep, And when all troubled burns life's flame, Think of the quiet, final sleep;",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000032_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"The tear which, welling from the heart, Burns where its drop corrosive falls, And makes each nerve, in torture, start, At feelings it too well recalls:",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000034_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"When the hand trembled to receive A thrilling clasp, which seemed so near, And the heart ventured to believe Another heart esteemed it dear.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000046_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Still strong and young, and warm with vigour, Though scathed, I long shall greenly grow; And many a storm of wildest rigour Shall yet break o'er my shivered bough.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000047_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"Rebellious now to blank inertion, My unused strength demands a task; Travel, and toil, and full exertion, Are the last, only boon I ask.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000050_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"The world is not in yonder tower, Earth is not prisoned in that room, 'Mid whose dark panels, hour by hour, I've sat, the slave and prey of gloom.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000051_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"One feeling-turned to utter anguish, Is not my being's only aim; When, lorn and loveless, life will languish, But courage can revive the flame.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000053_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"New scenes, new language, skies less clouded, May once more wake the wish to live; Strange, foreign towns, astir, and crowded, New pictures to the mind may give.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_139962_000055_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/139962/2288_139962_000055_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "\"And we might meet-time may have changed him; Chance may reveal the mystery, The secret influence which estranged him; Love may restore him yet to me.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000003_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Mrs General",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000005_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "A stiff commissariat officer of sixty, famous as a martinet, had then become enamoured of the gravity with which she drove the proprieties four in hand through the cathedral town society, and had solicited to be taken beside her on the box of the cool coach of ceremony to which that team was harnessed.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000005_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "His proposal of marriage being accepted by the lady, the commissary took his seat behind the proprieties with great decorum, and Mrs General drove until the commissary died.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000005_000003.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "In the course of their united journey, they ran over several people who came in the way of the proprieties; but always in a high style and with composure.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000006_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "It then transpired that the commissary had so far stolen a march on Mrs General as to have bought himself an annuity some years before his marriage, and to have reserved that circumstance in mentioning, at the period of his proposal, that his income was derived from the interest of his money.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000006_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Mrs General consequently found her means so much diminished, that, but for the perfect regulation of her mind, she might have felt disposed to question the accuracy of that portion of the late service which had declared that the commissary could take nothing away with him.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000007_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Mrs General's communication of this idea to her clerical and commissariat connection was so warmly applauded that, but for the lady's undoubted merit, it might have appeared as though they wanted to get rid of her.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000007_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Testimonials representing Mrs General as a prodigy of piety, learning, virtue, and gentility, were lavishly contributed from influential quarters; and one venerable archdeacon even shed tears in recording his testimony to her perfections (described to him by persons on whom he could rely), though he had never had the honour and moral gratification of setting eyes on Mrs General in all his life.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Thus delegated on her mission, as it were by Church and State, Mrs General, who had always occupied high ground, felt in a condition to keep it, and began by putting herself up at a very high figure.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000008_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "An interval of some duration elapsed, in which there was no bid for Mrs General.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000009_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "When her charge was at length formed, the marriage, not only of the young lady, but likewise of her father, the widower, was resolved on.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000009_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "The widower then finding Mrs General both inconvenient and expensive, became of a sudden almost as much affected by her merits as the archdeacon had been, and circulated such praises of her surpassing worth, in all quarters where he thought an opportunity might arise of transferring the blessing to somebody else, that Mrs General was a name more honourable than ever.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000010_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "The phoenix was to let, on this elevated perch, when Mr Dorrit, who had lately succeeded to his property, mentioned to his bankers that he wished to discover a lady, well bred, accomplished, well connected, well accustomed to good society, who was qualified at once to complete the education of his daughters, and to be their matron or chaperon.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000011_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Pursuing the light so fortunately hit upon, and finding the concurrent testimony of the whole of Mrs General's acquaintance to be of the pathetic nature already recorded, Mr Dorrit took the trouble of going down to the county of the county widower to see Mrs General, in whom he found a lady of a quality superior to his highest expectations.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'Might I be excused,' said Mr Dorrit, 'if I inquired-ha-what remune-'",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000013_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'Why, indeed,' returned Mrs General, stopping the word, 'it is a subject on which I prefer to avoid entering.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000013_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "I have never entered on it with my friends here; and I cannot overcome the delicacy, Mr Dorrit, with which I have always regarded it.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000013_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "I am not, as I hope you are aware, a governess-'",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000014_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'O dear no!' said Mr Dorrit. 'Pray, madam, do not imagine for a moment that I think so.' He really blushed to be suspected of it.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000015_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Mrs General gravely inclined her head.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000015_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'I cannot, therefore, put a price upon services which it is a pleasure to me to render if I can render them spontaneously, but which I could not render in mere return for any consideration.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000015_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Neither do I know how, or where, to find a case parallel to my own.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000015_000003.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "It is peculiar.'",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000016_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "No doubt.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000016_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "But how then (Mr Dorrit not unnaturally hinted) could the subject be approached.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000016_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'I cannot object,' said Mrs General-'though even that is disagreeable to me-to Mr Dorrit's inquiring, in confidence of my friends here, what amount they have been accustomed, at quarterly intervals, to pay to my credit at my bankers'.'",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'Permit me to add,' said Mrs General, 'that beyond this, I can never resume the topic.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000018_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Also that I can accept no second or inferior position. If the honour were proposed to me of becoming known to Mr Dorrit's family-I think two daughters were mentioned?--'",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000019_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'Two daughters.'",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000020_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'I could only accept it on terms of perfect equality, as a companion, protector, Mentor, and friend.'",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Mr Dorrit, in spite of his sense of his importance, felt as if it would be quite a kindness in her to accept it on any conditions.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000021_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "He almost said as much.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000022_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'I think,' repeated Mrs General, 'two daughters were mentioned?'",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000023_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'Two daughters,' said Mr Dorrit again.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000024_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "'It would therefore,' said Mrs General, 'be necessary to add a third more to the payment (whatever its amount may prove to be), which my friends here have been accustomed to make to my bankers'.'",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000025_000001.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Mrs General being an article of that lustrous surface which suggests that it is worth any money, he made a formal proposal to be allowed to have the honour and pleasure of regarding her as a member of his family.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000025_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "Mrs General conceded that high privilege, and here she was.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000026_000000.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "In person, Mrs General, including her skirts which had much to do with it, was of a dignified and imposing appearance; ample, rustling, gravely voluminous; always upright behind the proprieties.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000026_000002.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "If her countenance and hair had rather a floury appearance, as though from living in some transcendently genteel Mill, it was rather because she was a chalky creation altogether, than because she mended her complexion with violet powder, or had turned grey.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000026_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000026_000004.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "If she had few wrinkles, it was because her mind had never traced its name or any other inscription on her face.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2288_155711_000026_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2288/155711/2288_155711_000026_000005.wav",
        "speaker_id": "LibriTTS_R-2288",
        "content": "A cool, waxy, blown out woman, who had never lighted well.",
