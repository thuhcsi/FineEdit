        "speaker_id": "LibriTTS_R-7697",
        "content": "But man is nobler than other animals.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
