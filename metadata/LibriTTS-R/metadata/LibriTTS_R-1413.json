        "speaker_id": "LibriTTS_R-1413",
        "content": "He complains very bitterly of this at a dinner party, but his respect for Goethe has not diminished through this personal experience.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
