        "speaker_id": "LibriTTS_R-1413",
        "content": "The different elements are put one on top of the other; what is common to the composite picture stands out clearly, the opposing details cancel each other.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
