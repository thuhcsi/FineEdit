        "speaker_id": "LibriTTS_R-1413",
        "content": "The causal connection between two ideas is either left without presentation, or replaced by two different long portions of dreams one after the other.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
