        "speaker_id": "LibriTTS_R-1413",
        "content": "A trait, after the manner of the find in the Lido, forces itself upon me here.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
