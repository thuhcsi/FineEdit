        "speaker_id": "LibriTTS_R-1413",
        "content": "The motives for this part of the dream work are easily gauged.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
