        "speaker_id": "LibriTTS_R-1413",
        "content": "Goethe died in eighteen thirty two.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
