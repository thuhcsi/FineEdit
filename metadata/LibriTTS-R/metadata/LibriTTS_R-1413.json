        "speaker_id": "LibriTTS_R-1413",
        "content": "In the latter case they appear obscure, intricate, incoherent.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
