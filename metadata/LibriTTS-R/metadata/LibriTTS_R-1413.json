        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1413/121799/1413_121799_000030_000003.wav",
        "speaker_id": "LibriTTS_R-1413",
        "content": "When the dream appears openly absurd, when it contains an obvious paradox in its content, it is so of purpose.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
