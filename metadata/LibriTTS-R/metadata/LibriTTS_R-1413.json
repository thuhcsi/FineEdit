        "speaker_id": "LibriTTS_R-1413",
        "content": "The derogatory reception of my friend's work had made a deep impression upon me.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1413_121799_000034_000006",
