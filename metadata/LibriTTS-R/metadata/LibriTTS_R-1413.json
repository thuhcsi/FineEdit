        "speaker_id": "LibriTTS_R-1413",
        "content": "The first dream thoughts which are unravelled by analysis frequently strike one by their unusual wording.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
