        "speaker_id": "LibriTTS_R-1413",
        "content": "When there is nothing in common between the dream thoughts, the dream work takes the trouble to create a something, in order to make a common presentation feasible in the dream.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
