        "speaker_id": "LibriTTS_R-1413",
        "content": "The dream work is peculiarly adept at representing two contradictory conceptions by means of the same mixed image.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
