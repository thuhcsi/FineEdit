        "speaker_id": "LibriTTS_R-1413",
        "content": "In my judgment, it contained a fundamental biological discovery which only now, several years later, commences to find favor among the professors.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
