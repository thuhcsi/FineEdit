        "speaker_id": "LibriTTS_R-1413",
        "content": "The first person in the dream thoughts behind the ego was my friend who had been so scandalously treated.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
