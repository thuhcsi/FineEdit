        "speaker_id": "LibriTTS_R-1413",
        "content": "The dream work proceeds like Francis Galton with his family photographs.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
