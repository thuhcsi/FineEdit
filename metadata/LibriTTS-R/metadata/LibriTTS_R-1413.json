        "speaker_id": "LibriTTS_R-1413",
        "content": "It seemed to me that this view had something in it, because the unfortunate youth afterwards mutilated his genital organs.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
