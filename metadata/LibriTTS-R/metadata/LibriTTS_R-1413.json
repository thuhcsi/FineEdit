        "speaker_id": "LibriTTS_R-1413",
        "content": "I will not pursue the further result of the thought.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
