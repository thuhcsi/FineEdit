        "speaker_id": "LibriTTS_R-1413",
        "content": "Small wonder, says the dream thought, if this person is grateful to me for this-this love is not cost free.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
