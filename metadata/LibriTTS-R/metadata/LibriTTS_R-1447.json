        "speaker_id": "LibriTTS_R-1447",
        "content": "The girl paused, examining the point of her pen thoughtfully.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
