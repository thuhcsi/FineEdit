        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000052_000001.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "Uncle john hardly knew what to say further.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1447_17506_000052_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000052_000002.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "He felt he was in an awkward position, for Louise was the most experienced in worldly ways of his three nieces and he had no desire to pose as a stern guardian or to deprive his girls of any passing pleasure they might enjoy.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
