        "speaker_id": "LibriTTS_R-1447",
        "content": "Uncle john took the card and read:",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
