    },
    {
        "item_name": "LibriTTS_R-1447_17506_000048_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000048_000002.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "Floriano, the proprietor, who knows every aristocrat in Italy, has never before heard of him.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1447_17506_000049_000001",
