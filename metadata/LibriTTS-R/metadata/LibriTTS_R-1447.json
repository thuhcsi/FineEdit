        "speaker_id": "LibriTTS_R-1447",
        "content": "When an imposture is unmasked it is no longer dangerous.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1447_17506_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000044_000000.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "He joined his nieces, who were all busily engaged in writing letters home, and remarked, casually:",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
