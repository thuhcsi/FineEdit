        "speaker_id": "LibriTTS_R-1447",
        "content": "The young man greeted him with a smile and a bow.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
