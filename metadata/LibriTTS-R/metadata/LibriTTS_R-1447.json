        "speaker_id": "LibriTTS_R-1447",
        "content": "\"You've been deceived in your Italian friend, Louise.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
