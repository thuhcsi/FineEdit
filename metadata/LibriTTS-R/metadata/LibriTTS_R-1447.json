        "speaker_id": "LibriTTS_R-1447",
        "content": "\"I misunderstood your name last evening,\" he said.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1447_17506_000036_000001",
