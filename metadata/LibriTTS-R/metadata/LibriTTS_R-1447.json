        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000047_000000.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "\"Are you sure, Uncle john?\"",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1447_17506_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000048_000000.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "\"Quite sure, my dear.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1447_17506_000048_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000048_000001.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "I've just been through the list of Italian counts, and his name is not there.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
