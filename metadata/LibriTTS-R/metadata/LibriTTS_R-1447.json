        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000043_000001.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "He was glad that he had not suspected the young man unjustly.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
