    {
        "item_name": "LibriTTS_R-1447_17506_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1447/17506/1447_17506_000037_000001.wav",
        "speaker_id": "LibriTTS_R-1447",
        "content": "\"Allow me to offer you my card.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
