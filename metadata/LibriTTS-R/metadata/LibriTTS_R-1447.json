        "speaker_id": "LibriTTS_R-1447",
        "content": "\"Yet you say you don't know the Ferralti family.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
