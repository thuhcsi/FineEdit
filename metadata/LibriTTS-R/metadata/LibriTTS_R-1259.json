        "speaker_id": "LibriTTS_R-1259",
        "content": "They have weathered the storm, and may reasonably expect peace.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
