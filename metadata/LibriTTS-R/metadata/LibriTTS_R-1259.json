        "speaker_id": "LibriTTS_R-1259",
        "content": "Navvies came, and spilt it back into the grey.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
