        "speaker_id": "LibriTTS_R-1259",
        "content": "She cannot win in a real battle, having no muscles, only nerves.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
