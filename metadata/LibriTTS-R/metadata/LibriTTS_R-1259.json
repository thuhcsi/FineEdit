        "speaker_id": "LibriTTS_R-1259",
        "content": "By September it was a corpse, void of emotion, and scarcely hallowed by the memories of thirty years of happiness.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
