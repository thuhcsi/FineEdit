        "speaker_id": "LibriTTS_R-1259",
        "content": "Then it fell.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
