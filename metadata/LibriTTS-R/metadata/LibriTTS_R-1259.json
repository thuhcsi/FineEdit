        "speaker_id": "LibriTTS_R-1259",
        "content": "It had decayed in the spring, disintegrating the girls more than they knew, and causing either to accost unfamiliar regions.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
