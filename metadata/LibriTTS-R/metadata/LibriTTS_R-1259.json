        "speaker_id": "LibriTTS_R-1259",
        "content": "Margaret had a bad attack of these nerves during the honeymoon.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
