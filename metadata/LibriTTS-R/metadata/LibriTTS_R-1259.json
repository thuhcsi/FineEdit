        "speaker_id": "LibriTTS_R-1259",
        "content": "The heart of mrs Wilcox was alone hidden, and perhaps it is superstitious to speculate on the feelings of the dead.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
