        "speaker_id": "LibriTTS_R-1259",
        "content": "She moved south again, and spoke of wintering in Naples.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
