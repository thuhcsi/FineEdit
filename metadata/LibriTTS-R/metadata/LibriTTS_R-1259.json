        "speaker_id": "LibriTTS_R-1259",
        "content": "\"My dear girl!\"--he flung out his hand-\"have you eyes?",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
