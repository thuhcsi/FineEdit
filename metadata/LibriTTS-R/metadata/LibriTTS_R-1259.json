        "speaker_id": "LibriTTS_R-1259",
        "content": "Paul did send a cablegram.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
