        "speaker_id": "LibriTTS_R-1259",
        "content": "Margaret demurred, but Tibby accepted the offer gladly; it saved him from coming to any decision about the future.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
