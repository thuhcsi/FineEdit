        "speaker_id": "LibriTTS_R-1259",
        "content": "Through its round topped doorway passed furniture, and pictures, and books, until the last room was gutted and the last van had rumbled away.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
