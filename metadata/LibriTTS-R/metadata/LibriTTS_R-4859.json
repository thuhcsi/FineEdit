[
    {
        "item_name": "LibriTTS_R-4859_22176_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/22176/4859_22176_000015_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"I thought he had been killed.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_22176_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/22176/4859_22176_000015_000004.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "What a strange coincidence!\"",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_22176_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/22176/4859_22176_000016_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Pierre spoke rapidly and with animation.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_22176_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/22176/4859_22176_000020_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"But no, it can't be!\" he thought.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4859_22176_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/22176/4859_22176_000020_000004.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "It suffused him, seized him, and enveloped him completely.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4859_22176_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/22176/4859_22176_000021_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "He tried to hide his agitation.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_22176_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/22176/4859_22176_000022_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"No, it's only the unexpectedness of it,\" thought Pierre.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000001_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "One matter connected with his management sometimes worried Nicholas, and that was his quick temper together with his old hussar habit of making free use of his fists.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000002_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Nicholas went out into the porch to question him, and immediately after the elder had given a few replies the sound of cries and blows were heard.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000002_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "On returning to lunch Nicholas went up to his wife, who sat with her head bent low over her embroidery frame, and as usual began to tell her what he had been doing that morning.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000002_000003.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Among other things he spoke of the Bogucharovo elder.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000003_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"Such an insolent scoundrel!\" he cried, growing hot again at the mere recollection of him.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000003_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"If he had told me he was drunk and did not see...",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000003_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "But what is the matter with you, Mary?\" he suddenly asked.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000006_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She never cried from pain or vexation, but always from sorrow or pity, and when she wept her radiant eyes acquired an irresistible charm.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000007_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The moment Nicholas took her hand she could no longer restrain herself and began to cry.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000008_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"Nicholas, I saw it... he was to blame, but why do you...",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000009_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Nicholas said nothing.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000009_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "He flushed crimson, left her side, and paced up and down the room.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000009_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "He understood what she was weeping about, but could not in his heart at once agree with her that what he had regarded from childhood as quite an everyday event was wrong.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000009_000003.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"Is it just sentimentality, old wives' tales, or is she right?\" he asked himself.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000010_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"Mary,\" he said softly, going up to her, \"it will never happen again; I give you my word.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000010_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Never,\" he repeated in a trembling voice like a boy asking for forgiveness.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000011_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She took his hand and kissed it.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000013_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"Today-it was the same affair.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000013_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Oh, Mary, don't remind me of it!\" and again he flushed.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000013_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"I give you my word of honor it shan't occur again, and let this always be a reminder to me,\" and he pointed to the broken ring.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000014_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "But he did forget himself once or twice within a twelvemonth, and then he would go and confess to his wife, and would again promise that this should really be the very last time.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000015_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"Mary, you must despise me!\" he would say.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000015_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"I deserve it.\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000016_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"You should go, go away at once, if you don't feel strong enough to control yourself,\" she would reply sadly, trying to comfort her husband.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Among the gentry of the province Nicholas was respected but not liked.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "He did not concern himself with the interests of his own class, and consequently some thought him proud and others thought him stupid.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The whole summer, from spring sowing to harvest, he was busy with the work on his farm.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000003.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "In autumn he gave himself up to hunting with the same business like seriousness-leaving home for a month, or even two, with his hunt.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000004.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "In winter he visited his other villages or spent his time reading.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000007.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "He would sit in his study with a grave air, reading-a task he first imposed upon himself as a duty, but which afterwards became a habit affording him a special kind of pleasure and a consciousness of being occupied with serious matters.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000008.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "In winter, except for business excursions, he spent most of his time at home making himself one with his family and entering into all the details of his children's relations with their mother.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000017_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000017_000009.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The harmony between him and his wife grew closer and closer and he daily discovered fresh spiritual treasures in her.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000018_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "From the time of his marriage Sonya had lived in his house.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000018_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Before that, Nicholas had told his wife all that had passed between himself and Sonya, blaming himself and commending her.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000018_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "He had asked Princess Mary to be gentle and kind to his cousin.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000018_000003.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She thoroughly realized the wrong he had done Sonya, felt herself to blame toward her, and imagined that her wealth had influenced Nicholas' choice.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000018_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000018_000004.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She could not find fault with Sonya in any way and tried to be fond of her, but often felt ill will toward her which she could not overcome.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000020_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"You know,\" said Natasha, \"you have read the Gospels a great deal-there is a passage in them that just fits Sonya.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000021_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"What?\" asked Countess Mary, surprised.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000022_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "\"'To him that hath shall be given, and from him that hath not shall be taken away.' You remember?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000022_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She is one that hath not; why, I don't know.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000022_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Perhaps she lacks egotism, I don't know, but from her is taken away, and everything has been taken away.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000022_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000022_000004.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Formerly I very much wanted Nicholas to marry her, but I always had a sort of presentiment that it would not come off.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000022_000005.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She is a sterile flower, you know-like some strawberry blossoms.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000023_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Though Countess Mary told Natasha that those words in the Gospel must be understood differently, yet looking at Sonya she agreed with Natasha's explanation.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000023_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "It really seemed that Sonya did not feel her position trying, and had grown quite reconciled to her lot as a sterile flower.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000023_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She seemed to be fond not so much of individuals as of the family as a whole.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000023_000003.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "Like a cat, she had attached herself not to the people but to the home.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000023_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000023_000004.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "She waited on the old countess, petted and spoiled the children, was always ready to render the small services for which she had a gift, and all this was unconsciously accepted from her with insufficient gratitude.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000024_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The country seat at Bald Hills had been rebuilt, though not on the same scale as under the old prince.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000025_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The buildings, begun under straitened circumstances, were more than simple.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000025_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The immense house on the old stone foundations was of wood, plastered only inside.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000025_000002.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "It had bare deal floors and was furnished with very simple hard sofas, armchairs, tables, and chairs made by their own serf carpenters out of their own birchwood.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000025_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000025_000003.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The house was spacious and had rooms for the house serfs and apartments for visitors.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_26870_000025_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/26870/4859_26870_000025_000006.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "The rest of the year life pursued its unbroken routine with its ordinary occupations, and its breakfasts, lunches, dinners, and suppers, provided out of the produce of the estate.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_29340_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/29340/4859_29340_000004_000005.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "But Napoleon's power suppressed the ideas of the Revolution and the general temper of the age.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4859_29340_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/29340/4859_29340_000005_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "This curious contradiction is not accidental.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4859_29340_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/29340/4859_29340_000006_000000.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "To find component forces equal to the composite or resultant force, the sum of the components must equal the resultant.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_29340_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/29340/4859_29340_000006_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "This condition is never observed by the universal historians, and so to explain the resultant forces they are obliged to admit, in addition to the insufficient components, another unexplained force affecting the resultant action.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4859_29340_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4859/29340/4859_29340_000009_000001.wav",
        "speaker_id": "LibriTTS_R-4859",
        "content": "They see it in what is called culture-in mental activity.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    }
]