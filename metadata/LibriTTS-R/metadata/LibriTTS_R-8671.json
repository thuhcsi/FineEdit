[
    {
        "item_name": "LibriTTS_R-8671_285138_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000020_000003.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "And says I; \"Isn't it the laste little bit of a mistake in the world that ye've been afther the making, yer leddyship?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000021_000002.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "As for Sir Pathrick O'Grandison, Barronitt, it wasn't for the likes of his riverence to be afther the minding of a thrifle of a mistake.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000026_000001.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "That Pierre Bon Bon was, in an equal degree, skilled in the philosophy of that period is, I presume, still more especially undeniable.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000026_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000026_000007.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Bon Bon was Ionic-Bon Bon was equally Italic.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000026_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000026_000009.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "His ideas were innate-or otherwise.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000026_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000026_000011.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Bon Bon was emphatically a-Bon Bonist.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000027_000001.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "I would not, however, have any friend of mine imagine that, in fulfilling his hereditary duties in that line, our hero wanted a proper estimation of their dignity and importance.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000027_000002.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Far from it.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000027_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000027_000003.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "It was impossible to say in which branch of his profession he took the greater pride.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000027_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000027_000004.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "In his opinion the powers of the intellect held intimate connection with the capabilities of the stomach.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000027_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000027_000005.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "I am not sure, indeed, that he greatly disagreed with the Chinese, who held that the soul lies in the abdomen. The Greeks at all events were right, he thought, who employed the same words for the mind and the diaphragm.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000027_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000027_000009.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "He could never let slip an opportunity of making a bargain.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000029_000000.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Not that he was avaricious-no",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000029_000001.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "It was by no means necessary to the satisfaction of the philosopher, that the bargain should be to his own proper advantage.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000029_000002.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Provided a trade could be effected-a trade of any kind, upon any terms, or under any circumstances-a triumphant smile was seen for many days thereafter to enlighten his countenance, and a knowing wink of the eye to give evidence of his sagacity.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000030_000001.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "It was soon reported that, upon all occasions of the kind, the smile of Bon Bon was wont to differ widely from the downright grin with which he would laugh at his own jokes, or welcome an acquaintance.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000031_000000.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "The philosopher had other weaknesses-but they are scarcely worthy our serious examination.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000031_000001.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "For example, there are few men of extraordinary profundity who are found wanting in an inclination for the bottle. Whether this inclination be an exciting cause, or rather a valid proof of such profundity, it is a nice thing to say.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000031_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000031_000006.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Well had it been if the same quick sense of propriety had attended him in the peddling propensity to which I have formerly alluded-but this was by no means the case.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000031_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000031_000007.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Indeed to say the truth, that trait of mind in the philosophic Bon Bon did begin at length to assume a character of strange intensity and mysticism, and appeared deeply tinctured with the diablerie of his favorite German studies.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000032_000000.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "To enter the little Cafe in the cul de sac Le Febvre was, at the period of our tale, to enter the sanctum of a man of genius.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000032_000001.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "Bon Bon was a man of genius.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000032_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000032_000002.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "There was not a sous cusinier in Rouen, who could not have told you that Bon Bon was a man of genius.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000032_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000032_000006.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "A distinguished exterior will, I am constrained to say, have its way even with a beast; and I am willing to allow much in the outward man of the restaurateur calculated to impress the imagination of the quadruped.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000032_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000032_000008.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "If, however, Bon Bon was barely three feet in height, and if his head was diminutively small, still it was impossible to behold the rotundity of his stomach without a sense of magnificence nearly bordering upon the sublime.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8671_285138_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8671/285138/8671_285138_000033_000000.wav",
        "speaker_id": "LibriTTS_R-8671",
        "content": "I might here-if it so pleased me-dilate upon the matter of habiliment, and other mere circumstances of the external metaphysician.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    }
]