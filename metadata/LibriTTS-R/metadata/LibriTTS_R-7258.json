        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7258/91902/7258_91902_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7258",
        "content": "Little matters whence we sprang; we are what we are.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
