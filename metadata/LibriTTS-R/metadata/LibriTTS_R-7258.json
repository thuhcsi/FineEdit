        "speaker_id": "LibriTTS_R-7258",
        "content": "\"The sheeted dead Did squeak and gibber in the Roman streets.\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
