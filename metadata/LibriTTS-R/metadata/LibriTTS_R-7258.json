        "speaker_id": "LibriTTS_R-7258",
        "content": "The poets have chanted this momentous revolution according to their religion, their phantasy, or their mood.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
