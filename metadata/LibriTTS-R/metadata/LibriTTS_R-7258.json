        "speaker_id": "LibriTTS_R-7258",
        "content": "But the world, even the religious world, has always been ungrateful to its most generous benefactors.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
