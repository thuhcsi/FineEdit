        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7258/91905/7258_91905_000006_000007.wav",
        "speaker_id": "LibriTTS_R-7258",
        "content": "Milton in his Hymn on the Nativity shouts harsh Puritanical scorn on the oracles stricken dumb, and the deities overthrown.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
