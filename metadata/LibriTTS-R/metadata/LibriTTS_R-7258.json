        "speaker_id": "LibriTTS_R-7258",
        "content": "But much matters to what we may attain.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
