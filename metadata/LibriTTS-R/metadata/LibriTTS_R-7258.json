        "speaker_id": "LibriTTS_R-7258",
        "content": "Benjamin Disraeli attained the cynical sublime when he suggested a monument of gratitude to Judas.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
