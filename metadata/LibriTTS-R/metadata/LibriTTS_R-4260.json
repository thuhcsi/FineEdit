[
    {
        "item_name": "LibriTTS_R-4260_176853_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000004_000005.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "They encamped in the fields at night, because the habit they indulged in of stealing everything for which they had a fancy, caused them to fear being disturbed in the towns.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000004_000006.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "It was not long, however, before many of them were arrested and put to death for theft, when the rest speedily decamped.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000006_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "However, whether because a considerable number remained on the road, or because they had been reinforced by others of the same tribe during the year, a troop of fifty men, accompanied by a number of hideous women and filthy children, made their appearance in the neighbourhood of Augsburg.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000006_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "These vagabonds gave out that they were exiles from Lower Egypt, and pretended to know the art of predicting coming events.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000007_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Few men, however, left the house of the so-called Duke of Egypt without having their purses stolen, and but few women escaped without having the skirts of their dresses cut.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000007_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "The Egyptian women walked about the town in groups of six or seven, and whilst some were talking to the townspeople, telling them their fortunes, or bartering in shops, one of their number would lay her hands on anything which was within reach.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000007_000005.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "So many robberies were committed in this way, that the magistrates of the town and the ecclesiastical authorities forbad the inhabitants from visiting the Egyptians' camp, or from having any intercourse with them, under penalty of excommunication and of a fine of fifty livres.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000009_000001.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "They also modified their original tale, and stated that they were descendants of the Egyptians who refused hospitality to the Holy Virgin and to saint Joseph during their flight into Egypt: they also declared that, in consequence of this crime, God had doomed their race to perpetual misery and exile.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000010_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Five years later we find them in the neighbourhood of Paris.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000010_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000010_000009.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "What was worse, either by magic, by Satanic agency, or by sleight of hand, they managed to empty people's purses whilst talking to them....",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000010_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000010_000010.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "So, at least, every one said.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000010_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000010_000011.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "At last accounts respecting them reached the ears of the Bishop of Paris.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000010_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000010_000012.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "He went to them with a Franciscan friar, called Le Petit Jacobin, who, by the bishop's order, delivered an earnest address to them, and excommunicated all those who had anything to do with them, or who had their fortunes told.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000010_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000010_000013.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "He further advised the gipsies to go away, and, on the festival of Notre Dame, they departed for Pontoise.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000013_000001.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Suffice it to say that their quarrels with the authorities, or the inhabitants of the countries which had the misfortune to be periodically visited by them, have left numerous traces in history.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000014_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "On the seventh of November, fourteen fifty three, from sixty to eighty gipsies, coming from Courtisolles, arrived at the entrance of the town of Cheppe, near Chalons sur Marne.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000014_000002.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "During their unwilling retreat, they were pursued by many of the inhabitants of the town, one of whom killed a gipsy named Martin de la Barre: the murderer, however, obtained the King's pardon.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000015_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "In fifteen thirty two, at Pleinpalais, a suburb of Geneva, some rascals from among a band of gipsies, consisting of upwards of three hundred in number, fell upon several of the officers who were stationed to prevent their entering the town.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000015_000002.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "The gipsies retired to the monastery of the Augustin friars, in which they fortified themselves: the bourgeois besieged them, and would have committed summary justice on them, but the authorities interfered, and some twenty of the vagrants were arrested, but they sued for mercy, and were discharged.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000017_000001.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "The whole of them were killed, with the exception of their chief, who was taken prisoner and brought before the Parliament of Bordeaux, and ordered to be hung.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000017_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "On the twenty first of July, sixteen twenty two, the same magistrates ordered the gipsies to leave the parish of Eysines within twenty four hours, under penalty of the lash.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000018_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "It was not often that the gipsies used violence or openly resisted authority; they more frequently had recourse to artifice and cunning in order to attain their end.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000019_000002.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "In this difficulty, they pretended that one of them had committed a crime, and had been condemned to be hung a quarter of a league from the village, where they betook themselves with all their goods.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000019_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "The man, at the foot of the gibbet, asked for a confessor, and they went to fetch the cure.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000019_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "He, at first, refused to go, but his parishioners compelled him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000019_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000019_000007.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "I expected he would appeal.\" Immediately they packed up, secured the prisoner, and were far enough away from the scene before the cure re-entered his house.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000020_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Tallemant relates another good trick.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000020_000002.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "The butcher then went away; whereupon the gipsy pulled the sheep from a sack into which he had put it, and substituted for it a child belonging to his tribe.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000020_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "He then ran after the butcher, and said, \"Give me five livres, and you shall have the sack into the bargain.\" The butcher paid him the money, and went away.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000020_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "When he got home he opened the sack, and was much astonished when he saw a little boy jump out of it, who, in an instant, caught up the sack and ran off.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000020_000005.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "\"Never was a poor man so thoroughly hoaxed as this butcher,\" says Tallemant des Reaux.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000021_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Those who are well armed and mounted he sends off with a good almanac, on which are marked all the fairs, and they continually change their dress and their horses.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000021_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "When they take up their quarters in any village they steal very little in its immediate vicinity, but in the neighbouring parishes they rob and plunder in the most daring manner.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000021_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000021_000005.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "If they find a sum of money they give notice to the captain, and make a rapid flight from the place.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000021_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000021_000006.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "They coin counterfeit money, and put it into circulation.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000021_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000021_000008.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "When they buy food they pay for it in good money the first time, as they are held in such distrust; but, when they are about to leave a neighbourhood, they again buy something, for which they tender false coin, receiving the change in good money.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000021_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000021_000009.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "In harvest time all doors are shut against them; nevertheless they contrive, by means of picklocks and other instruments, to effect an entrance into houses, when they steal linen, cloaks, silver, and any other movable article which they can lay their hands on.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000021_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000021_000010.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "They give a strict account of everything to their captain, who takes his share of all they get, except of what they earn by fortune telling.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000024_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "After having forbidden them, with a threat of six years at the galleys, to sojourn in Spain, Charles the fifth ordered them to leave Flanders under penalty of death.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000024_000001.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "In fifteen forty five, a gipsy who had infringed the sentence of banishment was condemned by the Court of Utrecht to be flogged till the blood appeared, to have his nostrils slit, his hair removed, his beard shaved off, and to be banished for life.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000025_000002.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "The answer seems to us to be clear.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000025_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000025_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Receiving into their ranks all those whom crime, the fear of punishment, an uneasy conscience, or the charm of a roaming life, continually threw in their path, they made use of them either to find their way into countries of which they were ignorant, or to commit robberies which would otherwise have been impracticable.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176853_000025_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176853/4260_176853_000025_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Themselves adepts in all sorts of bad practices, they were not slow to form an alliance with profligate characters who sometimes worked in concert with them, and sometimes alone, and who always framed the model for their own organization from that of the gipsies.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000004_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "In this place I found a mud house, half buried, very shaky from old age and rottenness, and only eight metres square; but in which, nevertheless, some fifty families are living, who have the charge of a large number of children, many of whom are stolen or illegitimate....",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000005_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Some came and paid him the tribute which was required of them by the statutes of the craft; others rendered him an account of what they had done, and what they had earned during the year.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000005_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "When they had executed their work badly, he ordered them to be punished, either corporally or pecuniarily, according to the gravity of their offences.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000005_000005.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "When he had not himself properly governed his people, he was dethroned, and a successor was appointed by acclamation.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000008_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "We will therefore only mention those which were more especially Italian.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000008_000007.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "They asserted that these treasures could not be discovered without danger, except by means of fastings and offerings, which they and their brethren could alone make, in consideration of which they entered into a bargain, and received a certain sum of money from the owners.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000008_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000008_000014.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "In giving a description, therefore, of the mendicity practised in these two countries during the Middle Ages, we are sure to be representing what it was in other parts of Europe.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000011_000003.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "On this account they were looked upon with the utmost horror by the infidels, who dreaded more their savage ferocity than the valour of the Crusaders.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000012_000001.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "He was killed before Sandwich, in twelve seventeen.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000012_000004.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "We know that this charming poet, who was at the same time a most expert thief, narrowly escaped hanging on two occasions.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000014_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "The meaning of this doggrel, which is somewhat broad, may be rendered-\"He dines well who escapes without paying a penny, and who bids farewell to the innkeeper by wiping his nose on the tablecloth.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4260_176854_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4260/176854/4260_176854_000016_000000.wav",
        "speaker_id": "LibriTTS_R-4260",
        "content": "Brantome relates that King Charles the ninth. had the curiosity to wish to \"know how the cut purses performed their arts with so much skill and dexterity,\" and begged Captain La Chambre to introduce to him, on the occasion of a banquet and a ball, the cleverest cut purses, giving them full liberty to exhibit their skill.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    }
