        "speaker_id": "LibriTTS_R-458",
        "content": "But when she came in, and went to the beds, both the children were gone.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
