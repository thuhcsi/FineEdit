        "speaker_id": "LibriTTS_R-458",
        "content": "When she went home the mouse inquired: 'And what was the child christened?' 'Half done,' answered the cat.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
