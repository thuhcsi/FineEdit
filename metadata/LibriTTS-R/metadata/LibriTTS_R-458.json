        "speaker_id": "LibriTTS_R-458",
        "content": "She went straight to the church, stole to the pot of fat, began to lick at it, and licked the top of the fat off.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
