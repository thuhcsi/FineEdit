        "speaker_id": "LibriTTS_R-458",
        "content": "All gone; what can that mean?' and she shook her head, curled herself up, and lay down to sleep.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
