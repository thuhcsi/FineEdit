        "speaker_id": "LibriTTS_R-458",
        "content": "'Alas!' said the mouse, 'now I see what has happened, now it comes to light!",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
