        "speaker_id": "LibriTTS_R-458",
        "content": "She said to the mouse: 'You must do me a favour, and once more manage the house for a day alone.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
