        "speaker_id": "LibriTTS_R-458",
        "content": "There was a certain village wherein no one lived but really rich peasants, and just one poor one, whom they called the little peasant.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
