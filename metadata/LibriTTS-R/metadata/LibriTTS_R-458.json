        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/458/126290/458_126290_000004_000008.wav",
        "speaker_id": "LibriTTS_R-458",
        "content": "'Top off!' cried the mouse, 'that is a very odd and uncommon name, is it a usual one in your family?' 'What does that matter,' said the cat, 'it is no worse than Crumb stealer, as your godchildren are called.'",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
