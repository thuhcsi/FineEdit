        "speaker_id": "LibriTTS_R-458",
        "content": "'He is called All gone.' 'All gone,' cried the mouse 'that is the most suspicious name of all!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
