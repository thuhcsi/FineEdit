        "speaker_id": "LibriTTS_R-458",
        "content": "The two children therefore got up, dressed themselves quickly, and went away.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
