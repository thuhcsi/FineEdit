        "speaker_id": "LibriTTS_R-458",
        "content": "Early next morning the forester got up and went out hunting, and when he was gone the children were still in bed.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
