        "speaker_id": "LibriTTS_R-458",
        "content": "And the one, which he had found on a tree was called Fundevogel, because a bird had carried it away.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
