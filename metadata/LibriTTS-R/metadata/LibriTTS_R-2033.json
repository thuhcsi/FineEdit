        "speaker_id": "LibriTTS_R-2033",
        "content": "When it was the Seventy second Night,",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
