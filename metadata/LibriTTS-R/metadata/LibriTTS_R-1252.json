[
    {
        "item_name": "LibriTTS_R-1252_134983_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The King stroked it gently, and said to it:",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Well, bunny, as you have come to me for protection I will see that nobody hurts you.\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "And he took it home to his palace and had it put in a pretty little house, with all sorts of nice things to eat.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "That night, when he was alone in his room, a beautiful lady suddenly appeared before him; her long dress was as white as snow, and she had a crown of white roses upon her head.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The good King was very much surprised to see her, for he knew his door had been tightly shut, and he could not think how she had got in.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000005_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "But she said to him:",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I am the Fairy Truth.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000006_000003.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "I thank you for the kindness you have shown me, which has made me your friend for ever.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Madam,\" said the good King, \"since you are a fairy you no doubt know all my wishes.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "If you are really good enough to wish to do me a favor, I beg that you will become his friend.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"With all my heart,\" answered the Fairy.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000008_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I can make your son the handsomest prince in the world, or the richest, or the most powerful; choose whichever you like for him.\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I do not ask either of these things for my son,\" replied the good King; \"but if you will make him the best of princes, I shall indeed be grateful to you.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "You know well he would still be unhappy.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000009_000003.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Only a good man can be really contented.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The good King was quite satisfied with this promise; and very soon afterward he died.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Two days afterward, when the Prince had gone to bed, the Fairy suddenly appeared to him and said:",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I promised your father that I would be your friend, and to keep my word I have come to bring you a present.\" At the same time she put a little gold ring upon his finger.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "So saying, the Fairy disappeared, leaving Prince Darling very much astonished.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000018_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "When he got home and went to his own room, his little dog Bibi ran to meet him, jumping round him with pleasure.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000018_000003.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I don't want you, you are in the way.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The poor little dog, who didn't understand this at all, pulled at his coat to make him at least look at her, and this made Prince Darling so cross that he gave her quite a hard kick.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000020_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "He was very much surprised, and sat down in a corner of his room feeling quite ashamed of himself.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I believe the Fairy is laughing at me,\" he thought.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000021_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "What is the good of my being ruler of a great kingdom if I am not even allowed to beat my own dog?\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I am not making fun of you,\" said a voice, answering Prince Darling's thoughts.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"You have committed three faults.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000023_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The advantage of possessing a great empire is not to be able to do the evil that one desires, but to do all the good that one possibly can.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000024_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The Prince saw how naughty he had been, and promised to try and do better in future, but he did not keep his word.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000025_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "When the Prince grew old enough to understand, he soon learned that there could be nothing worse than to be proud, obstinate, and conceited, and he had really tried to cure himself of these defects, but by that time all his faults had become habits; and a bad habit is very hard to get rid of.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000025_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Not that he was naturally of a bad disposition; he was truly sorry when he had been naughty, and said:",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000026_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I am very unhappy to have to struggle against my anger and pride every day; if I had been punished for them when I was little they would not be such a trouble to me now.\"",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000028_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "One day, when the Prince was walking about, he saw a young girl who was so very pretty that he made up his mind at once that he would marry her. Her name was Celia, and she was as good as she was beautiful.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000029_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Prince Darling fancied that Celia would think herself only too happy if he offered to make her a great queen, but she said fearlessly:",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000030_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Sire, I am only a shepherdess, and a poor girl, but, nevertheless, I will not marry you.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000031_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Do you dislike me?\" asked the Prince, who was very much vexed at this answer.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000033_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The Prince was very angry at this speech, and commanded his officers to make Celia a prisoner and carry her off to his palace.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000034_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "One of the Prince's favorite companions was his foster brother, whom he trusted entirely; but he was not at all a good man, and gave Prince Darling very bad advice, and encouraged him in all his evil ways.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000035_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"You are very kind to trouble yourself about this little girl; if I were you I would soon make her obey me.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000036_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"But,\" said Prince Darling, \"would it not be a shame if I had an innocent girl put to death?",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000036_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "For Celia has done nothing to deserve punishment.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000040_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000040_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "His bad friends, when they heard him, resolved to turn his wrath upon an old nobleman who had formerly been his tutor; and who still dared sometimes to tell the Prince of his faults, for he loved him as if he had been his own son.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000040_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000040_000003.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "At first Prince Darling had thanked him, but after a time he grew impatient and thought it must be just mere love of fault finding that made his old tutor blame him when everyone else was praising and flattering him.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000040_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000040_000004.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "So he ordered him to retire from his Court, though he still, from time to time, spoke of him as a worthy man whom he respected, even if he no longer loved him.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000041_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The Prince, in great anger, sent his foster brother with a number of soldiers to bring his tutor before him, in chains, like a criminal.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000041_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "After giving this order he went to his own room, but he had scarcely got into it when there was a clap of thunder which made the ground shake, and the Fairy Truth appeared suddenly before him.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000042_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000042_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "It is time that I should fulfil my promise, and begin your punishment.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000042_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000042_000003.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "I condemn you to resemble the animals whose ways you have imitated.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000042_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000042_000004.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "You have made yourself like the lion by your anger, and like the wolf by your greediness.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000043_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "He had a lion's head, a bull's horns, a wolf's feet, and a snake's body.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000043_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000043_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "At the same instant he found himself in a great forest, beside a clear lake, in which he could see plainly the horrible creature he had become, and a voice said to him:",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000044_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Look carefully at the state to which your wickedness has brought you; believe me, your soul is a thousand times more hideous than your body.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000046_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I laugh at your powerlessness and anger, and I intend to punish your pride by letting you fall into the hands of your own subjects.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000047_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The Prince began to think that the best thing he could do would be to get as far away from the lake as he could, then at least he would not be continually reminded of his terrible ugliness.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000047_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "So he ran toward the wood, but before he had gone many yards he fell into a deep pit which had been made to trap bears, and the hunters, who were hiding in a tree, leaped down, and secured him with several chains, and led him into the chief city of his own kingdom.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000050_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Prince Darling roared with anger when he heard this; but it was still worse for him when he reached the great square before his own palace.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000052_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000052_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "He left off tearing at the iron bars of the cage in which he was shut up, and became as gentle as a lamb.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000053_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000053_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Unfortunately, this man was very rough and unkind, and though the poor monster was quite quiet, he often beat him without rhyme or reason when he happened to be in a bad temper. One day when this keeper was asleep a tiger broke its chain, and flew at him to eat him up.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000054_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"I would return good for evil,\" he said to himself, \"and save the unhappy man's life.\" He had hardly wished this when his iron cage flew open, and he rushed to the side of the keeper, who was awake and was defending himself against the tiger.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000058_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000058_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "The Queen petted and took care of him, but she was so afraid that he would get too fat that she consulted the court physician, who said that he was to be fed only upon bread, and was not to have much even of that.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000058_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000058_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "So poor Prince Darling was terribly hungry all day long, but he was very patient about it.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000059_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000059_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "But he was surprised to find that the brook was gone, and where it had been stood a great house that seemed to be built of gold and precious stones.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000060_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "But what seemed very strange was that those people who came out of the house were pale and thin, and their clothes were torn, and hanging in rags about them.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000061_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000061_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Prince Darling went up to a young girl who was trying to eat a few blades of grass, she was so hungry.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000061_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000061_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Touched with compassion, he said to himself:",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000064_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000064_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "She soon seemed to be quite well again, and the Prince, delighted to have been able to help her, was thinking of going home to the palace, when he heard a great outcry, and, turning round, saw Celia, who was being carried against her will into the great house.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000069_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000069_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Don't touch it, my poor little dog-that house is the palace of pleasure, and everything that comes out of it is poisoned!\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000070_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000070_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "At the same moment a voice said:",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000071_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000071_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"You see a good action always brings its reward,\" and the Prince found himself changed into a beautiful white dove.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000071_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000071_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "He remembered that white was the favorite color of the Fairy Truth, and began to hope that he might at last win back her favor.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000071_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000071_000002.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "But just now his first care was for Celia, and rising into the air he flew round and round the house, until he saw an open window; but he searched through every room in vain.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000071_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000071_000003.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "No trace of Celia was to be seen, and the Prince, in despair, determined to search through the world till he found her.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000071_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000071_000004.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "He flew on and on for several days, till he came to a great desert, where he saw a cavern, and, to his delight, there sat Celia, sharing the simple breakfast of an old hermit.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000074_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000074_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Take care what you are saying, Celia,\" said the old hermit; \"are you prepared to keep that promise?\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000075_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000075_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"You promised to love me always; tell me that you really mean what you said, or I shall have to ask the Fairy to give me back the form of the dove which pleased you so much.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000077_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000077_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Celia has loved you ever since she first saw you, only she would not tell you while you were so obstinate and naughty.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000078_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000078_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Celia and Prince Darling threw themselves at the Fairy's feet, and the Prince was never tired of thanking her for her kindness.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000078_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000078_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "Celia was delighted to hear how sorry he was for all his past follies and misdeeds, and promised to love him as long as she lived.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000079_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000079_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "\"Rise, my children,\" said the Fairy, \"and I will transport you to the palace, and Prince Darling shall have back again the crown he forfeited by his bad behavior.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000080_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000080_000000.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "While she was speaking, they found themselves in Suliman's hall, and his delight was great at seeing his dear master once more.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1252_134983_000080_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1252/134983/1252_134983_000080_000001.wav",
        "speaker_id": "LibriTTS_R-1252",
        "content": "He gave up the throne joyfully to the Prince, and remained always the most faithful of his subjects.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    }
]