[
    {
        "item_name": "LibriTTS_R-6782_61316_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000000_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Ancient Babylonia was for over four thousand years the garden of Western Asia.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000000_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Herodotus found it still flourishing and extremely fertile.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000000_000003.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "\"This territory\", he wrote, \"is of all that we know the best by far for producing grain; it is so good that it returns as much as two hundredfold for the average, and, when it bears at its best, it produces three hundredfold.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000001_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "This historic country is bounded on the east by Persia and on the west by the Arabian desert.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000001_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "A day's journey separated the river mouths when Alexander the Great broke the power of the Persian Empire.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000002_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "In the days of Babylonia's prosperity the Euphrates was hailed as \"the soul of the land\" and the Tigris as \"the bestower of blessings\". Skilful engineers had solved the problem of water distribution by irrigating sun parched areas and preventing the excessive flooding of those districts which are now rendered impassable swamps when the rivers overflow.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000002_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "A network of canals was constructed throughout the country, which restricted the destructive tendencies of the Tigris and Euphrates and developed to a high degree their potentialities as fertilizing agencies.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000002_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The greatest of these canals appear to have been anciently river beds.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000002_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It is believed to mark the course followed in the early Sumerian period by the Euphrates river, which has moved steadily westward many miles beyond the sites of ancient cities that were erected on its banks.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000002_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000002_000005.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Another important canal, the Shatt el Hai, crossed the plain from the Tigris to its sister river, which lies lower at this point, and does not run so fast.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000003_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Meanwhile the rivers are increasing in volume, being fed by the melting snows at their mountain sources far to the north.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000003_000005.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The swift Tigris, which is one thousand one hundred forty six miles long, begins to rise early in March and reaches its highest level in May; before the end of June it again subsides.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000003_000006.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "More sluggish in movement, the Euphrates, which is one thousand seven hundred eighty miles long, shows signs of rising a fortnight later than the Tigris, and is in flood for a more extended period; it does not shrink to its lowest level until early in September.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000003_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000003_000007.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "By controlling the flow of these mighty rivers, preventing disastrous floods, and storing and distributing surplus water, the ancient Babylonians developed to the full the natural resources of their country, and made it-what it may once again become-one of the fairest and most habitable areas in the world.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000003_000008.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Nature conferred upon them bountiful rewards for their labour; trade and industries flourished, and the cities increased in splendour and strength.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Babylonia is a treeless country, and timber had to be imported from the earliest times.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The date palm was probably introduced by man, as were certainly the vine and the fig tree, which were widely cultivated, especially in the north.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Stone, suitable for building, was very scarce, and limestone, alabaster, marble, and basalt had to be taken from northern Mesopotamia, where the mountains also yield copper and lead and iron.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000003.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Except Eridu, where ancient workers quarried sandstone from its sea shaped ridge, all the cities were built of brick, an excellent clay being found in abundance.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "When brick walls were cemented with bitumen they were given great stability.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000005.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "This resinous substance is found in the north and south.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000006.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It bubbles up through crevices of rocks on river banks and forms small ponds.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000007.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Two famous springs at modern Hit, on the Euphrates, have been drawn upon from time immemorial.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000004_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000004_000008.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "\"From one\", writes a traveller, \"flows hot water black with bitumen, while the other discharges intermittently bitumen, or, after a rainstorm, bitumen and cold water....",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000005_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It must, therefore, have had a brisk and flourishing foreign trade at an exceedingly remote period.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000005_000003.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It does not follow, however, that the peasant class was greatly affected by periodic revolutions of this kind, which brought little more to them than a change of rulers.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000005_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The needs of the country necessitated the continuance of agricultural methods and the rigid observance of existing land laws; indeed, these constituted the basis of Sumerian prosperity.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000005_000005.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Conquerors have ever sought reward not merely in spoil, but also the services of the conquered.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000005_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000005_000006.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "In northern Babylonia the invaders apparently found it necessary to conciliate and secure the continued allegiance of the tillers of the soil.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000005_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000005_000007.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Law and religion being closely associated, they had to adapt their gods to suit the requirements of existing social and political organizations. A deity of pastoral nomads had to receive attributes which would give him an agricultural significance; one of rural character had to be changed to respond to the various calls of city life.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000005_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000005_000008.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Besides, local gods could not be ignored on account of their popularity.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The petty kingdoms of Sumeria appear to have been tribal in origin. Each city was presided over by a deity who was the nominal owner of the surrounding arable land, farms were rented or purchased from the priesthood, and pasture was held in common.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000006_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The chief deity of a state was the central figure in a pantheon, which had its political aspect and influenced the growth of local theology.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000007_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "This description recalls the familiar figures of Egyptian gods and priests attired in the skins of the sacred animals from whom their powers were derived, and the fairy lore about swan maids and men, and the seals and other animals who could divest themselves of their \"skin coverings\" and appear in human shape.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000007_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The Indian creative gods Brahma and Vishnu had fish forms.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000007_000008.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It relates that when the fish was small and in danger of being swallowed by other fish in a stream it appealed to Manu for protection.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000007_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000007_000009.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The sage at once lifted up the fish and placed it in a jar of water.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000007_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000007_000010.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It gradually increased in bulk, and he transferred it next to a tank and then to the river Ganges.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000007_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000007_000011.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "In time the fish complained to Manu that the river was too small for it, so he carried it to the sea.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000008_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The growth of the fish suggests the growth of the river rising in flood.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000008_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "In Celtic folk tales high tides and valley floods are accounted for by the presence of a \"great beast\" in sea, loch, or river.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000008_000005.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The idea is that \"where a god dies, that is, ceases to exist in human form, his life passes into the waters where he is buried; and this again is merely a theory to bring the divine water or the divine fish into harmony with anthropomorphic ideas.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000009_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Another Egyptian fish deity was the god Rem, whose name signifies \"to weep\"; he wept fertilizing tears, and corn was sown and reaped amidst lamentations.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000009_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The connection between a fish god and a corn god is not necessarily remote when we consider that in Babylonia and Egypt the harvest was the gift of the rivers.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000010_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The Euphrates, indeed, was hailed as a creator of all that grew on its banks.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000012_000005.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "He taught the people how to form and use alphabetic signs and instructed them in mathematics: he gave them their code of laws.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000012_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000012_000007.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Ptah moulded the first man on his potter's wheel: he also moulded the sun and moon; he shaped the universe and hammered out the copper sky.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "His word became the creative force; he named those things he desired to be, and they came into existence.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000015_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "As rain fell from \"the waters above the firmament\", the god of waters was also a sky and earth god.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000016_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The Indian Varuna was similarly a sky as well as an ocean god before the theorizing and systematizing Brahmanic teachers relegated him to a permanent abode at the bottom of the sea.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000017_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "His worship was certainly of great antiquity.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Our knowledge regarding him is derived mainly from the Bible.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000003.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "He was a national rather than a city god.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000009.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Near the name is an ear of corn, and other symbols, such as the winged solar disc, a gazelle, and several stars, but there is no fish.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000010.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It may be, of course, that Baal dagon represents a fusion of deities.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000013.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The Philistines came from Crete, and if their Dagon was imported from that island, he may have had some connection with Poseidon, whose worship extended throughout Greece.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000014.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "This god of the sea, who is somewhat like the Roman Neptune, carried a lightning trident and caused earthquakes.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000015.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "He was a brother of Zeus, the sky and atmosphere deity, and had bull and horse forms.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000018_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000018_000017.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "In his train were the Tritons, half men, half fishes, and the water fairies, the Nereids.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000019_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Osiris and Isis of Egypt were associated with the Nile.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000019_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000019_000005.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The connection between agriculture and the water supply was too obvious to escape the early symbolists, and many other proofs of this than those referred to could be given.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000023_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "A suggestion of the Vedic Vritra and his horde of monsters.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000024_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "It is possible that he was developed as an atmospheric god with solar and lunar attributes.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000024_000003.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The seven demons, who were his messengers, recall the stormy Maruts, the followers of Indra.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000024_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000024_000004.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "They are referred to as",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000026_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "\"Evil spirits\", according to a Babylonian chant, were \"the bitter venom of the gods\".",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000026_000003.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Those attached to a deity as \"attendants\" appear to represent the original animistic group from which he evolved.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000029_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Associated with Bel Enlil was Beltis, later known as \"Beltu-the lady\".",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000030_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "In the later systematized theology of the Babylonians we seem to trace the fragments of a primitive mythology which was vague in outline, for the deities were not sharply defined, and existed in groups.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000030_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "Enneads were formed in Egypt by placing a local god at the head of a group of eight elder deities.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000032_000000.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "We cannot say definitely what these various deities represent.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000032_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000032_000002.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The others were phases of light and darkness and the forces of nature in activity and repose.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6782/61316/6782_61316_000034_000001.wav",
        "speaker_id": "LibriTTS_R-6782",
        "content": "The attributes of this beneficent god reflect the progress, and the social and moral ideals of a people well advanced in civilization.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6782_61316_000034_000002",
