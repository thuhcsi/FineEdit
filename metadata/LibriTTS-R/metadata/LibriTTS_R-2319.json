[
    {
        "item_name": "LibriTTS_R-2319_138631_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000003_000001.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "It made her think of things which she tried to forget, and to look into a little drawer at something soft and brown that lay in a curl there, wrapped in paper.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000003_000002.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "At last she could bear it no longer, and went downstairs.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Where are you going?' said mrs Garland.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Because you must not.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000009_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Don't mention him, mother, don't!'",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000010_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Well then, dear, walk in the garden.'",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000011_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "So poor Anne, who really had not the slightest wish to throw her heart away upon a soldier, but merely wanted to displace old thoughts by new, turned into the inner garden from day to day, and passed a good many hours there, the pleasant birds singing to her, and the delightful butterflies alighting on her hat, and the horrid ants running up her stockings.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "This garden was undivided from Loveday's, the two having originally been the single garden of the whole house.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000012_000001.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "It was a quaint old place, enclosed by a thorn hedge so shapely and dense from incessant clipping that the mill boy could walk along the top without sinking in-a feat which he often performed as a means of filling out his day's work.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000012_000002.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The soil within was of that intense fat blackness which is only seen after a century of constant cultivation.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000012_000003.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The paths were grassed over, so that people came and went upon them without being heard.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000012_000004.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The grass harboured slugs, and on this account the miller was going to replace it by gravel as soon as he had time; but as he had said this for thirty years without doing it, the grass and the slugs seemed likely to remain.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000013_000001.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The two households were on this account even more closely united in the garden than within the mill.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000013_000002.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "Out there they were almost one family, and they talked from plot to plot with a zest and animation which mrs Garland could never have anticipated when she first removed thither after her husband's death.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000014_000002.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The brooks were so far overhung at their brinks by grass and garden produce that, had it not been for their perpetual babbling, few would have noticed that they were there.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000015_000001.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "She always spoke to him when she saw him there, and he replied in deep, firm accents across the gooseberry bushes, or through the tall rows of flowering peas, as the case might be.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000015_000002.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "He thus gave her accounts at fifteen paces of his experiences in camp, in quarters, in Flanders, and elsewhere; of the difference between line and column, of forced marches, billeting, and such like, together with his hopes of promotion.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "Thus the month of July passed.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "At length the earnest trumpet major obtained mrs Garland's consent to take her and her daughter to the camp, which they had not yet viewed from any closer point than their own windows.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000018_000002.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The villagers were by this time driving a roaring trade with the soldiers, who purchased of them every description of garden produce, milk, butter, and eggs at liberal prices.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000018_000003.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The figures of these rural sutlers could be seen creeping up the slopes, laden like bees, to a spot in the rear of the camp, where there was a kind of market place on the greensward.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000020_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "They passed on to the tents of the German Legion, a well grown and rather dandy set of men, with a poetical look about their faces which rendered them interesting to feminine eyes.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000021_000004.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "Festus looked from Anne to the trumpet major, and from the trumpet major back to Anne, with a dark expression of face, as if he suspected that there might be a tender understanding between them.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000022_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Are you offended with me?' he said to her in a low voice of repressed resentment.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000024_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'When are you coming to the hall again?'",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000025_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Never, perhaps.'",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000029_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "The widow looked unhappily in her daughter's face, distressed between her desire that Anne should encourage Festus, and her wish to consult Anne's own feelings.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000030_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Leave her alone, leave her alone,' said Festus, his gaze blackening. 'Now I think of it I am glad she can't come with me, for I am engaged;' and he stalked away.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000032_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Well, where's mr Loveday?' asked mrs Garland.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000033_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'Father's behind,' said john.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000035_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'I'll overtake you in a minute,' she said to the younger pair, and went back, her colour, for some unaccountable reason, rising as she did so. The miller and she then came on slowly together, conversing in very low tones, and when they got to the bottom they stood still.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000038_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'That you do not care for Derriman, and mean to encourage john Loveday. What's all the world so long as folks are happy!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000039_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'What a weathercock you are, mother!",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138631_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138631/2319_138631_000043_000001.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "But mrs Garland could not keep the secret long.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2319_138656_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138656/2319_138656_000010_000000.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "'I'm from aboard the Victory,' said the sailor.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2319_138656_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2319/138656/2319_138656_000018_000003.wav",
        "speaker_id": "LibriTTS_R-2319",
        "content": "After that he and some other lads jumped aboard the French ship, and I believe they was in her when she struck her flag.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
