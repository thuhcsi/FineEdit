        "speaker_id": "LibriTTS_R-3679",
        "content": "Tom told the King that his father and mother were as tall as anybody about the court, but in rather poor circumstances.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
