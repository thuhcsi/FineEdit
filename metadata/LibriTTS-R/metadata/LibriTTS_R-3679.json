[
    {
        "item_name": "LibriTTS_R-3679_159362_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000001_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "There she went about from house to house for a while, and at last she came to the Lord Mayor.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000001_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "He was both open hearted and open handed, and he was married to the daughter of the richest merchant in the town, and they had one little daughter.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000001_000003.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "As they had no more children, you may fancy she was sugar and spice and all that's nice, and in a word there was nothing too good for her.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000001_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000001_000005.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Yes, they played and read and went to school together, and never had so much as one quarrel.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000003_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "One day the Lady Mayoress stood at the window, and watched the children as they were trudging off to school.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000003_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "There had been a shower of rain, and the street was flooded, and she saw how the boy first carried the basket with their dinner over the stream, and then he went back and lifted the little girl over, and when he set her down he gave her a kiss.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000004_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"To think of such a ragamuffin kissing our daughter-we who are the best people in the place!\" That was what she said.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000004_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Her husband did his best to stop her tongue.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000005_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "But no! it was all the same, whatever he said and whichever way he put it.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000005_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "The Lady Mayoress held her own, and said beggars on horseback always rode their cattle to death, and that no one had ever heard of a silk purse being made out of a sow's ear; adding, that a penny would never turn into a shilling, even though it glittered like a guinea.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000005_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "The end of it all was that the poor lad was turned out of the house, and had to pack up his rags and be off.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000006_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "He told his wife he had sold the boy for a roll of tobacco.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000007_000003.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "So he took the boat and rowed across, and there he saw an old hag, who called and roared.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000008_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Here have I stood a hundred years calling and bawling, and thinking how I should ever get over this water; but no one has ever heard or heeded but you, and you shall be well paid if you will put me over to the other side.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000009_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Yes! he would beg for it; and when the old witch who lived there knew that he had helped her sister over the water, she said he might have whatever he chose to ask.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000012_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Now I must be off,\" said the lad, \"to cook the Sunday dinner for the church goers.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000013_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Stop with me, and I will pay you better still.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000013_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Here have I stood and called and bawled for a hundred years, but no one has ever heeded me but you.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000014_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "So when they came over, and the second old witch heard how he had helped her sister across, she said he might have anything he chose to ask for her fare.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000017_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Then the old hag said again: \"Come on with me to my third sister.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000017_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Here have I stood and called and bawled for a hundred years, and no one has heeded me but you.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000017_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Come on to my third sister, and you shall have better pay still.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000018_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Well! when they got across, and the third old witch heard he had helped her sister across, she said he was to have whatever he chose to ask for his fare.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000019_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Oh,\" said the lad, \"then I won't have anything else but granny's old hymn book.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000021_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Yes! in a trice it was covered with good food and strong drink, enough and to spare.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000021_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "So he just took a little snack, and then he gave the ship's dog as much as it could eat.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000022_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Why, he's as round as a sausage, and as lazy as a snail.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000023_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Oh, if you must know,\" said the lad, \"I gave him the bones.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000024_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Good boy,\" said the captain, \"to think of the dog.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000026_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "But the book-that he could not get tried just then.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000027_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "The King came down to the shore, and asked was there anyone on board who could cure her and make her well again.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000029_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Is there no one else on board the ship than those I see?\" asked the King.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000030_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Yes; there's a little beggar boy.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000031_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Well,\" said the King, \"let him come on deck.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000033_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "But the King only said that wit came as children grew, and that there was the making of a man in every bairn.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000033_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "After all, there were many who had tried and failed before him.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000033_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000033_000003.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "So he took him home to his daughter, and the lad sang a hymn once.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000033_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000033_000004.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Then the Princess could lift her arm.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000033_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000033_000005.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Once again he sang it, and she could sit up in bed.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000033_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000033_000006.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "And when he had sung it thrice, the King's daughter was as well as you and I are.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000034_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "The King was so glad he wanted to give him half his kingdom and the princess to wife.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000035_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Yes,\" said the lad, \"land and power are fine things to have half of,\" and was very grateful; \"but as for the Princess, he was betrothed to another,\" he said, \"and he could not take her to wife.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000036_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "But when they had conquered, he turned the white edge, and they all rose up alive and became the King's soldiers, who had granted them their lives.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000036_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000036_000003.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "But then there were so many of them that they were badly off for food, though the King wished to send them away full, both of meat and drink.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000036_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000036_000004.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "So the lad had to bring out his tablecloth, and then there was not a man that lacked anything.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000037_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "On board those ships everything was as grand as in a King's palace; and as for himself, he had gold on every seam of his coat, so fine he was.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000037_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000037_000004.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Yes, he would go,\" he said; and so he went up to the Mansion House where the Lord Mayor lived, and there he took his seat between the Lady Mayoress and her daughter.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000039_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Do you know who that is in there, mother?\" said the daughter.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000040_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"No!\" said the Lady Mayoress.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000041_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"He whom papa sold for a roll of tobacco,\" said the daughter.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000042_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "At these words the Lady Mayoress fainted and fell down flat on the floor.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000043_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "In a little while the Lord Mayor came out to see what was the matter, and when he heard how things stood he was almost as uneasy as his wife.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000044_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"There is nothing to make a fuss about,\" said Master Tobacco.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000044_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"I have only come to claim the little girl I kissed as we were going to school.\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159362_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159362/3679_159362_000045_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "But to the Lady Mayoress he said:",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000004_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "IN the days of the great Prince Arthur there lived a mighty magician, called Merlin, the most learned and skillful enchanter the world has ever seen.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000005_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "This famous magician, who could take any form he pleased, was traveling about as a poor beggar, and being very tired, he stopped at the cottage of a plowman to rest himself, and asked for some food.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000006_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "The countryman bade him welcome, and his wife, who was a very good hearted woman, soon brought him some milk in a wooden bowl, and some coarse brown bread on a platter.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000007_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "He therefore asked them why they were so melancholy, and learned that they were miserable because they had no children.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000008_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "The poor woman said, with tears in her eyes: \"I should be the happiest creature in the world if I had a son; although he was no bigger than my husband's thumb, I would be satisfied.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000009_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Accordingly, in a short time after, the plowman's wife had a son, who, wonderful to relate, was not a bit bigger than his father's thumb!",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000010_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "The queen kissed the child, and, giving it the name of Tom Thumb, sent for some of the fairies, who dressed her little godson according to her orders:",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000012_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Tom never grew any larger than his father's thumb, which was only of ordinary size; but as he got older he became very cunning and full of tricks.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000012_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "When he was old enough to play with the boys, and had lost all his own cherry stones, he used to creep into the bags of his playfellows, fill his pockets, and, getting out without their noticing him, would again join in the game.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000013_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "One day, however, as he was coming out of a bag of cherry stones, where he had been stealing as usual, the boy to whom it belonged chanced to see him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000013_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "He roared loud with pain, and begged to be let out, promising never to steal again.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000014_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "A short time afterwards his mother was making a batter pudding, and Tom, being very anxious to see how it was made, climbed up to the edge of the bowl; but his foot slipped, and he plumped over head and ears into the batter, without his mother noticing him, who stirred him into the pudding bag, and put him in the pot to boil.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000015_000002.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "As Tom had now got his mouth cleared of the batter, he then began to cry aloud, which so frightened the tinker that he flung down the pudding and ran away.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000016_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "Soon after the adventure of the pudding, Tom's mother went to milk her cow in the meadow, and she took him along with her.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000016_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "As the wind was very high, for fear of being blown away, she tied him to a thistle with a piece of fine thread.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000017_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Where are you, Tommy, my dear Tommy?\" said his mother.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000018_000000.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "\"Here, mother,\" replied he, \"in the red cow's mouth.\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000019_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "She then put Tom in her bosom and ran home with him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3679_159363_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3679/159363/3679_159363_000020_000001.wav",
        "speaker_id": "LibriTTS_R-3679",
        "content": "A raven, which was flying over, picked him up, and flew with him over the sea, and there dropped him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
