        "speaker_id": "LibriTTS_R-3679",
        "content": "A large fish swallowed Tom the moment he fell into the sea, which was soon after caught and bought for the table of King Arthur.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
