        "speaker_id": "LibriTTS_R-3679",
        "content": "He also gave him a coach, drawn by six small mice.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
