        "speaker_id": "LibriTTS_R-3679",
        "content": "Tom went immediately to procure a purse, which was made of a water bubble, and then returned to the treasury, where he received a silver threepenny piece to put into it.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
