        "speaker_id": "LibriTTS_R-3679",
        "content": "But he soon returned to court.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
