        "speaker_id": "LibriTTS_R-3679",
        "content": "Our little hero had some difficulty in lifting the burden upon his back; but he at last succeeded in getting it placed to his mind, and set forward on his journey.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
