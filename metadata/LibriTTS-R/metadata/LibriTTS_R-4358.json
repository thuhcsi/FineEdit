        "speaker_id": "LibriTTS_R-4358",
        "content": "Their fathers had worshipped in the cold, and their sons might.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
