        "speaker_id": "LibriTTS_R-4358",
        "content": "But in winter the vast airy space had a peculiar and searching chill.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
