        "speaker_id": "LibriTTS_R-4358",
        "content": "The minister stood upon a heated slab of soap stone.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
