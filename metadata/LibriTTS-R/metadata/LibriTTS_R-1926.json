        "speaker_id": "LibriTTS_R-1926",
        "content": "He thought about that, but he pulled in his other foot.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
