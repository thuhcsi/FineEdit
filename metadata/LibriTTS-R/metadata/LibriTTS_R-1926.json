        "speaker_id": "LibriTTS_R-1926",
        "content": "Isabel came back to Florence, but only after several months; an interval sufficiently replete with incident.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
