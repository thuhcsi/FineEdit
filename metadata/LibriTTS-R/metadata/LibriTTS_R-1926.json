        "speaker_id": "LibriTTS_R-1926",
        "content": "Her manner was cold, and she talked little.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
