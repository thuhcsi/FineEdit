        "speaker_id": "LibriTTS_R-1926",
        "content": "Guests felt that they were receiving, not conferring, a favor when they stayed at her house.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
