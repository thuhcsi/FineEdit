        "speaker_id": "LibriTTS_R-1926",
        "content": "Now, gentlemen, I expect you've all got grand voices.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
