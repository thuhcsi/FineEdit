        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1926/147979/1926_147979_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1926",
        "content": "She was tall, dark, severe, with something Indian like in the rigid immobility of her face.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
