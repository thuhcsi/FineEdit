        "speaker_id": "LibriTTS_R-1926",
        "content": "He was born in the Far South, on the d'Arnault plantation, where the spirit if not the fact of slavery persisted.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
