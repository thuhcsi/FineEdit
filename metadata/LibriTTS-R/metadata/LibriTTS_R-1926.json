        "speaker_id": "LibriTTS_R-1926",
        "content": "The girls, still laughing, were trying to escape.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1926_147979_000019_000001",
