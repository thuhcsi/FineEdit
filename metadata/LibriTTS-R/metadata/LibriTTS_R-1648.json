[
    {
        "item_name": "LibriTTS_R-1648_144971_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1648/144971/1648_144971_000000_000001.wav",
        "speaker_id": "LibriTTS_R-1648",
        "content": "It is level, sandy, poorly planted by nature, and barren of all things likely to enlist the attention of predatory man.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1648_144971_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1648/144971/1648_144971_000000_000002.wav",
        "speaker_id": "LibriTTS_R-1648",
        "content": "To the harassed birds of mid ocean, it seemed like a secure haven, and for ages past it has been inhabited only by them.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
