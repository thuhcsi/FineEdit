        "speaker_id": "LibriTTS_R-1648",
        "content": "There several species of sea birds, large and small, have found homes and breeding places.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1648_144971_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1648/144971/1648_144971_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1648",
        "content": "Laysan Island is two miles long by one and one half miles broad, and at times it has been literally covered with birds.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1648_144971_000002_000002",
