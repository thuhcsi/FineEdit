[
    {
        "item_name": "LibriTTS_R-5513_39476_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000004_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "In the morning when he woke up they had the place to themselves, for on his instructions the servants had all left first thing: Janet and the cook to Oxford, where they would try and find new places, and Nanny going back to the cottage near Tangley, where her son lived, who was the pigman there.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000005_000003.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "She was still fond of the same food that she had been used to before her transformation, a lightly boiled egg or slice of ham, a piece of buttered toast or two, with a little quince and apple jam.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000006_000002.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "His vixen relished them exceedingly and seemed never to tire of them, so that he increased his order first from one pound to three pounds and afterwards to five.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000008_000002.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "Though you are a fox I would rather live with you than any woman.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000008_000003.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "I swear I would, and that too if you were changed to anything.\" But then, catching her grave look, he would say: \"Do you think I jest on these things, my dear?",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000008_000004.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "I do not.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000008_000005.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "I swear to you, my darling, that all my life I will be true to you, will be faithful, will respect and reverence you who are my wife.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000010_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "Often he would swear to her that the devil might have power to work some miracles, but that he would find it beyond him to change his love for her.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000011_000001.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "She would come to him, put her paw in his hand and look at him with sparkling eyes shining with joy and gratitude, would pant with eagerness, jump at him and lick his face.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000014_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "\"Good God!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000017_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "\"Day but just breaking....\" etc",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000018_000003.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "Nor did he ever repeat the experiment of reading to her.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000019_000003.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "Moreover she won all three of them. After this they often played a quiet game of piquet together, and cribbage too.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000021_000003.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "For his mind was filled not only with the fear that she might escape from him and run away, which he knew was groundless, but with more rational visions, such as wandering curs, traps, gins, spring guns, besides a dread of being seen with her by the neighbourhood.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000021_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000021_000006.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "After this he resolved to take her, though with full precautions.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000023_000001.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "First she ran this way, then that, though keeping always close to him, looking very sharply with ears cocked forward first at one thing, then another and then up to catch his eye.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000025_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "But her appearance threw the ducks into the utmost degree of consternation.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000025_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000025_000003.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "So in this case, too, for realising that the silly ducks thought his wife a fox indeed and were alarmed on that account he found painful that spectacle which to others might have been amusing.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000031_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "So she drove them before her back into the pond, the ducks running in terror from her with their wings spread, and she not pressing them, for he saw that had she been so minded she could have caught two or three of the nearest.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000032_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "But when they got within doors he picked her up in his arms, kissed her and spoke to her.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000033_000000.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "\"Silvia, what a light-hearted childish creature you are.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5513_39476_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39476/5513_39476_000035_000001.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "Then it seemed she would have him play to her on the pianoforte: she led him to it, nay, what is more, she would herself pick out the music he was to play.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5513_39477_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39477/5513_39477_000007_000003.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "Farewell, poor bird!",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5513_39477_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5513/39477/5513_39477_000007_000004.wav",
        "speaker_id": "LibriTTS_R-5513",
        "content": "Farewell!",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    }
