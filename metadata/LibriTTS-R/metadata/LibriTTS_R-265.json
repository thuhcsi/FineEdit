        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/136853/265_136853_000008_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Some of them, however, he observed were too gross for imitation.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_136853_000009_000000",
