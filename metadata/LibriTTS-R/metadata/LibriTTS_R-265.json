[
    {
        "item_name": "LibriTTS_R-265_122594_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000000_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "On that day, two men were lingering on the banks of a small but rapid stream, within an hour's journey of the encampment of Webb, like those who awaited the appearance of an absent person, or the approach of some expected event.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000000_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The vast canopy of woods spread itself to the margin of the river, overhanging the water, and shadowing its dark current with a deeper hue.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000000_000002.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The rays of the sun were beginning to grow less fierce, and the intense heat of the day was lessened, as the cooler vapors of the springs and fountains rose above their leafy beds, and rested in the atmosphere.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000000_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000000_000006.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The former was seated on the end of a mossy log, in a posture that permitted him to heighten the effect of his earnest language, by the calm but expressive gestures of an Indian engaged in debate.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000000_000007.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "His body, which was nearly naked, presented a terrific emblem of death, drawn in intermingled colors of white and black.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000000_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000000_000010.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The expanded chest, full formed limbs, and grave countenance of this warrior, would denote that he had reached the vigor of his days, though no symptoms of decay appeared to have yet weakened his manhood.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000002_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "His person, though muscular, was rather attenuated than full; but every nerve and muscle appeared strung and indurated by unremitted exposure and toil.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000002_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "He also bore a knife in a girdle of wampum, like that which confined the scanty garments of the Indian, but no tomahawk.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000005_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Even your traditions make the case in my favor, Chingachgook,\" he said, speaking in the tongue which was known to all the natives who formerly inhabited the country between the Hudson and the Potomac, and of which we shall give a free translation for the benefit of the reader; endeavoring, at the same time, to preserve some of the peculiarities, both of the individual and of the language.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000007_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Is there no difference, Hawkeye, between the stone headed arrow of the warrior, and the leaden bullet with which you kill?\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000008_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"There is reason in an Indian, though nature has made him with a red skin!\" said the white man, shaking his head like one on whom such an appeal to his justice was not thrown away.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000008_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "For a moment he appeared to be conscious of having the worst of the argument, then, rallying again, he answered the objection of his antagonist in the best manner his limited information would allow:",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000010_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"You have the story told by your fathers,\" returned the other, coldly waving his hand.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000010_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"What say your old men?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000011_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "For myself, I conclude the Bumppos could shoot, for I have a natural turn with a rifle, which must have been handed down from generation to generation, as, our holy commandments tell us, all good and evil gifts are bestowed; though I should be loath to answer for other people in such a matter.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000013_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Listen, Hawkeye, and your ear shall drink no lie.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000013_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "'tis what my fathers have said, and what the Mohicans have done.\" He hesitated a single instant, and bending a cautious glance toward his companion, he continued, in a manner that was divided between interrogation and assertion.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000013_000002.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Does not this stream at our feet run toward the summer, until its waters grow salt, and the current flows upward?\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000015_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"And the current!\" demanded the Indian, who expected his reply with that sort of interest that a man feels in the confirmation of testimony, at which he marvels even while he respects it; \"the fathers of Chingachgook have not lied!\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000016_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"The holy Bible is not more true, and that is the truest thing in nature.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000016_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "They call this up stream current the tide, which is a thing soon explained, and clear enough.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000017_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"The waters in the woods, and on the great lakes, run downward until they lie like my hand,\" said the Indian, stretching the limb horizontally before him, \"and then they run no more.\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000018_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"No honest man will deny it,\" said the scout, a little nettled at the implied distrust of his explanation of the mystery of the tides; \"and I grant that it is true on the small scale, and where the land is level. But everything depends on what scale you look at things.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000018_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Now, on the small scale, the 'arth is level; but on the large scale it is round.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000018_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "You might as well expect the river to lie still on the brink of those black rocks a mile above us, though your own ears tell you that it is tumbling over them at this very moment.\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000019_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "If unsatisfied by the philosophy of his companion, the Indian was far too dignified to betray his unbelief.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000019_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "He listened like one who was convinced, and resumed his narrative in his former solemn manner.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000020_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"We came from the place where the sun is hid at night, over great plains where the buffaloes live, until we reached the big river.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000020_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "There we fought the Alligewi, till the ground was red with their blood.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000020_000002.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "From the banks of the big river to the shores of the salt lake, there was none to meet us.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000020_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The Maquas followed at a distance.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000020_000004.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "We said the country should be ours from the place where the water runs up no longer on this stream, to a river twenty sun's journey toward the summer.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000020_000005.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "We drove the Maquas into the woods with the bears.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000021_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"All this I have heard and believe,\" said the white man, observing that the Indian paused; \"but it was long before the English came into the country.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000022_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"A pine grew then where this chestnut now stands.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000022_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The first pale faces who came among us spoke no English.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000022_000002.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "They came in a large canoe, when my fathers had buried the tomahawk with the red men around them.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000022_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Then, Hawkeye,\" he continued, betraying his deep emotion, only by permitting his voice to fall to those low, guttural tones, which render his language, as spoken at times, so very musical; \"then, Hawkeye, we were one people, and we were happy.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000022_000005.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "We took wives who bore us children; we worshipped the Great Spirit; and we kept the Maquas beyond the sound of our songs of triumph.\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000023_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Know you anything of your own family at that time?\" demanded the white. \"But you are just a man, for an Indian; and as I suppose you hold their gifts, your fathers must have been brave warriors, and wise men at the council fire.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000024_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"My tribe is the grandfather of nations, but I am an unmixed man.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000024_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The blood of chiefs is in my veins, where it must stay forever.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000024_000002.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The Dutch landed, and gave my people the fire water; they drank until the heavens and the earth seemed to meet, and they foolishly thought they had found the Great Spirit.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000024_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Then they parted with their land.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000024_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000024_000004.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Foot by foot, they were driven back from the shores, until I, that am a chief and a Sagamore, have never seen the sun shine but through the trees, and have never visited the graves of my fathers.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000025_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "But where are to be found those of your race who came to their kin in the Delaware country, so many summers since?\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000026_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "I am on the hilltop and must go down into the valley; and when Uncas follows in my footsteps there will no longer be any of the blood of the Sagamores, for my boy is the last of the Mohicans.\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000027_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Uncas is here,\" said another voice, in the same soft, guttural tones, near his elbow; \"who speaks to Uncas?\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000029_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "No exclamation of surprise escaped the father, nor was any question asked, or reply given, for several minutes; each appearing to await the moment when he might speak, without betraying womanish curiosity or childish impatience.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000029_000002.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The white man seemed to take counsel from their customs, and, relinquishing his grasp of the rifle, he also remained silent and reserved.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000030_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Do the Maquas dare to leave the print of their moccasins in these woods?\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000031_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"I have been on their trail,\" replied the young Indian, \"and know that they number as many as the fingers of my two hands; but they lie hid like cowards.\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000032_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"That busy Frenchman, Montcalm, will send his spies into our very camp, but he will know what road we travel!\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000033_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Hawkeye, let us eat to night, and show the Maquas that we are men to morrow.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000035_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"It cannot be!\" said the young Indian, springing to his feet with youthful eagerness; \"all but the tips of his horns are hid!\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000036_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"He's a boy!\" said the white man, shaking his head while he spoke, and addressing the father.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000036_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Does he think when a hunter sees a part of the creature', he can't tell where the rest of him should be!\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000037_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Adjusting his rifle, he was about to make an exhibition of that skill on which he so much valued himself, when the warrior struck up the piece with his hand, saying:",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000038_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Hawkeye! will you fight the Maquas?\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000039_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"These Indians know the nature of the woods, as it might be by instinct!\" returned the scout, dropping his rifle, and turning away like a man who was convinced of his error.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000039_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"I must leave the buck to your arrow, Uncas, or we may kill a deer for them thieves, the Iroquois, to eat.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000040_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The instant the father seconded this intimation by an expressive gesture of the hand, Uncas threw himself on the ground, and approached the animal with wary movements.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000040_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000040_000002.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "In another moment the twang of the cord was heard, a white streak was seen glancing into the bushes, and the wounded buck plunged from the cover, to the very feet of his hidden enemy.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000040_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000040_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Avoiding the horns of the infuriated animal, Uncas darted to his side, and passed his knife across the throat, when bounding to the edge of the river it fell, dyeing the waters with its blood.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000041_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"'twas done with Indian skill,\" said the scout laughing inwardly, but with vast satisfaction; \"and 'twas a pretty sight to behold!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000041_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "Though an arrow is a near shot, and needs a knife to finish the work.\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000043_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"By the Lord, there is a drove of them!\" exclaimed the scout, whose eyes began to glisten with the ardor of his usual occupation; \"if they come within range of a bullet I will drop one, though the whole Six Nations should be lurking within sound!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000044_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"There is but one deer, and he is dead,\" said the Indian, bending his body till his ear nearly touched the earth.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000044_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"I hear the sounds of feet!\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000045_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"Perhaps the wolves have driven the buck to shelter, and are following on his trail.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-265_122594_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/122594/265_122594_000046_000000.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "\"no",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-265_136853_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/136853/265_136853_000002_000001.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "He therefore not only exerted his talents in occasional composition very different from Lexicography, but formed a club in Ivy lane, Paternoster row, with a view to enjoy literary discussion, and amuse his evening hours.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-265_136853_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/265/136853/265_136853_000006_000003.wav",
        "speaker_id": "LibriTTS_R-265",
        "content": "The fervid rapidity with which it was produced, is scarcely credible.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
