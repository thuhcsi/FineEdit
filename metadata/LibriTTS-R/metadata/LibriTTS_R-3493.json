        "speaker_id": "LibriTTS_R-3493",
        "content": "\"She's rounded up the whole gang for us, and that's more than anybody else has been able to do yet!",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
