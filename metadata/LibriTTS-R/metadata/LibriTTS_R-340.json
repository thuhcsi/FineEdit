        "speaker_id": "LibriTTS_R-340",
        "content": "He spoke of Virginia; and, as to the power of emancipation, I speak of the slave holding States only.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
