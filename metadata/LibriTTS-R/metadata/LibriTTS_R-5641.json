[
    {
        "item_name": "LibriTTS_R-5641_32124_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000004_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Sir Henry Rawlinson says:",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000005_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "\"So great is the analogy between the first principles of the Science of writing, as it appears to have been pursued in Chaldea, and as we can actually trace its progress in Egypt, that we can hardly hesitate to assign the original invention to a period before the Hamitic race had broken up and divided.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000007_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Humboldt says:",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000011_000004.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "The Greeks converted the Phoenician alphabet, which was partly consonantal, into one purely phonetic-\"a perfect instrument for the expression of spoken language.\" The w was also added to the Phoenician alphabet.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000011_000005.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "The romans added the y.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000011_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000011_000006.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "At first i and j were both indicated by the same sound; a sign for j was afterward added.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000013_000001.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "It cannot be the Chinese alphabet, which has more signs than words; it cannot be the cuneiform alphabet of Assyria, with its seven hundred arrow shaped characters, none of which bear the slightest affinity to the Phoenician letters.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000014_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "It is a surprising fact that we find in Central America a phonetic alphabet.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000014_000001.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "This is in the alphabet of the Mayas, the ancient people of the peninsula of Yucatan, who claim that their civilization came to them across the sea in ships from the east, that is, from the direction of Atlantis.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000014_000004.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "He fortunately, however, preserved for posterity the alphabet of this people.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000017_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Diego de Landa was the first bishop of Yucatan.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000020_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "The Alphabet",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000021_000001.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "If we find decided affinities between two or three letters, we may reasonably presume that similar coincidences existed as to many others which have disappeared under the attrition of centuries.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000022_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "The first thought that occurs to us on examining the Landa alphabet is the complex and ornate character of the letters.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000022_000001.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Instead of the two or three strokes with which we indicate a sign for a sound, we have here rude pictures of objects.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000022_000002.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "And we find that these are themselves simplifications of older forms of a still more complex character.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000022_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000022_000004.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "The same appear, but not so plainly, in the sign for x, which is hash hash hash .",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000024_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "We can see, therefore, in the Landa alphabet a tendency to simplification.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000024_000001.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "And this is what we would naturally expect.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000025_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000025_000005.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Hence the Maya sign becomes in the archaic Phoenician this, hash hash hash .",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000026_000001.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "If it is, it is certainly remarkable.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000026_000002.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "But let us go a step farther:",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000027_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000027_000004.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "It is clearly taken from the heart of the original figure wherein it appears.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000027_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000027_000005.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "What does this prove?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000027_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000027_000006.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "That the Atlanteans, or Mayas, when they sought to simplify their letters and combine them with others, took from the centre of the ornate hieroglyphical figure some characteristic mark with which they represented the whole figure.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000027_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000027_000007.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Now let us apply this rule:",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000028_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "We have seen in the table of alphabets that in every language, from our own day to the time of the Phoenicians, o has been represented by a circle or a circle within a circle.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000030_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Are these another set of coincidences?",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000031_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Take another letter:",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000034_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Now turn to the letter k.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000034_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000034_000002.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "This does not look much like our letter K; but let us examine it.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000035_000001.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "What is the distinctive mark about this figure?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
