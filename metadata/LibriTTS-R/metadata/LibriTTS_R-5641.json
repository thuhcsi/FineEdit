        "speaker_id": "LibriTTS_R-5641",
        "content": "We have thus traced back the forms of eighteen of the ancient letters to the Maya alphabet.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
