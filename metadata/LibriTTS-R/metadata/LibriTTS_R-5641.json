        "speaker_id": "LibriTTS_R-5641",
        "content": "This is exactly the form found on the American monuments.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
