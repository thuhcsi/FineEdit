        "speaker_id": "LibriTTS_R-5641",
        "content": "The form of p p in the Maya alphabet is this, hash hash hash .",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
