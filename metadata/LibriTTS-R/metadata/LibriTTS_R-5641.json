        "speaker_id": "LibriTTS_R-5641",
        "content": "In the Maya we have one sign for p, and another for p p.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000039_000003",
