        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000037_000007.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Can all this be accident?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
