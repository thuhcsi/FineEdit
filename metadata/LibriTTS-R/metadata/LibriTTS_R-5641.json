        "speaker_id": "LibriTTS_R-5641",
        "content": "What is the Phoenician form for g as found on the Moab stone?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
