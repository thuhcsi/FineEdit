        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000036_000000.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "Take the letter a.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5641_32124_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5641/32124/5641_32124_000037_000002.wav",
        "speaker_id": "LibriTTS_R-5641",
        "content": "The circle below is not significant, for there are many circular figures in the Maya alphabet.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
