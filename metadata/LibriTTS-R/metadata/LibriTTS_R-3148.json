        "speaker_id": "LibriTTS_R-3148",
        "content": "Fair knight, said Sir Launcelot, tell me your name?",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
