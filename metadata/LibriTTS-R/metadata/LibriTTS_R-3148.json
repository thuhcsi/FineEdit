        "speaker_id": "LibriTTS_R-3148",
        "content": "Then Sir Tristram asked Sir Gawaine and Sir Bleoberis if they met with such a knight, with such a cognisance, with a covered shield.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
