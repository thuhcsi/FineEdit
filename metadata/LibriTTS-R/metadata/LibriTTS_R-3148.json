        "speaker_id": "LibriTTS_R-3148",
        "content": "Fair sir, said these knights, such a knight met with us to our great damage.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
