        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3148/4666/3148_4666_000019_000005.wav",
        "speaker_id": "LibriTTS_R-3148",
        "content": "He beareth, said Sir Tristram, a covered shield close with cloth.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3148_4666_000019_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3148/4666/3148_4666_000019_000008.wav",
        "speaker_id": "LibriTTS_R-3148",
        "content": "And then Sir Tristram asked them their names, and so either told other their names.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
