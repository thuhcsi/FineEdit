        "speaker_id": "LibriTTS_R-3148",
        "content": "And when he had done so I might not for shame but I must joust with him.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
