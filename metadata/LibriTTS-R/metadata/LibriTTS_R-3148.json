        "speaker_id": "LibriTTS_R-3148",
        "content": "And then they rode together, and so he hurt my fellow.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3148_4666_000018_000014",
