        "speaker_id": "LibriTTS_R-3148",
        "content": "That me repenteth, said Sir Tristram, of your great anger; an it please you tell me your husband's name.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
