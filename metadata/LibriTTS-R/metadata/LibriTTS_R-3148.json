        "speaker_id": "LibriTTS_R-3148",
        "content": "Truly, said he, my name is Sir Tristram de Liones.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3148_4666_000025_000008",
