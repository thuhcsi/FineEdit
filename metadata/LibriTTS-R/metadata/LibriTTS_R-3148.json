        "speaker_id": "LibriTTS_R-3148",
        "content": "O Jesu, said Sir Launcelot, what adventure is befallen me!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
