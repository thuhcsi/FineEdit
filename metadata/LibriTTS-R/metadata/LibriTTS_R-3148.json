        "speaker_id": "LibriTTS_R-3148",
        "content": "So they were agreed.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
