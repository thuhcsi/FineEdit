        "speaker_id": "LibriTTS_R-3148",
        "content": "And so either gave other the degree.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
