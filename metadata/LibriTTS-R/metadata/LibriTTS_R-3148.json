        "speaker_id": "LibriTTS_R-3148",
        "content": "And therewith Sir Tristram kneeled adown, and yielded him up his sword.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
