        "speaker_id": "LibriTTS_R-3148",
        "content": "So departed Sir Tristram from that dolorous lady, and had much evil lodging.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
