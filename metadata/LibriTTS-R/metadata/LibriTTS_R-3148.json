        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3148/4666/3148_4666_000025_000004.wav",
        "speaker_id": "LibriTTS_R-3148",
        "content": "Fair knight, he said, my name is Sir Launcelot du Lake.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
