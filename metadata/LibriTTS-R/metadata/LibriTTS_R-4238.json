        "speaker_id": "LibriTTS_R-4238",
        "content": "\"MY DEAR COUSIN: I am leaving next week with my husband for England, where we intend to pass some time visiting his friends.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
