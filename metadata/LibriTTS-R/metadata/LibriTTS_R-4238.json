        "speaker_id": "LibriTTS_R-4238",
        "content": "\"What is it?\" they exclaimed.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
