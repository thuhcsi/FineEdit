        "speaker_id": "LibriTTS_R-4238",
        "content": "\"He went out to scout round the house, leaving me at the gate,\" Harold said.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
