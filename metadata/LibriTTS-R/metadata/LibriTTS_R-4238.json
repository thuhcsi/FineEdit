        "speaker_id": "LibriTTS_R-4238",
        "content": "\"MARY WILSON.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4238_12895_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4238/12895/4238_12895_000012_000001.wav",
        "speaker_id": "LibriTTS_R-4238",
        "content": "Behind them was a large clearing of about a hundred acres in extent; a comfortable house, with buildings for cattle, stood at a distance of some three hundred yards from the lake; broad fields of yellow corn waved brightly in the sun; and from the edge of the clearing came the sound of a woodsman's ax, showing that the proprietor was still enlarging the limits of his farm.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4238_12895_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4238/12895/4238_12895_000013_000000.wav",
        "speaker_id": "LibriTTS_R-4238",
        "content": "William Welch had settled ten years before on this spot, which was then far removed from the nearest habitation.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
