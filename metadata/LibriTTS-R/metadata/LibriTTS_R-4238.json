        "speaker_id": "LibriTTS_R-4238",
        "content": "\"Concord, march first seventeen seventy four.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
