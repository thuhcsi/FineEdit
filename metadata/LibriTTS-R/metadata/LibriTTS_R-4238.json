        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4238/12895/4238_12895_000009_000006.wav",
        "speaker_id": "LibriTTS_R-4238",
        "content": "john joins me in kind love to yourself and your husband, and believe me to remain,",
        "style_prompt": "F_p-low_s-slow_e-low",
