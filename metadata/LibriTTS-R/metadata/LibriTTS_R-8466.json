        "speaker_id": "LibriTTS_R-8466",
        "content": "I took thee, just now, from a rose wood coffin inlaid with ivory.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000011_000003",
