        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8466/274557/8466_274557_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8466",
        "content": "The corners of the room were rounded into niches.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8466/274557/8466_274557_000014_000001.wav",
        "speaker_id": "LibriTTS_R-8466",
        "content": "Three of these were filled with statues of gigantic proportions.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8466/274557/8466_274557_000014_000003.wav",
        "speaker_id": "LibriTTS_R-8466",
        "content": "In the fourth niche the statue was veiled; it was not colossal.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8466/274557/8466_274557_000015_000000.wav",
        "speaker_id": "LibriTTS_R-8466",
        "content": "But the paintings!--Kupris!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
