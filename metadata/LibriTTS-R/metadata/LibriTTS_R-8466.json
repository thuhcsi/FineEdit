        "speaker_id": "LibriTTS_R-8466",
        "content": "Unable to restrain his feelings, his Grace swallows an olive.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
