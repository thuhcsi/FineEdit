        "speaker_id": "LibriTTS_R-8466",
        "content": "Hereupon his Grace rubbed his eyes, yawned, shrugged his shoulders, reflected.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8466/274557/8466_274557_000012_000003.wav",
        "speaker_id": "LibriTTS_R-8466",
        "content": "Having become satisfied of his identity, he took a bird's eye view of his whereabouts.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
