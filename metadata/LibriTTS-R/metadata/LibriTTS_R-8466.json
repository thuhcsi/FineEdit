        "speaker_id": "LibriTTS_R-8466",
        "content": "He measures two points, and, with a grace inimitable, offers his Majesty the choice.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
