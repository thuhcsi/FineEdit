        "speaker_id": "LibriTTS_R-8466",
        "content": "But the chances-the chances!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
