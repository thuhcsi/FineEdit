        "speaker_id": "LibriTTS_R-8466",
        "content": "He is not, however, as you suppose, dizzy with magnificence, nor drunk with the ecstatic breath of those innumerable censers.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000017_000001",
