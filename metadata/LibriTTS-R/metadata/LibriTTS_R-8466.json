        "speaker_id": "LibriTTS_R-8466",
        "content": "\"Why, surely you are not serious,\" retorted De L'Omelette.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
