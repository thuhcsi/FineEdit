        "speaker_id": "LibriTTS_R-8466",
        "content": "The apartment was superb.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
