        "speaker_id": "LibriTTS_R-8466",
        "content": "There were some foils upon a table-some points also.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
