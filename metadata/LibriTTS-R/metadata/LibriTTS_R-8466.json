        "speaker_id": "LibriTTS_R-8466",
        "content": "\"Strip, indeed! very pretty i' faith!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
