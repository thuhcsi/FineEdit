        "speaker_id": "LibriTTS_R-8466",
        "content": "Thou wast curiously scented, and labelled as per invoice.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000012_000002",
