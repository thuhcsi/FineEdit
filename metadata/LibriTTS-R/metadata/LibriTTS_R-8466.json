        "speaker_id": "LibriTTS_R-8466",
        "content": "\"Who am I?--ah, true!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8466/274557/8466_274557_000011_000001.wav",
        "speaker_id": "LibriTTS_R-8466",
        "content": "I am Baal Zebub, Prince of the Fly.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8466_274557_000011_000002",
