        "speaker_id": "LibriTTS_R-8466",
        "content": "But the Duc's heart is fainting within him.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
