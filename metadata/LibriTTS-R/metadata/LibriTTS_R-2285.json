        "speaker_id": "LibriTTS_R-2285",
        "content": "mr Harry Quincel was looked upon as quite a star for this sort of work.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
