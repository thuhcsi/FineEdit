        "speaker_id": "LibriTTS_R-2285",
        "content": "It's the spirit of the part, you know, that is difficult.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
