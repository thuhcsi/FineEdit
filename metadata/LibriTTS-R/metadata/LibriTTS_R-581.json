[
    {
        "item_name": "LibriTTS_R-581_126955_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000001_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "CHAPTER eleven",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000003_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "Summer was now over.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000003_000001.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The winter following, the plague a second time attacked the Athenians; for although it had never entirely left them, still there had been a notable abatement in its ravages.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000003_000003.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "At the same time took place the numerous earthquakes in Athens, Euboea, and Boeotia, particularly at Orchomenus in the last named country.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000004_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The same winter the Athenians in Sicily and the Rhegians, with thirty ships, made an expedition against the islands of Aeolus; it being impossible to invade them in summer, owing to the want of water.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000005_000002.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "A similar inundation also occurred at Atalanta, the island off the Opuntian Locrian coast, carrying away part of the Athenian fort and wrecking one of two ships which were drawn up on the beach.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000005_000005.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "Without an earthquake I do not see how such an accident could happen.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000006_000003.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "This town afterwards also submitted upon the approach of the Athenians and their allies, and gave hostages and all other securities required.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000008_000007.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The settlement effected, they fortified anew the city, now called Heraclea, distant about four miles and a half from Thermopylae and two miles and a quarter from the sea, and commenced building docks, closing the side towards Thermopylae just by the pass itself, in order that they might be easily defended.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000011_000002.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The plan which they recommended was to attack first the Apodotians, next the Ophionians, and after these the Eurytanians, who are the largest tribe in Aetolia, and speak, as is said, a language exceedingly difficult to understand, and eat their flesh raw.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000011_000003.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "These once subdued, the rest would easily come in.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000015_000004.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "These were by far the best men in the city of Athens that fell during this war.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000017_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The same summer the Aetolians, who before the Athenian expedition had sent an embassy to Corinth and Lacedaemon, composed of Tolophus, an Ophionian, Boriades, an Eurytanian, and Tisander, an Apodotian, obtained that an army should be sent them against Naupactus, which had invited the Athenian invasion.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000019_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "His preparations completed, Eurylochus lodged the hostages in Kytinium, in Doris, and advanced upon Naupactus through the country of the Locrians, taking upon his way Oeneon and Eupalium, two of their towns that refused to join him.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000020_000001.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The winter ensuing, the Athenians in Sicily with their Hellenic allies, and such of the Sicel subjects or allies of Syracuse as had revolted from her and joined their army, marched against the Sicel town Inessa, the acropolis of which was held by the Syracusans, and after attacking it without being able to take it, retired.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000021_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The same winter the Athenians purified Delos, in compliance, it appears, with a certain oracle.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000021_000001.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "It had been purified before by Pisistratus the tyrant; not indeed the whole island, but as much of it as could be seen from the temple.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000022_000002.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "Nothing can be clearer on this point than the following verses of Homer, taken from a hymn to Apollo:",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000024_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "That there was also a poetical contest in which the Ionians went to contend, again is shown by the following, taken from the same hymn. After celebrating the Delian dance of the women, he ends his song of praise with these verses, in which he also alludes to himself:",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000027_000002.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "On their part, the Ambraciots at Olpae sent a messenger to their own city, to beg them to come with their whole levy to their assistance, fearing that the army of Eurylochus might not be able to pass through the Acarnanians, and that they might themselves be obliged to fight single handed, or be unable to retreat, if they wished it, without danger.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000029_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "Uniting here at daybreak, they sat down at the place called Metropolis, and encamped.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000029_000002.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "While the fleet off Olpae blockaded the hill from the sea, the Acarnanians and a few of the Amphilochians, most of whom were kept back by force by the Ambraciots, had already arrived at Argos, and were preparing to give battle to the enemy, having chosen Demosthenes to command the whole of the allied army in concert with their own generals.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126955_000029_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126955/581_126955_000029_000003.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "Demosthenes led them near to Olpae and encamped, a great ravine separating the two armies. During five days they remained inactive; on the sixth both sides formed in order of battle.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000001_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "CHAPTER thirteen",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000003_000004.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "These last, however, gave them the slip by coming in the dark; and being informed by signals of the fact the Corinthians left half their number at Cenchreae, in case the Athenians should go against Crommyon, and marched in all haste to the rescue.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000004_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "Battus, one of the two generals present at the action, went with a company to defend the village of Solygia, which was unfortified; Lycophron remaining to give battle with the rest.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000004_000002.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "The battle was an obstinate one, and fought throughout hand to hand.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000005_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "After holding on for a long while without either giving way, the Athenians aided by their horse, of which the enemy had none, at length routed the Corinthians, who retired to the hill and, halting, remained quiet there, without coming down again.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000006_000002.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "After walling off this spot, the fleet sailed off home.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000020_000003.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "But if both should happen to have chosen the wrong moment for acting in this way, advice to make peace would not be unserviceable; and this, if we did but see it, is just what we stand most in need of at the present juncture.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000023_000000.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "\"So far as regards the Athenians, such are the great advantages proved inherent in a wise policy.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-581_126957_000034_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/581/126957/581_126957_000034_000005.wav",
        "speaker_id": "LibriTTS_R-581",
        "content": "And so it turned out.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    }
]