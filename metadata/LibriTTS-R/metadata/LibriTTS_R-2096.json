        "speaker_id": "LibriTTS_R-2096",
        "content": "JOHNSON.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
