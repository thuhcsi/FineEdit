        "speaker_id": "LibriTTS_R-2096",
        "content": "Johnson.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2096_136868_000025_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2096/136868/2096_136868_000025_000005.wav",
        "speaker_id": "LibriTTS_R-2096",
        "content": "One day when I was at her house, I put on a very grave countenance, and said to her, \"Madam, I am now become a convert to your way of thinking.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
