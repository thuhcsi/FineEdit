        "speaker_id": "LibriTTS_R-2096",
        "content": "'Suppose a shoemaker should claim an equality with him, as he does with a Lord; how he would stare.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
