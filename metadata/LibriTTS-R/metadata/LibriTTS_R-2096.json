        "speaker_id": "LibriTTS_R-2096",
        "content": "(says the shoemaker,) I do great service to society.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
