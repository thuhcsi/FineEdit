        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2096/136868/2096_136868_000025_000007.wav",
        "speaker_id": "LibriTTS_R-2096",
        "content": "She has never liked me since.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
