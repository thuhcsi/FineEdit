        "speaker_id": "LibriTTS_R-3889",
        "content": "The gamin loves the city, he also loves solitude, since he has something of the sage in him.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
