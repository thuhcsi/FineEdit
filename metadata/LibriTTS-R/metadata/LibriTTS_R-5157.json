        "speaker_id": "LibriTTS_R-5157",
        "content": "Yesterday, when we brought home all we killed, it filled the house, completely; and, to day, they are obliged to white wash the walls, to take away the blood.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
