        "speaker_id": "LibriTTS_R-5157",
        "content": "Your's, ever, my dear wife,",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
