        "speaker_id": "LibriTTS_R-5157",
        "content": "Admire the Creator, and all his works, to us incomprehensible: and do all the good you can upon earth; and take the chance of eternity, without dismay.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
