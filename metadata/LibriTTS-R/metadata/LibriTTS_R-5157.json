        "speaker_id": "LibriTTS_R-5157",
        "content": "Suppose you had put it on nine parts out of ten of the ladies in company, would any one have appeared angelic?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5157_47237_000059_000000",
