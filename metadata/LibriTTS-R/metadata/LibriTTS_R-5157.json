        "speaker_id": "LibriTTS_R-5157",
        "content": "My cold is better, notwithstanding the weather.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
