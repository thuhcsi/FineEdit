        "speaker_id": "LibriTTS_R-5157",
        "content": "I dined, this morning, at nine o'clock; and, I think, it agreed better with me than tea.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
