        "speaker_id": "LibriTTS_R-5157",
        "content": "MY DEAR EMMA,",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5157_47237_000014_000000",
