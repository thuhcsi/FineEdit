        "speaker_id": "LibriTTS_R-5157",
        "content": "MY DEAR EM.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5157_47237_000070_000000",
