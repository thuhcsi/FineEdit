        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5157/47237/5157_47237_000035_000000.wav",
        "speaker_id": "LibriTTS_R-5157",
        "content": "thirteen.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
