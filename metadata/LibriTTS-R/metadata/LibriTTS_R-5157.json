        "speaker_id": "LibriTTS_R-5157",
        "content": "I have killed five boars, and two great ones got off after falling; two bucks; six does; and a hare: fourteen in all.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
