        "speaker_id": "LibriTTS_R-5157",
        "content": "We have had a miserable cold day, but good sport.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
