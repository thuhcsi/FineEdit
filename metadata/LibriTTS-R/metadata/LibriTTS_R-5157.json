        "speaker_id": "LibriTTS_R-5157",
        "content": "I approve of all you do in my absence; but it would be nonsense, and appear affected, to carry your scruples too far.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
