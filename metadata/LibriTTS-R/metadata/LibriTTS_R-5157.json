        "speaker_id": "LibriTTS_R-5157",
        "content": "By having grumbled a little, I got a better post to day; and have killed two boars and a sow, all enormous.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
