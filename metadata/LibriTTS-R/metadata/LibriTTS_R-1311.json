        "speaker_id": "LibriTTS_R-1311",
        "content": "\"I want you to keep him,\" he said.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
