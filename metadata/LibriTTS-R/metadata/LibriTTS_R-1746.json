[
    {
        "item_name": "LibriTTS_R-1746_143015_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000000_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Perhaps the less said of her the better.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000000_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "She was a coarse and, it is to be feared, a very sinful woman.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000000_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000000_000004.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The primal curse had come to her in that original isolation which must have made the punishment of the first transgression so dreadful.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000000_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000000_000006.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Yet a few of the spectators were, I think, touched by her sufferings.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It will be seen also that the situation was novel.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000001_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Deaths were by no means uncommon in Roaring Camp, but a birth was a new thing.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000001_000003.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Hence the excitement.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"You go in there, Stumpy,\" said a prominent citizen known as \"Kentuck,\" addressing one of the loungers.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Go in there, and see what you kin do. You've had experience in them things.\"",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Perhaps there was a fitness in the selection.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Stumpy, in other climes, had been the putative head of two families; in fact, it was owing to some legal informality in these proceedings that Roaring Camp-a city of refuge-was indebted to his company.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The crowd approved the choice, and Stumpy was wise enough to bow to the majority.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "One or two of these were actual fugitives from justice, some were criminal, and all were reckless.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000004_000006.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The strongest man had but three fingers on his right hand; the best shot had but one eye.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000005_000002.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The only outlet was a steep trail over the summit of a hill that faced the cabin, now illuminated by the rising moon.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Bets were freely offered and taken regarding the result.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000006_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Above the swaying and moaning of the pines, the swift rush of the river, and the crackling of the fire rose a sharp, querulous cry,--a cry unlike anything heard before in the camp.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000006_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000006_000007.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It seemed as if Nature had stopped to listen too.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The camp rose to its feet as one man!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was proposed to explode a barrel of gunpowder; but in consideration of the situation of the mother, better counsels prevailed, and only a few revolvers were discharged; for whether owing to the rude surgery of the camp, or some other reason, Cherokee Sal was sinking fast.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000007_000003.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "I do not think that the announcement disturbed them much, except in speculation as to the fate of the child.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000007_000004.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Can he live now?\" was asked of Stumpy.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000007_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The answer was doubtful.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000007_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000007_000007.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "There was some conjecture as to fitness, but the experiment was tried.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000007_000008.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was less problematical than the ancient treatment of Romulus and Remus, and apparently as successful.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "When these details were completed, which exhausted another hour, the door was opened, and the anxious crowd of men, who had already formed themselves into a queue, entered in single file.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000008_000003.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Beside the candle box was placed a hat.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000008_000004.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Its use was soon indicated.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000008_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000008_000010.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Only one incident occurred to break the monotony of the curious procession.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000008_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000008_000012.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Kentuck looked foolish and embarrassed. Something like a blush tried to assert itself in his weather beaten cheek.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000008_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000008_000017.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"He rastled with my finger,\" he remarked to Tipton, holding up the member, \"the damned little cuss!\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was four o'clock before the camp sought repose.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "He drank quite freely, and related with great gusto his experience, invariably ending with his characteristic condemnation of the newcomer.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Then he walked up the gulch past the cabin, still whistling with demonstrative unconcern.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000007.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Halfway down to the river's bank he again paused, and then returned and knocked at the door.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000008.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was opened by Stumpy.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000009.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"How goes it?\" said Kentuck, looking past Stumpy toward the candle box.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000010.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"All serene!\" replied Stumpy. \"Anything up?\" \"Nothing.\" There was a pause-an embarrassing one-Stumpy still holding the door.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000011.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Then Kentuck had recourse to his finger, which he held up to Stumpy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000009_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000009_000012.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Rastled with it,--the damned little cuss,\" he said, and retired.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The next day Cherokee Sal had such rude sepulture as Roaring Camp afforded.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000010_000003.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "But an animated discussion in regard to the manner and feasibility of providing for its wants at once sprang up.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000010_000004.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was remarkable that the argument partook of none of those fierce personalities with which discussions were usually conducted at Roaring Camp.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000010_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Tipton proposed that they should send the child to Red Dog,--a distance of forty miles,--where female attention could be procured.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000010_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000010_000006.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "But the unlucky suggestion met with fierce and unanimous opposition.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Stumpy advanced nothing.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000011_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Stumpy was retained.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000011_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000011_000007.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Mind,\" said the treasurer, as he pressed a bag of gold dust into the expressman's hand, \"the best that can be got,--lace, you know, and filigree work and frills,--damn the cost!\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Strange to say, the child thrived.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000012_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Perhaps the invigorating climate of the mountain camp was compensation for material deficiencies.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Nature took the foundling to her broader breast.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000012_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Me and that ass,\" he would say, \"has been father and mother to him!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000012_000006.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Don't you,\" he would add, apostrophizing the helpless bundle before him, \"never go back on us.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000002.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Gamblers and adventurers are generally superstitious, and Oakhurst one day declared that the baby had brought \"the luck\" to Roaring Camp.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000004.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "No allusion was made to the mother, and the father was unknown.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000006.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Call him Luck, and start him fair.\" A day was accordingly set apart for the christening.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000008.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The master of ceremonies was one \"Boston,\" a noted wag, and the occasion seemed to promise the greatest facetiousness.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000009.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "This ingenious satirist had spent two days in preparing a burlesque of the Church service, with pointed local allusions.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000010.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The choir was properly trained, and Sandy Tipton was to stand godfather.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000013.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It's playing it pretty low down on this yer baby to ring in fun on him that he ain't goin' to understand.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000013_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000013_000018.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The form of christening was perhaps even more ludicrous than the satirist had conceived; but strangely enough, nobody saw it and nobody laughed. \"Tommy\" was christened as seriously as he would have been under a Christian roof and cried and was comforted in as orthodox fashion.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "And so the work of regeneration began in Roaring Camp.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Almost imperceptibly a change came over the settlement.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000002.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The cabin assigned to \"Tommy Luck\"--or \"The Luck,\" as he was more frequently called-first showed signs of improvement.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000003.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was kept scrupulously clean and whitewashed.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000007.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The reflections of the latter on the appearance of Roaring Camp tended to produce stricter habits of personal cleanliness.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000008.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Again Stumpy imposed a kind of quarantine upon those who aspired to the honor and privilege of holding The Luck.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000011.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Nor were moral and social sanitary laws neglected.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000012.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Tommy,\" who was supposed to spend his whole existence in a persistent attempt to repose, must not be disturbed by noise.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000014_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000014_000018.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "An indistinct idea that this was pastoral happiness pervaded the camp.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000015_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000015_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was wonderful how many treasures the woods and hillsides yielded that \"would do for Tommy.\" Surrounded by playthings such as never child out of fairyland had before, it is to be hoped that Tommy was content.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000015_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000015_000008.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "He was extricated without a murmur.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000015_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000015_000009.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "I hesitate to record the many other instances of his sagacity, which rest, unfortunately, upon the statements of prejudiced friends.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Such was the golden summer of Roaring Camp.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000016_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "They were \"flush times,\" and the luck was with them.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000016_000003.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The camp was jealous of its privileges and looked suspiciously on strangers.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000016_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000016_000006.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The expressman-their only connecting link with the surrounding world-sometimes told wonderful stories of the camp.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000016_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000016_000008.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "They've got vines and flowers round their houses, and they wash themselves twice a day.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000016_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000016_000009.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "But they're mighty rough on strangers, and they worship an Ingin baby.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "With the prosperity of the camp came a desire for further improvement. It was proposed to build a hotel in the following spring, and to invite one or two decent families to reside there for the sake of The Luck, who might perhaps profit by female companionship.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "The winter of eighteen fifty one will long be remembered in the foothills.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000018_000003.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Red Dog had been twice under water, and Roaring Camp had been forewarned.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000018_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000018_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"It been here once and will be here again!\" And that night the North Fork suddenly leaped over its banks and swept up the triangular valley of Roaring Camp.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "In the confusion of rushing water, crashing trees, and crackling timber, and the darkness which seemed to flow with the water and blot out the fair valley, but little could be done to collect the scattered camp. When the morning broke, the cabin of Stumpy, nearest the river bank, was gone.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000019_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "Higher up the gulch they found the body of its unlucky owner; but the pride, the hope, the joy, The Luck, of Roaring Camp had disappeared. They were returning with sad hearts when a shout from the bank recalled them.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It was a relief boat from down the river.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000020_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "They had picked up, they said, a man and an infant, nearly exhausted, about two miles below.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "It needed but a glance to show them Kentuck lying there, cruelly crushed and bruised, but still holding The Luck of Roaring Camp in his arms.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000021_000001.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "As they bent over the strangely assorted pair, they saw that the child was cold and pulseless.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000021_000004.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Yes, my man, and you are dying too.\" A smile lit the eyes of the expiring Kentuck.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1746_143015_000021_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1746/143015/1746_143015_000021_000005.wav",
        "speaker_id": "LibriTTS_R-1746",
        "content": "\"Dying!\" he repeated; \"he's a taking me with him.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    }
