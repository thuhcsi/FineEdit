        "speaker_id": "LibriTTS_R-1284",
        "content": "Instead of shoes, the old man wore boots with turnover tops and his blue coat had wide cuffs of gold braid.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1284_1180_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1284/1180/1284_1180_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1284",
        "content": "Ojo was hungry, though; so he divided the piece of bread upon the table and ate his half for breakfast, washing it down with fresh, cool water from the brook.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
