        "speaker_id": "LibriTTS_R-8296",
        "content": "\"And i\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000082_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000082_000000.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "Elsie returned the loving glance and smile, while her namesake daughter remarked, \"Mamma couldn't be nicer or sweeter than she is now; nobody could.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000083_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000083_000002.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "You never did tell it to us.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
