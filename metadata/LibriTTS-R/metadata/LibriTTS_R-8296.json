        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Yes, poor dear grandma!\" sighed little Elsie.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
