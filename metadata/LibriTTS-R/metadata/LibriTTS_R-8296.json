        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Mamma, how pleasant that will be,\" said Elsie thoughtfully.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000036_000000",
