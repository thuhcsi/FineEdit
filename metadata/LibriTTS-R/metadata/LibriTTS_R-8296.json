        "speaker_id": "LibriTTS_R-8296",
        "content": "\"And then it is a lasting pleasure.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
