        "speaker_id": "LibriTTS_R-8296",
        "content": "Elsie expected her children to find it a little hard to go back to the old routine; but it was not so.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
