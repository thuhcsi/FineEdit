        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Mamma,\" said Eddie, \"we've had a nice long holiday, and it's really pleasant to get back to lessons again.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
