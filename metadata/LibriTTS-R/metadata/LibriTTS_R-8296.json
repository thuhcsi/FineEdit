        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Yes, indeed!",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
