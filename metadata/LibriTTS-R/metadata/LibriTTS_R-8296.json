        "speaker_id": "LibriTTS_R-8296",
        "content": "But at length even the children began to grow somewhat weary of constant play.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
