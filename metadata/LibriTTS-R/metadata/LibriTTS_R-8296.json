        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Yes, we will go now.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000038_000000.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Yes, all of you come.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000038_000001.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "I want you all to see everything that I have that once belonged to my dear mother.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000041_000000",
