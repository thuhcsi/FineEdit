        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000065_000000.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Yes, poor little girl, playing up here all alone,\" said Eddie.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
