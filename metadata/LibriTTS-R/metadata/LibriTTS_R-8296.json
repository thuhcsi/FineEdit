        "speaker_id": "LibriTTS_R-8296",
        "content": "The young Carringtons too, and their mother preferred the old way.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
