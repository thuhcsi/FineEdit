        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000066_000000.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "\"'Cept mammy,\" corrected Vi.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
