        "speaker_id": "LibriTTS_R-8296",
        "content": "\"So they shall, my darlings,\" she answered, \"for mamma loves to teach you.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
