        "speaker_id": "LibriTTS_R-8296",
        "content": "I want no one but my own little children now,\" replied mamma, taking Harold's hand, and leading the way.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000047_000000.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Oh what nice times Herbert and Harry and I shall have!\" he exclaimed. \"What pretty things we'll make!",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8296/266250/8296_266250_000051_000000.wav",
        "speaker_id": "LibriTTS_R-8296",
        "content": "\"God, our kind heavenly Father,\" murmured little Elsie, happy, grateful tears shining in her soft eyes.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
