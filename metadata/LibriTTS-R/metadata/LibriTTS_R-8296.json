        "speaker_id": "LibriTTS_R-8296",
        "content": "\"I too, mamma.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
