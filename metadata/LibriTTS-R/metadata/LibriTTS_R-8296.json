        "speaker_id": "LibriTTS_R-8296",
        "content": "\"They shall see them afterwards.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8296_266250_000041_000001",
