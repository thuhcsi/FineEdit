        "speaker_id": "LibriTTS_R-8296",
        "content": "\"Yes, my son, one of our homes.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
