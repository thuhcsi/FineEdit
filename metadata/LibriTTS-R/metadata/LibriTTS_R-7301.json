[
    {
        "item_name": "LibriTTS_R-7301_92166_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000000_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "A WARM HALF HOUR",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000001_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Whatever the papers say, it was the hottest afternoon of the year.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000001_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "At six thirty I had just finished dressing after my third cold bath since lunch, when Celia tapped on the door.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000002_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"I want you to do something for me,\" she said.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000002_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"It's a shame to ask you on a day like this.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000005_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"And I'm busy,\" I said, opening and shutting a drawer with great rapidity.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"Just threepennyworth,\" she pleaded.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"Nice cool ice.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000006_000002.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Think of sliding home on it.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "I took my hat and staggered out.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "On an ordinary cool day it is about half a mile to the fishmonger; to day it was about two miles and a quarter.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000009_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "I got up, slightly refreshed.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"I want,\" I said, \"some-\" and then a thought occurred to me.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000011_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Probably the large block in front of me was just a trade sign like the coloured bottles at the chemist's. Suppose I said to a fellow of the Pharmaceutical Society, \"I want some of that green stuff in the window,\" he would only laugh.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000012_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "So I said to the fishmonger, \"I want some-some nice lobsters.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000013_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"How many would you like?\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"One,\" I said.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "We selected a nice one between us, and he wrapped a piece of \"Daily Mail\" round it, leaving only the whiskers visible, and gave it to me.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "The ice being now broken-I mean the ice being now-well, you see what I mean-I was now in a position to ask for some of his ice.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000016_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"I wonder if you could let me have a little piece of your ice,\" I ventured.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"Sixpennyworth,\" I said, feeling suddenly that Celia's threepennyworth sounded rather paltry.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000019_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "He wrapped a piece of \"Daily News\" round it and gave it to me.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "\"That is all,\" I said faintly; and, with Algernon, the overwhiskered crustacean, firmly clutched in the right hand and Stonehenge supported on the palm of the left hand, I retired.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000022_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Hot though it was, I would walk.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000023_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "For some miles all went well.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000023_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Then the ice began to drip through the paper, and in a little while, the underneath part of \"The Daily News\" had disappeared altogether.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000023_000002.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Tucking the lobster under my arm I turned the block over, so that it rested on another part of the paper.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000023_000003.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Soon that had dissolved too.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000024_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Fortunately \"The Daily Mail\" remained.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000024_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "But to get it I had to disentangle Algernon first, and I had no hand available.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000025_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "She was the last person I wanted at that moment.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000025_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "In an hour and a half she would be dining with us.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000025_000002.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Algernon would not be dining with us.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000026_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "There was no time to lose.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000026_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "I decided to abandon the ice.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000026_000002.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "Leaving it on the pavement I clutched the lobster and walked hastily back the way I had come.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000027_000000.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "By the time I had shaken off mrs Thompson I was almost at the fishmonger's.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000027_000001.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "That decided me.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7301_92166_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7301/92166/7301_92166_000027_000002.wav",
        "speaker_id": "LibriTTS_R-7301",
        "content": "I would begin all over again, and would do it properly this time.",
        "style_prompt": "M_p-low_s-fast_e-low",
