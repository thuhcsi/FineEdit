[
    {
        "item_name": "LibriTTS_R-2930_163436_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000008_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He overthrew the enemy in several battles, and drove them far back into the depths of the desert.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000008_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Nor did he desist from pursuing them, until an apparition, in the form of a barbarian woman, of more than human size, appeared to him, and, in the Latin tongue, forbad him to proceed any farther.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000008_000007.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "The senate likewise, among various other honours, decreed for him a triumphal arch of marble, with trophies, in the Appian Way, and gave the cognomen of Germanicus to him and his posterity.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000008_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000008_000009.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He likewise often declared that he would, some time or other, if possible, restore the ancient government.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000008_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000008_000010.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "In this account, I suppose, some have ventured to affirm that Augustus was jealous of him, and recalled him; and because he made no haste to comply with the order, took him off by poison.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000010_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "But never, with all his endeavours, could he attain to any public post in the government, or afford any hope of arriving at distinction thereafter.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000011_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "We are both agreed in this, that, once for all, we ought to determine what course to take with him.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000011_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000011_000011.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Thus, my dear Livia, you have my thoughts upon the matter.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000011_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000011_000014.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "I wish the poor creature was more cautious and attentive in the choice of some one, whose manners, air, and gait might be proper for his imitation:",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000015_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "When he entered the theatre, they used to rise, and put off their cloaks.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000015_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000015_000005.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "This decree was, however, repealed; Tiberius insisting to have him excused on account of his imbecility, and promising to make good his loss at his own expense.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000017_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000017_000005.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Sometimes they would put slippers upon his hands; as he lay snoring, that he might, upon awaking, rub his face with them.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000018_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Some even say, that he was thrown into a river, in his travelling dress.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000020_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Having thus established himself in power, his first object was to abolish all remembrance of the two preceding days, in which a revolution in the state had been canvassed.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000020_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Accordingly, he passed an act of perpetual oblivion and pardon for every thing said or done during that time; and this he faithfully observed, with the exception only of putting to death a few tribunes and centurions concerned in the conspiracy against Caius, both as an example, and because he understood that they had also planned his own death.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000020_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000020_000008.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "And though he cancelled all the acts of Caius, yet he forbad the day of his assassination, notwithstanding it was that of his own accession to the empire, to be reckoned amongst the festivals.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000021_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "But with regard to his own aggrandisement, he was sparing and modest, declining the title of emperor, and refusing all excessive honours.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000021_000004.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He asked of the consuls likewise the privilege of holding fairs upon his private estate.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000021_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000021_000005.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He frequently assisted the magistrates in the trial of causes, as one of their assessors.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000021_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000021_000006.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "And when they gave public spectacles, he would rise up with the rest of the spectators, and salute them both by words and gestures.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000022_000005.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "For when orders were given them to march, to meet their new emperor, the eagles could not be decorated, nor the standards pulled out of the ground, whether it was by accident, or a divine interposition.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000023_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "For where persons lost their suits by insisting upon more than appeared to be their due, before the judges of private causes, he granted them the indulgence of a second trial.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000023_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "And with regard to such as were convicted of any great delinquency, he even exceeded the punishment appointed by law, and condemned them to be exposed to wild beasts.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163436_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163436/2930_163436_000024_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "But in hearing and determining causes, he exhibited a strange inconsistency of temper, being at one time circumspect and sagacious, at another inconsiderate and rash, and sometimes frivolous, and like one out of his mind.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000000_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000000_000006.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "One of the knights who was charged with stabbing himself, laid his bosom bare, to show that there was not the least mark of violence upon his body.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000000_000007.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "The following incidents were remarkable in his censorship.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000001_000008.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Crassus Frugi was mounted upon a horse richly caparisoned, in a robe embroidered with palm leaves, because this was the second time of his obtaining that honour.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000002_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He paid particular attention to the care of the city, and to have it well supplied with provisions.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000003_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He proposed to the merchants a sure profit, by indemnifying them against any loss that might befall them by storms at sea; and granted great privileges to those who built ships for that traffic.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000004_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He completed some important public works, which, though not numerous, were very useful.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000004_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He brought to the city the cool and plentiful springs of the Claudian water, one of which is called Caeruleus, and the other Curtius and Albudinus, as likewise the river of the New Anio, in a stone canal; and distributed them into many magnificent reservoirs.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000005_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000005_000010.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Immediately before he drew off the waters from the Fucine lake, he exhibited upon it a naval fight.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000005_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000005_000012.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "We, who are about to peril our lives, salute you;\" and he replying, \"Health attend you too,\" they all refused to fight, as if by that response he had meant to excuse them.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000005_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000005_000013.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Upon this, he hesitated for a time, whether he should not destroy them all with fire and sword.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000005_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000005_000014.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "At last, leaping from his seat, and running along the shore of the lake with tottering steps, the result of his foul excesses, he, partly by fair words, and partly by threats, persuaded them to engage.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000006_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "With regard to religious ceremonies, the administration of affairs both civil and military, and the condition of all orders of the people at home and abroad, some practices he corrected, others which had been laid aside he revived; and some regulations he introduced which were entirely new.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000006_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "In appointing new priests for the several colleges, he made no appointments without being sworn.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000007_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000007_000006.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "When any affair of importance came before the senate, he used to sit between the two consuls upon the seats of the tribunes. He reserved to himself the power of granting license to travel out of Italy, which before had belonged to the senate.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000008_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He likewise granted the consular ornaments to his Ducenarian procurators.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000008_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "From those who declined the senatorian dignity, he took away the equestrian.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000009_000001.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "His military organization of the equestrian order was this.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000009_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He procured an act of the senate to prohibit all soldiers from attending senators at their houses, in the way of respect and compliment.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000009_000004.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He confiscated the estates of all freedmen who presumed to take upon themselves the equestrian rank.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000009_000008.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He quartered a cohort of soldiers at Puteoli, and another at Ostia, to be in readiness against any accidents from fire.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000009_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000009_000010.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Those who falsely pretended to the freedom of Rome, he beheaded on the Esquiline.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000010_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000010_000006.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He concluded treaties with foreign princes in the forum, with the sacrifice of a sow, and the form of words used by the heralds in former times.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000011_000004.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "But he divorced them both; Paetina, upon some trifling causes of disgust; and Urgulanilla, for scandalous lewdness, and the suspicion of murder.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000011_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000011_000010.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "No person was found, however, to follow the example, excepting one freedman, and a centurion of the first rank, at the solemnization of whose nuptials both he and Agrippina attended.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000012_000002.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He lost Drusus at Pompeii, when he was very young; he being choked with a pear, which in his play he tossed into the air, and caught in his mouth.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000012_000004.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Claudia, who was, in truth, the daughter of Boter his freedman, though she was born five months before his divorce, he ordered to be thrown naked at her mother's door.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_163437_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/163437/2930_163437_000012_000006.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "He often earnestly commended him to the soldiers, holding him in his arms before their ranks; and would likewise show him to the people in the theatre, setting him upon his lap, or holding him out whilst he was still very young; and was sure to receive their acclamations, and good wishes on his behalf.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000000_000000.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "This is a LibriVox recording.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
