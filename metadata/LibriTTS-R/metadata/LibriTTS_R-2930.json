    },
    {
        "item_name": "LibriTTS_R-2930_5059_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "by Nennius",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000005_000000.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Translated by j a Giles",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000009_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "For zealous efforts very often fail: but bold enthusiasm, were it in its power, would not suffer me to fail.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000009_000005.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "For it is better to drink a wholesome draught of truth from the humble vessel, than poison mixed with honey from a golden goblet.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000011_000000.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "For I yield to those who are greater and more eloquent than myself, who, kindled with generous ardour, have endeavoured by Roman eloquence to smooth the jarring elements of their tongue, if they have left unshaken any pillar of history which I wished to see remain.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000011_000003.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "I shall obediently accomplish the rest to the utmost of my power.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000013_000000.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "Here begins the apology of Nennius, the historiographer of the Britons, of the race of the Britons.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2930_5059_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2930/5059/2930_5059_000014_000004.wav",
        "speaker_id": "LibriTTS_R-2930",
        "content": "I pray that every reader who shall read this book, may pardon me, for having attempted, like a chattering jay, or like some weak witness, to write these things, after they had failed.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    }
]