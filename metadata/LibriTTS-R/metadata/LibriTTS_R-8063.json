        "speaker_id": "LibriTTS_R-8063",
        "content": "\"Let us go on,\" said D'Artagnan.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
