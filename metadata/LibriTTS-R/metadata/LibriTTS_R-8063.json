        "speaker_id": "LibriTTS_R-8063",
        "content": "\"Very well,\" said Porthos, \"it does not trouble me in the least.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
