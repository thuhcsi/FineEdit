        "speaker_id": "LibriTTS_R-8063",
        "content": "Chapter four.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
