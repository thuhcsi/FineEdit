        "speaker_id": "LibriTTS_R-8063",
        "content": "\"But what is that I see out there,--crosses and stones?\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
