        "speaker_id": "LibriTTS_R-8063",
        "content": "\"Yes,\" said Porthos; \"I see a man.\"",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
