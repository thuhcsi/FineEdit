        "speaker_id": "LibriTTS_R-8063",
        "content": "D'Artagnan, whom nothing ever escaped, remarked how much redder Truchen's left cheek was than her right.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
