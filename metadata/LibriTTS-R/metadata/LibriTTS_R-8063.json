        "speaker_id": "LibriTTS_R-8063",
        "content": "Porthos embraced Madame Truchen, heaving an enormous sigh.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
