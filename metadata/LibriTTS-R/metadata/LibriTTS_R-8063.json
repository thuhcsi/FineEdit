        "speaker_id": "LibriTTS_R-8063",
        "content": "\"Oh, I don't deny that.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
