        "speaker_id": "LibriTTS_R-8063",
        "content": "I had four windows here, but I bricked up two.\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8063_274117_000009_000000",
