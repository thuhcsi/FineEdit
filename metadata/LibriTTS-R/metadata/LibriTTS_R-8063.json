        "speaker_id": "LibriTTS_R-8063",
        "content": "\"Yes, I will join you presently.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
