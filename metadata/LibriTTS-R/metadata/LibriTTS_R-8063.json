        "speaker_id": "LibriTTS_R-8063",
        "content": "\"Which?\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8063_274115_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8063/274115/8063_274115_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8063",
        "content": "\"There is no doubt at all of it, monsieur.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
