        "speaker_id": "LibriTTS_R-8063",
        "content": "\"What about?\" inquired Porthos.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
