        "speaker_id": "LibriTTS_R-8063",
        "content": "\"Not yet.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
