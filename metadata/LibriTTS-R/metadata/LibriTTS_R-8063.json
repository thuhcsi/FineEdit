        "speaker_id": "LibriTTS_R-8063",
        "content": "\"I should not like that,\" said Porthos.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
