        "speaker_id": "LibriTTS_R-8063",
        "content": "The latter, to show that she bore no ill will, approached Porthos, upon whom she conferred the same favor.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
