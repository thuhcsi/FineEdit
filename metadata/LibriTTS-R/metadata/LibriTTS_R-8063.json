        "speaker_id": "LibriTTS_R-8063",
        "content": "But the grocer had a heart of gold, ever mindful of the good old times-a trait that carries youth into old age.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
