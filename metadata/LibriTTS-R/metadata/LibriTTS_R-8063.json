        "speaker_id": "LibriTTS_R-8063",
        "content": "Who is this lady?",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
