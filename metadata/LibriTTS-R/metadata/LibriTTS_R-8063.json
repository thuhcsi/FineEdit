        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8063/274117/8063_274117_000027_000000.wav",
        "speaker_id": "LibriTTS_R-8063",
        "content": "\"That is exactly the reason,\" said Planchet, timidly, \"why I feel it does me good to contemplate a few dead.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
