        "speaker_id": "LibriTTS_R-8063",
        "content": "\"I am a great stickler for a good view myself,\" said Porthos.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
