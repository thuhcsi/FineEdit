        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6323/10337/6323_10337_000032_000000.wav",
        "speaker_id": "LibriTTS_R-6323",
        "content": "Objection one: It would seem that the angel does not love himself both with natural love and a love of choice.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
