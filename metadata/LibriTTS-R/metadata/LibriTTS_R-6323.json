        "speaker_id": "LibriTTS_R-6323",
        "content": "Objection one: It would seem that there is no natural love or dilection in the angels.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
