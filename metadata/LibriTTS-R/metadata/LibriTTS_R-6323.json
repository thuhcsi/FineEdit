        "speaker_id": "LibriTTS_R-6323",
        "content": "Whether the Angel Loves Himself with Both Natural Love, and Love of Choice?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
