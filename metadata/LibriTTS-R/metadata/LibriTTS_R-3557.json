        "speaker_id": "LibriTTS_R-3557",
        "content": "And everybody said that he was as clever as he was handsome, and that no one could be compared to him.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
