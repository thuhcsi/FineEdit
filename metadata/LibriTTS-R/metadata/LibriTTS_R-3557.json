        "speaker_id": "LibriTTS_R-3557",
        "content": "If he could find such a paragon he would marry her.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3557_159359_000001_000004",
