        "speaker_id": "LibriTTS_R-3557",
        "content": "Pretty fool-no!",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    }
