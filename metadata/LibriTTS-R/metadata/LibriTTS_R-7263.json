        "speaker_id": "LibriTTS_R-7263",
        "content": "But ever and awhile the boar made a stand, and many a champion of Arthur's did he slay.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
