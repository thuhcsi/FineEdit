        "speaker_id": "LibriTTS_R-7263",
        "content": "Throughout all Wales did Arthur follow him, and one by one the young pigs were killed.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
