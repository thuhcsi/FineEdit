        "speaker_id": "LibriTTS_R-7263",
        "content": "\"I am shaved,\" answered he.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
