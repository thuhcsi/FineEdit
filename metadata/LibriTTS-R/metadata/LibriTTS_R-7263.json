[
    {
        "item_name": "LibriTTS_R-7263_86687_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000001_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Shortly after the birth of Kilhuch, the son of King Kilyth, his mother died.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000001_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "She foretold to her stepson, Kilhuch, that it was his destiny to marry a maiden named Olwen, or none other, and he, at his father's bidding, went to the court of his cousin, King Arthur, to ask as a boon the hand of the maiden.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000001_000003.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "He rode upon a grey steed with shell formed hoofs, having a bridle of linked gold, and a saddle also of gold.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000001_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000001_000005.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "A gold hilted sword was on his thigh, and the blade was of gold, having inlaid upon it a cross of the hue of the lightning of heaven.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000001_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000001_000007.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Upon the steed was a four cornered cloth of purple, and an apple of gold was at each corner.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000001_000008.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Precious gold was upon the stirrups and shoes, and the blade of grass bent not beneath them, so light was the courser's tread as he went towards the gate of King Arthur's palace.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000002_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Arthur received him with great ceremony, and asked him to remain at the palace; but the youth replied that he came not to consume meat and drink, but to ask a boon of the king.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Then said Kilhuch, \"Every one has received his boon, and I yet lack mine.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "I will depart and bear away thy honour with me.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000009_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Then said Kay, \"Rash chieftain!",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "dost thou reproach Arthur?",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000009_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Go with us, and we will not part until thou dost either confess that the maiden exists not in the world, or until we obtain her.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Thereupon Kay rose up.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000011_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Kay had this peculiarity, that his breath lasted nine nights and nine days under water, and he could exist nine nights and nine days without sleep.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000011_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "A wound from Kay's sword no physician could heal.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000011_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Very subtle was Kay.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000011_000003.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "When it pleased him he could render himself as tall as the highest tree in the forest.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000012_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And Arthur called Bedwyr, who never shrank from any enterprise upon which Kay was bound.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000012_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And although he was one handed, three warriors could not shed blood faster than he on the field of battle.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000012_000003.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Another property he had; his lance would produce a wound equal to nine opposing lances.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"Go thou upon this expedition with the chieftain.\" For as good a guide was he in a land which he had never seen as he was in his own.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000015_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "He was nephew to Arthur, the son of his sister, and his cousin.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000017_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "But so far away was it that at night it seemed no nearer, and they scarcely reached it on the third day.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000017_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "When they came before the castle they beheld a vast flock of sheep, boundless and without end.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000017_000004.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "They gave to him a gold ring, which he conveyed to his wife, telling her who the visitors were.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "On the approach of the latter, she ran out with joy to greet them, and sought to throw her arms about their necks.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "But Kay, snatching a billet out of the pile, placed the log between her two hands, and she squeezed it so that it became a twisted coil.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000019_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Evil love were this.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000020_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "They entered the house, and after meat she told them that the maiden Olwen came there every Saturday to wash.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000020_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "They pledged their faith that they would not harm her, and a message was sent to her.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000020_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "So Olwen came, clothed in a robe of flame coloured silk, and with a collar of ruddy gold, in which were emeralds and rubies, about her neck.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000020_000004.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Brighter were her glances than those of a falcon; her bosom was more snowy than the breast of the white swan, her cheek redder than the reddest roses.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000020_000005.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Whoso beheld was filled with her love.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000022_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Accordingly they went up to the castle and laid their request before him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000024_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "They did so, and he promised them an answer on the morrow.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000026_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Then said he, \"A cursed ungentle son in law, truly I shall ever walk the worse for his rudeness.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000026_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "This poisoned iron pains me like the bite of a gad fly.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000026_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Cursed be the smith who forged it, and the anvil whereon it was wrought.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000030_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "The knights again withdrew, and as they were going he took the second dart and cast it after them.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000032_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"A cursed ungentle son in law, truly,\" says he, \"the hard iron pains me like the bite of a horse leech.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000032_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Cursed be the hearth whereon it was heated!",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000032_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000032_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Henceforth whenever I go up a hill, I shall have a scant in my breath and a pain in my chest.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000034_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "But Kilhuch caught it and threw it vigorously, and wounded him through the eyeball, so that the dart came out at the back of his head.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000035_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"A cursed ungentle son in law, truly.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000035_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "As long as I remain alive my eyesight will be the worse.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000035_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Whenever I go against the wind my eyes will water, and peradventure my head will burn, and I shall have a giddiness every new moon.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000035_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000035_000003.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Cursed be the fire in which it was forged. Like the bite of a mad dog is the stroke of this poisoned iron.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000036_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And they went to meat.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000040_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"I promise thee that willingly,\" said Kilhuch, \"name what thou wilt.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000043_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"It will be easy for me to compass this, although thou mayest think that it will not be easy.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000044_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"Though thou get this, there is yet that which thou wilt not get.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000045_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"It will be easy for me to compass this, although thou mayest think that it will not be easy.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000046_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Thou wilt not get Mabon, for it is not known where he is, unless thou find Eidoel, his kinsman in blood, the son of Aer.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000046_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000046_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "For it would be useless to seek for him.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000046_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000046_000003.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "He is his cousin.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000047_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"It will be easy for me to compass this, although thou mayest think that it will not be easy.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000047_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Horses shall I have, and chivalry; and my lord and kinsman Arthur will obtain for me all these things.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000048_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"Go forward.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000050_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"It will be best,\" said they, \"to seek Mabon the son of Modron; and he will not be found unless we first find Eidoel, the son of Aer, his kinsman.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000051_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Then Arthur rose up, and the warriors of the Islands of Britain with him, to seek for Eidoel; and they proceeded until they came before the castle of Glivi, where Eidoel was imprisoned.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000053_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Said Arthur, \"Not to injure thee came I hither, but to seek for the prisoner that is with thee.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000054_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "\"I will give thee my prisoner, though I had not thought to give him up to any one; and therewith shalt thou have my support and my aid.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000058_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000058_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Nevertheless, there is a race of animals who were formed before me, and I will be your guide to them.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000060_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000060_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Say, knowest thou aught of Mabon?\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000061_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000061_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "The stag said, \"When first I came hither, there was a plain all around me, without any trees save one oak sapling, which grew up to be an oak with an hundred branches.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000061_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000061_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Nevertheless, I will be your guide to the place where there is an animal which was formed before I was.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000063_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000063_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And the owl said, \"If I knew I would tell you.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000063_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000063_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "When first I came hither, the wide valley you see was a wooded glen.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000063_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000063_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And a race of men came and rooted it up.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000063_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000063_000003.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And there grew there a second wood, and this wood is the third.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000063_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000063_000004.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "My wings, are they not withered stumps?",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000069_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000069_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And the voice replied, \"Alas, it is Mabon, the son of Modron, who is here imprisoned!\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000070_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000070_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Then they returned and told Arthur, who, summoning his warriors attacked the castle.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000073_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000073_000000.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Then Arthur summoned unto him all the warriors that were in the three islands of Britain and in the three islands adjacent; and he went as far as Esgeir Oervel in Ireland where the Boar Truith was with his seven young pigs.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000073_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000073_000001.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "And the dogs were let loose upon him from all sides. But he wasted the fifth part of Ireland, and then set forth through the sea to Wales.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7263_86687_000073_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7263/86687/7263_86687_000073_000002.wav",
        "speaker_id": "LibriTTS_R-7263",
        "content": "Arthur and his hosts, and his horses, and his dogs followed hard after him.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
