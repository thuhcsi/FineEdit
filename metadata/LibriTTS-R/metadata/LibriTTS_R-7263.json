        "speaker_id": "LibriTTS_R-7263",
        "content": "\"She is thine, but therefore needst thou not thank me, but Arthur who hath accomplished this for thee.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
