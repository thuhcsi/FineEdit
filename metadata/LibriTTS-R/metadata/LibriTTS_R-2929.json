        "speaker_id": "LibriTTS_R-2929",
        "content": "\"You have no sister-no son-no father?\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2929_86777_000024_000000",
