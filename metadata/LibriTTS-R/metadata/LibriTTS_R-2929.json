        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2929/86777/2929_86777_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2929",
        "content": "\"My present happiness equals my past misery,\" said the count.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2929_86777_000018_000000",
