        "speaker_id": "LibriTTS_R-2929",
        "content": "Perhaps my heart was weaker than the hearts of most men, and I suffered more than they would have done in my place; that is all.\" The countess stopped for a moment, as if gasping for breath.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
