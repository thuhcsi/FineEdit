        "speaker_id": "LibriTTS_R-2929",
        "content": "\"And your present happiness, has it softened your heart?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
