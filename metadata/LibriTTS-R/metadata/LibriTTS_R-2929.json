        "speaker_id": "LibriTTS_R-2929",
        "content": "\"I think so.\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2929_86777_000035_000000",
