        "speaker_id": "LibriTTS_R-2929",
        "content": "\"Are you not married?\" asked the countess.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2929_86777_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2929/86777/2929_86777_000018_000001.wav",
        "speaker_id": "LibriTTS_R-2929",
        "content": "\"I, married?\" exclaimed Monte Cristo, shuddering; \"who could have told you so?\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2929_86777_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2929/86777/2929_86777_000020_000000.wav",
        "speaker_id": "LibriTTS_R-2929",
        "content": "\"She is a slave whom I bought at Constantinople, madame, the daughter of a prince.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
