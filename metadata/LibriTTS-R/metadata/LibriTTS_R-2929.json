        "speaker_id": "LibriTTS_R-2929",
        "content": "\"I never returned to the country where she lived.\"",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
