        "speaker_id": "LibriTTS_R-2929",
        "content": "\"I have no one.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2929_86777_000026_000002",
