        "speaker_id": "LibriTTS_R-2929",
        "content": "\"Never.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
