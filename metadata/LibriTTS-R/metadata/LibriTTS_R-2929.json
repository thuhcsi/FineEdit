        "speaker_id": "LibriTTS_R-2929",
        "content": "I thought she loved me well enough to wait for me, and even to remain faithful to my memory.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
