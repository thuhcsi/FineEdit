        "speaker_id": "LibriTTS_R-2929",
        "content": "\"Yes; Malta.\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2929_86777_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2929/86777/2929_86777_000032_000000.wav",
        "speaker_id": "LibriTTS_R-2929",
        "content": "\"She is, then, now at Malta?\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
