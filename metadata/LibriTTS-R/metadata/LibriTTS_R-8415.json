        "speaker_id": "LibriTTS_R-8415",
        "content": "To have had him fixed, no matter how effectively, would have been a limitation.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
