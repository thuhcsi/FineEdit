        "speaker_id": "LibriTTS_R-8415",
        "content": "\"Under eating and over thinking\" was what the doctor said while he felt her translucent wrist and prescribed nails in her drinking water.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
