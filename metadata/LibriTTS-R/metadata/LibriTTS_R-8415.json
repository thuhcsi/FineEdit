        "speaker_id": "LibriTTS_R-8415",
        "content": "And then she wept because, after all, he did not come.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
