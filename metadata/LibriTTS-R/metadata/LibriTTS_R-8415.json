        "speaker_id": "LibriTTS_R-8415",
        "content": "Imagine her when her hair dye started to give out-green streaks in that pompadour!",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
