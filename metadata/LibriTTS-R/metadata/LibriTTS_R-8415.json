        "speaker_id": "LibriTTS_R-8415",
        "content": "It was really better to feel him surely and broadly within-at large in the great house, free to pass at will from one room to another.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
