        "speaker_id": "LibriTTS_R-8415",
        "content": "At any rate, mrs Morris cried.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
