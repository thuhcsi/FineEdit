        "speaker_id": "LibriTTS_R-8415",
        "content": "So, as I say, it spoiled the picture for me, for a while.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
