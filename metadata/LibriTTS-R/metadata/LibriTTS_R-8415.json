        "speaker_id": "LibriTTS_R-8415",
        "content": "His business was with the body, and he ordered repairs.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
