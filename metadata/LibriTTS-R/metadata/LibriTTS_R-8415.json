        "speaker_id": "LibriTTS_R-8415",
        "content": "\"Yes, Kitty!",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
