        "speaker_id": "LibriTTS_R-8415",
        "content": "And as she slipped the ladder back into the closet, she remarked-this to herself, strictly:",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
