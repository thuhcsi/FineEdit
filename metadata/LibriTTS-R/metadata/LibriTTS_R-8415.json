        "speaker_id": "LibriTTS_R-8415",
        "content": "\"Then I'd get some relief in thinkin' about his disposition.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
