        "speaker_id": "LibriTTS_R-8415",
        "content": "With occupation and a modest success, emotional disturbance was surely giving place to an even calm, when, one day, something happened.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
