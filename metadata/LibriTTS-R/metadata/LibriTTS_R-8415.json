        "speaker_id": "LibriTTS_R-8415",
        "content": "That's Morris.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very high"
