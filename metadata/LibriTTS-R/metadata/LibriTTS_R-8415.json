        "speaker_id": "LibriTTS_R-8415",
        "content": "\"Did you ever!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8415_283469_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8415/283469/8415_283469_000046_000001.wav",
        "speaker_id": "LibriTTS_R-8415",
        "content": "Yes, I did hear there'd been a fire, but you never can tell.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8415_283469_000046_000002",
