        "speaker_id": "LibriTTS_R-8415",
        "content": "Think of all that inside a close fence, an' a town so dull an' news hungry----",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
