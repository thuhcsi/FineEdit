        "speaker_id": "LibriTTS_R-8415",
        "content": "I thought the chimney might 'a' burned out-an' I was in the thick of bein' engaged to the night clerk at the Singin' Needles Hotel at Pineville at the time-an' there's no regular mail there.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8415_283469_000046_000003",
