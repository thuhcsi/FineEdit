        "speaker_id": "LibriTTS_R-8415",
        "content": "He's 'most as much care to me dead as he was alive-I made sure-made sure he'd come after me!\"",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
