        "speaker_id": "LibriTTS_R-8415",
        "content": "Dear me, how full o' b'oyancy he was-a regular boy at thirty five, when he passed away!\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
