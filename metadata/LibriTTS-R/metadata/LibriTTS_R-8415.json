        "speaker_id": "LibriTTS_R-8415",
        "content": "Fire is white in its ultimate intensity.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
