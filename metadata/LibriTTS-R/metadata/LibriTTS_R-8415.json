        "speaker_id": "LibriTTS_R-8415",
        "content": "I thought the story might be exaggerated.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8415_283469_000046_000008",
