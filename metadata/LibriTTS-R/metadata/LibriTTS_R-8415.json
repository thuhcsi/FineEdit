        "speaker_id": "LibriTTS_R-8415",
        "content": "It would make an excuse for me to go in.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
