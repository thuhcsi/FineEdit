        "speaker_id": "LibriTTS_R-8415",
        "content": "It's as red as a flannen drawer, every bit an' grain!",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
