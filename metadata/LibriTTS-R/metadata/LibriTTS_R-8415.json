        "speaker_id": "LibriTTS_R-8415",
        "content": "Spit away!\" she exclaimed.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
