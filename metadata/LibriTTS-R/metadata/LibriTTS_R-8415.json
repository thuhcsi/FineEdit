        "speaker_id": "LibriTTS_R-8415",
        "content": "It was not long after this incident that the widow confided to a friend that she was coming to depend upon Morris for advice in her business.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
