        "speaker_id": "LibriTTS_R-8415",
        "content": "I wouldn't wait because, tell the truth, I was afraid.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
