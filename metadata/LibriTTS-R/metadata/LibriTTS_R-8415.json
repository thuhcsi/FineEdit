        "speaker_id": "LibriTTS_R-8415",
        "content": "She was only thirty seven and \"well\" when she passed painlessly out of life.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
