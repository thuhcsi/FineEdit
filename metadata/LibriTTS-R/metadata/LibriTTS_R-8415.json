        "speaker_id": "LibriTTS_R-8415",
        "content": "Then, feeling her own fidelity challenged, she hastened to add:",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
