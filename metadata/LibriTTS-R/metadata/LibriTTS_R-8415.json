        "speaker_id": "LibriTTS_R-8415",
        "content": "\"Yes, this amethyst is the weddin'-ring.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8415_283469_000049_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8415/283469/8415_283469_000049_000003.wav",
        "speaker_id": "LibriTTS_R-8415",
        "content": "The year not bein' up is why he stayed home this trip.",
