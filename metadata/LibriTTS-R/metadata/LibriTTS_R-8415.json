        "speaker_id": "LibriTTS_R-8415",
        "content": "\"Well, what I seen, I seen!",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
