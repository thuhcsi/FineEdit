        "speaker_id": "LibriTTS_R-8415",
        "content": "The blonde was a person of words.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "high"
