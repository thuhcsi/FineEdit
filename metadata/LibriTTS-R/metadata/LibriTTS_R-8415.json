        "speaker_id": "LibriTTS_R-8415",
        "content": "Some days they let the inmates do 'most any old thing that's harmless.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
