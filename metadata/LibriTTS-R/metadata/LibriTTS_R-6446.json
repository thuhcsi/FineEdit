        "speaker_id": "LibriTTS_R-6446",
        "content": "BY j t TROWBRIDGE",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
