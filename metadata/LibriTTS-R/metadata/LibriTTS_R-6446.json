        "speaker_id": "LibriTTS_R-6446",
        "content": "It was he who taught the people how to build better houses and how to hang their doors on hinges and how to support the roofs with pillars and posts.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6446_57416_000005_000002",
