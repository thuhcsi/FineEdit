    {
        "item_name": "LibriTTS_R-6446_57416_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6446/57416/6446_57416_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6446",
        "content": "While Athens was still only a small city there lived within its walls a man named Daedalus who was the most skillful worker in wood and stone and metal that had ever been known.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6446_57416_000005_000001",
