        "speaker_id": "LibriTTS_R-6346",
        "content": "When it was the Four Hundred and Twenty first Night,",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
