        "speaker_id": "LibriTTS_R-6346",
        "content": "And of the tales they tell is one of",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6346_60784_000004_000000",
