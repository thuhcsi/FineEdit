        "speaker_id": "LibriTTS_R-6346",
        "content": "'My censors say, 'What means this pine for him?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
