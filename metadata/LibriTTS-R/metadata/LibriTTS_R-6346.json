        "speaker_id": "LibriTTS_R-6346",
        "content": "And the glory be to Him who is eternal and in whose hand are annulling and confirming.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
