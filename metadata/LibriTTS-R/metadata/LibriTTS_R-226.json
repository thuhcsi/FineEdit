        "speaker_id": "LibriTTS_R-226",
        "content": "Not of half crowns; of those she had plenty.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
