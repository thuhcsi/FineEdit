        "speaker_id": "LibriTTS_R-226",
        "content": "\"Oh, thank you, my good fellow,\" said Jane, putting the plate on the seat, while she dived into her pocket.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
