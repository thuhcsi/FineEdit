        "speaker_id": "LibriTTS_R-226",
        "content": "But above all else she needed just now a wise, strong, helpful friend, and Deryck had not failed her.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
