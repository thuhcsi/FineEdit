        "speaker_id": "LibriTTS_R-226",
        "content": "\"Here! you have done very well for me.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
