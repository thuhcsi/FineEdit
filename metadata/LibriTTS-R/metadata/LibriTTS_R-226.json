        "speaker_id": "LibriTTS_R-226",
        "content": "Coffee was the last thing she wanted; but it never occurred to any one to disobey the doctor, even at a distance.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
