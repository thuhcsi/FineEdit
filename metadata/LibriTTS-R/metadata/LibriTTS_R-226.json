        "speaker_id": "LibriTTS_R-226",
        "content": "Coffee at a moment's notice should fetch a fancy price.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
