        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7886/110519/7886_110519_000000_000004.wav",
        "speaker_id": "LibriTTS_R-7886",
        "content": "Then she took it and went to her mother's grave and planted it there, and cried so much that it was watered with her tears; and there it grew and became a fine tree.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
