        "speaker_id": "LibriTTS_R-7886",
        "content": "Now the princess's horse was called Falada, and could speak.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
