        "speaker_id": "LibriTTS_R-7886",
        "content": "An old queen, whose husband had been dead some years, had a beautiful daughter.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
