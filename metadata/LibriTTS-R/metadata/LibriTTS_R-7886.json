        "speaker_id": "LibriTTS_R-7886",
        "content": "\"Alas! alas! if thy mother knew it, Sadly, sadly her heart would rue it.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
