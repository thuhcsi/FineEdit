        "speaker_id": "LibriTTS_R-3595",
        "content": "I form'd a score different plans.-- There was no such thing as a man's asking her directly;--the thing was impossible.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
