        "speaker_id": "LibriTTS_R-3595",
        "content": "That grave people hate love for the name's sake; -",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
