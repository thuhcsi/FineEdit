        "speaker_id": "LibriTTS_R-3595",
        "content": "'tis their fort, replied the lady.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
