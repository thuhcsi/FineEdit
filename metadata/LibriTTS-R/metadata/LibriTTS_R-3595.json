        "speaker_id": "LibriTTS_R-3595",
        "content": "The lady attended as if she expected I should go on.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
