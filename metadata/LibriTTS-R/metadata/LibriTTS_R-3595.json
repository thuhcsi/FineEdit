        "speaker_id": "LibriTTS_R-3595",
        "content": "Consider then, Madame, continued I, laying my hand upon hers:-",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
