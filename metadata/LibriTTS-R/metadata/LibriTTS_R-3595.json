    {
        "item_name": "LibriTTS_R-3595_191322_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3595/191322/3595_191322_000016_000000.wav",
        "speaker_id": "LibriTTS_R-3595",
        "content": "- To think of making love by SENTIMENTS!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
