[
    {
        "item_name": "LibriTTS_R-6563_285357_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000001_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "It stimulated financial support, and the second airship was taken in hand.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000001_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "But misfortune still pursued him.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000001_000003.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Accidents were of almost daily occurrence.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000001_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000001_000005.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "So soon as one trouble was overcome another made itself manifest.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000001_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000001_000006.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The result was that the whole of the money collected by his hard work was expended before the ship could take to the air.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000001_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000001_000007.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "A further crash and blasting of cherished hopes appeared imminent, but at this moment another Royal personage came to the inventor's aid.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000002_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The King of Wurtemberg took a personal interest in his subject's uphill struggle, and the Wurtemberg Government granted him the proceeds of a lottery.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000002_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "With this capital a third ship was taken in hand, and in nineteen o five it was launched.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000002_000004.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The airship was four hundred fourteen feet in length by thirty eight feet in diameter, was equipped with seventeen gas balloons having an aggregate capacity of three hundred sixty seven thousand cubic feet of hydrogen, was equipped with two eighty five horse power motors driving four propellers, and displaced nine tons.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000002_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000002_000005.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "All the imperfections incidental to the previous craft had been eliminated, while the ship followed improved lines in its mechanical and structural details.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000003_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The trials with this vessel commenced on november thirtieth nineteen o five, but ill luck had not been eluded.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000003_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "A strong wind caught the ungainly airship, she dipped her nose into the water, and as the motor was set going she was driven deeper into the lake, the vessel only being saved by hurried deflation.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000004_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The trials were fairly satisfactory, but inconclusive.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000004_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "One of the motors went wrong, and the longitudinal stability was found to be indifferent.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000004_000003.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The vessel was brought down, and was to be anchored, but the Fates ruled otherwise.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000004_000004.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "A strong wind caught her during the night and she was speedily reduced to indistinguishable scrap.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Despite catastrophe the inventor wrestled gamely with his project.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000005_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The lessons taught by one disaster were taken to heart, and arrangements to prevent the recurrence thereof incorporated in the succeeding craft. Unfortunately, however, as soon as one defect was remedied another asserted itself.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000005_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "It was this persistent revelation of the unexpected which caused another period of indifference towards his invention. Probably nothing more would have been heard of the Zeppelin after this last accident had it not been for the intervention of the Prussian Government at the direct instigation of the Kaiser, who had now taken Count Zeppelin under his wing.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Another craft was built, larger than its predecessors, and equipped with two motors developing one hundred seventy horse power.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000006_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "On june twentieth nineteen o eight, at eight twenty six a m the craft ascended and remained aloft for twelve hours, during which time it made an encouraging circular tour.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000007_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The crucial test was essayed on august fifth nineteen o eight.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000007_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Then a slight mishap demanded attention, but was speedily repaired, and was ignored officially as being too trivial to influence the main issue.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000007_000003.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Victory appeared within measurable distance: the arduous toil of many patient years was about to be rewarded.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000007_000004.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The airship was within sight of home when it had to descend owing to the development of another motor fault.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000007_000005.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "But as it approached the ground, Nature, as if infuriated at the conquest, rose up in rebellion.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000007_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000007_000006.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "A sudden squall struck the unwieldy monster.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "It was a catastrophe that would have completely vanquished many an inventor, but the Count was saved the gall of defeat.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000008_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "His flight, which was remarkable, inasmuch as he had covered three hundred eighty miles within twenty four hours, including two unavoidable descents, struck the Teuton imagination.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000008_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The seeds so carefully planted by the \"Most High of Prussia\" now bore fruit. The German nation sympathised with the indomitable inventor, appreciated his genius, and promptly poured forth a stream of subscriptions to enable him to build another vessel.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000008_000003.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The intimation that other Powers had approached the Count for the acquisition of his idea became known far and wide, together with the circumstance that he had unequivocally refused all offers.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000008_000004.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "He was striving for the Fatherland, and his unselfish patriotism appealed to one and all.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000009_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "He could forge ahead untrammelled by anxiety and worry.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000009_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Another Zeppelin was built and it created a world's record.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000009_000003.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "It remained aloft for thirty eight hours, during which time it covered six hundred ninety miles, and, although it came to grief upon alighting, by colliding with a tree, the final incident passed unnoticed.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000009_000004.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Germany was in advance of the world.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000009_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000009_000006.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Here was a means of obtaining the mastery of the air: a formidable engine of invasion and aerial attack had been perfected.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000009_000007.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Consequently the Grand Idea must be supported with unbounded enthusiasm.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000009_000008.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The Count was hailed by his august master as \"The greatest German of the twentieth century,\" and in this appreciation the populace wholeheartedly concurred.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000010_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Although the Zeppelin was accepted as a perfect machine it has never been possible to disperse the atmosphere of disaster with which it has been enveloped from the first.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000010_000003.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Unshaken by this adverse criticism, Germany rests assured that by means of its Zeppelins it will achieve that universal supremacy which it is convinced is its Destiny.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000011_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "This blind child like faith has been responsible for the establishment and development of the Zeppelin factories.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000011_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "At Friedrichshafen the facilities are adequate to produce two of these vessels per month, while another factory of a similar capacity has been established at Berlin. Unfortunately such big craft demand large docks to accommodate them, and in turn a large structure of this character constitutes an easy mark for hostile attack, as the raiding airmen of the Allies have proved very convincingly.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000012_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "But the Zeppelin must not be under rated.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000012_000002.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "It is quite true that each astounding achievement has been attended by an equally stupendous accident, but that is accepted as a mere incidental detail by the faithful Teutonic nation.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000012_000003.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Many vivid prophecies of the forthcoming flights by Zeppelin have been uttered, and it is quite probable that more than one will be fulfilled, but success will be attributable rather to accident than design.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000013_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Although the Zeppelin is the main stake of the German people in matters pertaining to aerial conquest, other types of airships have not been ignored, as related in another chapter.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "They have been fostered upon a smaller but equally effective scale.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000014_000000.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "The Parseval is pronounced by experts to be the finest expression of aeronautical engineering so far as Teuton effort is concerned.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6563_285357_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6563/285357/6563_285357_000014_000001.wav",
        "speaker_id": "LibriTTS_R-6563",
        "content": "Certainly it has placed many notable flights to its credit.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
