        "speaker_id": "LibriTTS_R-7085",
        "content": "Then said he, \"Weep not, for it was Satan and covetise that led you to do thus.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
