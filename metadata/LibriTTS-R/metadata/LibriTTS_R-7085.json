        "speaker_id": "LibriTTS_R-7085",
        "content": "He must certainly be warned.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
