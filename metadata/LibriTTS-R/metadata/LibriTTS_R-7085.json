        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7085/2327/7085_2327_000022_000006.wav",
        "speaker_id": "LibriTTS_R-7085",
        "content": "Robert would come spurring after her and seize her bridle just as she was turning in at Sir John's gates.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
