        "speaker_id": "LibriTTS_R-7085",
        "content": "When it was the Six Hundred and Nineteenth Night,",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7085_75810_000005_000000",
