        "speaker_id": "LibriTTS_R-7085",
        "content": "The chances were that she would be watched.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
