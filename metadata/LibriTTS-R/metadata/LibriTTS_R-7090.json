        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7090/91801/7090_91801_000071_000000.wav",
        "speaker_id": "LibriTTS_R-7090",
        "content": "\"Make some day a decent end, Shrewder fellows than your friend. Fare you well, for ill fare I: Live, lads, and I will die.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
