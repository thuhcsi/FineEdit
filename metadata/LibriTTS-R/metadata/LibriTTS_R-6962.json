        "speaker_id": "LibriTTS_R-6962",
        "content": "So did Rosamond insult over King Henry the Second.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
