        "speaker_id": "LibriTTS_R-1705",
        "content": "Then her thoughts went back to Milton, with a strange sense of the contrast between the life there, and here.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
