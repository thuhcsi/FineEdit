        "speaker_id": "LibriTTS_R-1705",
        "content": "Edith was impatient to get well, in order to fill Margaret's bed room with all the soft comforts, and pretty nick knacks, with which her own abounded.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
