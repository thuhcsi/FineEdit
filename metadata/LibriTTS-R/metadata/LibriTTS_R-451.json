        "speaker_id": "LibriTTS_R-451",
        "content": "\"I'm going to do penance all day for coaxing Sara to disobey her mother,\" she announced with chastened triumph.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
