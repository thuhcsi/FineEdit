        "speaker_id": "LibriTTS_R-451",
        "content": "\"Yes.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
