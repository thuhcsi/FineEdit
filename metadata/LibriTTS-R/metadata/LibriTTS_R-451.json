        "speaker_id": "LibriTTS_R-451",
        "content": "I'm going to deny myself everything I like, and do everything I can think of that I don't like, just to punish myself for being so wicked.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
