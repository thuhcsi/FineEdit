        "speaker_id": "LibriTTS_R-451",
        "content": "So it doesn't matter what you do, whether it's useful or not, so long as it's nasty.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-451_126826_000039_000000",
