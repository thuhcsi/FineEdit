        "speaker_id": "LibriTTS_R-451",
        "content": "\"Penance?\" we murmured in bewilderment.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
