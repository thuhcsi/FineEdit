        "speaker_id": "LibriTTS_R-451",
        "content": "\"She has a cold and sore throat, and she is feverish.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
