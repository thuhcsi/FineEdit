        "speaker_id": "LibriTTS_R-451",
        "content": "The Story Girl was not to be comforted.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
