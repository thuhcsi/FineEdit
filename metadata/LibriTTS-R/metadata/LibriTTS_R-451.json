        "speaker_id": "LibriTTS_R-451",
        "content": "And I'm going to work buttonholes all over this cotton.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
