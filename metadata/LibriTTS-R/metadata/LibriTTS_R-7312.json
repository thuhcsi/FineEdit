[
    {
        "item_name": "LibriTTS_R-7312_92432_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "In compliance with your request, I have the honor to state, succinctly, the circumstances connected with my acquaintance with the late Madame Ossoli, your deceased sister, during her residence in Rome.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000005_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "In the month of April, eighteen forty nine, Rome, as you are no doubt aware, was placed in a state of siege by the approach of the French army.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000005_000002.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "Among these was to be seen every variety of age, sentiment, and condition,--striplings and blanched heads; wild, visionary enthusiasts; grave, heroic men, who, in the struggle for freedom, had ventured all, and lost all; nobles and beggars; bandits, felons and brigands.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000005_000003.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "Great excitement naturally existed; and, in the general apprehension which pervaded all classes, that acts of personal violence and outrage would soon be committed, the foreign residents, especially, found themselves placed in an alarming situation.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "On the thirtieth of April the first engagement took place between the French and Roman troops, and in a few days subsequently I visited several of my countrymen, at their request, to concert measures for their safety.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000006_000002.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "She received me with much kindness, and thus an acquaintance commenced.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "In the engagements which succeeded between the Roman and French troops, the wounded of the former were brought into the city, and disposed throughout the different hospitals, which were under the superintendence of several ladies of high rank, who had formed themselves into associations, the better to ensure care and attention to those unfortunate men.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "The weather was intensely hot; her health was feeble and delicate; the dead and dying were around her in every stage of pain and horror; but she never shrank from the duty she had assumed.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "Her heart and soul were in the cause for which those men had fought, and all was done that Woman could do to comfort them in their sufferings.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000008_000005.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "And in a letter which I received not long since from this lady, who was gaining the bread of an exile by teaching languages in Constantinople, she alludes with much feeling to the support afforded by Miss Fuller to the republican party in Italy.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000008_000006.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "Here, in Rome, she is still spoken of in terms of regard and endearment, and the announcement of her death was received with a degree of sorrow not often bestowed upon a foreigner, especially one of a different faith.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000009_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "On the twenty ninth of June, the bombardment from the French camp was very heavy, shells and grenades falling in every part of the city.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "In the afternoon of the thirtieth, I received a brief note from Miss Fuller, requesting me to call at her residence.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000009_000002.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "I did so without delay, and found her lying on a sofa, pale and trembling, evidently much exhausted.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000009_000005.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "It was not to be expected, she said, that he could escape the dangers of another night, such as the last; and therefore it was her intention to remain with him, and share his fate.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000009_000007.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "The packet which she placed in my possession, contained, she said, the certificates of her marriage, and of the birth and baptism of her child.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000009_000008.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "After a few words more, I took my departure, the hour she named having nearly arrived.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "Happily, the cannonading was not renewed that night, and at dawn of day she returned to her apartments, with her husband by her side.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000011_000001.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "During this period I received several letters from her, all of which, though reluctant to part with them, I enclose to your address in compliance with your request.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000012_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "I am, Madame, very respectfully,",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7312_92432_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7312/92432/7312_92432_000013_000000.wav",
        "speaker_id": "LibriTTS_R-7312",
        "content": "Your obedient servant,",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    }
]