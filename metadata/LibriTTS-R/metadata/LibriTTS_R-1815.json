[
    {
        "item_name": "LibriTTS_R-1815_143382_000002_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143382/1815_143382_000002_000008.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "A Locrian, who proposed any new law, stood forth in the assembly of the people with a cord round his neck, and if the law was rejected, the innovator was instantly strangled.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143382_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143382/1815_143382_000010_000003.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The insolvent debtor consulted the wishes of his creditor; the client would have blushed to oppose the views of his patron; the general was followed by his veterans, and the aspect of a grave magistrate was a living lesson to the multitude.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143382_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143382/1815_143382_000010_000004.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "A new method of secret ballot abolished the influence of fear and shame, of honor and interest, and the abuse of freedom accelerated the progress of anarchy and despotism.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143382_000010_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143382/1815_143382_000010_000006.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Once, and once only, he experienced a sincere and strenuous opposition.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_143382_000010_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143382/1815_143382_000010_000007.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "His subjects had resigned all political liberty; they defended the freedom of domestic life.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143382_000010_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143382/1815_143382_000010_000011.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The loss of executive power was alleviated by the gift of legislative authority; and Ulpian might assert, after the practice of two hundred years, that the decrees of the senate obtained the force and validity of laws.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The free citizens of Athens and Rome enjoyed, in all criminal cases, the invaluable privilege of being tried by their country.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The first consuls succeeded to this regal prerogative; but the sacred right of appeal soon abolished the jurisdiction of the magistrates, and all public causes were decided by the supreme tribunal of the people.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "But a wild democracy, superior to the forms, too often disdains the essential principles, of justice: the pride of despotism was envenomed by plebeian envy, and the heroes of Athens might sometimes applaud the happiness of the Persian, whose fate depended on the caprice of a single tyrant.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000004_000006.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The right of accusation was confined to the magistrates.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Repeated proclamations and adjournments were interposed, to allow time for prejudice and resentment to subside: the whole proceeding might be annulled by a seasonable omen, or the opposition of a tribune; and such popular trials were commonly less formidable to innocence than they were favorable to guilt.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000005_000003.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The task of convening the citizens for the trial of each offender became more difficult, as the citizens and the offenders continually multiplied; and the ready expedient was adopted of delegating the jurisdiction of the people to the ordinary magistrates, or to extraordinary inquisitors.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "In the first ages these questions were rare and occasional.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000005_000005.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "In the beginning of the seventh century of Rome they were made perpetual: four praetors were annually empowered to sit in judgment on the state offences of treason, extortion, peculation, and bribery; and Sylla added new praetors and new questions for those crimes which more directly injure the safety of individuals.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000005_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000005_000006.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "By these inquisitors the trial was prepared and directed; but they could only pronounce the sentence of the majority of judges, who with some truth, and more prejudice, have been compared to the English juries.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000005_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000005_000014.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The rules and precautions of freedom have required some explanation; the order of despotism is simple and inanimate.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000008_000002.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "A bolder effort was required to escape from the tyranny of the Caesars; but this effort was rendered familiar by the maxims of the stoics, the example of the bravest romans, and the legal encouragements of suicide.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000008_000004.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "But, if the victims of Tiberius and Nero anticipated the decree of the prince or senate, their courage and despatch were recompensed by the applause of the public, the decent honors of burial, and the validity of their testaments.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000008_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000008_000009.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "But the precepts of the gospel, or the church, have at length imposed a pious servitude on the minds of Christians, and condemn them to expect, without a murmur, the last stroke of disease or the executioner.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "This singular distinction, though something may be allowed for the urgent necessity of defending the peace of society, is derived from the nature of criminal and civil jurisprudence.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000002.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Our duties to the state are simple and uniform: the law by which he is condemned is inscribed not only on brass or marble, but on the conscience of the offender, and his guilt is commonly proved by the testimony of a single fact.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000003.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "But our relations to each other are various and infinite; our obligations are created, annulled, and modified, by injuries, benefits, and promises; and the interpretation of voluntary contracts and testaments, which are often dictated by fraud or ignorance, affords a long and laborious exercise to the sagacity of the judge.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000005.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Justinian, the Greek emperor of Constantinople and the East, was the legal successor of the Latin shepherd who had planted a colony on the banks of the Tyber.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000006.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "In a period of thirteen hundred years, the laws had reluctantly followed the changes of government and manners; and the laudable desire of conciliating ancient names with recent institutions destroyed the harmony, and swelled the magnitude, of the obscure and irregular system.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000009.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Such costly justice might tend to abate the spirit of litigation, but the unequal pressure serves only to increase the influence of the rich, and to aggravate the misery of the poor.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000010.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "By these dilatory and expensive proceedings, the wealthy pleader obtains a more certain advantage than he could hope from the accidental corruption of his judge.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000011.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The experience of an abuse, from which our own age and country are not perfectly exempt, may sometimes provoke a generous indignation, and extort the hasty wish of exchanging our elaborate jurisprudence for the simple and summary decrees of a Turkish cadhi.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_143388_000013_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/143388/1815_143388_000013_000012.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Our calmer reflection will suggest, that such forms and delays are necessary to guard the person and property of the citizen; that the discretion of the judge is the first engine of tyranny; and that the laws of a free people should foresee and determine every question that may probably arise in the exercise of power and the transactions of industry.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000000_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "CHAPTER twelve-THE FUTURE LATENT IN THE PEOPLE",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "As for the Parisian populace, even when a man grown, it is always the street Arab; to paint the child is to paint the city; and it is for that reason that we have studied this eagle in this arrant sparrow.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000002.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "There exist there immense numbers of unknown beings, among whom swarm types of the strangest, from the porter of la Rapee to the knacker of Montfaucon.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000003.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Fex urbis, exclaims Cicero; mob, adds Burke, indignantly; rabble, multitude, populace.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000004.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "These are words and quickly uttered.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000005.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "But so be it.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000006.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "What does it matter?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000007.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "What is it to me if they do go barefoot! They do not know how to read; so much the worse.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000008.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Would you abandon them for that?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000009.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Would you turn their distress into a malediction?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000010.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Cannot the light penetrate these masses?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000011.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Let us return to that cry: Light! and let us obstinately persist therein!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000012.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Light!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000013.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Light!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000014.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Who knows whether these opacities will not become transparent?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000015.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Are not revolutions transfigurations?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000017.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Make a whirlwind of the idea.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000018.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "This crowd may be rendered sublime.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000019",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000019.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Let us learn how to make use of that vast conflagration of principles and virtues, which sparkles, bursts forth and quivers at certain hours.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000020.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "These bare feet, these bare arms, these rags, these ignorances, these abjectnesses, these darknesses, may be employed in the conquest of the ideal.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000021",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000021.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Gaze past the people, and you will perceive truth.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000001_000022",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000001_000022.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Let that vile sand which you trample under foot be cast into the furnace, let it melt and seethe there, it will become a splendid crystal, and it is thanks to it that Galileo and Newton will discover stars.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "CHAPTER thirteen-LITTLE GAVROCHE",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Some people or other had clothed him in rags out of charity.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Still, he had a father and a mother.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "But his father did not think of him, and his mother did not love him.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "He was one of those children most deserving of pity, among all, one of those who have father and mother, and who are orphans nevertheless.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "This child never felt so well as when he was in the street.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The pavements were less hard to him than his mother's heart.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "His parents had despatched him into life with a kick.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "He simply took flight.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "He was a boisterous, pallid, nimble, wide awake, jeering, lad, with a vivacious but sickly air.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "He went and came, sang, played at hopscotch, scraped the gutters, stole a little, but, like cats and sparrows, gayly laughed when he was called a rogue, and got angry when called a thief. He had no shelter, no bread, no fire, no love; but he was merry because he was free.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "When these poor creatures grow to be men, the millstones of the social order meet them and crush them, but so long as they are children, they escape because of their smallness.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "The tiniest hole saves them.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Nevertheless, abandoned as this child was, it sometimes happened, every two or three months, that he said, \"Come, I'll go and see mamma!\" Then he quitted the boulevard, the Cirque, the Porte Saint Martin, descended to the quays, crossed the bridges, reached the suburbs, arrived at the Salpetriere, and came to a halt, where?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "I know not what philosopher has said: \"Old women are never lacking.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "This family was that of the merry barefoot boy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000017_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "He arrived there and found distress, and, what is still sadder, no smile; a cold hearth and cold hearts.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000017_000002.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "When he entered, he was asked: \"Whence come you?\" He replied: \"From the street.\" When he went away, they asked him: \"Whither are you going?\" He replied: \"Into the streets.\" His mother said to him: \"What did you come here for?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "This child lived, in this absence of affection, like the pale plants which spring up in cellars.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000018_000002.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "He did not know exactly how a father and mother should be.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Nevertheless, his mother loved his sisters.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000020_000001.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Why was he called Little Gavroche?",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1815_9918_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1815/9918/1815_9918_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1815",
        "content": "Probably because his father's name was Jondrette.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
