        "speaker_id": "LibriTTS_R-6938",
        "content": "Even the sun came out, pale and watery, at noon.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
