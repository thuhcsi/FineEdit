        "speaker_id": "LibriTTS_R-6938",
        "content": "The life of the city grew gay, and the very Revolution ran swifter....",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
