        "speaker_id": "LibriTTS_R-8590",
        "content": "So he saluted him and the other returned his salam.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
