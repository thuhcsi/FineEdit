        "speaker_id": "LibriTTS_R-8590",
        "content": "So let us send him a messenger in the King's name and seek of him our need, beseeching him to put up prayer to his Lord, that He vouchsafe each of us boon of issue.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8590_258290_000009_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8590/258290/8590_258290_000009_000010.wav",
        "speaker_id": "LibriTTS_R-8590",
        "content": "Rejoice in the certain winning of your wish!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
