        "speaker_id": "LibriTTS_R-8590",
        "content": "When it was the Seven Hundred and Fifty ninth Night,",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
