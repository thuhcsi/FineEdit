[
    {
        "item_name": "LibriTTS_R-2654_158744_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000001_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lucy Morris",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000002_000002.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Poor Lizzie Greystock!--as men double her own age, and who had known her as a forward, capricious, spoilt child in her father's lifetime, would still call her.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000003_000001.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "In the meantime, let it be understood that poor little Lucy Morris was a governess in the house of old Lady Fawn, when our beautiful young widow established herself in Mount Street.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lady Eustace and Lucy Morris had known each other for many years,--had indeed been children together,--there having been some old family friendship between the Greystocks and the Morrises.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000004_000002.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She had often been a guest at the deanery.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000004_000004.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lucy, who was a year younger than Lizzie, had at that time been an orphan for the last four years.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000004_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000004_000007.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "The dean and the dean's wife and the dean's daughters had been her best friends, but they were not friends on whom she could be dependent.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000004_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000004_000008.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "They were in no way connected with her by blood.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000001.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "The proposed engagement with Lady Fawn was thought to be a great thing for her.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000002.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lady Fawn was known as a miracle of Virtue, Benevolence, and Persistency.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000005.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She must be able to teach music up to a certain point.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000006.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"Then it's all over,\" said Lucy to the dean with her pretty smile,--that smile which caused all the old and middle aged men to fall in love with her.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000007.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"It's not over at all,\" said the dean.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000008.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"You've got four months.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000009.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Our organist is about as good a teacher as there is in England.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000005_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000005_000010.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "You are clever and quick, and he shall teach you.\" So Lucy went to Bobsborough, and was afterwards accepted by Lady Fawn.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000006_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "While she was at the deanery there sprung up a renewed friendship between her and Lizzie.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000006_000004.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Now Lucy did not like to hear the Greystocks abused, and would say so.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000006_000006.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "This one was Frank Greystock, the barrister.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000007_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"Remember her position,\" said mrs Dean to her son.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"Her position!",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000008_000001.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Well;--and what is her position mother?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000009_000002.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "But with a governess, unless you mean to marry her, you should be more careful than with another girl, because you may do her such a world of mischief.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000010_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"I don't see that at all.\"",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000012_000002.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Who can hinder it?\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000014_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"Yes-I do; well.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000014_000001.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "I don't suppose I can afford to marry Lucy Morris. At any rate, mother, I will never say a word to raise a hope in her,--if it would be a hope-\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000015_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"Of course it would be a hope.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"Oh, Frank, it would be impossible!\" said mrs Dean.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "mrs Dean was a very good woman, but she had aspirations in the direction of filthy lucre on behalf of her children, or at least on behalf of this special child, and she did think it would be very nice if Frank would marry an heiress.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000018_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000018_000007.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "A governess, if she were given to falling in love, could hardly perform her duties in life.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000018_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000018_000010.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She was very fond of Lucy Morris, and treated her dependent with affectionate consideration;--but she did not approve of visits from mr Frank Greystock.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000018_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000018_000011.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lucy, blushing up to the eyes, had once declared that she desired to have no personal visitors at Lady Fawn's house; but that, as regarded her own friendships, the matter was one for her own bosom.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000018_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000018_000017.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "But then Lady Fawn hated Lady Linlithgow as only two old women can hate each other;--and she had not heard the story of the diamond necklace.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000019_000001.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She was never forward, but never bashful.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000019_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000019_000010.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "They were good-natured, plain, unattractive girls, who spoke of her to her face as one who could easily do anything to which she might put her hand. Lady Fawn did really love her.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000019_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000019_000013.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lord Fawn had suffered a disappointment in love, but he had consoled himself with blue books, and mastered his passion by incessant attendance at the India Board. The lady he had loved had been rich, and Lord Fawn was poor; but nevertheless he had mastered his passion.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000019_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000019_000014.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "There was no fear that his feelings towards the governess would become too warm;--nor was it likely that Miss Morris should encounter danger in regard to him.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000019_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000019_000015.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "It was quite an understood thing in the family that Lord Fawn must marry money.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000020_000003.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lord Fawn was pompous, slow, dull, and careful; but even he had given way to it at once.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000020_000004.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lady Fawn, too, was very careful, but she had owned to herself long since that she could not bear to look forward to any permanent severance.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000020_000005.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Of course Lucy would be made over to the Hittaways, whose mother lived in Warwick Square, and whose father was Chairman of the Board of Civil Appeals.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She was but a little thing;--and it cannot be said of her, as of Lady Eustace, that she was a beauty.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000021_000002.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Her light brown hair was soft and smooth and pretty.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000021_000003.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "As hair it was very well, but it had no speciality.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000021_000004.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Her mouth was somewhat large, but full of ever varying expression.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000021_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000021_000009.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She would take up your subject, whatever it was, and make it her own.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000021_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000021_000010.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "There was forward just then a question as to whether the Sawab of Mygawb should have twenty millions of rupees paid to him and be placed upon a throne, or whether he should be kept in prison all his life.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000022_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "What else can be said of her face or personal appearance that will interest a reader?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000022_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000022_000004.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She was a little, thin, quick, graceful creature, whom it was impossible that you should see without wishing to have near you.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000022_000005.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "A most unselfish little creature she was, but one who had a well formed idea of her own identity.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000022_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000022_000007.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She was the humblest little thing in the world in regard to any possible putting of herself forward or needful putting of herself back; and yet, to herself, nobody was her superior.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000022_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000022_000010.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She coveted no man's possessions,--and no woman's; but she was minded to hold by her own.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000022_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000022_000011.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Of present advantages or disadvantages,--whether she had the one or suffered from the other,--she thought not at all.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000001.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She had given her heart,--for good and all, as she owned to herself,--to Frank Greystock.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000003.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Frank was becoming a man of mark,--but was becoming a man of mark without much money.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000004.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Of all men he was the last who could afford to marry a governess.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000005.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "And then, moreover, he had never said a word to make her think that he loved her.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000007.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Seeing that there had been friendship between the families for so many years, who could complain of that?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000008.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lady Fawn, however, had-not complained, but just said a word.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000009.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "A word in season, how good is it?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000023_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000023_000010.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lucy did not much regard the word spoken to herself; but when she reflected that a word must also have been spoken to mr Greystock,--otherwise how should it have been that he never came again?--that she did not like.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000001.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "It is a great nuisance, a loss that maims the whole life,--a misfortune to be much regretted.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000003.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "A man with a wooden leg may stump about through much action, and may enjoy the keenest pleasures of humanity.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000004.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "He has his eyes left to him, and his ears, and his intellect.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000005.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "He will not break his heart for the loss of that leg.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000006.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "And so it was with Lucy Morris.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000007.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She would still stump about and be very active.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000008.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Eyes, ears, and intellect were left to her.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000010.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "Lady Fawn, she thought, was right.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000011.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "A governess should make up her mind to do without a lover.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000024_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000024_000012.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "She had given away her heart, and yet she would do without a lover.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000027_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"He is not going to prove a false knight?\" asked Lady Eustace, in her lowest whisper.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2654_158744_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2654/158744/2654_158744_000029_000000.wav",
        "speaker_id": "LibriTTS_R-2654",
        "content": "\"Nonsense, my dear; as if I didn't know.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    }
]