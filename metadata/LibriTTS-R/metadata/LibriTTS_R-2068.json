[
    {
        "item_name": "LibriTTS_R-2068_146217_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000000_000007.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "It was dark night when he alighted at the Khan, so he spread out his prayer carpet and took down the saddle bags from the back of his mule and gave her with her furniture in charge of the door keeper that he might walk her about.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000000_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000000_000008.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "The man took her and did as he was bid.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000000_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000000_000009.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Now it so happened that the Wazir of Bassorah, a man shot in years, was sitting at the lattice window of his palace opposite the Khan and he saw the porter walking the mule up and down.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000000_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000000_000018.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Then the Wazir bade his servants take Nur al Din to the Hammam baths and sent him a suit of the best of his own especial raiment, and napkins and towelry and bowls and perfume burners and all else that was required.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000001_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "When it was the Twenty first Night,",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000002_000002.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Thereupon Shams al Din despaired of finding his brother and said, \"Indeed I went beyond all bounds in what I said to him with reference to the marriage of our children. Would that I had not done so!",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "And as another also said:--",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000007_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "\"The world's best joys long be thy lot, my lord!",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Then the Sultan rose up to honour them, and thanking Nur al Din for his fine compliment, asked the Wazir, \"Who may be this young man?\"; and the Minister answered, \"This is my brother's son,\" and related his tale from first to last.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000010_000002.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "When the Divan was dismissed Nur al Din returned to his house and related what had passed to his father in law who rejoiced.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000010_000003.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "And thenceforward Nur al Din ceased not so to administer the Wazirate that the Sultan would not be parted from him night or day; and increased his stipend and supplies until his means were ample and he became the owner of ships that made trading voyages at his command, as well as of Mamelukes and blackamoor slaves; and he laid out many estates and set up Persian wheels and planted gardens.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000012_000001.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "His grandfather the old Wazir had bequeathed to him the whole of his property when he was but four years of age.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000014_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "And they blessed him aloud as he passed and called upon Almighty Allah to bless him.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000014_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000014_000007.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "And he fell to weeping over his father and at parting with him, and he but a boy.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000016_000001.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "And I have heard a poet say:- -",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "The THIRD BEHEST is, Learn to be silent in society and let thine own faults distract thine attention from the faults of other men: for it is said:--In silence dwelleth safety, and thereon I have heard the lines that tell us:--",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000024_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "On this wise Nur al Din ceased not to counsel his son Badr al Din Hasan till his hour came and, sighing one sobbing sigh, his life went forth.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000030_000000.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Then he wept with exceeding weeping and night came upon him; so he leant his head against his father's grave and sleep overcame him: Glory to him who sleepeth not!",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000030_000002.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Now the cemetery was haunted day and night by Jinns who were of the True Believers, and presently came out a Jinniyah who, seeing Hasan asleep, marvelled at his beauty and loveliness and cried, \"Glory to God!",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000030_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000030_000007.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Now the cause of his departure was that one night, as we were sitting together and talking of wives and children to come, we had words on the matter and he went off in high dudgeon.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000030_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000030_000009.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "I have lately heard that my brother died at Bassorah, where he married the daughter of the Wazir and that she bare him a son; and I will not marry my daughter but to him in honour of my brother's memory.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000030_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000030_000011.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "Now, by the life of my head I will marry her to the meanest of my men in spite of the nose of thee!",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2068_146217_000030_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2068/146217/2068_146217_000030_000014.wav",
        "speaker_id": "LibriTTS_R-2068",
        "content": "As for the Minister's daughter she sitteth among her nurses and tirewomen, weeping and wailing; for they have forbidden her father to come near her.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    }
]