        "speaker_id": "LibriTTS_R-1650",
        "content": "But no, it can't be true that I am in Moscow,\" he suddenly thought.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1650_173552_000012_000010",
