        "speaker_id": "LibriTTS_R-1650",
        "content": "It is terser and more to the point than most panegyrics: \"A pipe!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1650_157641_000049_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1650/157641/1650_157641_000049_000006.wav",
        "speaker_id": "LibriTTS_R-1650",
        "content": "It is a great soother, a pleasant comforter.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
