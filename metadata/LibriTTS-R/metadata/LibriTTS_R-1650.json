        "speaker_id": "LibriTTS_R-1650",
        "content": "\"I don't understand what is meant by 'a skillful commander,'\" replied Prince Andrew ironically.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
