        "speaker_id": "LibriTTS_R-1650",
        "content": "A general with a brilliant suite galloped off at once to fetch the boyars.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1650_173552_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1650/173552/1650_173552_000016_000001.wav",
        "speaker_id": "LibriTTS_R-1650",
        "content": "Napoleon had lunched and was again standing in the same place on the Poklonny Hill awaiting the deputation.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
