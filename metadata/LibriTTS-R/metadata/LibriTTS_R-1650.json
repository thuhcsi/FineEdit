        "speaker_id": "LibriTTS_R-1650",
        "content": "The dwarf's tastes, however, were catholic.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
