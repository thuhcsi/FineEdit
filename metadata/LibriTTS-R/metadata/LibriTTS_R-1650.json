        "speaker_id": "LibriTTS_R-1650",
        "content": "Meanwhile an agitated consultation was being carried on in whispers among his generals and marshals at the rear of his suite.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
