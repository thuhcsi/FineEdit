        "speaker_id": "LibriTTS_R-1650",
        "content": "\"Ask them,\" replied Prince Andrew, indicating the officers.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1650_167613_000019_000006",
