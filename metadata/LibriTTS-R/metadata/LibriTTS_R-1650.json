        "speaker_id": "LibriTTS_R-1650",
        "content": "Kingsley's devotion to smoke seems to have surprised Tennyson, who was no light smoker himself.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
