        "speaker_id": "LibriTTS_R-1650",
        "content": "\"I was very glad of his appointment, that's all I know,\" replied Prince Andrew.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
