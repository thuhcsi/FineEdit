        "speaker_id": "LibriTTS_R-1650",
        "content": "CHAPTER twenty five",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1650_167613_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1650/167613/1650_167613_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1650",
        "content": "\"So you understand the whole position of our troops?\" Prince Andrew interrupted him.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
