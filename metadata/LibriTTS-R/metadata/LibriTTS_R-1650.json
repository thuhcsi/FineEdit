        "speaker_id": "LibriTTS_R-1650",
        "content": "The faces of those who were not conferring together were pale and perturbed.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1650_173552_000020_000004",
