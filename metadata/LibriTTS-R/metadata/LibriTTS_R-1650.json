        "speaker_id": "LibriTTS_R-1650",
        "content": "Carlyle, as every one knows, was a great smoker.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
