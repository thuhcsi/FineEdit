        "speaker_id": "LibriTTS_R-1650",
        "content": "\"But, gentlemen...\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
