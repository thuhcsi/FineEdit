        "speaker_id": "LibriTTS_R-1650",
        "content": "\"Well, then, you know more than anyone else, be it who it may,\" said Prince Andrew.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
