        "speaker_id": "LibriTTS_R-1650",
        "content": "\"Now, mrs Quilp,\" he says, \"I feel in a smoking humour, and shall probably blaze away all night.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
