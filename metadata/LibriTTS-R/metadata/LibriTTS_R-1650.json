        "speaker_id": "LibriTTS_R-1650",
        "content": "mr w m",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1650_157641_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1650/157641/1650_157641_000038_000000.wav",
        "speaker_id": "LibriTTS_R-1650",
        "content": "In more fashionable circles the mere possession of a pipe might be looked at askance.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
