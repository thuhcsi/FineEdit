        "speaker_id": "LibriTTS_R-1650",
        "content": "The growth of cigar smoking was rapid.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
