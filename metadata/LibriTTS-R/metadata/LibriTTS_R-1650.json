        "speaker_id": "LibriTTS_R-1650",
        "content": "The vulgar thing falls upon the floor, and Tom is ashamed to claim his property and so acknowledge his ownership of a pipe.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
