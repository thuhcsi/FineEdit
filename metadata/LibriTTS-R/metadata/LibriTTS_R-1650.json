        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1650/157641/1650_157641_000018_000002.wav",
        "speaker_id": "LibriTTS_R-1650",
        "content": "That was reserved for the secluded apartment after the ladies had gone to bed.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
