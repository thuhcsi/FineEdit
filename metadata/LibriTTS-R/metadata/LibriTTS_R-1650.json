        "speaker_id": "LibriTTS_R-1650",
        "content": "The pipe is a feature in all illustrations of Cogerian meetings.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
