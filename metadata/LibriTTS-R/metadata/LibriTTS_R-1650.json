        "speaker_id": "LibriTTS_R-1650",
        "content": "Another correspondent of the same journal, Colonel w f",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1650_157641_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1650/157641/1650_157641_000023_000003.wav",
        "speaker_id": "LibriTTS_R-1650",
        "content": "University men used to be rather particular about the pipes they smoked.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1650_157641_000023_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1650/157641/1650_157641_000023_000007.wav",
        "speaker_id": "LibriTTS_R-1650",
        "content": "Of course, in those days no one ever thought of smoking a pipe in the presence of ladies.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1650_157641_000025_000002",
