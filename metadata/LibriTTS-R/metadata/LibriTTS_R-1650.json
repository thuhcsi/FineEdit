        "speaker_id": "LibriTTS_R-1650",
        "content": "In Moscow they are saying heaven knows what about him....",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
