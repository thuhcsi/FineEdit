        "speaker_id": "LibriTTS_R-1650",
        "content": "This must have been before eighteen forty one, when Sir Astley died.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
