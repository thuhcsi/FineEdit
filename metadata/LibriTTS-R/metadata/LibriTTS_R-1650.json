        "speaker_id": "LibriTTS_R-1650",
        "content": "\"Yet here she is lying at my feet, with her golden domes and crosses scintillating and twinkling in the sunshine.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
