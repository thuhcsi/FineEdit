        "speaker_id": "LibriTTS_R-1650",
        "content": "He was himself carried away by the tone of magnanimity he intended to adopt toward Moscow.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
