[
    {
        "item_name": "LibriTTS_R-8168_116789_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000003_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And, for aught I know, after so many thousand years, it is still gushing out of the very selfsame spot.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000003_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "In his hand he held a bridle, studded with brilliant gems, and adorned with a golden bit.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000004_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Will you be kind enough to tell me whether the fountain has any name?\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000005_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Yes; it is called the Fountain of Pirene,\" answered the maiden; and then she added, \"My grandmother has told me that this clear fountain was once a beautiful woman; and when her son was killed by the arrows of the huntress Diana, she melted all away into tears.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000005_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And so the water, which you find so cool and sweet, is the sorrow of that poor mother's heart!\"",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"I should not have dreamed,\" observed the young stranger, \"that so clear a well spring, with its gush and gurgle, and its cheery dance out of the shade into the sunlight, had so much as one tear drop in its bosom!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000006_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And this, then, is Pirene?",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000006_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "I thank you, pretty maiden, for telling me its name.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000006_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "I have come from a far away country to find this very spot.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000008_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"The watercourses must be getting low, friend, in your part of the world,\" remarked he, \"if you come so far only to find the Fountain of Pirene.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000008_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But, pray, have you lost a horse?",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000008_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "If the horse was as fine as the bridle, you are much to be pitied for losing him.\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000009_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"I have lost no horse,\" said Bellerophon, with a smile.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000009_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"But I happen to be seeking a very famous one, which, as wise people have informed me, must be found hereabouts, if anywhere.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Some of you, my little friends, have probably heard that this Pegasus was a snow white steed, with beautiful silvery wings, who spent most of his time on the summit of Mount Helicon.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000012_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Oh, how fine a thing it is to be a winged horse!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000012_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "It was very pretty to behold him plunge into the fleecy bosom of a bright cloud, and be lost in it, for a moment or two, and then break forth from the other side.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000012_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Or, in a sullen rain storm, when there was a gray pavement of clouds over the whole sky, it would sometimes happen that the winged horse descended right through it, and the glad light of the upper region would gleam after him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000012_000004.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "In another instant, it is true, both Pegasus and the pleasant light would be gone away together.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000013_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "In the summer time, and in the beautifullest of weather, Pegasus often alighted on the solid earth, and, closing his silvery wings, would gallop over hill and dale for pastime, as fleetly as the wind.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000013_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Sometimes, too (but Pegasus was very dainty in his food), he would crop a few of the clover blossoms that happened to be sweetest.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "To the Fountain of Pirene, therefore, people's great grandfathers had been in the habit of going (as long as they were youthful and retained their faith in winged horses), in hopes of getting a glimpse at the beautiful Pegasus.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000014_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But, of late years, he had been very seldom seen. Indeed, there were many of the country folks, dwelling within half an hour's walk of the fountain, who had never beheld Pegasus, and did not believe that there was any such creature in existence.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000014_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "The country fellow to whom Bellerophon was speaking chanced to be one of those incredulous persons.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000015_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And that was the reason why he laughed.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000016_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Pegasus, indeed!\" cried he, turning up his nose as high as such a flat nose could be turned up-\"Pegasus, indeed!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000016_000005.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "No, no! I don't believe in Pegasus.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000017_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"I have some reason to think otherwise,\" said Bellerophon, quietly.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And then he turned to an old, gray man, who was leaning on a staff, and listening very attentively, with his head stretched forward and one hand at his ear, because, for the last twenty years, he had been getting rather deaf.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000019_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"And what say you, venerable sir?\" inquired he, \"In your younger days, I should imagine, you must frequently have seen the winged steed!\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Ah, young stranger, my memory is very poor!\" said the aged man.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000020_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But, nowadays, I hardly know what to think, and very seldom think about the winged horse at all.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000020_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "If I ever saw the creature, it was a long, long while ago; and, to tell you the truth, I doubt whether I ever did see him.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000020_000005.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Pegasus might have made those hoof marks; and so might some other horse.\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000022_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Once I thought I saw him,\" replied the maiden, with a smile and a blush.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000022_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"It was either Pegasus or a large white bird, a very great way up in the air.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000022_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And one other time, as I was coming to the fountain with my pitcher, I heard a neigh.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000022_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Oh, such a brisk and melodious neigh as that was!",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000025_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Well, my little fellow,\" cried Bellerophon, playfully pulling one of his curls, \"I suppose you have often seen the winged horse.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000026_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"That I have,\" answered the child, very readily.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000027_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"You are a fine little man!\" said Bellerophon, drawing the child closer to him.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000027_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Come, tell me all about it.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000028_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Why,\" replied the child, \"I often come here to sail little boats in the fountain, and to gather pretty pebbles out of its basin.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000028_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And sometimes, when I look down into the water, I see the image of the winged horse in the picture of the sky that is there.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000028_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "I wish he would come down, and take me on his back, and let me ride him up to the moon!",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000028_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000028_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But, if I so much as stir to look at him, he flies far away out of sight.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000030_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "He held the bridle, with its bright gems and golden bit, always ready in his hand.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000030_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000030_000005.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "They offered to sell him a horse, if he wanted one; and when Bellerophon declined the purchase, they tried to drive a bargain with him for his fine bridle.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000031_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But the gentle child, who had seen the picture of Pegasus in the water, comforted the young stranger more than all the naughty boys could torment him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000032_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And we shall find no better opportunity to speak about this matter than while he is waiting for Pegasus to appear.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000033_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000033_000004.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And a hot blast of fire came flaming out of each of its three mouths!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000033_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000033_000005.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Being an earthly monster, I doubt whether it had any wings; but, wings or no, it ran like a goat and a lion, and wriggled along like a serpent, and thus contrived to make about as much speed as all the three together.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000034_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Oh, the mischief, and mischief, and mischief that this naughty creature did!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000034_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "With its flaming breath, it could set a forest on fire, or burn up a field of grain, or, for that matter, a village, with all its fences and houses.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000034_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000034_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Mercy on us, little children, I hope neither you nor I will ever happen to meet a Chimaera!",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000035_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Bellerophon was one of the bravest youths in the world, and desired nothing so much as to do some valiant and beneficent deed, such as would make all mankind admire and love him.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000035_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000035_000005.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Bellerophon hesitated not a moment, but assured the king that he would either slay this dreaded Chimaera, or perish in the attempt.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000036_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But, in the first place, as the monster was so prodigiously swift, he bethought himself that he should never win the victory by fighting on foot.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000036_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "The wisest thing he could do, therefore, was to get the very best and fleetest horse that could anywhere be found.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000036_000002.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And what other horse in all the world was half so fleet as the marvellous horse Pegasus, who had wings as well as legs, and was even more active in the air than on the earth?",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000036_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000036_000004.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But, wonderful as it appeared, Bellerophon believed that Pegasus was a real steed, and hoped that he himself might be fortunate enough to find him; and, once fairly mounted on his back, he would be able to fight the Chimaera at better advantage.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000038_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "But, indeed, it was a weary and anxious time, while Bellerophon waited and waited for Pegasus, in hopes that he would come and drink at the Fountain of Pirene.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000038_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "He was afraid lest King Iobates should imagine that he had fled from the Chimaera.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000038_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000038_000003.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And as Pegasus came thither so seldom in these latter years, and scarcely alighted there more than once in a lifetime, Bellerophon feared that he might grow an old man, and have no strength left in his arms nor courage in his heart, before the winged horse would appear.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000038_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000038_000004.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Oh, how heavily passes the time, while an adventurous youth is yearning to do his part in life, and to gather in the harvest of his renown!",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000038_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000038_000005.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "How hard a lesson it is to wait! Our life is brief, and how much of it is spent in teaching us only this!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000039_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "Every morning the child gave him a new hope to put in his bosom, instead of yesterday's withered one.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000040_000000.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "\"Dear Bellerophon,\" he would cry, looking up hopefully into his face, \"I think we shall see Pegasus to day!\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8168_116789_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8168/116789/8168_116789_000041_000001.wav",
        "speaker_id": "LibriTTS_R-8168",
        "content": "And in that case poor Bellerophon would at least have been terribly scorched by the creature's breath, and would most probably have been killed and devoured.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    }
]