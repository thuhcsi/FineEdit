        "speaker_id": "LibriTTS_R-5217",
        "content": "They longed as earnestly as ever to hear about Him, and to read in His Book; but what was to be done?",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
