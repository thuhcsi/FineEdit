        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5217/24510/5217_24510_000043_000001.wav",
        "speaker_id": "LibriTTS_R-5217",
        "content": "According to the Samaritans, Moses was the only true prophet.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "low"
    },
    {
