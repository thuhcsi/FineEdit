        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5217/24510/5217_24510_000039_000002.wav",
        "speaker_id": "LibriTTS_R-5217",
        "content": "They are kept in a silver cylinder, covered with crimson satin, heavily embroidered with gold.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
