        "speaker_id": "LibriTTS_R-5217",
        "content": "Other copies soon afterwards came to light: the world had rediscovered the Samaritan Bible!",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "low"
    },
    {
