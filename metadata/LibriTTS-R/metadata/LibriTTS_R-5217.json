        "speaker_id": "LibriTTS_R-5217",
        "content": "The Samaritans, however, in their hatred of everything Jewish, refused to follow their example.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5217_24510_000033_000002",
