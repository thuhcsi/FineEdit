        "speaker_id": "LibriTTS_R-5217",
        "content": "By the blue waters of the Mediterranean Sea, on the coast of Egypt, lies Alexandria, a busy and prosperous city of to day.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
