        "speaker_id": "LibriTTS_R-254",
        "content": "The waters are the heats that the players take till they sweat again.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
