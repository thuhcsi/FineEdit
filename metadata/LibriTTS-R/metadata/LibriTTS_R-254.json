        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/254/12312/254_12312_000004_000009.wav",
        "speaker_id": "LibriTTS_R-254",
        "content": "The cords of the rackets are made of the guts of sheep or goats.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
