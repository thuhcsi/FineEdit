        "speaker_id": "LibriTTS_R-254",
        "content": "The globe terrestrial is the tennis ball.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-254_12312_000004_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/254/12312/254_12312_000004_000011.wav",
        "speaker_id": "LibriTTS_R-254",
        "content": "After playing, when the game is done, they refresh themselves before a clear fire, and change their shirts; and very willingly they make all good cheer, but most merrily those that have gained.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
