        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000031_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The Earl nodded his head.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
