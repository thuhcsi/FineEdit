[
    {
        "item_name": "LibriTTS_R-2275_150140_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000000_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "CHAPTER twenty seven",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Upon that motionless figure his sight gradually centred with every faculty of mind and soul.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000002_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "He knew the next moment the signal would be given that was to bring him either glory or shame from that iron statue. He ground his teeth together with stern resolve to do his best in the coming encounter, and murmured a brief prayer in the hallow darkness of his huge helm.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000002_000004.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "He gathered himself together, and the next moment a bugle sounded loud and clear.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000002_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000002_000005.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "In one blinding rush he drove his spurs into the sides of his horse, and in instant answer felt the noble steed spring forward with a bound.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000003_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Through all the clashing of his armor reverberating in the hollow depths of his helmet, he saw the mail clad figure from the other end of the lists rushing towards him, looming larger and larger as they came together.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Then he realized that he had met his opponent, and had borne the meeting well.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000004_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "As he turned his horse's head towards his own end of the lists, he saw the other trotting slowly back towards his station, also holding a broken spear shaft in his hand.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000005_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "When he had reached his own end of the lists, he flung away his broken spear, and Gascoyne came forward with another.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000006_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Oh, Myles!\" he said, with sob in his voice, \"it was nobly done.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000006_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Never did I see a better ridden course in all my life.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000006_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "I did not believe that thou couldst do half so well.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "When, in answer to the command of the Marshal, he took his place a second time, he found himself calmer and more collected than before, but every faculty no less intensely fixed than it had been at first.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000008_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Once more the Marshal raised his baton, once more the horn sounded, and once more the two rushed together with the same thunderous crash, the same splinter of broken spears, the same momentary trembling recoil of the horse, and the same onward rush past one another.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000009_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "This time as they met midway the Sieur de la Montaigne reined in his horse.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000009_000004.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Now I shall do my endeavor to unhorse thee as I would an acknowledged peer in arms.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000009_000005.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Nevertheless, on account of thy youth, I give thee this warning, so that thou mayst hold thyself in readiness.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Myles, with Gascoyne running beside him, rode across to his pavilion, and called to Edmund Wilkes to bring him a cup of spiced wine.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000012_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "After Gascoyne had taken off his helmet, and as he sat wiping the perspiration from his face Sir james came up and took him by the hand.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000013_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"My dear boy,\" said he, gripping the hand he held, \"never could I hope to be so overjoyed in mine old age as I am this day.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000013_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Thou dost bring honor to me, for I tell thee truly thou dost ride like a knight seasoned in twenty tourneys.\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000015_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Did he indeed so say?\" said Sir james.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000015_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Then belike he meaneth to strike at thy helm.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000016_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Not now,\" answered Myles.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Then keep thy head cool and thine eye true.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000019_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The charge that Sir james Lee had given to Myles to strike at his adversary's helm was a piece of advice he probably would not have given to so young a knight, excepting as a last resort.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000019_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "A blow perfectly delivered upon the helm was of all others the most difficult for the recipient to recover from, but then a blow upon the helm was not one time in fifty perfectly given.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000019_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The huge cylindrical tilting helm was so constructed in front as to slope at an angle in all directions to one point.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000020_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "It was of seasoned oak, somewhat thicker than the other, a tough weapon, not easily to be broken even in such an encounter as he was like to have.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000020_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "He balanced the weapon, and found that it fitted perfectly to his grasp. As he raised the point to rest, his opponent took his station at the farther extremity of the lists, and again there was a little space of breathless pause.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000020_000004.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Before, he had been conscious of the critical multitude looking down upon him; now it was a conflict of man to man, and such a conflict had no terrors for his young heart of iron.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The spectators had somehow come to the knowledge that this was to be a more serious encounter than the two which had preceded it, and a breathless silence fell for the moment or two that the knights stood in place.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000023_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Again he saw the iron figure of his opponent rushing nearer, nearer, nearer.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000023_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000023_000005.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "He felt his horse stagger under him with the recoil, and hardly knowing what he did, he drove his spurs deep into its sides with a shout.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000023_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000023_000007.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "He heard a great shout arise from all, and thought, with a sickening, bitter disappointment, that it was because he had lost.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000024_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "There, in a tangle of his horse's harness and of embroidered trappings, the Sieur de la Montaigne lay stretched upon the ground, with his saddle near by, and his riderless horse was trotting aimlessly about at the farther end of the lists.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000025_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Myles saw the two squires of the fallen knight run across to where their master lay, he saw the ladies waving their kerchiefs and veils, and the castle people swinging their hats and shouting in an ecstasy of delight. Then he rode slowly back to where the squires were now aiding the fallen knight to arise.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000025_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The senior squire drew his dagger, cut the leather points, and drew off the helm, disclosing the knight's face-a face white as death, and convulsed with rage, mortification, and bitter humiliation.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000027_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Sir,\" said the Marshal calmly, and speaking in French, \"surely thou knowest that the loss of helmet does not decide an encounter.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000027_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "If he then was justified in doing so of his own choice, and wilfully suffering to be unhelmed, how then can this knight be accused of evil who suffered it by chance?\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000028_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Nevertheless,\" said the Sieur de la Montaigne, in the same hoarse, breathless voice, \"I do affirm, and will make my affirmation good with my body, that I fell only by the breaking of my girth.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000028_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Who says otherwise lies!\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000029_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"It is the truth he speaketh,\" said Myles.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000029_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"I myself saw the stitches were some little what burst, and warned him thereof before we ran this course.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000030_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Was it not right knightly for him so to do?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000032_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Gascoyne had picked up Myles's fallen helmet as the Sieur de la Montaigne moved away, and Lord George and Sir james Lee came walking across the lists to where Myles still sat",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000033_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Myles, his heart swelling with a passion of triumphant delight, looked up and met the gaze of Lady Alice fixed intently upon him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000033_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "A red spot of excitement still burned in either cheek, and it flamed to a rosier red as he bowed his head to her before turning away.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000034_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Gascoyne had just removed Myles's breastplate and gorget, when Sir james Lee burst into the pavilion.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150140_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150140/2275_150140_000034_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "All his grim coldness was gone, and he flung his arms around the young man's neck, hugging him heartily, and kissing him upon either cheek.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000001_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "It was not until more than three weeks after the King had left Devlen Castle that Lord George and his company of knights and archers were ready for the expedition to France.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000001_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Two weeks of that time Myles spent at Crosbey Dale with his father and mother.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000001_000003.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "He had never appreciated before how low and narrow and poor the farm house was.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000001_000004.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Now, with his eyes trained to the bigness of Devlen Castle, he looked around him with wonder and pity at his father's humble surroundings.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000002_000003.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Prior Edward added many things to those which Myles already knew-things of which the Earl either did not know, or did not choose to speak.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000003_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Haply my father was Bolingbroke's enemy, but, sure, thou dost not believe he is justly and rightfully tainted with treason?\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Nay,\" answered the priest, \"how canst thou ask me such a thing?",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000004_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Nay, Myles, I do know thy father well, and have known him for many years, and this of him, that few men are so honorable in heart and soul as he.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000007_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Meseems even an evil thing is sometimes passing good when rightfully used.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000009_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "So Myles went to France in Lord George's company, a soldier of fortune, as his Captain was.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000009_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "He was there for only six months, but those six months wrought a great change in his life.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000010_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Then one day a courier came, bringing a packet.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000011_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "It was a bright day in April when he and Gascoyne rode clattering out through Temple Bar, leaving behind them quaint old London town, its blank stone wall, its crooked, dirty streets, its high gabled wooden houses, over which rose the sharp spire of saint Paul's, towering high into the golden air.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "It was the first time that Myles had seen famous London town.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000012_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Now he jogged along with Gascoyne, gazing about him with calm interest at open shops and booths and tall, gabled houses; at the busy throng of merchants and craftsmen, jostling and elbowing one another; at townsfolk-men and dames-picking their way along the muddy kennel of a sidewalk.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000013_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "It was with a great deal of interest that Myles and his patron regarded one another when they met for the first time after that half year which the young soldier had spent in France.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000013_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "To Myles it seemed somehow very strange that his Lordship's familiar face and figure should look so exactly the same.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000013_000003.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The rugged exposure in camp and field during the hard winter that had passed had roughened the smooth bloom of his boyish complexion and bronzed his fair skin almost as much as a midsummer's sun could have done.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000013_000004.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "His beard and mustache had grown again, (now heavier and more mannish from having been shaved), and the white seam of a scar over the right temple gave, if not a stern, at least a determined look to the strong, square jawed young face.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000013_000006.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Myles was the first to break the silence.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000015_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"When didst thou land, Sir Myles?\" said the Earl.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The Earl of Mackworth stroked his beard softly.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Myles smiled somewhat grimly.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000018_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"I have seen such things, my Lord, in France and in Paris,\" said he, quietly, \"as, mayhap, may make a lad a man before his time.\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000019_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"From which I gather,\" said the Earl, \"that many adventures have befallen thee.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000020_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "A little space of silence followed, during which the Earl sat musingly, half absently, regarding the tall, erect, powerful young figure standing before him, awaiting his pleasure in motionless, patient, almost dogged silence.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000020_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The strong, sinewy hands were clasped and rested upon the long heavy sword, around the scabbard of which the belt was loosely wrapped, and the plates of mail caught and reflected in flashing, broken pieces, the bright sunlight from the window behind.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Sir Myles,\" said the Earl, suddenly, breaking the silence at last, \"dost thou know why I sent for thee hither?\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000022_000003.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "I am here.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000023_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"I do hope that thy deeds be as bold as thy words.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000024_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"That,\" said Myles, \"thou must ask other men.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000024_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Methinks no one may justly call me coward.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000025_000002.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The time is now nearly ripe, and I will straightway send for thy father to come to London.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000026_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "The Earl waited for a little while, as though to give him the opportunity to answer.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000027_000001.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "Meseems thou takest all this with marvellous coolness.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2275_150141_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2275/150141/2275_150141_000028_000000.wav",
        "speaker_id": "LibriTTS_R-2275",
        "content": "\"Have I then my Lord's permission to speak my mind?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
