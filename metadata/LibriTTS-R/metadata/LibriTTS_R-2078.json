        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2078/142845/2078_142845_000019_000010.wav",
        "speaker_id": "LibriTTS_R-2078",
        "content": "If baked in tins or pans, rub them with a tiny piece of butter laid on a piece of clean paper, to prevent the dough from sticking to them.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
