    {
        "item_name": "LibriTTS_R-2078_142845_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2078/142845/2078_142845_000019_000002.wav",
        "speaker_id": "LibriTTS_R-2078",
        "content": "Pour the yeast into the hole made in the flour, and stir into it as much of that which lies round it as will make a thick batter, in which there must be no lumps.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2078_142845_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2078/142845/2078_142845_000019_000003.wav",
        "speaker_id": "LibriTTS_R-2078",
        "content": "Strew plenty of flour on the top; throw a thick clean cloth over, and set it where the air is warm; but do not place it upon the kitchen fender, for it will become too much heated there.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2078_142845_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2078/142845/2078_142845_000019_000004.wav",
        "speaker_id": "LibriTTS_R-2078",
        "content": "Look at it from time to time: when it has been laid for nearly an hour, and when the yeast has risen and broken through the flour, so that bubbles appear in it, you will know that it is ready to be made up into dough.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2078_142845_000019_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2078/142845/2078_142845_000019_000005.wav",
        "speaker_id": "LibriTTS_R-2078",
        "content": "Then place the pan on a strong chair, or dresser, or table, of convenient height; pour into the sponge the remainder of the warm milk and water; stir into it as much of the flour as you can with the spoon; then wipe it out clean with your fingers, and lay it aside.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2078_142845_000019_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2078/142845/2078_142845_000019_000008.wav",
        "speaker_id": "LibriTTS_R-2078",
        "content": "In three quarters hour look at it, and should it have swollen very much, and begin to crack, it will be light enough to bake.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
