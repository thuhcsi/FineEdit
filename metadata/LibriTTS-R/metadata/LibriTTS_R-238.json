        "speaker_id": "LibriTTS_R-238",
        "content": "Jane struck it softly, lingeringly; then rose, turned from the piano, and was leaving the platform, when a sudden burst of wild applause broke from the audience.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
