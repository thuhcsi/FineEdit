        "speaker_id": "LibriTTS_R-238",
        "content": "The accompaniment, which opens with a single chord, closes with a single note.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
