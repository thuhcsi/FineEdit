        "speaker_id": "LibriTTS_R-238",
        "content": "In the pause which followed, could be heard the tension of feeling produced.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-238_122530_000017_000002",
