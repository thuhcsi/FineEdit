        "speaker_id": "LibriTTS_R-238",
        "content": "Then with a sudden movement he caught her by the shoulders and turned her round.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
