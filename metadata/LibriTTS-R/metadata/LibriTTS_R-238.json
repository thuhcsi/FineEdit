        "speaker_id": "LibriTTS_R-238",
        "content": "He remained motionless until she stepped from the last stair and stood close to him.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
