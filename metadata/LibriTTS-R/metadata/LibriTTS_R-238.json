        "speaker_id": "LibriTTS_R-238",
        "content": "\"O memories that bless and burn! O barren gain and bitter loss! I kiss each bead, and strive at last to learn To kiss the cross ... to kiss the cross.\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
