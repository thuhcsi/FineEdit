        "speaker_id": "LibriTTS_R-238",
        "content": "\"Then why this flattering demonstration?\" inquired Jane, laughing.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
