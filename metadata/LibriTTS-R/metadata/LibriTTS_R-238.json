        "speaker_id": "LibriTTS_R-238",
        "content": "His face was absolutely colourless, and his eyes shone out from it like burning stars.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
