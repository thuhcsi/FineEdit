        "speaker_id": "LibriTTS_R-238",
        "content": "\"I do not know whether I liked your song.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
