[
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000001.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "To what a state am I reduced, and for what?",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000013.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "This, you see, she has done, because my intentions grew serious, and if complied with, would deprive her of THE PLEASURES OF A SINGLE LIFE!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000018.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Such is her power over me!",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000019",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000019.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I cannot run the least risk of offending her-I love her so.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000020.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "When I look in her face, I cannot doubt her truth!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000021",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000021.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Wretched being that I am!",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000027",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000027.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "It lies low in a rude, but sheltered valley, hid from the vulgar gaze, and powerfully reminds one of the old song.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000031",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000031.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Demoniacal possessions.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000007_000034",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000007_000034.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "The moonlight streams over the silver waters: the bark is in the bay that might waft me to her, almost with a wish.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000010_000003.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "\"To the winds, to the waves, to the rocks I complain\"--you may suppose with what effect! I fear I shall be obliged to return.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000011_000003.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Is it not so, that poets see nature, veiled to the sight, but revealed to the soul in visionary grace and grandeur!",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000011_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000011_000008.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I was at Stirling Castle not long ago.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000011_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000011_000013.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I wept myself almost blind, and I gazed at the broad golden sunset through my tears that fell in showers.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000011_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000011_000015.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "There was a time when I could bear solitude; but it is too much for me at present.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000011_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000011_000017.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "She was my stay, my hope: without her hand to cling to, I stagger like an infant on the edge of a precipice.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000011_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000011_000018.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "The universe without her is one wide, hollow abyss, in which my harassed thoughts can find no resting place.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "My dear and good Friend, I am afraid I trouble you with my querulous epistles, but this is probably the last.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "To morrow or the next day decides my fate with respect to the divorce, when I expect to be a free man.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000002.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "In vain!",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000004.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "If so, I hardly think I can survive it.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000011.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "\"Why can you not go on as we have done, and say nothing about the word, FOREVER?\" Was it not plain from this that she even then meditated an escape from me to some less sentimental lover?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000013.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "\"No, not now!\" was her answer; that is, because there was nobody else in the house to take freedoms with her.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000014.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I was very well as a stopgap, but I was to be nothing more.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000016.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "It was then my mad proceedings commenced.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000020.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "\"She has had,\" she says, \"enough of my conversation,\" so it could not be that!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000023",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000023.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Intolerable conviction!",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000029",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000029.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I see nothing for it but madness, unless Friday brings a change, or unless she is willing to let me go back.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000013_000031",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000013_000031.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "What effect it will have, I know not.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000014_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Ever yours.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000015_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "TO s l",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000016_000002.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Your sweet friendship was the balm of my life; and I have lost it, I fear for ever, by one fault and folly after another. What would I give to be restored to the place in your esteem, which, you assured me, I held only a few months ago!",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000016_000004.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Can you not forget and forgive the past, and judge of me by my conduct in future?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000017_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Your obliged friend,",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000018_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "And sincere well wisher.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000019_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "LETTER twelve.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000020_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "TO c P----",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000021_000001.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I'm mad.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000021_000002.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I wish you to call on M---- in confidence, to say I intend to make her an offer of my hand, and that I will write to her father to that effect the instant I am free, and ask him whether he thinks it will be to any purpose, and what he would advise me to do.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000022_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "UNALTERED LOVE",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000023_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "\"Love is not love that alteration finds: Oh no! it is an ever fixed mark, That looks on tempests and is never shaken.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000024_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Shall I not love her for herself alone, in spite of fickleness and folly?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000024_000001.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "To love her for her regard to me, is not to love her, but myself.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000024_000002.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "She has robbed me of herself: shall she also rob me of my love of her?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000024_000003.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Did I not live on her smile?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000024_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000024_000004.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Is it less sweet because it is withdrawn from me?",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000024_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000024_000005.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Did I not adore her every grace?",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000024_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000024_000010.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "This is my idea of the only true and heroic love!",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000025_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "PERFECT LOVE",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000026_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Perfect love has this advantage in it, that it leaves the possessor of it nothing farther to desire.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000026_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000026_000004.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "What idle sounds the common phrases, adorable creature, angel, divinity, are?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000028_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "London, july fourth eighteen twenty two.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000029_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000029_000005.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "But he sees great difficulties attending the affair-which he frankly professes to consider as an altogether unfortunate one.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000029_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000029_000012.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "In fact as I said before, the affair rests entirely with herself.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000030_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000030_000007.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Of course I use the terms \"wise\" and \"prudent\" with reference to your object. Whether the pursuit of that object is wise, only yourself can judge.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000030_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000030_000015.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "He once, and without my referring in the slightest manner to that part of the subject, spoke of her as a GOOD GIRL, and LIKELY TO MAKE ANY MAN AN EXCELLENT WIFE!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000031_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Believe me,",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000032_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Ever truly your friend,",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000033_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "c p",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000034_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "LETTER thirteen",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000035_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "My dear P----, You have saved my life.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000035_000001.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "If I do not keep friends with her now, I deserve to be hanged, drawn, and quartered.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000035_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000035_000003.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "What could she find in me?",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000035_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000035_000009.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "But I will have such a kiss when I get back, as shall last me twenty years. May God bless her for not utterly disowning and destroying me!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000035_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000035_000014.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "You see I am not hard to please, after all.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000035_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000035_000020.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I deserve to call her mine; for nothing else CAN atone for what I've gone through for her.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000036_000001.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "There are good people in the world: I begin to see it, and believe it.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000037_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "LETTER THE LAST",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000000.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Dear P----, To morrow is the decisive day that makes me or mars me.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000003.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "My reception with her is doubtful, and my fate is then certain.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000006.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "You are going abroad, you say, happy in making happy.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000007.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Where shall I be?",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000008.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "In the grave, I hope, or else in her arms.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000009.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "To me, alas! there is no sweetness out of her sight, and that sweetness has turned to bitterness, I fear; that gentleness to sullen scorn!",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000010.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Still I hope for the best.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000012.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "Her holding out to the last also, I think, proves that she was never to have been gained but with honour.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000014.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "I should be most proud.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6804_79287_000038_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6804/79287/6804_79287_000038_000016.wav",
        "speaker_id": "LibriTTS_R-6804",
        "content": "In the latter case I shall be there, and visible on Saturday evening.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    }
]