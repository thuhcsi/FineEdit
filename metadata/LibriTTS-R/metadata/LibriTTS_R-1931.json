[
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000001.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "But his good friend was unable to recognise him by his utterance; for he was prevented by his low tone and by his voice which was hoarse, weak, and broken; for his blood was all stirred up by the blows he had received.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000002.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "\"My lord,\" he says, \"the night comes on!",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000003.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I think no blame or reproach will attach to us if the night comes between us.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000007.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "And if I should tell you the simple truth, I think you would not be loath to hear it, for if I have lent you anything of mine, you have fully paid me back, principal and interest; for you were more ready to pay back than I was to accept the payment.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000009.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Through what unhappy ignorance in not recognising each other have we waged this battle!",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000010.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "For if I had known who you were, I should never have fought with you; but, upon my word, I should have surrendered without a blow.\" \"How is that?\" my lord Gawain inquires, \"who are you, then?\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000013.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "This honour shall never be claimed as mine, but it shall be yours, to whom I resign it.\" \"Ah, fair sire, do not speak so.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000014.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "For that could never be.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000018.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I, Gawain, who am your nephew, did not recognise this companion of mine, my lord Yvain, until he fortunately, by the will of God, asked me my name.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000021",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000021.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "But I would rather be defeated than killed by a friend in battle.\" Then my lord Yvain's blood was stirred, as he said to him in reply: \"Fair dear sire, so help me God, you have no right to say so much.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000022",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000022.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Let my lord, The King, well know in this battle I am surely the one who has been defeated and overcome!\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000025",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000025.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "He was well pleased with what he heard and with the sight of them in each other's arms, though they had wounded and injured each other in several places.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000026",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000026.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "\"My lords,\" he says, \"there is deep affection between you two.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000028",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000028.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Now leave it all to me!",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000029",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000029.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "For I think I can arrange it in such a way that it will redound to your honour, and every one will give consent.\" Then they both promised him that they would do his will in every particular.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000030",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000030.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "And the King says that he will decide the quarrel fairly and faithfully.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000033",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000033.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I saw plainly some time ago that you were disinheriting her.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000034",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000034.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "But her right shall no longer be denied; for you yourself have avowed the truth to me.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000035",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000035.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "You must now resign her share to her.\" \"Sire,\" she says, \"if I uttered a foolish and thoughtless word, you ought not to take me up in it.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000036",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000036.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "For God's sake, sire, do not be hard on me!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000037",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000037.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "You are a king, and you ought to guard against wrong and error.\" The King replies: \"That is precisely why I wish to give your sister her rights; for I have never defended what is wrong.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000040",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000040.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "In his desire to honour the other, each one says that he has been defeated.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000041",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000041.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "But there is no need to delay further: since the matter has been left to me, either you will do in all respects what I say, without resistance, or I shall announce that my nephew has been defeated in the fight.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000043",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000043.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "In fear and apprehension, she replied to him: \"Fair lord, I must now respect your desire, though my heart is very loath to yield.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000046",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000046.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Then the King asked the valiant and brave knight who was his nephew to allow himself to be disarmed; and he requested my lord Yvain to lay aside his arms also; for now they may well dispense with them.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000047",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000047.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Then the two vassals lay aside their arms and separate on equal terms.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000048",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000048.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "And while they are taking off their armour, they see the lion running up in search of his master.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000049",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000049.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "As soon as he catches sight of him, he begins to show his joy.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000050",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000050.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Then you would have seen people draw aside, and the boldest among them takes to flight. My lord Yvain cries out: \"Stand still, all!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000051",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000051.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Why do you flee?",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000052",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000052.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "No one is chasing you.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000053",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000053.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Have no fear that yonder lion will do you harm.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000057",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000057.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I have been thinking about you for some time, and I was troubled because it was said that we were acquainted as loving friends.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000000_000060",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000000_000060.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "King Arthur, who loved them well, had them both brought before him, and summoned a surgeon whose knowledge of surgery was supreme.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000001.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "But he had with him his lion, who never in his life wished to desert him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000002.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "They travelled until they saw the spring and made the rain descend.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000003.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Think not that this is a lie of mine, when I tell you that the disturbance was so violent that no one could tell the tenth part of it: for it seemed as if the whole forest must surely be engulfed.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000004.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "The lady fears for her town, lest it, too, will crumble away; the walls totter, and the tower rocks so that it is on the verge of falling down.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000005.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "The bravest Turk would rather be a captive in Persia than be shut up within those walls.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000008.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "In the future we shall never be secure in this town, nor dare to pass beyond the walls and gate.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000010.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "If it is true that you have no one to defend your spring, you will appear ridiculous and humiliated.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000011.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "It will redound greatly to your honour, forsooth, if he who has attacked you shall retire without a fight!",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000013.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "\"Indeed, lady, if I had any plan, I should gladly propose it to you.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000016.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Say no more of the people of my household; for I cherish no further expectation that the spring and its marble brim will ever be defended by any of them.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000019",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000019.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "\"I have no objection,\" the lady says. With delicate courtesy, Lunete procured at once for her a very precious relic, and the lady fell upon her knees.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000020.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Thus Lunete very courteously accepted her upon her oath.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000021",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000021.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "In administering the oath, she forgot nothing which it might be an advantage to insert.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000023",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000023.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I do not wish that the day after to morrow you should lay any charge upon me; for you are not doing anything for me, but you are acting for your own good.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000001_000025",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000001_000025.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "If I have the strength and ability, I will restore to him the love and favour which with his lady he once enjoyed.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "Indeed, she had thought that she would have to seek afar before discovering him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000003.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "As soon as she saw him, she recognised him by the lion, and coming toward him rapidly, she dismounted upon the solid earth.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000006.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "He could not sufficiently show his gratitude to her who had accomplished this for him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000007.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "He kisses her eyes, and then her face, saying: \"Surely, my sweet friend, I can never repay you for this service.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000008.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I fear that ability and time will fail me to do you the honour and service which is your due.\" \"Sire,\" she replies, \"have no concern, and let not that thought worry you!",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000009.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "For you will have an abundance of strength and time to show me and others your good will.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000010.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "If I have paid this debt I owed, I am entitled to only so much gratitude as the man who borrows another's goods and then discharges the obligation. Even now I do not consider that I have paid you the debt I owed.\" \"Indeed you have, as God sees me, more than five hundred thousand times. Now, when you are ready, let us go.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000011.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "But have you told her who I am?\" \"No, I have not, upon my word.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000002_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000002_000012.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "She knows you only by the name of 'The Knight with the Lion.'\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "They said not a word to any man or woman there, until they arrived where the lady was.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000003_000005.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "For he has no other mistress than you. This is your husband, my lord Yvain.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "You have caught me neatly in a trap!",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "You will make me love, in spite of myself, a man who neither loves nor esteems me.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "This is a fine piece of work, and a charming way of serving me!",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I would rather endure the winds and the tempests all my life: And if it were not a mean and ugly thing to break one's word, he would never make his peace or be reconciled with me.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000004_000005.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "This purpose would have always lurked within me, as a fire smoulders in the ashes; but I do not wish to renew it now, nor do I care to refer to it, since I must be reconciled with him.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000005_000002.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "I have had to pay, and dearly to pay, for my mad act.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000005_000003.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "It was madness that made me stay away, and I now admit my guilt and sin.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000005_000005.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "So, if you please, I grant your request.\" \"Lady,\" says he, \"so truly as God in this mortal life could not otherwise restore me to happiness, so may the Holy Spirit bless me five hundred times!\"",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1931_156647_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1931/156647/1931_156647_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1931",
        "content": "All has turned out well at last; for he is beloved and treasured by his lady, and she by him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    }
]