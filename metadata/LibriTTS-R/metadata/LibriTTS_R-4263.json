        "speaker_id": "LibriTTS_R-4263",
        "content": "\"Lean on me.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
