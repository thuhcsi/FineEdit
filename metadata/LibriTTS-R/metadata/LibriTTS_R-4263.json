        "speaker_id": "LibriTTS_R-4263",
        "content": "Just one?",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000038_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000038_000007.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "You know I'm going away, and that is why I spoke to you now.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
