        "speaker_id": "LibriTTS_R-4263",
        "content": "\"Because-lots of reasons.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
