        "speaker_id": "LibriTTS_R-4263",
        "content": "What did you go without your crutch for?",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "normal"
