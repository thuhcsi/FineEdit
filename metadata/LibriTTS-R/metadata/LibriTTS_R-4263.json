        "speaker_id": "LibriTTS_R-4263",
        "content": "Long this night he lay planning and thinking.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
