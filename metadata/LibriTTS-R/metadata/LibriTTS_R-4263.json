        "speaker_id": "LibriTTS_R-4263",
        "content": "I won't get flour on your coat.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
