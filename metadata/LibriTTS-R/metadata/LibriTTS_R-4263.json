        "speaker_id": "LibriTTS_R-4263",
        "content": "\"That's all right.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000038_000001.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "I can wait.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "low"
    },
    {
