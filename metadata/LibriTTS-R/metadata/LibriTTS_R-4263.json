        "speaker_id": "LibriTTS_R-4263",
        "content": "\"I always ask people to go when I don't want them to.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
