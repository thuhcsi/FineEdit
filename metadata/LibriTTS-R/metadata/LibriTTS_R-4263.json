        "speaker_id": "LibriTTS_R-4263",
        "content": "Should he speak to Betty and tell her he loved her?",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very high"
    },
    {
