        "speaker_id": "LibriTTS_R-4263",
        "content": "I didn't dare go without telling you this first.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
