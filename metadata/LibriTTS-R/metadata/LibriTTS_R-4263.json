        "speaker_id": "LibriTTS_R-4263",
        "content": "Don't you see you're getting flour all over your clothes?\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
