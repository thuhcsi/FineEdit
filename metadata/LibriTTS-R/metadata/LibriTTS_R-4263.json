        "speaker_id": "LibriTTS_R-4263",
        "content": "\"It's rather late for a business call,\" said an apologetic voice outside, \"but my client was anxious to see you without delay.\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
