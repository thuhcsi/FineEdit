        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000028_000004.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "His discretion was all gone.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000030_000001.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "\"Please, Betty, dear! just hear me this far.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000030_000002.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "I'm going away, Betty, and I love you.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000030_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000030_000005.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "It's love, and it's what I want you to feel for me.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000030_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000030_000008.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "Say you'll love me and be my wife-some day-won't you, Betty?\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000031_000000.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "She drooped in his arms, hanging her head and looking down on her floury hands.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000033_000000.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "Her lip quivered.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4263_16194_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4263/16194/4263_16194_000033_000001.wav",
        "speaker_id": "LibriTTS_R-4263",
        "content": "\"I don't want to be anybody's wife-and, anyway-I liked you better the other way.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
