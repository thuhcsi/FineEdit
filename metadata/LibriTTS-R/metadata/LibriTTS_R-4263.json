        "speaker_id": "LibriTTS_R-4263",
        "content": "It's very silly of you.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
