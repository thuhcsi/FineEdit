        "speaker_id": "LibriTTS_R-2709",
        "content": "The exciting national election contest was approaching.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
