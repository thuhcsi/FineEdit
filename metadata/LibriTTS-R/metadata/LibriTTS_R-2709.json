        "speaker_id": "LibriTTS_R-2709",
        "content": "Women from all the voting states assembled in a mass convention september fourteenth fifteen and sixteen.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2709_158074_000023_000001",
