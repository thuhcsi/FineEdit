        "speaker_id": "LibriTTS_R-2709",
        "content": "\"Sirs, that depends upon what you gentlemen do.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
