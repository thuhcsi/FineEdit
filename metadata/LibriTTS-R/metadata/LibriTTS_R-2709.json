        "speaker_id": "LibriTTS_R-2709",
        "content": "This visit of the representatives of women with power marked rather an advance in the President's position.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
