        "speaker_id": "LibriTTS_R-2709",
        "content": "Nor did they relish spending more money publishing more literature, in short, adding greatly to the burdens of their campaign.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
