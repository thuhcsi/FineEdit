        "speaker_id": "LibriTTS_R-2709",
        "content": "The envoys waited upon the President at the White House.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
