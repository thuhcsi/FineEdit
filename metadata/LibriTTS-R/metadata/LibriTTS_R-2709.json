        "speaker_id": "LibriTTS_R-2709",
        "content": "Casting a vote for it would help his case with women voters, and still not bring suffrage in the East a step nearer.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
