        "speaker_id": "LibriTTS_R-2709",
        "content": "Logic must not be pressed too hard upon the \"reasoning\" sex.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
