        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2709/158074/2709_158074_000032_000000.wav",
        "speaker_id": "LibriTTS_R-2709",
        "content": "No more questions on mother and home!",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
