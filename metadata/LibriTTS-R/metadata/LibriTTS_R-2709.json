        "speaker_id": "LibriTTS_R-2709",
        "content": "Oh, no, indeed; it was men's business to keep the nation out of war.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
