        "speaker_id": "LibriTTS_R-2709",
        "content": "The envoys replied by asking that their message be carried by friends of the measure to the floor of the Senate and House, and this was done.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
