        "speaker_id": "LibriTTS_R-2709",
        "content": "To be sure, they were planks that failed to satisfy us.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
