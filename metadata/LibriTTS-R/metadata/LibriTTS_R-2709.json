        "speaker_id": "LibriTTS_R-2709",
        "content": "\"You can do no good here.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
