        "speaker_id": "LibriTTS_R-2709",
        "content": "For the first time in history representatives of men's political parties came to plead before these women voters for the support of their respective parties.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
