        "speaker_id": "LibriTTS_R-2709",
        "content": "power to free women; a party which became a potent factor of protest in the following national election.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
