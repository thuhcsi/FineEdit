        "speaker_id": "LibriTTS_R-2709",
        "content": "These women from the deserts of Arizona, from the farms of Oregon, from the valleys of California, from the mountains of Nevada and Utah, were in deadly earnest.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
