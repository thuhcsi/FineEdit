        "speaker_id": "LibriTTS_R-2709",
        "content": "All laid their claims for suffrage support before the women with the result that the convention resolved itself into another political party The Woman's Party.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
