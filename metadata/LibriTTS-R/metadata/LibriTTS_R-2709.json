        "speaker_id": "LibriTTS_R-2709",
        "content": "The instant response which met this appeal surpassed the most optimistic hopes.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2709_158074_000042_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2709/158074/2709_158074_000042_000002.wav",
        "speaker_id": "LibriTTS_R-2709",
        "content": "For the first time in history, women came together to organize their political power into a party to free their own sex.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2709_158074_000042_000003",
