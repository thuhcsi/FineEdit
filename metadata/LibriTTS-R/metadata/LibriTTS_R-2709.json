        "speaker_id": "LibriTTS_R-2709",
        "content": "But the mere hint of organized political action on suffrage had moved the two dominant parties to advance a step.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
