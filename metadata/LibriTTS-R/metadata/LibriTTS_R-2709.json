        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2709_158074_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2709/158074/2709_158074_000014_000000.wav",
        "speaker_id": "LibriTTS_R-2709",
        "content": "Our aim in this campaign was primarily to call to the attention of the public the bad suffrage record of the Democratic Party. The effect of our campaign was soon evident in Congress.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2709_158074_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2709/158074/2709_158074_000014_000001.wav",
        "speaker_id": "LibriTTS_R-2709",
        "content": "The most backward member realized for the first time that women had voted. Even the President perceived that the movement had gained new strength, though he was not yet politically moved by it.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2709_158074_000018_000002",
