        "speaker_id": "LibriTTS_R-6848",
        "content": "Why didn't the girl confide in her father at least about these things?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
