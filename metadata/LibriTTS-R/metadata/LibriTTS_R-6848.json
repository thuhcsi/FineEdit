        "speaker_id": "LibriTTS_R-6848",
        "content": "That affair was all right, quite all right.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
