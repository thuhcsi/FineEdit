        "speaker_id": "LibriTTS_R-6848",
        "content": "\"I ought to see more of her,\" he thought.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
