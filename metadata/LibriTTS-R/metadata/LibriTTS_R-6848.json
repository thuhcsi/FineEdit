        "speaker_id": "LibriTTS_R-6848",
        "content": "He fought against it as a possibility.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
