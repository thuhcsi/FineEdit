        "speaker_id": "LibriTTS_R-6848",
        "content": "But if it was for some other lover, some good looking, worthless impostor, some European title or suchlike folly-!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
