        "speaker_id": "LibriTTS_R-6848",
        "content": "But suppose she was not all ordinary female person....",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
