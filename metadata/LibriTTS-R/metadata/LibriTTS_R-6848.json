        "speaker_id": "LibriTTS_R-6848",
        "content": "It is duty, his protective duty to them.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
