        "speaker_id": "LibriTTS_R-6848",
        "content": "Years of business experience, mitigated only by such exercise as the game of poker affords, had intensified an instinctive inexpressiveness.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
