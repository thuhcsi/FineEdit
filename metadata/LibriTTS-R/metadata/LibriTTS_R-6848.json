        "speaker_id": "LibriTTS_R-6848",
        "content": "Old Grammont had struck the table sharply and the eyes that looked out of his mask had blazed.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
