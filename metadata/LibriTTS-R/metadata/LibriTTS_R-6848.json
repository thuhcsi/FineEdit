        "speaker_id": "LibriTTS_R-6848",
        "content": "When old Grammont's enquiry man had come back with his report, old Grammont had been very particular about that.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
