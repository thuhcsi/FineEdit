        "speaker_id": "LibriTTS_R-6848",
        "content": "\"'Is it you,' said he, with a quiet laugh, 'that accuses Pope of a bull?'",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
