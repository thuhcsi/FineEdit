        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Absolutely nothing, Sir,\" said the agent, suddenly white to the lips....",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
