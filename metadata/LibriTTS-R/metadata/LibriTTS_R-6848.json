        "speaker_id": "LibriTTS_R-6848",
        "content": "Of course it was all right.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
