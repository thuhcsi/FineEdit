        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/76049/6848_76049_000004_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "What did matter was not whether she threw Lake over but what she threw him over for.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
