        "speaker_id": "LibriTTS_R-6848",
        "content": "Under the most solitary circumstances old Grammont was still inexpressive, and the face that stared at the ceiling of his cabin and the problem of his daughter might have been the face of a pickled head in a museum, for any indication it betrayed of the flow of thought within.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_76049_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/76049/6848_76049_000002_000003.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "He lay on his back and his bent knees lifted the bed clothes into a sharp mountain.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
