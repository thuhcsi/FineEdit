        "speaker_id": "LibriTTS_R-6848",
        "content": "What was afoot?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_76049_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/76049/6848_76049_000003_000006.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "With her fortune and his-you could buy the world.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
