        "speaker_id": "LibriTTS_R-6848",
        "content": "\"'With brains reduced a doable debt to pay, To dream by night, sell Sheffield ware by day.'",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
