        "speaker_id": "LibriTTS_R-6848",
        "content": "In itself that wasn't a thing to break her father's heart.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
