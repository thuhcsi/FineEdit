[
    {
        "item_name": "LibriTTS_R-6848_252322_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000003_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "When the Corporal, followed by Billy, entered the gloomy hall of the Castle, they found two or three country people conversing in a low but eager voice together, who speedily turned towards them, to learn if the doctor had come.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000007_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"He's getting weaker and weaker, sir; I believe he's sinking.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000012_000001.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Leave me, Craggs-leave me alone with him.\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000014_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Is it fever?\" asked the sick man, in a faint but unfaltering accent.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000023_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"What do you mean by this, Craggs?\" said the Viscount, trembling with passion.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000036_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"What do you think of him?\" asked the Corporal, eagerly.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000037_000001.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"He's a sanguineous temperament, and he'll bear the lancet.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000037_000002.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "It's just like weatherin' a point at say.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000039_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000039_000003.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "There's chaps, ay, and far from stupid ones either, that could n't compose you ten hexameters if ye'd put them on a hot griddle for it; and there's others that would talk rhyme rather than rayson!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000041_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Have you seen my father?",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000041_000001.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "What do you think of him?\" asked he, eagerly.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000044_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"What could I do, sir?\" was the answer; \"it was this fellow or nothing.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000046_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Don't be hasty, your honor,\" said Billy, submissively, \"and don't be unjust.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000048_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"I took a bleeding from him, little short of sixteen ounces, from the temporial,\" said Billy, proudly, \"and I'll give him now a concoction of meadow saffron with a pinch of saltpetre in it, to cause diaphoresis, d'ye mind?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000048_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000048_000004.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "Watch what's coming, look out and see which way the mischief is brewin', and make your preparations. That's the great study of physic.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252322_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252322/6848_252322_000049_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "The boy listened patiently and even attentively to this speech, and when Billy had concluded, he turned to the Corporal and said, \"Look to him, Craggs, and let him have his supper, and when he has eaten it send him to my room.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000004_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Didn't I tell you how it would be?\" said Billy, as he re-entered the kitchen, now crowded by the workpeople, anxious for tidings of the sick man.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Musha, but I 'm glad,\" muttered one; \"he 'd be a great loss to us.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000009_000001.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"I'll have to be up at the office for the bags at six o'clock.\"",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000011_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Sorra taste of it,\" muttered another; \"there's a sea runnin' outside now that would swamp a life boat.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000018_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Spoke like a British Grenadier,\" cried Billy, with enthusiasm.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000025_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Or a song would be better,\" observed another.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000027_000002.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "By Jove! how they did sing-all together, like the swell of a church organ.\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000028_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Yes, you're right,\" said Billy, but evidently yielding an unwilling assent to this doctrine.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000029_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"And which is best, Billy?\" asked one of the company.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000032_000001.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "Now for it, Billy.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000034_000001.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "In the present case, it is but fair to say, there was neither comment nor impatience; on the contrary, they seemed to accept these convulsive throes of sound as an earnest of the grand flood of melody that was coming.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000034_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000034_000002.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "That Billy was occupied with other thoughts than those of tuning was, however, apparent, for his lips continued to move rapidly; and at moments he was seen to beat time with his foot, as though measuring out the rhythm of a verse.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000046_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"You're right, there, Jim Morris,\" said he, turning suddenly round towards one of the company; \"you never said a truer thing than that. The poetic temperament is riches to a poor man.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000046_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000046_000003.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "I can bestow kingdoms.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000049_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Well, one evening-it was in August-I came down by a narrow path to the side of a lake, where there was a stone seat, put up to see the view from, and in front was three wooden steps of stairs going down into the water, where a boat might come in.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000049_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000049_000002.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "Well, I put down my pack in the leaves, for I did n't like to see or think of it, and I stretched myself down at the water's edge, and I fell into a fit of musing.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000049_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000049_000005.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "And from musing I fell off asleep; and it was the sound of voices near that first awoke me!",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000050_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000050_000001.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "I never listened to such a voice before, so soft, so sweet, so musical, and the words came droppin' down, like the clear water filterin' over a rocky ledge, and glitterin' like little spangles over moss and wild flowers.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000053_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"The Lord forgive me, but when he came to the last words and said, 'useful light,' I couldn't restrain myself, but broke out, 'That's mighty like a bull, anyhow, and reminds me of the ould song,--",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000055_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6848/252323/6848_252323_000055_000000.wav",
        "speaker_id": "LibriTTS_R-6848",
        "content": "\"Before I knew where I was, the boat glided in to the steps, and a tall man, a little stooped in the shoulders, stood before me.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6848_252323_000056_000000",
