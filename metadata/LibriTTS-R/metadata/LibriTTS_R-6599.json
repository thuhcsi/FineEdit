[
    {
        "item_name": "LibriTTS_R-6599_38591_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000000_000000.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "He did not find such as have deserved a place in history.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000000_000002.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "In those days of war and discord, fraught with violence, there was no man who was more personally rough and violent than Montmorency.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000000_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000000_000004.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "\"Go hang me such a one,\" he would say, according to Brantome.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000000_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000000_000008.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "In fifteen sixty two, at the battle of Dreux, he was aged and so ill that none expected to see him on horseback.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000000_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000000_000011.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "He did accept his disgrace; he retired first to Chantilly, and then to Ecouen; and there he waited for the dauphin, when he became King Henry the second., to recall him to his side and restore to him the power which Francis the first, on his very death bed, had dissuaded his son from giving back.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000000_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000000_000012.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "The ungratefulnesses of kings are sometimes as capricious as their favors.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000001_000003.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "It was Charles the fifth who tackled them.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000001_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000001_000006.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "\"You don't see, then,\" said Clement the seventh's ambassador, \"that she brings France three jewels of great price, Genoa, Milan, and Naples?\" When this language was reported at the court of Charles the fifth, it caused great irritation there.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000001_000008.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Montmorency made up his mind to defend, on the whole coast of Provence, only Marseilles and Arles; he pulled down the ramparts of the other towns, which were left exposed to the enemy.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000001_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000001_000009.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "For two months Charles the fifth prosecuted this campaign without a fight, marching through the whole of Provence an army which fatigue, shortness of provisions, sickness, and ambuscades were decimating ingloriously.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000001_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000001_000010.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "At last he decided upon retreating.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000001_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000001_000013.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "It was Garcilaso de la Vega, the prince of Spanish poesy, the Spanish Petrarch, according to his fellow countrymen.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000001_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000001_000014.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "The tower was taken, and Charles the fifth avenged his poet's death by hanging twenty five of these patriot peasants, being all that survived of the fifty who had maintained the defence.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000001.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Queen Mary of Hungary, his sister and deputy in the government of the Low Countries, advised a local truce; his other sister, Eleanor, the Queen of France, was of the same opinion; Francis the first adopted it; and the truce in the north was signed for a period of three months.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000002.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Montmorency signed a similar one for Piedmont.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000004.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Pope Paul the third. (Alexander Farnese), who, on the thirteenth of October, fifteen thirty four, had succeeded Clement the seventh., came forward as mediator.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000011.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "They all repaired together to the house prepared for their reception, and, after dinner, the emperor, being tired, lay down to rest on a couch.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000012.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Queen Eleanor, before long, went and tapped at his door, and sent word to the king that the emperor was awake.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000013.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Francis, with the Cardinal de Lorraine and the Constable de Montmorency, soon arrived.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000014.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "On entering the chamber, he found the emperor still lying down and chatting with his sister the queen, who was seated beside him on a chair.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000016.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "\"Well, brother,\" said the king, \"how do you feel?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000017.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Have you rested well?\" \"Yes,\" said Charles; \"I had made such cheer that I was obliged to sleep it off.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000019",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000019.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Charles put the ring on his finger; and, taking from his neck the collar of the order (the Golden Fleece) he was wearing, he put it upon the king's neck.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6599_38591_000002_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6599/38591/6599_38591_000002_000020.wav",
        "speaker_id": "LibriTTS_R-6599",
        "content": "Francis did the converse with his own collar. Only seven of the attendants remained in the emperor's chamber; and there the two sovereigns conversed for an hour, after which they moved to the hall, where a splendid supper awaited them.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    }
]