        "speaker_id": "LibriTTS_R-8500",
        "content": "Quoth Salih, \"O King of the Age, these jewels and jacinths are a present from me to thee.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
