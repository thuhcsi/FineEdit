        "speaker_id": "LibriTTS_R-8500",
        "content": "When it was the Seven Hundred and Forty third Night,",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
