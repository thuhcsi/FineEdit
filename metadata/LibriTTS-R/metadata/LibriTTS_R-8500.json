        "speaker_id": "LibriTTS_R-8500",
        "content": "Then they showed the child to his uncle Salih, who took him in his arms and arising began to walk about the chamber with him in all directions right and left.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
