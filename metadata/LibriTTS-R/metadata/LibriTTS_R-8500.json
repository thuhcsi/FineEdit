        "speaker_id": "LibriTTS_R-8500",
        "content": "Presently he carried him forth of the palace and going down to the salt sea, fared on with him, till he was hidden from the King's sight.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
