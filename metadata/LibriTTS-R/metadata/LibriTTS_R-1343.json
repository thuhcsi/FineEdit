[
    {
        "item_name": "LibriTTS_R-1343_139681_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000001_000002.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "When the news reached Norman William, hunting in his park at Rouen, he dropped his bow, returned to his palace, called his nobles to council, and presently sent ambassadors to Harold, calling on him to keep his oath and resign the Crown.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000001_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000001_000006.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "The Pope sent to Normandy a consecrated banner, and a ring containing a hair which he warranted to have grown on the head of Saint peter.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000001_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000001_000007.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "He blessed the enterprise; and cursed Harold; and requested that the Normans would pay 'Peter's Pence'--or a tax to himself of a penny a year on every house-a little more regularly in future, if they could make it convenient.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "This brother, and this Norwegian King, joining their forces against England, with Duke William's help, won a fight in which the English were commanded by two nobles; and then besieged York. Harold, who was waiting for the Normans on the coast at Hastings, with his army, marched to Stamford Bridge upon the river Derwent to give them instant battle.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "He found them drawn up in a hollow circle, marked out by their shining spears.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "Riding round this circle at a distance, to survey it, he saw a brave figure on horseback, in a blue mantle and a bright helmet, whose horse suddenly stumbled and threw him.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'Who is that man who has fallen?' Harold asked of one of his captains.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'The King of Norway,' he replied.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'He is a tall and stately king,' said Harold, 'but his end is near.'",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "He added, in a little while, 'Go yonder to my brother, and tell him, if he withdraw his troops, he shall be Earl of Northumberland, and rich and powerful in England.'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'Seven feet of earth for a grave,' replied the captain.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'No more?' returned the brother, with a smile.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'Ride back!' said the brother, 'and tell King Harold to make ready for the fight!'",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "He did so, very soon.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000015_000001.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "They had been tossed about by contrary winds, and some of their ships had been wrecked.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000015_000003.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "But they had once more made sail, led by the Duke's own galley, a present from his wife, upon the prow whereof the figure of a golden boy stood pointing towards England.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000015_000004.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "By day, the banner of the three Lions of Normandy, the diverse coloured sails, the gilded vans, the many decorations of this gorgeous ship, had glittered in the sun and sunny water; by night, a light had sparkled like a star at her mast head.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "Harold broke up the feast and hurried to London.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000016_000001.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "Within a week, his army was ready.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000016_000002.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "He sent out spies to ascertain the Norman strength.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000016_000003.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "William took them, caused them to be led through his whole camp, and then dismissed.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000016_000004.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'The Normans,' said these spies to Harold, 'are not bearded on the upper lip as we English are, but are shorn.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000016_000005.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "They are priests.' 'My men,' replied Harold, with a laugh, 'will find those priests good soldiers!'",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "'The Saxons,' reported Duke William's outposts of Norman soldiers, who were instructed to retire as King Harold's army advanced, 'rush on us through their pillaged country with the fury of madmen.'",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "Some proposals for a reconciliation were made, but were soon abandoned. In the middle of the month of October, in the year one thousand and sixty six, the Normans and the English came front to front.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000019_000001.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "All night the armies lay encamped before each other, in a part of the country then called Senlac, now called (in remembrance of them) Battle.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "On an opposite hill, in three lines, archers, foot soldiers, horsemen, was the Norman force.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000020_000002.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "The English answered with their own battle cry, 'God's Rood!",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000020_000003.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "Holy Rood!' The Normans then came sweeping down the hill to attack the English.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "There was one tall Norman Knight who rode before the Norman army on a prancing horse, throwing up his heavy sword and catching it, and singing of the bravery of his countrymen.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000021_000002.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "Another English Knight rode out, and he fell too.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000021_000003.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "But then a third rode out, and killed the Norman.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "The English, keeping side by side in a great mass, cared no more for the showers of Norman arrows than if they had been showers of Norman rain. When the Norman horsemen rode against them, with their battle axes they cut men and horses down.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "The Normans gave way.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000022_000002.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "The English pressed forward.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000022_000003.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "A cry went forth among the Norman troops that Duke William was killed.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000022_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1343/139681/1343_139681_000022_000004.wav",
        "speaker_id": "LibriTTS_R-1343",
        "content": "Duke William took off his helmet, in order that his face might be distinctly seen, and rode along the line before his men.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000022_000005",
