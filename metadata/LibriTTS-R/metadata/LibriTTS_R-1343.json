        "speaker_id": "LibriTTS_R-1343",
        "content": "\"Good night, Lizzie.\" Then she went, and he returned to a room below which had been prepared for purposes of tobacco and soda water and brandy.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
