        "speaker_id": "LibriTTS_R-1343",
        "content": "\"I wonder if he'd take a twenty pound note if I sent it to him,\" said Frank, when they broke up for the night.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
