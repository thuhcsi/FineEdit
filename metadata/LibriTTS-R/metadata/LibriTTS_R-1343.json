        "speaker_id": "LibriTTS_R-1343",
        "content": "She did not look into his face as she asked this question, but stood with her eyes fixed on the stair carpet.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
