        "speaker_id": "LibriTTS_R-1343",
        "content": "This gave them courage.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1343_139681_000022_000006",
