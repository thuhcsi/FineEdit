        "speaker_id": "LibriTTS_R-1343",
        "content": "And if you don't, what do you mean to do; and all the rest of it?\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
