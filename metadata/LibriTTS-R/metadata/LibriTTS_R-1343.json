        "speaker_id": "LibriTTS_R-1343",
        "content": "\"Why, Griff, you're rather out of sorts to night,\" said Lord George to his friend, before Frank had joined them.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
