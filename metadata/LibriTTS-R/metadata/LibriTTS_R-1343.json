        "speaker_id": "LibriTTS_R-1343",
        "content": "\"How would you like me to ask you questions?",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
