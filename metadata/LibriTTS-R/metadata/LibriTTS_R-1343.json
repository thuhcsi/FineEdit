        "speaker_id": "LibriTTS_R-1343",
        "content": "\"Good night, Frank.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
