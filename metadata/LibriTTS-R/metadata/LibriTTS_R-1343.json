        "speaker_id": "LibriTTS_R-1343",
        "content": "I don't like young women when they're damp and smell of mud.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
