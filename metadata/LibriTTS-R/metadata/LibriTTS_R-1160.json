        "speaker_id": "LibriTTS_R-1160",
        "content": "SCIENTIFIC EXPERIMENTS",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1160_139730_000004_000002",
