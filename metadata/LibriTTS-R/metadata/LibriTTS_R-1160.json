[
    {
        "item_name": "LibriTTS_R-1160_134674_000002_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/134674/1160_134674_000002_000007.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "But the haughty monarch was incapable of the magnanimity which dares to acknowledge a fault.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_134674_000002_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/134674/1160_134674_000002_000014.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "He reviled, in the most intemperate language, their baseness, their ingratitude, their insolence.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "OF THE ORIGIN AND DESIGN OF GOVERNMENT IN GENERAL, WITH CONCISE REMARKS ON THE ENGLISH CONSTITUTION",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Society is produced by our wants, and government by wickedness; the former promotes our happiness POSITIVELY by uniting our affections, the latter NEGATIVELY by restraining our vices.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000006_000003.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "The first is a patron, the last a punisher.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Society in every state is a blessing, but government even in its best state is but a necessary evil; in its worst state an intolerable one; for when we suffer, or are exposed to the same miseries BY A GOVERNMENT, which we might expect in a country WITHOUT GOVERNMENT, our calamity is heightened by reflecting that we furnish the means by which we suffer.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Government, like dress, is the badge of lost innocence; the palaces of kings are built on the ruins of the bowers of paradise.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "In order to gain a clear and just idea of the design and end of government, let us suppose a small number of persons settled in some sequestered part of the earth, unconnected with the rest, they will then represent the first peopling of any country, or of the world.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000008_000004.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Disease, nay even misfortune would be death, for though neither might be mortal, yet either would disable him from living, and reduce him to a state in which he might rather be said to perish than to die.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "In this first parliament every man, by natural right, will have a seat.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000011_000003.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "And as this frequent interchange will establish a common interest with every part of the community, they will mutually and naturally support each other, and on this (not on the unmeaning name of king) depends the STRENGTH OF GOVERNMENT, AND THE HAPPINESS OF THE GOVERNED.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000013_000003.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "But that it is imperfect, subject to convulsions, and incapable of producing what it seems to promise, is easily demonstrated.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Absolute governments (tho' the disgrace of human nature) have this advantage with them, that they are simple; if the people suffer, they know the head from which their suffering springs, know likewise the remedy, and are not bewildered by a variety of causes and cures.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "I know it is difficult to get over local or long standing prejudices, yet if we will suffer ourselves to examine the component parts of the English constitution, we shall find them to be the base remains of two ancient tyrannies, compounded with some new republican materials.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "FIRST.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000016_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "The remains of monarchical tyranny in the person of the king.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "SECONDLY.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000018_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "The new republican materials, in the persons of the commons, on whose virtue depends the freedom of England.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "To say that the constitution of England is a UNION of three powers reciprocally CHECKING each other, is farcical, either the words have no meaning, or they are flat contradictions.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "To say that the commons is a check upon the king, presupposes two things.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "FIRST.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "That the king is not to be trusted without being looked after, or in other words, that a thirst for absolute power is the natural disease of monarchy.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000023_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "SECONDLY.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000023_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "That the commons, by being appointed for that purpose, are either wiser or more worthy of confidence than the crown.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000024_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "But as the same constitution which gives the commons a power to check the king by withholding the supplies, gives afterwards the king a power to check the commons, by empowering him to reject their other bills; it again supposes that the king is wiser than those whom it has already supposed to be wiser than him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000026_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "HOW CAME THE KING BY A POWER WHICH THE PEOPLE ARE AFRAID TO TRUST, AND ALWAYS OBLIGED TO CHECK?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000026_000002.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Such a power could not be the gift of a wise people, neither can any power, WHICH NEEDS CHECKING, be from God; yet the provision, which the constitution makes, supposes such a power to exist.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000028_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "That the crown is this overbearing part in the English constitution needs not be mentioned, and that it derives its whole consequence merely from being the giver of places and pensions is self evident; wherefore, though we have been wise enough to shut and lock a door against absolute monarchy, we at the same time have been foolish enough to put the crown in possession of the key.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139336_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139336/1160_139336_000029_000001.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Individuals are undoubtedly safer in England than in some other countries, but the WILL of the king is as much the LAW of the land in Britain as in France, with this difference, that instead of proceeding directly from his mouth, it is handed to the people under the more formidable shape of an act of parliament.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139717/1160_139717_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Keimer and I liv'd on a pretty good familiar footing, and agreed tolerably well, for he suspected nothing of my setting up.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139717/1160_139717_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "We therefore had many disputations.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139717/1160_139717_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "He agreed to try the practice, if I would keep him company.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139717/1160_139717_000004_000005.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "I did so, and we held it for three months.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000004_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139717/1160_139717_000004_000009.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "He invited me and two women friends to dine with him; but, it being brought too soon upon table, he could not resist the temptation, and ate the whole before we came.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139717/1160_139717_000006_000003.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "Ralph was ingenious, genteel in his manners, and extremely eloquent; I think I never knew a prettier talker.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1160/139717/1160_139717_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1160",
        "content": "When the time of our meeting drew nigh, Ralph called on me first, and let me know his piece was ready.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1160_139717_000009_000004",
