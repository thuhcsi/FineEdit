        "speaker_id": "LibriTTS_R-4766",
        "content": "\"I don't know as I properly understand what you mean by emotion,\" said Herbert, reflectively.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
