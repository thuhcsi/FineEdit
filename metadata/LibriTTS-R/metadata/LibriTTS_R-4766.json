        "speaker_id": "LibriTTS_R-4766",
        "content": "Sir Norman looked at him in amazement.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
