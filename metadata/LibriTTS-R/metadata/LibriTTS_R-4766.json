        "speaker_id": "LibriTTS_R-4766",
        "content": "And O Hubert, if you only knew what she is to you!\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
