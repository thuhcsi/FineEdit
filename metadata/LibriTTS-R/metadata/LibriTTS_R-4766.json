        "speaker_id": "LibriTTS_R-4766",
        "content": "\"So I have, and you merely abused me for it.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
