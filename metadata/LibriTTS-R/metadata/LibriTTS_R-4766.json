        "speaker_id": "LibriTTS_R-4766",
        "content": "\"Let me see-no-I think not-she simply mentioned the fact.\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
