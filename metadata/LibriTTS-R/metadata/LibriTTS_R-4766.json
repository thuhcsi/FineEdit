        "speaker_id": "LibriTTS_R-4766",
        "content": "if you insinuate such a thing again, I'll throttle you!",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
