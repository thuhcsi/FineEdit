        "speaker_id": "LibriTTS_R-4766",
        "content": "\"Of course I would.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
