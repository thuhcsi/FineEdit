        "speaker_id": "LibriTTS_R-4766",
        "content": "I haven't lived in courts half my life to get up a scene for a small matter!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
