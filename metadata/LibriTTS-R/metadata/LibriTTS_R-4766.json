        "speaker_id": "LibriTTS_R-4766",
        "content": "\"She told you, and you take it like this?\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
