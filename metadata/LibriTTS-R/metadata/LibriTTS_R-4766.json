        "speaker_id": "LibriTTS_R-4766",
        "content": "\"Which of them?\" inquired Hubert, with provoking gravity.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
