        "speaker_id": "LibriTTS_R-4766",
        "content": "\"It would be more to the point if you asked me who the others were, I think.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
