        "speaker_id": "LibriTTS_R-4766",
        "content": "\"Yes, yes.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very high"
