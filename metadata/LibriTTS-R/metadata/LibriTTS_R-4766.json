        "speaker_id": "LibriTTS_R-4766",
        "content": "She told me she was my sister!\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
