        "speaker_id": "LibriTTS_R-4766",
        "content": "\"Exactly.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
