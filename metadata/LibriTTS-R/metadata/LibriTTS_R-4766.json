        "speaker_id": "LibriTTS_R-4766",
        "content": "Did she tell you how she discovered it herself?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
