[
    {
        "item_name": "LibriTTS_R-7962_110061_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000005_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "We shall, necessarily, have little to say on this head; there are, however, some little rules which are not to be neglected.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "It is proper to vary the phraseology of these formal questions, as much as possible; and we must abstain from them entirely, towards a superior, or a person with whom we are but little acquainted, for such inquiries presuppose some degree of intimacy.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "In the last case, there is a method of manifesting our interest, without violating etiquette; it consists in making these inquiries of the domestics, or of other persons of the house, and of saying afterwards when introduced; 'I am happy Sir, to hear that you are in good health.'",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "To put a corrective upon this mark of regard, a lady who addresses a gentleman, should be earnest in her inquiries of the health of his family, however little intimacy she may have with them.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Many persons ask this question mechanically, without waiting for the answer, or else hasten to reply, before they have received it.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "We can put a general question, designating the most important members.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "In case of the absence of near relations, we ask the person we are visiting, if they have heard from them lately, if the news is favorable.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000008_000003.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "They, on their part, ask the same of us.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Politeness infuses into visits of some little ceremony, a coloring of modesty, grace, and deference, which should be preserved with the greatest care.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000014_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "The rules of politeness in this respect, are the same in speaking of the husband.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000017_000004.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "With these forms, they think they comply with the rules of politeness.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000017_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000017_000005.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "It is incivility with affectation.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000022_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "If you strike against any one in the least, ask pardon for it immediately.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000023_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "It is customary to employ the few moments of a visit of mere politeness, in looking at the portraits which adorn the fireplace, and even taking them down, if you are invited to do it.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000023_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "It would moreover be improper to make long compliments; indirect, and ingenious praise, is all that is proper.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000026_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Questions are therefore necessary, but they demand infinite delicacy and tact, in order neither to fatigue nor ever wound the feelings.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000027_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Madame Necker ingeniously observes that these favorite and frequently repeated terms with which we fill our conversation, serve, ordinarily as a mark of people's character.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000028_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "They embarrass and overwhelm our conversation, turn away the attention of those who listen to us, and render us importunate, and ridiculous, without our being able to perceive it.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000030_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "SECTION three.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000032_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "There are many conditions indispensable to the success of a narrative. These conditions are, first, novelty; the best stories weary when they are multiplied too much, because every one wishes to be an actor in his turn upon the stage of the world.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000032_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000032_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "There are but too many people who discover the secret of wearying while telling very good things, on account of their too great eagerness to tell them.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000033_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "The next thing is to take a suitable opportunity.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000037_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "If your opinion is asked, give it frankly, and without wishing to appear better informed than the narrator himself.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000037_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000037_000003.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Frequently, in the midst of a recital, the narrator, through forgetfulness, hesitates, and thinks that he can recall it.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000037_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000037_000004.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Look at him attentively.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000037_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000037_000005.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "If he is in doubt, declare that you are altogether ignorant of the subject in question.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000037_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000037_000007.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "This delicate politeness is particularly to be observed towards old persons.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000038_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "When your narrations have had success, keep a modest countenance; leave others to point out the striking parts which have pleased them.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000038_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "The surest means of not having the approbation of others, in actions as well as other things, is to solicit it, whether it be by looks, or by words.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000041_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "When arrived at this point, abstain from these kinds of analysis, which though indeed more correct, seem labored.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000041_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000041_000003.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "They have besides less freedom, appropriateness, and grace.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000042_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Know this, and remember it well, that every other preparation than thinking what you are about to say, will make you acquire two intolerable faults, affectation and stiffness.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000044_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Those who are less engaged in these things, should content themselves with simply and briefly explaining a subject, and of mentioning the emotion they felt; with speaking of some brilliant passage, and adding that they do not pretend to pronounce judgment.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000045_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "The first degree of digression is the parenthesis; provided it is short, natural, and seldom repeated; and that you take care to announce it always; and finally, in order not to abuse it, you should make a skilful use of it.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000045_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000045_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "This method of speaking in italics may be striking and artless; but it often becomes obscure and trivial; the habit is dangerous, and one should use this difficult digression only before intimate friends.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000046_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000046_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "But if it is an affair of nothings succeeding nothings, let it flow on.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000048_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Lawyers, literary people, military men, travellers, invalids and aged ladies, ought to have a prudent and continual distrust of the abuse of digressions.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000051_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "The two shoals to be avoided in this form of language are directly opposed to each other; the one is triviality, the other bombast.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000053_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "They are not so used, if, in the course of a discussion, you suppose a respectable person to supply the place of a madman, an ill bred person, or a robber; or, if you suppose him to be in a situation disgraceful or even ridiculous.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000059_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000059_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "If you do not bring over your opponent to your own opinion, you will at least gain his esteem.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000060_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "But if you have to do with one of those people who, possessed with a mania of discussion, commence by contradicting before they hear, and who are always ready to sustain the contrary opinion, yield to him; you will have nothing to gain with him.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000060_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000060_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Be assured that the spirit of contradiction can be conquered only by silence.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000069_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000069_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Popular quotations and proverbs, as well as other quotations, require some care; and, except in familiar conversation, are altogether misplaced.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000069_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000069_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "If they are frequent, conversation becomes a tedious gossipping; if introduced without a short previous remark, one of two things will take place, they will either prevent the speaker from being understood, or they will give him the air of Sancho Panza.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000069_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000069_000003.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "A proverb well applied, and placed at the end of a phrase, frequently makes a very happy conclusion.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000070_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000070_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "I only speak to censure; I entreat my readers not to suffer themselves to be the manufacturers of puns, and to despise this talent of fools and childish means to excite a passing laugh.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000071_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000071_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "What pleasure can we find in causing ladies to blush, and in meriting the name of a man of bad society?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000072_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000072_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "It requires but a moment to lose those delicate shades of character which constitute a man of the world, and which cost us so much labor to acquire.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000078_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000078_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "If we remain silent, we appear to be inhaling the incense with complacency; if we repel it, we only seem to excite it the more.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000078_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000078_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Thus we see, in such a case, and even among very clever persons too, those who reply by silly exclamations and by rude assertions.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000079_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000079_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "This is a mistake, gentlemen, and I can with relation to this point, reveal to you what my sex prefers to these vulgar eulogiums.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000081_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000081_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "But is it then necessary to proscribe eulogiums entirely?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000082_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000082_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "I repeat, as I have often said, let there be moderation in everything.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000083_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000083_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "It is much better to cause people to think more than we say, and not outrage language, and run the risk of going beyond what we ought to say.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000084_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000084_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Under any circumstances, complaining has always a bad grace.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000086_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000086_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "Politeness is not less opposed to making excessive complaints to the first person you meet, than to the frequent and extravagant eulogiums which you bestow improperly upon those from whom you expect a favor in return.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000087_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000087_000000.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "By the word improprieties, we generally understand all violations of politeness.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000087_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000087_000001.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "We, however, give to this word a particular and limited sense.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7962_110061_000087_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7962/110061/7962_110061_000087_000002.wav",
        "speaker_id": "LibriTTS_R-7962",
        "content": "It signifies a want of due regard to, and a forgetfulness of, the delicate attentions which seem to identify us with the situation of others.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    }
]