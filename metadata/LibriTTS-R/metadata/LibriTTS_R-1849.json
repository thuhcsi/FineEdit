        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1849/138063/1849_138063_000037_000001.wav",
        "speaker_id": "LibriTTS_R-1849",
        "content": "Don Stockfish, soul of a mortar, stone of a date, more obstinate and obdurate than a clown asked a favour when he has his mind made up, if I fall upon you I'll tear your eyes out!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1849_138063_000037_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1849/138063/1849_138063_000037_000003.wav",
        "speaker_id": "LibriTTS_R-1849",
        "content": "All that you have seen to night has been make believe; I'm not the woman to let the black of my nail suffer for such a camel, much less die!\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
