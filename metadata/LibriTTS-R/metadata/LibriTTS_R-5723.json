        "speaker_id": "LibriTTS_R-5723",
        "content": "Thus, for a while, was none so bold as to seek the high Princess.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
