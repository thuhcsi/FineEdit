[
    {
        "item_name": "LibriTTS_R-2201_160438_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/160438/2201_160438_000000_000001.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "OF THE DIFFERENT PROGRESS OF OPULENCE IN DIFFERENT NATIONS",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2201_160438_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/160438/2201_160438_000002_000001.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "It consists in the exchange of rude for manufactured produce, either immediately, or by the intervention of money, or of some sort of paper which represents money. The country supplies the town with the means of subsistence and the materials of manufacture.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2201_160438_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/160438/2201_160438_000002_000002.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "The town repays this supply, by sending back a part of the manufactured produce to the inhabitants of the country. The town, in which there neither is nor can be any reproduction of substances, may very properly be said to gain its whole wealth and subsistence from the country.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2201_160438_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/160438/2201_160438_000005_000001.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "Smiths, carpenters, wheelwrights and ploughwrights, masons and bricklayers, tanners, shoemakers, and tailors, are people whose service the farmer has frequent occasion for.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2201_160438_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/160438/2201_160438_000005_000003.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "The butcher, the brewer, and the baker, soon join them, together with many other artificers and retailers, necessary or useful for supplying their occasional wants, and who contribute still further to augment the town.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2201_160438_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/160438/2201_160438_000007_000001.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "The smith erects some sort of iron, the weaver some sort of linen or woollen manufactory.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000000_000001.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "OF DRAWBACKS.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "Of these encouragements, what are called drawbacks seem to be the most reasonable.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000003_000001.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "By the second of the rules, annexed to the act of parliament, which imposed what is now called the old subsidy, every merchant, whether English or alien. was allowed to draw back half that duty upon exportation; the English merchant, provided the exportation took place within twelve months; the alien, provided it took place within nine months.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000007_000004.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "It is under these regulations only that we can import wrought silks, French cambrics and lawns, calicoes, painted, printed, stained, or dyed, etc",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000009_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000009_000006.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "These rules took place with regard to all places of lawful exportation, except the British colonies in America.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000011_000001.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "Upon the exportation of the greater part of commodities to other countries, half the old subsidy was drawn back.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000012_000003.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "The carrying trade, though it deserves no preference, ought not to be precluded, but to be left free, like all other trades.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2201_7371_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2201/7371/2201_7371_000013_000000.wav",
        "speaker_id": "LibriTTS_R-2201",
        "content": "The revenue of the customs, instead of suffering, profits from such drawbacks, by that part of the duty which is retained.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    }
]