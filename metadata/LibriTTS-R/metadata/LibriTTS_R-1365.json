[
    {
        "item_name": "LibriTTS_R-1365_134804_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He put an end to differences, he prevented lawsuits, he reconciled enemies.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Every one took him for the judge, and with good reason.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000004_000005.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It seemed as though he had for a soul the book of the natural law.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000004_000006.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It was like an epidemic of veneration, which in the course of six or seven years gradually took possession of the whole district.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "One single man in the town, in the arrondissement, absolutely escaped this contagion, and, whatever Father Madeleine did, remained his opponent as though a sort of incorruptible and imperturbable instinct kept him on the alert and uneasy.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "In any case, I am not his dupe.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "His name was Javert, and he belonged to the police.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Certain police officers have a peculiar physiognomy, which is complicated with an air of baseness mingled with an air of authority. Javert possessed this physiognomy minus the baseness.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000012_000003.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "On the contrary, our souls being realities and having a goal which is appropriate to them, God has bestowed on them intelligence; that is to say, the possibility of education.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000013_000002.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Having made this reservation, let us pass on.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000017_000002.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He observed that society unpardoningly excludes two classes of men,--those who attack it and those who guard it; he had no choice except between these two classes; at the same time, he was conscious of an indescribable foundation of rigidity, regularity, and probity, complicated with an inexpressible hatred for the race of bohemians whence he was sprung.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000017_000003.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He entered the police; he succeeded there.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000017_000004.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "At forty years of age he was an inspector.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "During his youth he had been employed in the convict establishments of the South.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000020_000004.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "As for the rest, he had very little skull and a great deal of jaw; his hair concealed his forehead and fell over his eyebrows; between his eyes there was a permanent, central frown, like an imprint of wrath; his gaze was obscure; his mouth pursed up and terrible; his air that of ferocious command.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "This man was composed of two very simple and two very good sentiments, comparatively; but he rendered them almost bad, by dint of exaggerating them,--respect for authority, hatred of rebellion; and in his eyes, murder, robbery, all crimes, are only forms of rebellion.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000021_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000021_000006.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He was stoical, serious, austere; a melancholy dreamer, humble and haughty, like fanatics.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000021_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000021_000007.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "His glance was like a gimlet, cold and piercing.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000021_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000021_000008.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "His whole life hung on these two words: watchfulness and supervision.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000021_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000021_000009.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He had introduced a straight line into what is the most crooked thing in the world; he possessed the conscience of his usefulness, the religion of his functions, and he was a spy as other men are priests.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000021_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000021_000012.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "And he would have done it with that sort of inward satisfaction which is conferred by virtue.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000021_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000021_000014.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It was implacable duty; the police understood, as the Spartans understood Sparta, a pitiless lying in wait, a ferocious honesty, a marble informer, Brutus in Vidocq.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000022_000002.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "His brow was not visible; it disappeared beneath his hat: his eyes were not visible, since they were lost under his eyebrows: his chin was not visible, for it was plunged in his cravat: his hands were not visible; they were drawn up in his sleeves: and his cane was not visible; he carried it under his coat.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000023_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "In his leisure moments, which were far from frequent, he read, although he hated books; this caused him to be not wholly illiterate.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000023_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "This could be recognized by some emphasis in his speech.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134804_000027_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134804/1365_134804_000027_000003.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He did not even put a question to Javert; he neither sought nor avoided him; he bore that embarrassing and almost oppressive gaze without appearing to notice it. He treated Javert with ease and courtesy, as he did all the rest of the world.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "\"Gentlemen of the jury, order the prisoner to be released!",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "\"Is there a physician present?\"",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000017_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000017_000014.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "But, pardon me, you cannot understand what I am saying.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000017_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000017_000018.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Do not, at least, condemn this man!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000033_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "That was clear.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000034_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It was an impression which vanished speedily, but which was irresistible at the moment.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000036_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000036_000004.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He traversed the crowd slowly.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000038_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Then he addressed the audience:--",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134825_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134825/1365_134825_000039_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "\"All of you, all who are present-consider me worthy of pity, do you not?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000006_000004.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Good God!\" \"He has been arrested.\" \"Arrested!\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000006_000005.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "\"In prison, in the city prison, while waiting to be transferred.\" \"Until he is transferred!\" \"He is to be transferred!\" \"Where is he to be taken?\" \"He will be tried at the Assizes for a highway robbery which he committed long ago.\" \"Well!",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000006_000006.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "I suspected as much.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000006_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000006_000007.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "That man was too good, too perfect, too affected. He refused the cross; he bestowed sous on all the little scamps he came across.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000006_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000006_000008.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "I always thought there was some evil history back of all that.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "One old lady, a subscriber to the Drapeau Blanc, made the following remark, the depth of which it is impossible to fathom:--",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It will be a lesson to the Bonapartists!\"",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It was only at the expiration of two hours that she roused herself from her revery, and exclaimed, \"Hold!",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "At that moment the small window in the lodge opened, a hand passed through, seized the key and the candlestick, and lighted the taper at the candle which was burning there.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "The portress raised her eyes, and stood there with gaping mouth, and a shriek which she confined to her throat.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "She stopped; the conclusion of her sentence would have been lacking in respect towards the beginning.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He finished her thought.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "\"I was there; I broke a bar of one of the windows; I let myself drop from the top of a roof, and here I am.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000029_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "From a cupboard he pulled out one of his old shirts, which he tore in pieces.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000029_000002.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "In the strips of linen thus prepared he wrapped the two silver candlesticks.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000029_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000029_000003.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He betrayed neither haste nor agitation; and while he was wrapping up the Bishop's candlesticks, he nibbled at a piece of black bread.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000031_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "There came two taps at the door.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000034_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "She was pale; her eyes were red; the candle which she carried trembled in her hand.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000034_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "The peculiar feature of the violences of destiny is, that however polished or cool we may be, they wring human nature from our very bowels, and force it to reappear on the surface.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000036_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "The paper was not folded.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000038_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "She read:--",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000040_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "The sister tried to speak, but she only managed to stammer a few inarticulate sounds.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000045_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "A man responded:--",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000049_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "The door opened.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000050_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Javert entered.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000055_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000055_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It will be remembered that the fundamental point in Javert, his element, the very air he breathed, was veneration for all authority.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000055_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000055_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "This was impregnable, and admitted of neither objection nor restriction.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000055_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000055_000002.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "In his eyes, of course, the ecclesiastical authority was the chief of all; he was religious, superficial and correct on this point as on all others. In his eyes, a priest was a mind, who never makes a mistake; a nun was a creature who never sins; they were souls walled in from this world, with a single door which never opened except to allow the truth to pass through.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000056_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000056_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "On perceiving the sister, his first movement was to retire.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000057_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000057_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "But there was also another duty which bound him and impelled him imperiously in the opposite direction.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000058_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000058_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "This was Sister Simplice, who had never told a lie in her life.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000058_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000058_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Javert knew it, and held her in special veneration in consequence.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000060_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "A terrible moment ensued, during which the poor portress felt as though she should faint.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000063_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000063_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "\"Then,\" resumed Javert, \"you will excuse me if I persist; it is my duty; you have not seen a certain person-a man-this evening?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000063_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000063_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "He has escaped; we are in search of him-that Jean Valjean; you have not seen him?\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000064_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000064_000000.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "The sister replied:--",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000066_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000066_000001.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "She had lied twice in succession, one after the other, without hesitation, promptly, as a person does when sacrificing herself.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000070_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000070_000002.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "It has been established by the testimony of two or three carters who met him, that he was carrying a bundle; that he was dressed in a blouse.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000070_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000070_000003.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "Where had he obtained that blouse?",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1365_134830_000070_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1365/134830/1365_134830_000070_000004.wav",
        "speaker_id": "LibriTTS_R-1365",
        "content": "No one ever found out. But an aged workman had died in the infirmary of the factory a few days before, leaving behind him nothing but his blouse.",
