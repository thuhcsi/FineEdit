        "speaker_id": "LibriTTS_R-6727",
        "content": "Under the first head there are four points of inquiry:",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
