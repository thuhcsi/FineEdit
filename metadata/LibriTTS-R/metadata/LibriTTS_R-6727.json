        "speaker_id": "LibriTTS_R-6727",
        "content": "(three) Whether light is a quality?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6727_10344_000011_000000",
