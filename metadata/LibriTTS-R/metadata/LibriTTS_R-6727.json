        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6727_10344_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6727/10344/6727_10344_000034_000001.wav",
        "speaker_id": "LibriTTS_R-6727",
        "content": "But this is not the case with light since darkness is merely a privation of light.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
