        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6727/10344/6727_10344_000032_000000.wav",
        "speaker_id": "LibriTTS_R-6727",
