        "speaker_id": "LibriTTS_R-4599",
        "content": "In the first place, a taste for reading had rooted itself-reading of the adventurous and poetical kind.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
