        "speaker_id": "LibriTTS_R-4599",
        "content": "But what a story teller was Mary Lant!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
