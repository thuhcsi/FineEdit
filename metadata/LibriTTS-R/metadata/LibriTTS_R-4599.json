        "speaker_id": "LibriTTS_R-4599",
        "content": "Nor was the week quite barren of similar delights.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
