        "speaker_id": "LibriTTS_R-4599",
        "content": "To take the adoration first.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
