        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4599/21274/4599_21274_000026_000003.wav",
        "speaker_id": "LibriTTS_R-4599",
        "content": "Marcella had better go on with her studies as long as possible.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
