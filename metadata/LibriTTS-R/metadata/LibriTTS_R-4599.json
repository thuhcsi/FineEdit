        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4599/21274/4599_21274_000028_000003.wav",
        "speaker_id": "LibriTTS_R-4599",
        "content": "She was something altogether different.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4599_21274_000032_000005",
