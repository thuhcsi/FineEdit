        "speaker_id": "LibriTTS_R-4599",
        "content": "\"I wish my great uncle were here!",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
