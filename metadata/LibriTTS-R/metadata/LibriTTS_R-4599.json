        "speaker_id": "LibriTTS_R-4599",
        "content": "She was generally sent to practise on an old square piano in one of the top rooms.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
