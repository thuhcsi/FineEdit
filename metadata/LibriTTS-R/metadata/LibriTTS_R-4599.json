        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4599/21274/4599_21274_000041_000001.wav",
        "speaker_id": "LibriTTS_R-4599",
        "content": "Upon my word!",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4599_21274_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4599/21274/4599_21274_000041_000002.wav",
        "speaker_id": "LibriTTS_R-4599",
        "content": "And who may he be, miss?",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4599_21274_000041_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4599/21274/4599_21274_000041_000006.wav",
        "speaker_id": "LibriTTS_R-4599",
        "content": "You get along with you, and behave yourself, and don't talk stuff to me.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
