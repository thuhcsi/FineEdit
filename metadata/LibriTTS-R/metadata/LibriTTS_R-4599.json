        "speaker_id": "LibriTTS_R-4599",
        "content": "There were two or three books which Marcella had absorbed in a way it now made her envious to remember.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
