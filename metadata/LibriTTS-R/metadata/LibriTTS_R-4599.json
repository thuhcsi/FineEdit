        "speaker_id": "LibriTTS_R-4599",
        "content": "But at thirteen-what concentration!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
