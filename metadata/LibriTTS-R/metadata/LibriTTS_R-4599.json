        "speaker_id": "LibriTTS_R-4599",
        "content": "The whole of her first year was one continual series of sulks, quarrels, and revolts.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
