        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2628/153964/2628_153964_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2628",
        "content": "\"If this be so,\" said my opponent, \"we must bear it as best we may.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
