        "speaker_id": "LibriTTS_R-2628",
        "content": "\"But, my dear Knight,\" said I, \"it sounds incredible.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
