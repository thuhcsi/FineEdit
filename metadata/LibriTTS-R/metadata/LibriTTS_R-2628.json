        "speaker_id": "LibriTTS_R-2628",
        "content": "THE DETECTIVE DETECTOR",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2628_109663_000005_000000",
