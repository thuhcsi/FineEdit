        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2628/109663/2628_109663_000007_000000.wav",
        "speaker_id": "LibriTTS_R-2628",
        "content": "\"You pique my professional pride, doctor,\" he said in a nettled tone. \"I will convince you.\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2628_109663_000008_000000",
