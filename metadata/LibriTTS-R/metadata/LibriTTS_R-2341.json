[
    {
        "item_name": "LibriTTS_R-2341_151701_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000003_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "A CALL ON THE WARDEN",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000004_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "Here and there in the grim corridors a guard dozed in the glare of an electric light; and in the office, too, a desk light glimmered where the warden sat at his desk, poring over a report.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000004_000002.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "Once he glanced up at the clock-it was five minutes of eleven-and then he went on with his reading.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000005_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "He was rather tall and slender, and a sinister black mask hid his face from the quickly raised eyes of the warden.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000005_000003.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "The intruder noted both gestures, and, unarmed himself, stood silent.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000005_000004.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "The warden was first to speak.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000006_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"Well, what is it?\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000007_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"You have a prisoner here, Pietro Petrozinni,\" was the reply, in a pleasant voice.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000007_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"I have come to demand his release.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "The warden's right hand was raised above the desk top, and the revolver in it clicked warningly.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000009_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "He still sat motionless, with his eyes fixed on the black mask.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000009_000002.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"How did you pass the outside guard?\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000010_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"He was bribed,\" was the ready response.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000010_000002.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "I may add that no bribe was offered to you because your integrity was beyond question.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"Oh, that isn't loaded,\" said the masked man quietly.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000016_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"And that wire was cut, too,\" the stranger explained.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "The warden came to his feet with white face, and nails biting into the palms of his hands.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000018_000003.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "I want your prisoner, Signor Petrozinni-you will release him at once! That's all!\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"Then I shall take him,\" was the reply.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000021_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"It has been made impossible for you to give an alarm,\" the stranger went on.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000021_000002.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"The very men on whom you most depended have been bought, and even if they were within sound of your voice now they wouldn't respond.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000021_000003.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "One of your assistants who has been here for years unloaded the revolver in the desk there, and less than an hour ago cut the prison alarm wire.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000021_000004.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "I, personally, cut the police alarm outside the building.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000021_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000021_000005.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "So you see!\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000022_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "His tone was a perfectly normal one.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000023_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"These are four inner guards and the outer guard.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000023_000002.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "They have all been bought-the turnkeys at five thousand dollars each, and the outer guard at seven thousand.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000025_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"He is a man who can command a vast fortune-and Senor Alvarez is at the point of death.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000025_000002.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "Now, if you'll sit down, please!\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000026_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"Sit down?\" bellowed the warden.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000027_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "Suddenly he was seized by a violent, maddening rage.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000027_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "He took one step forward and raised the empty revolver to strike.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000027_000002.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "The masked man moved slightly to one side and his clenched fist caught the warden on the point of the chin.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000029_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"Better send some of your men up to investigate.\"",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2341_151701_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/151701/2341_151701_000031_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "The stranger replaced the receiver on the hook, stripped off his black mask, dropped it on the floor beside the motionless warden, and went out.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2341_163407_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/163407/2341_163407_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"Where's the butter?\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_163407_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/163407/2341_163407_000006_000001.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "And then mosey right down the lightning rod and come along.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2341_163407_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2341/163407/2341_163407_000008_000000.wav",
        "speaker_id": "LibriTTS_R-2341",
        "content": "\"You been down cellar?\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2341_163407_000010_000000",
