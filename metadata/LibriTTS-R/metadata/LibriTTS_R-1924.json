[
    {
        "item_name": "LibriTTS_R-1924_132574_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "My tongue hath but a heavier tale to say. I play the torturer, by small and small, To lengthen out the worst that must be spoken. RICHARD the second",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "We now return, for a moment, to Venice, where Count Morano was suffering under an accumulation of misfortunes.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Soon after his arrival in that city, he had been arrested by order of the Senate, and, without knowing of what he was suspected, was conveyed to a place of confinement, whither the most strenuous enquiries of his friends had been unable to trace him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "In the affair of the poisoned cup, Montoni had suspected Morano; but, being unable to obtain the degree of proof, which was necessary to convict him of a guilty intention, he had recourse to means of other revenge, than he could hope to obtain by prosecution.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "As, on these occasions, the accuser is not confronted with the accused, a man may falsely impeach his enemy, and accomplish an unjust revenge, without fear of punishment, or detection.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Montoni, meantime, was beset by dangers of another kind.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "His castle was besieged by troops, who seemed willing to dare every thing, and to suffer patiently any hardships in pursuit of victory.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "The strength of the fortress, however, withstood their attack, and this, with the vigorous defence of the garrison and the scarcity of provision on these wild mountains, soon compelled the assailants to raise the siege.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "When Udolpho was once more left to the quiet possession of Montoni, he dispatched Ugo into Tuscany for Emily, whom he had sent from considerations of her personal safety, to a place of greater security, than a castle, which was, at that time, liable to be overrun by his enemies.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Tranquillity being once more restored to Udolpho, he was impatient to secure her again under his roof, and had commissioned Ugo to assist Bertrand in guarding her back to the castle.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "It was noon, when she had left the cottage, and the evening was closed, long before she came within the neighbourhood of Udolpho.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'No,' answered Ugo, 'he crowed as loud as the best of them in the midst of it all.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "There he was roaring out in the hottest fire I have seen this many a day!",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Its massy and gloomy walls gave her terrible ideas of imprisonment and suffering: yet, as she advanced, some degree of hope mingled with her terror; for, though this was certainly the residence of Montoni, it was possibly, also, that of Valancourt, and she could not approach a place, where he might be, without experiencing somewhat of the joy of hope.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "They continued to wind along the valley, and, soon after, she saw again the old walls and moon lit towers, rising over the woods: the strong rays enabled her, also, to perceive the ravages, which the siege had made,--with the broken walls, and shattered battlements, for they were now at the foot of the steep, on which Udolpho stood.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000012_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Massy fragments had rolled down among the woods, through which the travellers now began to ascend, and there mingled with the loose earth, and pieces of rock they had brought with them.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "The woods, too, had suffered much from the batteries above, for here the enemy had endeavoured to screen themselves from the fire of the ramparts.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000012_000003.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Many noble trees were levelled with the ground, and others, to a wide extent, were entirely stripped of their upper branches.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000012_000004.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'We had better dismount,' said Ugo, 'and lead the mules up the hill, or we shall get into some of the holes, which the balls have left.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000012_000005.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Here are plenty of them.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000012_000006.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Give me the torch,' continued Ugo, after they had dismounted, 'and take care you don't stumble over any thing, that lies in your way, for the ground is not yet cleared of the enemy.'",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'How!' exclaimed Emily, 'are any of the enemy here, then?'",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Nay, I don't know for that, now,' he replied, 'but when I came away I saw one or two of them lying under the trees.'",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "As they proceeded, the torch threw a gloomy light upon the ground, and far among the recesses of the woods, and Emily feared to look forward, lest some object of horror should meet her eye.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000016_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Presently, the castle clock struck twelve, and then a trumpet sounded, of which Emily enquired the occasion.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000017_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "We have sounded it, at midnight, ever since the place was besieged.'",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000018_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "She complained of cold, and begged to go on.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000018_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Presently, lady,' said Bertrand, turning over some broken arms with the pike he usually carried.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000018_000003.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'What have we here?'",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Hark!' cried Emily, 'what noise was that?'",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'What noise was it?' said Ugo, starting up and listening.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Hush!' repeated Emily. 'It surely came from the ramparts above:' and, on looking up, they perceived a light moving along the walls, while, in the next instant, the breeze swelling, the voice sounded louder than before.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Who goes yonder?' cried a sentinel of the castle.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Speak or it will be worse for you.' Bertrand uttered a shout of joy.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000022_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Hah! my brave comrade, is it you?' said he, and he blew a shrill whistle, which signal was answered by another from the soldier on watch; and the party, then passing forward, soon after emerged from the woods upon the broken road, that led immediately to the castle gates, and Emily saw, with renewed terror, the whole of that stupendous structure.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000022_000003.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Alas!' said she to herself, 'I am going again into my prison!'",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000028_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "They were now arrived at the gates, where Bertrand, observing the light glimmer through a small casement of the portal chamber, called aloud; and the soldier, looking out, demanded who was there.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000029_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Tell me first who it is, that demands entrance,' replied the soldier. 'What! my old comrade,' cried Ugo, 'don't you know me?",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000029_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "I have brought home a prisoner here, bound hand and foot-a fellow, who has been drinking Tuscany wine, while we here have been fighting.'",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000031_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Emily presently heard his steps descending the stairs within, and then the heavy chain fall, and the bolts undraw of a small postern door, which he opened to admit the party.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000031_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "He held the lamp low, to shew the step of the gate, and she found herself once more beneath the gloomy arch, and heard the door close, that seemed to shut her from the world for ever.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000031_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000031_000006.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Who is carousing at this late hour?'",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000033_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Courage, my lad, courage ought to warm your heart,' said Ugo. 'Courage!' replied the soldier sharply, with a menacing air, which Ugo perceiving, prevented his saying more, by returning to the subject of the carousal.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132574_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132574/1924_132574_000033_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'This is a new custom,' said he; 'when I left the castle, the Signors used to sit up counselling.'",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Several of her succeeding days passed in suspense, for Ludovico could only learn from the soldiers, that there was a prisoner in the apartment, described to him by Emily, and that he was a Frenchman, whom they had taken in one of their skirmishes, with a party of his countrymen.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "During this interval, Emily escaped the persecutions of Bertolini, and Verezzi, by confining herself to her apartment; except that sometimes, in an evening, she ventured to walk in the adjoining corridor.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Montoni appeared to respect his last promise, though he had prophaned his first; for to his protection only could she attribute her present repose; and in this she was now so secure, that she did not wish to leave the castle, till she could obtain some certainty concerning Valancourt; for which she waited, indeed, without any sacrifice of her own comfort, since no circumstance had occurred to make her escape probable.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "On the fourth day, Ludovico informed her, that he had hopes of being admitted to the presence of the prisoner; it being the turn of a soldier, with whom he had been for some time familiar, to attend him on the following night.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "He was not deceived in his hope; for, under pretence of carrying in a pitcher of water, he entered the prison, though, his prudence having prevented him from telling the sentinel the real motive of his visit, he was obliged to make his conference with the prisoner a very short one.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Emily, having then uttered the name of Valancourt, could articulate no more, but hesitated in trembling expectation.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Valancourt,' said Annette, and looked impatiently at Ludovico, who understood her look, and replied to Emily: 'Yes, lady, the Chevalier does, indeed, remember you, and, I am sure, has a very great regard for you, and I made bold to say you had for him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000005_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "He then enquired how you came to know he was in the castle, and whether you ordered me to speak to him.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000005_000003.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "The first question I could not answer, but the second I did; and then he went off into his ecstasies again.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "I was afraid his joy would have betrayed him to the sentinel at the door.'",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'But how does he look, Ludovico?' interrupted Emily: 'is he not melancholy and ill with this long confinement?'--'Why, as to melancholy, I saw no symptom of that, lady, while I was with him, for he seemed in the finest spirits I ever saw any body in, in all my life.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "His countenance was all joy, and, if one may judge from that, he was very well; but I did not ask him.' 'Did he send me no message?' said Emily. 'O yes, Signora, and something besides,' replied Ludovico, who searched his pockets.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'Surely, I have not lost it,' added he.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Tears of mingled joy and tenderness flowed to her eyes, while Ludovico proceeded-'\"Tell your lady,\" said the Chevalier, as he gave me the picture, \"that this has been my companion, and only solace in all my misfortunes.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'How, Ludovico, shall I reward you for your zeal?' said Emily: 'but, indeed, I do not now possess the means.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000008_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "When can you see the Chevalier again?' 'That is uncertain, Signora,' replied he.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'I need not bid you remember, Ludovico,' resumed Emily, 'how very much interested I am in your seeing the Chevalier soon; and, when you do so, tell him, that I have received the picture, and, with the sentiments he wished.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'The place, and the hour, must be regulated by his opportunities.'",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "'As to the place, mademoiselle,' said Annette, 'there is no other place in the castle, besides this corridor, where WE can see him in safety, you know; and, as for the hour,--it must be when all the Signors are asleep, if that ever happens!' 'You may mention these circumstances to the Chevalier, Ludovico,' said she, checking the flippancy of Annette, 'and leave them to his judgment and opportunity.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Tell him, my heart is unchanged.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "But, above all, let him see you again as soon as possible; and, Ludovico, I think it is needless to tell you I shall very anxiously look for you.' Having then wished her good night, Ludovico descended the staircase, and Emily retired to rest, but not to sleep, for joy now rendered her as wakeful, as she had ever been from grief.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000010_000003.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Montoni and his castle had all vanished from her mind, like the frightful vision of a necromancer, and she wandered, once more, in fairy scenes of unfading happiness:",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "A week elapsed, before Ludovico again visited the prison; for the sentinels, during that period, were men, in whom he could not confide, and he feared to awaken curiosity, by asking to see their prisoner.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Her name was frequently mentioned in the conversations, which Bertolini and Verezzi held together, and, at those times, they were frequently in contention.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000014_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Never, since her residence in the castle, had she watched, with so much pleasure, the sun set behind the mountains, and twilight shade, and darkness veil the scene, as on this evening.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000014_000005.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "The idea of Valancourt, and that she should see him so soon, alone occupied her heart.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "At length the clock struck twelve; she opened the door to listen, if any noise was in the castle, and heard only distant shouts of riot and laughter, echoed feebly along the gallery.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000015_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "She guessed, that the Signor and his guests were at the banquet.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000015_000003.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Annette, whom she detained, was, in the meantime, as loquacious as usual; but Emily heard scarcely any thing she said, and having at length risen to the casement, she distinguished the chords of the lute, struck with an expressive hand, and then the voice, she had formerly listened to, accompanied it.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Emily wept in doubtful joy and tenderness; and, when the strain ceased, she considered it as a signal, that Valancourt was about to leave the prison.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000017_000001.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "Soon after, she heard steps in the corridor;--they were the light, quick steps of hope; she could scarcely support herself, as they approached, but opening the door of the apartment, she advanced to meet Valancourt, and, in the next moment, sunk in the arms of a stranger.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1924_132576_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1924/132576/1924_132576_000017_000002.wav",
        "speaker_id": "LibriTTS_R-1924",
        "content": "His voice-his countenance instantly convinced her, and she fainted away.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    }
]