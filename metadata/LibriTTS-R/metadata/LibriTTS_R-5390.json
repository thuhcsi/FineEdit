        "speaker_id": "LibriTTS_R-5390",
        "content": "\"Partly, miss.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5390_30102_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30102/5390_30102_000027_000001.wav",
        "speaker_id": "LibriTTS_R-5390",
