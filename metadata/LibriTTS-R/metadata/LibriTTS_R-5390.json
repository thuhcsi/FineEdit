        "speaker_id": "LibriTTS_R-5390",
        "content": "He wanted capital to patent the pump and put it on the market.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000027_000000",
