        "speaker_id": "LibriTTS_R-5390",
        "content": "\"Beth and Patsy have planned a tramp to the lake, and a row after water lilies.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
