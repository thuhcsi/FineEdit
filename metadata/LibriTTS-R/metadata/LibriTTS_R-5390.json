        "speaker_id": "LibriTTS_R-5390",
        "content": "The farm's the thing.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000052_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30096/5390_30096_000052_000000.wav",
        "speaker_id": "LibriTTS_R-5390",
