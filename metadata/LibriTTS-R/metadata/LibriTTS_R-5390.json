        "speaker_id": "LibriTTS_R-5390",
        "content": "They were looking for an earthly king, and the beautiful words spoken by the ancient prophets had no meaning to them.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
