        "speaker_id": "LibriTTS_R-5390",
        "content": "UNCLE JOHN'S FARM.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30096/5390_30096_000006_000000.wav",
        "speaker_id": "LibriTTS_R-5390",
        "content": "\"And it's true,\" asserted the other.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
