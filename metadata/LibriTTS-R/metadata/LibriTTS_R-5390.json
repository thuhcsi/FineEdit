        "speaker_id": "LibriTTS_R-5390",
        "content": "\"I'm so sorry!\" said Patsy, sympathetically.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000035_000000",
