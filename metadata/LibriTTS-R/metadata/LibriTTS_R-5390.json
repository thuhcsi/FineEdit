        "speaker_id": "LibriTTS_R-5390",
        "content": "\"Well?\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30096/5390_30096_000028_000000.wav",
        "speaker_id": "LibriTTS_R-5390",
        "content": "\"It's gone, john; and you've got the farm.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30096/5390_30096_000028_000001.wav",
        "speaker_id": "LibriTTS_R-5390",
        "content": "The other fellows were too clever for my young friend, Joseph Wegg, and knocked out his patent.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
