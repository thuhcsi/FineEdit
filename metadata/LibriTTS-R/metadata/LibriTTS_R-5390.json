        "speaker_id": "LibriTTS_R-5390",
        "content": "\"Somewhere at the north of the State, I believe.\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30096/5390_30096_000049_000000.wav",
        "speaker_id": "LibriTTS_R-5390",
        "content": "\"Yes, my dear.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000049_000003",
