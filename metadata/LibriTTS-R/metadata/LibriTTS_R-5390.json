        "speaker_id": "LibriTTS_R-5390",
        "content": "\"I guessed it.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5390_30102_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30102/5390_30102_000026_000000.wav",
        "speaker_id": "LibriTTS_R-5390",
        "content": "As he appeared indisposed to say more on the subject she asked: \"Did you sail with Captain Wegg?\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5390_30102_000027_000000",
