        "speaker_id": "LibriTTS_R-5390",
        "content": "\"Pah!\" said the Major, scornfully.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5390_30096_000058_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5390/30096/5390_30096_000058_000000.wav",
        "speaker_id": "LibriTTS_R-5390",
        "content": "\"Perhaps so; at an expense that will add to your loss.\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
