        "speaker_id": "LibriTTS_R-8545",
        "content": "Yet the suggestion attracted Helen, too.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
