[
    {
        "item_name": "LibriTTS_R-4420_5802_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000001_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Banks of the Forth.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000002_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "In the collected council of the following day, the Earl of March made his treacherous request; and Wallace, trusting his vehement oaths of fidelity (because he thought the versatile earl had now discovered his true interest), granted him charge of the Lothians.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000002_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "The Lords Athol and Buchan were not backward in offering their services to the regent; and the rest of the discontented nobles, following the base example, with equal deceit bade him command their lives and fortunes.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000003_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Lord Loch awe knew his own influence in the minds of the bravest chieftains.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000003_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "From the extent of his territories and his tried valor, he might well have assumed the title of his great ancestor, and been called King of Woody Morven, but he was content with a patriarch's sway over so many valiant clans; and previous to the regent's appearance in the council hall he opened his intentions to the assembled lords.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000004_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Wallace soon after entered.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000004_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Mar and Bothwell enforced it.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000004_000004.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "The disaffected lords thought proper to throw in their conjurations also; and every voice but that of Badenoch poured forth fervent entreaties that he, their liberator, would grant the supplication of the nation.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000005_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Wallace rose, and every tongue was mute.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000005_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"My gratitude to Scotland increases with my life; but my answer must still be the same-I cannot be its king.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000006_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "At these words the venerable Loch awe threw himself on his knees before him.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000006_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "still bleeding with the effects of former struggles for empire, she would throw off all claims but those of virtue, and receive as her anointed sovereign, her father and deliverer!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000006_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "She has no more arguments to utter-these are her prayers, and thus I offer them.\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000007_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"Kneel not to me, brave Loch awe!\" cried Wallace; \"nor believe the might of these victories lies so thoroughly on this arm that I dare outrage its Maker.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000007_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Your rightful king yet lives; he is an alien from his country, but Heaven may return him to your prayers. Meanwhile, as his representative, as your soldier and protector, I shall be blessed in wearing out my life.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000007_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "My ancestors were ever faithful to the blood of Alexander, and in the same fidelity I will die.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000008_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "The firmness with which he spoke, and the determined expression of his noble countenance, convinced Loch awe that he was not to be shaken; and rising from his knee, he bowed in silence.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000008_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "March whispered to Buchan, \"Behold the hypocrite!",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000008_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "But we shall unmask him.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000008_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "He thinks to blind us to his towering ambition, by this affected moderation.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000009_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "When the council broke up, these sentiments were actively disseminated among the disaffected throng; and each gloomy recess in the woods murmured with seditious meetings.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000009_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "But every lip in the country at large breathed the name of Wallace, as they would have done a god's; while the land that he had blessed, bloomed on every hill and valley like a garden.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000010_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Stirling now exhibited a constant carnival; peace was in every heart, and joy its companion.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000011_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "His munificent hand stretched itself far and near, that all who had shared the sufferings of Scotland might drink largely of her prosperity.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000011_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Her heart gave him his title; which she believed the not to be repressed affection of the people would at last force him to accept.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000013_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Eager to be rid of so dangerous a spy and adversary as she deemed Edwin to be, she was laboring day and night to effect by clandestine schemes his banishment, when an unforeseen circumstance carried him far away.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000013_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Lord Ruthven, while on an embassy to the Hebrides, fell ill.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000014_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Busy, then, as this lady was, the enemies of the regent were not less active in the prosecution of their plans.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000014_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "The wary king then told the earl, that if he would send his wife and family to London, as hostages for his faith, he was ready to bring a mighty army to Dunbar; and, by that gate, once more enter Scotland.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000014_000004.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "So careful was he, in overlooking, by his well chosen officers, civil and military, every transaction, that the slightest dereliction from the straight order of things was immediately seen and examined into.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000015_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "He knew that nobleman would gladly welcome the recall of the King of England; for ever since the revolution in favor of Scotland, he had remained obstinately shut up within his castle of Hermitage.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000016_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "While treason secretly prepared to spring its mine beneath the feet of the regent, he, unsuspicious that any could be discontented where all were free and prosperous, thought of no enemy to the tranquil fulfillment of his duties but the minor persecutions of Lady Mar.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000016_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "No day escaped without bringing him letters, either to invite him to Snawdoun or to lead her to the citadel, where he resided.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000016_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "And though perfectly aware of all that was behind these asseverations (for she had deceived him once into a belief of this please, and had made him feel its falseness), he found himself forced at times, out of the civility due to her sex, to comply with her invitations.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000016_000005.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "The frequency of these scenes at last made him never go to Snawdoun unaccompanied (for she rarely allowed him to have even a glimpse of Helen), and by this precaution he avoided much of her solicitations.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000017_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Things were in this situation when Wallace, one night, received a hasty summons from his pillow by a page of Lord Mar's, requesting him to immediately repair to his chamber.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000017_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Concluding that something alarming must have happened, he threw on his brigandine and plaid, and entered the apartments of the governor.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000018_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"What has happened?\" inquired Wallace.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000019_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"Treason,\" answered Mar; \"but from what point I cannot guess.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000019_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "My daughter has braved a dark and lonely walk from Snawdoun, to bring the proofs.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000020_000004.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Blushing and silent, she extended her hand to him to rise.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000020_000005.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "He pressed it warmly.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000022_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "The earl held a roll of vellum toward him.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000022_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"This writing,\" said he, \"was found this evening by my daughter.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000022_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "She was enjoying with my wife and other ladies a moonlight walk on the shores of the Forth behind the palace, when, having strayed at some distance from her friends, she saw this packet lying in the path before her, as if it had just been dropped.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000022_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "It bore no direction; she therefore opened it, and part of the contents soon told her she must conceal the whole, till she could reveal them to me.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000022_000005.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "As soon as the family were gone to rest, she wrapped herself in her plaid and finding a passage through one of the low embrasures of Snawdoun, with a fleet step made her way to the citadel and to me.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000022_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000022_000006.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "She gave me the packet.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000022_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000022_000007.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Read it, my friend, and judge if we do not owe ourselves to Heaven for so critical a discovery!\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000023_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Wallace took the scroll, and read as follows:",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000024_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"Our trusty fellows will bring you this, and deliver copies of the same to the rest.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000024_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Keep all safe, and neither himself nor any of his adherents shall have a head on their shoulders by this day week.\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000025_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Neither superscription, name, nor date, was to this letter; but Wallace immediately knew the handwriting to be that of Lord March.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000025_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"Then we must have traitors, even within these walls,\" exclaimed Mar; \"none but the most powerful chiefs would the proud Cospatrick admit into his conspiracies.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000026_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"No,\" cried Wallace.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000026_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"Thanks to God and this guardian angel!\" fervently clasping Helen's hand as he spoke, \"we must not be intimidated by treachery!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000026_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Let us be faithful to ourselves, my veteran friend, and all will go well.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000026_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "It matters not who the other traitors are; they must soon discover themselves, and shall find us prepared to counteract their machinations.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000028_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "The Lords Bothwell, Loch awe, and Badenoch were the first that obeyed the call.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000028_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000028_000003.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"What!\" cried Bothwell, \"but to open his castle gates to the enemy!\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000029_000000.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "\"And to repel him before he reaches ours, my brave chiefs,\" replied Wallace, \"I have summoned you!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000029_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Edward will not make this attempt without tremendous powers.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000029_000002.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "He knows what he risks; his men, his life, and his honor.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000029_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000029_000005.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "I will call up mine from the banks of the Clyde, and be ready to meet him ere he crosses the Carrou.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000030_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000030_000004.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Was she then beloved?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4420_5802_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4420/5802/4420_5802_000031_000001.wav",
        "speaker_id": "LibriTTS_R-4420",
        "content": "Forgive me-but I am exhausted; my frame is weaker than my mind.\" She spoke this at intervals, and Wallace respectfully touching the hand she extended, pressed it to his breast.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    }
]