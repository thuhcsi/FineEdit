        "speaker_id": "LibriTTS_R-4198",
        "content": "Babylon next claimed the attention of Tiglath pileser.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
