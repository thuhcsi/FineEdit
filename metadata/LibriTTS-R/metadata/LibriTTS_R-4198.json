        "speaker_id": "LibriTTS_R-4198",
        "content": "How a monk of Seville saved the close of the abbey from being ransacked by the enemy.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
