        "speaker_id": "LibriTTS_R-4198",
        "content": "Shalmaneser died before Samaria was captured, and may have been assassinated.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
