        "speaker_id": "LibriTTS_R-4198",
        "content": "He was met with a stubborn resistance.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4198_61336_000034_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4198/61336/4198_61336_000034_000003.wav",
        "speaker_id": "LibriTTS_R-4198",
        "content": "Two years afterwards Tiglath pileser returned, captured Shapia, and restored peace throughout Babylonia.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
