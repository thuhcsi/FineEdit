        "speaker_id": "LibriTTS_R-4198",
        "content": "The Philistines and the Arabians of the desert were also subdued.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
