        "speaker_id": "LibriTTS_R-4198",
        "content": "Samaria closed its gates against him although their king had been dispatched to Assyria.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
