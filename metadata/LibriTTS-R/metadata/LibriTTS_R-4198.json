        "speaker_id": "LibriTTS_R-4198",
        "content": "Tiglath pileser had now reached the height of his ambition.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
