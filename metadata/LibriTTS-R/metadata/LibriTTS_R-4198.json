        "speaker_id": "LibriTTS_R-4198",
        "content": "He swept through Israel \"like a hurricane\".",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
