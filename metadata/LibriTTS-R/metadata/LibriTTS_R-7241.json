        "speaker_id": "LibriTTS_R-7241",
        "content": "\"I will try to morrow,\" said the cat.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
