[
    {
        "item_name": "LibriTTS_R-7241_90850_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000002_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "THE BIRD BOY",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Suddenly, far, far up in the sky, she heard the weird cry of birds flying southward, and lifting her eyes, the Queen beheld bird after bird fly across the golden shield of the moon.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000005_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Now it came to pass that before the harvest moon rose again over the land, the Queen became the mother of a little boy who was born with wings on his shoulders.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000005_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "So the Queen and her baby were taken to an old and gloomy tower on a great rock overlooking the northern sea; and after they had been there a day or two, the chief jailer came to the Queen's room to take the child and kill him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "But although she fought for her baby with all her might, the rude strength of the jailers prevailed, and the child was torn from its mother's arms.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Then, before anyone could prevent her, the poor Queen beat open the rotted fastening of an old casement window, sprang upon the ledge, and giving one last look of love and tenderness to her unhappy child, leaped down into the sea surging and pounding over the rocks hundreds of feet below.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000008_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "She certainly would have been dashed to pieces, had not a good spirit of the ocean taken pity on her, and changed her into a great gray bird.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000008_000004.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Crying mournfully, the bird circled the old tower thrice, and disappeared over the white capped waters.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "So, instead of killing the bird boy, he carried him many leagues back into the dark forest which bordered the sea, and gave him to a family of charcoal burners.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000009_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "And every year, on the boy's birthday, a great gray bird came flying over the forest from the distant ocean, circled thrice the charcoal burners' hut, and disappeared again, crying mournfully.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "One midsummer day, with a great deal of merry hallooing and blowing of sweet voiced horns, the King of the country, accompanied by his young wife, came hunting through the wood.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "There was a pretty spring near the door of the hut, and the party came to a halt at its edge.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000010_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "And a wonderful sight it was, indeed, to see the horses tossing their jeweled bridles, the hooded falcons riding on the saddlebow, clutching the leather with their curving claws, the merry young pages in their dark suits, and all the gay company in rich attire.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000011_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Really, dear, I must have him for my page.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000011_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Besides, he will be a playmate for Rosabella.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000013_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "So the bird boy became the best beloved playmate of the Queen's only child, her darling Rosabella.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Now, if the bird boy was the prettiest little boy in all the world, Rosabella was the prettiest little girl. Moreover, she had a sweet disposition, which is a gift even more precious than the gift of beauty.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000013_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "It was a lovely picture to see the children building toy castles on the floor of the nursery in the castle tower, the sun streaming on the black brown hair and silver white wings of the little boy, and on the golden curls of Rosabella.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Twelve years passed.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Every year, on the bird boy's birthday, a great gray bird would fly in from over the sea, circle the castle thrice, and disappear, crying mournfully.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "His enemy was no other than the wicked chamberlain Malefico, who had succeeded to the kingdom of the bird boy's father, when that Prince had died some years before. So the good King, who had been a real father to the bird boy, put on his shining armor, kissed his dear wife and child good bye, and rode off to the battlefield.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "A month passed, an unhappy month in which there were no tidings from the King.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000017_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "A great battle had been fought, the army of Rosabella's father had been completely defeated, and the troops of the wicked Malefico were hurrying toward the castle as fast as they could come.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000019_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "When Malefico saw the bird boy, a look of surprise appeared on his face, for he had believed that the wonderful child was dead.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000020_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "\"If it were known that the winged child is alive,\" he thought, \"the people would thrust me from my place, and restore him to his father's throne.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000020_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Now that the bird boy is in my hands, I will destroy him, and be sure of my power.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000021_000004.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "When it was over, he sent a soldier to tell the King and the bird boy that they were to be punished the following day.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000022_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "And now dawned the unhappy day.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000022_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The morning was fresh and fair; a pleasant southwest wind was blowing.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000022_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000022_000004.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The clock marked a quarter to twelve.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000025_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "And even if it were to come, what could it do to save us from these cruel people?\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000026_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "When the clock stood at five minutes to twelve, there was a confused noise below, and Malefico and the judges who shared with him the guilt of the unrighteous punishment took their places on a kind of platform which overlooked the place of execution.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000027_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "\"They will soon be coming to get us,\" said the King to the bird boy.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000028_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "And sure enough, they heard the jangle of the jailer's keys at the foot of the stair.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000030_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000030_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The doom which Malefico had intended for another had overtaken him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000031_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The King and the Queen, Rosabella and the bird boy, rushed down the stairs and out into the sunlight.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000031_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000031_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "She took her son in her arms, and told them all his history and her misfortunes, and how she had watched over him year after year and gathered the birds to save him.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90850_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90850/7241_90850_000032_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Thus it came to pass that, when the troops of Malefico saw their former Queen and heard her story, they acclaimed the bird boy as their rightful king, and carried him back in triumph into his own country.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000003_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The old enchanter liked this life of quiet and study, and doubtless would have been teaching in Fairyland to this very day, had he not been so unfortunate as to quarrel with the terrible sorcerer Zidoc, who was then Lord High Chancellor of the Fairies' College.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "I have forgotten exactly what the quarrel was about, but I think that it had to do with the best spell for causing castles to fall to pieces in an instant.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000003_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "At any rate, Zidoc, who considered himself quite the most wonderful enchanter in Fairyland, was furious at being opposed, and told the old enchanter, very angrily, that he was not to have his classes any more and must leave the college at once.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000003_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "So the poor old gentleman packed up his magic books, put his enchanter's wand into its silver case, and went to the country one pleasant day in search of a house.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Thanks to the advice of a friendly chimney swift, it did not take him long to find one.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000004_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The dwelling was the property of the Fairy Jocapa.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000005_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "It was very quiet.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000005_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Only the far away klingle klangle of a cow bell could be heard.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "And he brought his possessions to the house.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Now, one autumnal morning, when a blue haze hung over the lonely fields from which the reapers had departed, and the golden leaves were wet underfoot, the old enchanter went for a walk down the lane, and finding the day agreeable, kept on until he found himself in the woods.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Arriving at the crest of a little hill in the woodland, he saw below him, almost at the foot of the slope, a countryman with a white puppy and a black kitten following at his heels.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000012_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "\"Give them to me,\" said the old enchanter, \"I will bring them up.\" The countryman nodded his head.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000013_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Thus did the white puppy and black kitten change hands.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "So he taught the cat and the dog all the known languages, then history, arithmetic, dancing, social deportment, and a variety of the best magic and spells. The cat, as was to be expected, was particularly good on anything that had 'cat' in it; he once catalogued all the principal catastrophes; while the dog, although a good student, had a fancy for writing doggerel.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000015_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "For a long time the enchanter, who loved his charges very much indeed, resisted their request; but as they continued to press him, he came at length to yield.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000015_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Calling them before him, he said to them:--",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000016_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "\"Well, dear pupils, if you must go, you must go.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "I owe the Fairy Jocapa twelve months rent for this house.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "So the white dog, who was the stronger of the two, took the purse with the twelve golden coins, and put it in a large wallet which he wore at his side, and then both the wonderful animals said good bye.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000018_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000018_000004.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Both the cat and the dog were awarded countless honorary decorations.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000019_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Arriving in the twilight, they were somewhat surprised to find a number of torchbearers waiting for them in the castle courtyard.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000019_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "With great respect, these attendants conducted the cat and the dog into a little ante room, and then retired, leaving them alone.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000019_000004.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "A few minutes later, a very old woman, who, the animals noticed, was stone blind, came to take them before the king.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "\"Very,\" whispered back the dog in his deeper tone.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000022_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The cat, who could see quite well in the dark, did not mind this, but the dog was not particularly pleased.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000024_000003.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Beside the fireplace, in which a wood fire was cheerily burning, sat a gray haired lady, who was no other than the Fairy Jocapa, and in the centre of the room, reading a great book by the light of many candles, sat a young man, the King.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000026_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "Listen, then, to my story and help me if you can.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000027_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "It was she who caused this enchanted chamber to appear in the heart of the foundations of my castle; and in this chamber I have hidden since that terrible hour when the spell was put upon me.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000027_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000027_000004.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The Lord Chancellor rules the kingdom in my stead.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000027_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000027_000005.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "But hearken to my story.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000028_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The driver of the chariot was a tall, elderly man, wearing a wizard's cap; his face was red as with anger, an evil light gleamed in his small malicious eyes.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000028_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000028_000009.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "You know the rest.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000033_000002.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "The dog's plan was to pretend to be but an everyday stray dog, and to this end, he rolled several times in a mud puddle; the cat, too, was to appear as a stray cat, and neglected his fine black coat in order to look the part.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000035_000001.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "When twilight came, the dog ran out and met the cat in the castle garden.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7241_90852_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7241/90852/7241_90852_000037_000000.wav",
        "speaker_id": "LibriTTS_R-7241",
        "content": "\"Nothing whatever,\" replied the dog.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
