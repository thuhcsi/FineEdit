        "speaker_id": "LibriTTS_R-6295",
        "content": "He that loveth not his brother whom he hath seen, how shall he love God whom he hath not seen?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
