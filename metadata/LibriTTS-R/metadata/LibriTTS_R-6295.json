        "speaker_id": "LibriTTS_R-6295",
        "content": "It broke the enchantment in which Joseph was bound.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
