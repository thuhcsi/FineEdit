        "speaker_id": "LibriTTS_R-6295",
        "content": "That enchantment had possessed him, usurping as it were the throne of his life, and displacing it; when it ceased, he was not his own master.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
