        "speaker_id": "LibriTTS_R-6295",
        "content": "He was watching the boats.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6295_244435_000014_000000",
