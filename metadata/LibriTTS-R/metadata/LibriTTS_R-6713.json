        "speaker_id": "LibriTTS_R-6713",
        "content": "There are sterile knotty sciences, chiefly hammered out for the crowd; let such be left to them who are engaged in the world's service.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
