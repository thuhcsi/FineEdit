        "speaker_id": "LibriTTS_R-6713",
        "content": "The imagination of those who seek solitude upon the account of devotion, filling their hopes and courage with certainty of divine promises in the other life, is much more rationally founded.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
