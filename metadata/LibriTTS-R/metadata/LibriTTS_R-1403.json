[
    {
        "item_name": "LibriTTS_R-1403_130575_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/130575/1403_130575_000000_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "One day a tiger spied them out as they were roasting tubers and came up to them suddenly and said.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1403_130575_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/130575/1403_130575_000000_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "\"What are you cooking?",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_130575_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/130575/1403_130575_000000_000007.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Kara wanted to eat it but Guja would not let him, so Kara carried it away on his shoulder.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_130575_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/130575/1403_130575_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Presently they sat down in the shade of a banyan tree by the side of a road and along the road came a Raja's wedding procession; when Kara and Guja saw this they climbed into the tree and took the tiger's paunch up with them.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_130575_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/130575/1403_130575_000001_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The wedding party came to a halt at the foot of the tree and some of them lay down to eat and the Raja got out of his palki and lay down to sleep in the shade.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_130575_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/130575/1403_130575_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "When the Raja's attendants came back and saw that there were two men in the tree, they called out: \"Why have you dishonoured our Raja?",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_130575_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/130575/1403_130575_000002_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "We will kill you.\" Kara and Guja answered \"Come and see who will do the killing.\" So they began to fight and the Raja's men fired their guns at Kara and Guja till they were tired of shooting, and had used up all their powder and shot, but they never hit them.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "\"Vizier,\" said he, \"I will take a walk round the town, to inform myself what people say, and particularly how they are pleased with my officers of justice.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "They passed through several places, and by several markets.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "As they entered a small street, they perceived by the light of the moon, a tall man, with a white beard, who carried nets on his head, and a staff in his hand.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000003_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The old man replied, \"Sir, I am a fisher, but one of the poorest and most miserable of the trade.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The caliph, moved with compassion, said to the fisherman, \"Hast thou the courage to go back and cast thy net once more?",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "They came to the bank of the river, and the fisherman, having thrown in his net, when he drew it again, brought up a trunk close shut, and very heavy.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The caliph made the grand vizier pay him one hundred sequins immediately, and sent him away.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000005_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "When the trunk was opened, they found in it a large basket made of palm leaves, shut up, and the covering of it sewed with red thread.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The astonishment of the caliph was great at this dreadful spectacle.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "His surprise was instantly changed into passion, and darting an angry look at the vizier, \"Thou wretch,\" said he, \"is this your inspection into the actions of my people?",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "He ordered the officers of the police and justice to make strict search for the criminal.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000008_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "They sent their servants about, and they were not idle themselves, for they were no less concerned in this matter than the vizier.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000008_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "But all their endeavours were to no purpose; what pains soever they took they could not discover the murderer; so that the vizier concluded his life to be lost.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The third day being arrived, an officer came to the unfortunate minister, with a summons to follow him, which the vizier obeyed. The caliph asked him for the murderer.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "When all things were ready, the criminal judge, and many officers belonging to the palace, having brought out the grand vizier with the forty Bermukkees, set each by the stake designed for him.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000012_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Withdraw, and let me expiate the death of the lady that was thrown into the Tigris.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "It is I who murdered her, and I deserve to be punished for my offence.\"",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000014_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "When he came before the prince, he kissed the ground seven times, and spake after this manner: \"Commander of the faithful, I have brought here before your majesty this old and this young man, each of whom declares himself to be the sole murderer of the lady.\" The caliph asked the criminals which of them it was that so cruelly murdered the lady, and threw her into the Tigris?",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_135907_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/135907/1403_135907_000014_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The young man assured him it was he, but the old man maintained the contrary.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "THE DEVELOPMENT OF COLONIAL NATIONALISM",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The imperative call to common defense, the habit of sharing common burdens, the fusing force of common service-these things, induced by the necessity of resisting outside interference, act as an amalgam drawing together all elements, except, perhaps, the most discordant.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The presence of the enemy allays the most virulent of quarrels, temporarily at least.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000003_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "\"Politics,\" runs an old saying, \"stops at the water's edge.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The necessity for common defense, if not equally great, was certainly always pressing.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Though it has long been the practice to speak of the early settlements as founded in \"a wilderness,\" this was not actually the case.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "From the earliest days of Jamestown on through the years, the American people were confronted by dangers from without.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "All about their tiny settlements were Indians, growing more and more hostile as the frontier advanced and as sharp conflicts over land aroused angry passions.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000004_000005.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "To the south and west was the power of Spain, humiliated, it is true, by the disaster to the Armada, but still presenting an imposing front to the British empire.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000004_000006.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "To the north and west were the French, ambitious, energetic, imperial in temper, and prepared to contest on land and water the advance of British dominion in America.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The problem was presented in different shape in different sections of America.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "It was not handled according to any coherent or uniform plan by the British government, which alone could speak for all the provinces at the same time.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000006_000004.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "As the difficulties arose mainly on the frontiers, where the restless and pushing pioneers were making their way with gun and ax, nearly everything that happened was the result of chance rather than of calculation.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "On the other side of the ledger must be recorded many a cruel and bloody conflict as the frontier rolled westward with deadly precision.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The Pequots on the Connecticut border, sensing their doom, fell upon the tiny settlements with awful fury in sixteen thirty seven only to meet with equally terrible punishment.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000007_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "A generation later, King Philip, son of Massasoit, the friend of the Pilgrims, called his tribesmen to a war of extermination which brought the strength of all New England to the field and ended in his own destruction.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000007_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000007_000006.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "In sixteen twenty two Opecacano, a brother of Powhatan, the friend of the Jamestown settlers, launched a general massacre; and in sixteen forty four he attempted a war of extermination.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000007_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000007_000007.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "In sixteen seventy five the whole frontier was ablaze. Nathaniel Bacon vainly attempted to stir the colonial governor to put up an adequate defense and, failing in that plea, himself headed a revolt and a successful expedition against the Indians.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Pennsylvania, consistently following a policy of conciliation, was likewise spared until her western vanguard came into full conflict with the allied French and Indians.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Georgia, by clever negotiations and treaties of alliance, managed to keep on fair terms with her belligerent Cherokees and Creeks.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000010_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "But neither diplomacy nor generosity could stay the inevitable conflict as the frontier advanced, especially after the French soldiers enlisted the Indians in their imperial enterprises.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000010_000004.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "It was then that desultory fighting became general warfare.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000012_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "It was the ambition of Louis the fourteenth of France, rather than the labors of Jesuit missionaries and French rangers, that sounded the first note of colonial alarm.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000014_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "In seventeen eighteen, the French founded New Orleans, thus taking possession of the gateway to the Mississippi as well as the saint Lawrence.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000014_000005.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Though they were warned by George Washington, in the name of the governor of Virginia, to keep out of territory \"so notoriously known to be property of the crown of Great Britain,\" the French showed no signs of relinquishing their pretensions.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000017_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "On the continent of Europe, England subsidized Prussian arms to hold France at bay.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000017_000004.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "In India, on the banks of the Ganges, as on the banks of the saint Lawrence, British arms were triumphant.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000017_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000017_000005.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "Well could the historian write: \"Conquests equaling in rapidity and far surpassing in magnitude those of Cortes and Pizarro had been achieved in the East.\" Well could the merchants of London declare that under the administration of William Pitt, the imperial genius of this world-wide conflict, commerce had been \"united with and made to flourish by war.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "From the point of view of the British empire, the results of the war were momentous.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000018_000002.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "The remainder of the Louisiana territory was transferred to Spain and French imperial ambitions on the American continent were laid to rest.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1403_138552_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1403/138552/1403_138552_000018_000003.wav",
        "speaker_id": "LibriTTS_R-1403",
        "content": "In exchange for Havana, which the British had seized during the war, Spain ceded to King George the colony of Florida.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    }
]