        "speaker_id": "LibriTTS_R-7170",
        "content": "We buried him darkly at dead of night, The sods with our bayonets turning; By the struggling moonbeam's misty light And the lantern dimly burning.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
