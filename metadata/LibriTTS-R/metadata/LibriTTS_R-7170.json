        "speaker_id": "LibriTTS_R-7170",
        "content": "On Linden, when the sun was low, All bloodless lay the untrodden snow; And dark as winter was the flow Of Iser, rolling rapidly.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
