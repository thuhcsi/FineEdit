        "speaker_id": "LibriTTS_R-7170",
        "content": "Then shook the hills with thunder riven; Then rush'd the steed, to battle driven; And louder than the bolts of Heaven Far flash'd the red artillery.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
