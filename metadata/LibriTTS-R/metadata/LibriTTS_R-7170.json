        "speaker_id": "LibriTTS_R-7170",
        "content": "And what if she had seen those glories fade, Those titles vanish, and that strength decay,-- Yet shall some tribute of regret be paid",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
