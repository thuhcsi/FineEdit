        "speaker_id": "LibriTTS_R-7170",
        "content": "But Linden saw another sight, When the drum beat at dead of night Commanding fires of death to light The darkness of her scenery.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7170_291969_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7170/291969/7170_291969_000031_000000.wav",
        "speaker_id": "LibriTTS_R-7170",
        "content": "By torch and trumpet fast array'd Each horseman drew his battle blade, And furious every charger neigh'd To join the dreadful revelry.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
