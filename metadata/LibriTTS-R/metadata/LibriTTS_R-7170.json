        "speaker_id": "LibriTTS_R-7170",
        "content": "Rapine, avarice, expense, This is idolatry; and these we adore: Plain living and high thinking are no more:",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
