        "speaker_id": "LibriTTS_R-8322",
        "content": "No additional appropriations were therefore required for the ensuing six months.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
