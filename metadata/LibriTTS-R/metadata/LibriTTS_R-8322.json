        "speaker_id": "LibriTTS_R-8322",
        "content": "The officers who, at the time of the adoption of the provisional Constitution, held any office connected with the collection of the customs, duties, and imposts in the several States of the Confederacy, or as assistant treasurers intrusted with the keeping of moneys arising therefrom, were continued in office with the same powers and subject to the same duties.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
