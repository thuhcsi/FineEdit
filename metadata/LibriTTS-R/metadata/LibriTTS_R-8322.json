        "speaker_id": "LibriTTS_R-8322",
        "content": "The tariff laws of the United States were continued in force until they might be altered.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
