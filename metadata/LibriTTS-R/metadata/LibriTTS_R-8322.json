[
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "\"The first year of our history has been the most eventful in the annals of this continent.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "A new Government has been established, and its machinery put in operation over an area exceeding seven hundred thousand square miles.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The great principles upon which we have been willing to hazard everything that is dear to man, have made conquests for us which could never have been achieved by the sword.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Our Confederacy has grown from six to thirteen States; and Maryland, already united to us by hallowed memories and material interests, will, I believe, when enabled to speak with unstifled voice, connect her destiny with the South.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000004.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Our people have rallied with unexampled unanimity to the support of the great principles of constitutional government, with firm resolve to perpetuate by arms the rights which they could not peacefully secure.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000005.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "A million of men, it is estimated, are now standing in hostile array and waging war along a frontier of thousands of miles.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000006.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Battles have been fought, sieges have been conducted, and, although the contest is not ended, and the tide for the moment is against us, the final result in our favor is not doubtful....",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000007.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Fellow citizens, after the struggles of ages had consecrated the right of the Englishman to constitutional representative government, our colonial ancestors were forced to vindicate that birthright by an appeal to arms.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000004_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000004_000008.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Success crowned their efforts, and they provided for their posterity a peaceful remedy against future aggression.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000005_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "\"The tyranny of an unbridled majority, the most odious and the least responsible form of despotism, has denied us both the right and the remedy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The financial system which had been adopted from necessity proved adequate at this early period to supply all the wants of the Government and of the people.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000006_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "An unexpected and very large increase of expenditures had resulted from the great enlargement of the necessary means of defense.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000006_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Yet the Government entered on its second year without a floating debt and with its credit unimpaired.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000006_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The total expenditures of the first year, ending february first eighteen sixty two, amounted to one hundred and seventy million dollars.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000006_000004.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "A statement of the Secretary of the Treasury, comprising the period from the organization of the Government to august first eighteen sixty two, presents the following results:",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000008_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The receipts were derived as follows:",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Such was the result presented by the Treasury of a Government that had been in existence only eighteen months.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "It commenced that existence without a treasury, and, without the sinews and the munitions of war, was in less than two months invaded on every side by an implacable foe. Its ways and means consisted in loans and taxes, and to these it resorted.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "On february twenty eighth I was authorized by Congress to borrow, at any time within twelve months, fifteen million dollars, or less, as might be needed.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000004.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "For the payment of the interest and principal of this loan a tax or duty of one eighth of one per cent. per pound was laid on all cotton exported.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000006.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "A reissue was authorized for a year.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000007.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "On may sixteenth a loan of fifty million dollars in bonds, payable after twenty years at eight per cent. interest, was authorized.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000009.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "In lieu of any amount of these bonds, not exceeding twenty million dollars, an equal amount of Treasury notes, without interest, in denominations of five dollars and upward, was authorized to be issued.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000011.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "They were also convertible into bonds payable in ten years at eight per cent. interest.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000013.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "They were of the denominations of five dollars and upward.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000014.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "They were receivable for the war tax and all other public dues except the export duty on cotton.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000016.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Thirty millions were to be a substitute for the same amount, authorized by the act of may sixteenth eighteen sixty one. These bonds could be exchanged for specie, military and naval stores, or for the proceeds of raw produce and manufactured articles.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000018.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "On december twenty fourth an additional issue of fifty millions of Treasury notes like those of the act of august nineteenth was authorized.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000025",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000025.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "An amount of Treasury notes bearing interest at two cents per day on each hundred dollars, as a substitute for as much of the one hundred and sixty five millions of bonds authorized, was also authorized to be issued.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000010_000027",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000010_000027.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "On september twenty third eighteen sixty two, the amount of Treasury notes under the denomination of five dollars was increased from five million to ten million dollars, and a further issue of bonds or certificates of stock, to the amount of fifty million dollars, was authorized.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "On march twenty third eighteen sixty three, an effort was made to remove from circulation some of the issues of Treasury notes by funding them.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000011_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Call certificates were made fundable in thirty years bonds at eight per cent., and all outstanding on the ensuing july first were deemed bonds at six per cent., payable in thirty years.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000011_000004.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "A monthly issue of Treasury notes, without interest, to the amount of fifty million dollars, was also authorized.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000011_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000011_000008.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "All disposable means in the Treasury were to be applied to the purchase of Treasury notes, bearing no interest, until the amount in circulation did not exceed one hundred and seventy five millions.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000011_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000011_000011.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Treasury notes so purchased were not to be reissued.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000012_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "An important measure was adopted on february seventeenth eighteen sixty four, the object of which was to reduce the currency and to authorize a new issue of notes and bonds.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000012_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "At the same time a new issue of Treasury notes was authorized, and made receivable for all public dues, except customs duties, at the rate of two dollars for three of the old.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000012_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The issue of other Treasury notes, after the first of the ensuing April, was prohibited.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000013_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "To pay the expenses of the Government an issue of five hundred million dollars in six per cent. bonds was authorized.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "A review of this statement of the legislation of Congress will clearly present the financial system of the Government.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000014_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "At the next session, after the commencement of the war, provision was made for the issue of twenty million dollars in Treasury notes, and for borrowing thirty million dollars in bonds.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000014_000005.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "It was assumed that any tendency to depreciation, which might arise from the over issue of the currency, would be checked by the constant exercise of the holder's right to fund the notes at a liberal interest, payable in specie.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000014_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000014_000006.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The success of this system depended on the ability of the Government constantly to pay the interest in specie.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000015_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The first operation of this plan was quite successful.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000016_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Wheat, in the beginning of the year eighteen sixty two, was selling at one dollar and thirty cents per bushel, thus but little exceeding its average price in time of peace.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000016_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The other agricultural products of the country were at similarly moderate rates, thus indicating that there was no excess of circulation.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000016_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "At the same time the premium on coin had reached about twenty per cent.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000016_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "But it had become apparent that the commerce of our country was threatened with permanent suspension by reason of the conduct of neutral nations, who virtually gave aid to the United States Government by sanctioning its declaration of a blockade.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000016_000004.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "These neutral nations treated our invasion by our former limited and special agent as though it were the attempt of a sovereign to suppress a rebellion against lawful authority.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000016_000005.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "This exceptional cause heightened the premium on specie, because it indicated the exhaustion of our reserve, without the possibility of renewing the supply.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000017_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "At the inauguration of the permanent Government, in February, eighteen sixty two, a popular aversion to internal taxation had been so strongly manifested as to indicate its partial failure.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000017_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "This will be further explained presently in our statement of the system of taxation.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Under all these circumstances the effort was made to avoid the increase in the volume of notes in circulation, by offering inducements to voluntary funding.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000018_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The measures adopted for that purpose were but partially successful.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000018_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Meanwhile the intervening exigencies from the fortunes of war permitted no delay.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000018_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The issues of Treasury notes were increased until, in December, eighteen sixty three, the currency in circulation amounted to more than six hundred million dollars, or more than threefold the amount required by the business of the country.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000018_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000018_000004.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The evil effects of this financial condition were but too apparent.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000019_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "I therefore recommended to Congress, in December, eighteen sixty three, the compulsory reduction of the currency to the amount required by the business of the country, accompanied by a pledge that, under no stress of circumstances, would the amount be increased.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000019_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "If, on the contrary, a funded debt, with interest secured by adequate taxation, could be substituted for the outstanding currency, its entire amount would be made available to the holder, and the Government would be in a condition, beyond the reach of any probable contingency, to prosecute the war to a successful issue.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "This recommendation was followed by the passage of the act of february seventeenth eighteen sixty four, above mentioned.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000020_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "One of its features is the tax levied on the circulation.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000020_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Regarding the Government when contracting a debt as the agent of the people, its debt is their debt.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000020_000004.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Under such circumstances, the notes remaining in the hands of each holder after the payment of his tax would be worth quite as much as the whole sum previously held, for it would have an equal purchasing capacity.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000021_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "After this law had been in operation for one year, it was manifest that it had the desired effect of withdrawing from circulation the large excess of Treasury notes which had been issued.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000021_000001.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "On july first eighteen sixty four, the outstanding amount was estimated at two hundred and thirty million dollars.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000021_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The estimate of the amount funded under this act, about this time, was three hundred million dollars, while new notes were authorized to be issued to the extent of two thirds of the sum received under its provisions.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000021_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The chief difficulty apprehended in connection with our finances, up to the close of the war, resulted from the depreciation of our Treasury notes, which was to be attributed to the increasing redundancy in amount and the diminishing confidence in their ultimate redemption.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000022_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The financial condition of the Government, near its close, is very correctly represented in the report of the Treasury Department.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000022_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The sources from which this revenue was derived were as follows:",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000024_000002.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "Of this amount, five hundred forty one million three hundred forty thousand ninety dollars consisted of funded debt, and the balance unfunded debt, or Treasury notes.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000024_000003.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The foreign debt is omitted in these statements.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8322/276748/8322_276748_000025_000000.wav",
        "speaker_id": "LibriTTS_R-8322",
        "content": "The aggregate appropriations called for by the different departments of the Government for the six months ending on june thirtieth eighteen sixty five, amounted to four hundred thirty eight million four hundred sixteen thousand five hundred four dollars.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8322_276748_000025_000002",
