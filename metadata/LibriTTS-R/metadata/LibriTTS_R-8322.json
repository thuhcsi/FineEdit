        "speaker_id": "LibriTTS_R-8322",
        "content": "A system of measures by which to obtain a revenue from direct taxes and duties was commenced at the first session of Congress under the provisional Government.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
