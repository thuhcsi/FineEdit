        "speaker_id": "LibriTTS_R-8322",
        "content": "At the second session, in May, a complete tariff law was enacted, with a lower scale of duties than had previously existed.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
