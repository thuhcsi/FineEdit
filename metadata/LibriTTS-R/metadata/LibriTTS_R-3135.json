[
    {
        "item_name": "LibriTTS_R-3135_166688_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000003_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "CHAPTER TWELVE",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000004_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "THE DIME MUSEUMS.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Feats of strength have always interested me greatly, so that in my travels around the world I have made it a point to come in contact with the most powerful human beings of my generation.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The one among these who deserves first mention is Charles Jefferson, with whose achievements I became quite familiar while we were working in the same museum many years ago.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "I am convinced that he must have been the strongest man of his time at lifting with the bare hands alone.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "He had two feats that he challenged any mortal to duplicate.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000004.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "One was picking up a heavy blacksmith's anvil by the horn and placing it on a kitchen table; for the other he had a block of steel, which, as near as I can remember, must have been about fourteen inches long, twelve inches wide, and seven inches thick.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000005.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "This block lay on the floor, and his challenge was for anyone to pick it up with bare hands.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000007.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Though thousands tried, I never saw, or heard, of anyone else who could juggle his anvil or pick up the weight.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000005_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000005_000008.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "True, I saw him surreptitiously rub his fingers with resin, to assist in the gripping, but that could have been only of slight assistance to the marvelous grip the man possessed.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000007_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "john Grun Marx, a Luxemberger, must have been among the strongest men in the world at the time I knew him.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000007_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "We worked on the same bill several times; but it was at the Olympia, in Paris, that he shone supreme as a strongman-and at the same time as a weak one.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000008_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Marx's strength was prodigious, and he juggled hundreds, and toyed with thousands, of pounds as a child plays with a rattle.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000008_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "He must have weighed in the neighborhood of three hundred pounds, and he walked like a veritable colossus.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000008_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "In fact, he reminded me of a two footed baby elephant.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000009_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Always good-natured, he made a host of friends both in the profession and out of it.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000009_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Wishing to die in his native city, he returned to Luxemberg.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000009_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "He did not realize that he was bereft of his enormous strength, and those about him humored him: the doctor and the nurses would pretend that he hurt them when he grasped their hands.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000009_000004.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "He died almost forgotten except by his brother artists, but they (myself among them) built a monument to this good-natured Hercules, whose only care was to entertain.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000011_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Le Roy was born in cincinnati ohio, october third eighteen seventy three.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000011_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The inordinate strength of his jaws, teeth, and neck, enabled him to push a nail, held between his teeth, through a one inch board; or to nail together, with his teeth, two three quarters-inch boards.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000011_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "He could draw with his teeth a large nail that had been driven completely through a two inch plank.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000011_000005.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "When he had performed these stunts in various positions, he would bend his body backward till his head pointed toward the floor, and in that position push a nail through a one inch board held perpendicularly in a metal frame.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000011_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000011_000006.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "I saw no chance for trickery in Le Roy's act.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000012_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "But since this act did not get him very far either on the road to fame, or toward the big money-he turned to magic and finally became one of the leading Continental magicians, boasting that he was one of the few really expert sleight of hand magicians of the world.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000013_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "I met Weyer at Liege, Belgium, where we had an all night match with playing cards.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000013_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "On this occasion, however, he was unable to make the boast good.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000014_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Another clever performer of those days was Mexican Billy Wells, who worked on the Curio platform.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000014_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "His act was the old stone breaking stunt, already explained, except that he had the stones broken on his head instead of on his body.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000014_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "He protected his head with a small blanket, which he passed for examination, and this protection seemed excusable, considering that he had to do at least seven shows a day.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000014_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "A strong man from the audience did the real work of the act by swinging the heavy sledge hammer on the stone, as shown in the accompanying illustration.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000014_000004.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Usually the stone would be riven by a single blow; but if it was not, Wells would yell, \"Harder! harder! hit harder!\" until the stone was broken.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000015_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The last I saw of Billy was during one of my engagements at the Palace Theater, New York.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000016_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Of all the acts of this nature that I have ever seen I think the most foolhardy was that of an under sized Italian who lay on his back on the floor and let fall from his hands, extended upward at arm's length heavy weights upon his chest-the silly fool!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000016_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "I said as much to him-and some other things too.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000016_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "His act had little entertainment to show as compared with the pain and danger involved.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000016_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "I do not know what became of him, but I can guess.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000017_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Among the museum attractions of those years was a man named Wilson who had the incredible chest expansion of twenty one inches.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000018_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Another \"Samson,\" a German, among other sensational feats, such as breaking coins with his fingers, used to flex his muscles and break a dog chain that had been fastened round the biceps of his right arm. While he was performing at the Aquarium, in London, he issued a challenge.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000018_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Sandow, then a youth without reputation, accepted the challenge, went upon the stage, defeated him, and, since Samson's act had been the talk of the town, thus brought himself into instant notice, the beginning of a career in which he rose to the top of his profession.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000018_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "After several successful years on the stage, Sandow settled down in London, where I last heard of him as conducting a school of instruction in health and strength methods.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000019_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "I remember these ladies particularly because both were remarkably good talkers-and I am referring to conversational quality, not to volume.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000020_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Although she was exposed many times, her success was so marked that several other muscular ladies entered her province with acts that were, in several instances, superior to the original.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000021_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "One of the cleverest of these was Annie Abbott, who, if I remember rightly, also called herself The Georgia Magnet.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000021_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The second sensation was credited to the Bullet Proof Man.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000021_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "This chap wore a jacket that rifle bullets, fired point blank, failed to penetrate.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000021_000004.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The composition of this jacket was a secret, but after the owner's death the garment was ripped open and found to contain ground glass!",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000022_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The Magnet failed to attract after about forty eight hours, for a keen witted reporter discovered her methods and promptly published them.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000022_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The bullet detainer also lasted only a short time only.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000022_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "When my opening added a third sensational surprise, one of the London dailies asked, \"Is this going to be another Georgia Magnet fiasco?\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000024_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Some twenty six years ago I was on the bill with Mattie Lee Price, who, though less well known, was in many ways superior to either Miss Hurst or Miss Abbott.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000024_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "For a time she was a sensation of the highest order, for which thanks were largely due to the management of her husband, a wonderful lecturer and a thorough showman.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000025_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "He had interfered between the couple, and was, I am sorry to say, quite successful as an interferer; but he was a diabolical failure when he attempted to duplicate White's work as lecturer, and the act, after playing a date or two, sank out of sight and I have heard nothing more of her professionally.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000025_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000025_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Lately I have learned that she died in London in nineteen hundred and is buried in Clements Cemetery, Fulham.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000027_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "In Chapter Eleven we read dr Desaguliers' analysis of the mechanics of what may be called strongmanship.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000027_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Similar investigations have attended the appearance of more recent performers.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000029_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The \"Phenomenon of the Nineteenth Century,\" which may be seen nightly at Wallack's, is not so much the famous Georgia girl, with her mysterious muscle, as is the audience which gathers to wonder at her performance.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000030_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Then follows a description of her performance, which was far from successful, thanks to the efforts of one of the committee, a man described as \"mr",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000030_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Thomas Johnson, a powerfully built engraver connected with the Century magazine.\" mr Johnson had evidently caught her secret, and he got the better of her in all the tests in which he was allowed to take part.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000032_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "These explanations are taken from the French periodical La Nature, in which mr Nelson w Perry thus sums up the attitude of the public in regard to this class of performance: \"Electricity is a mysterious agent; therefore everything mysterious is electric.\" Of the performance of the Electric Girl this magazine says:",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000033_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "It is a question of a simple application of the elementary principles of the laws of mechanics, chapter of equilibrium.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000035_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "This first experiment is so elementary and infantile that it is not necessary to dwell upon it.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000036_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Next we have a second and more complex experiment, less easily explained at first sight.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000038_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "mr Perry explains this exercise as follows: The men are requested to place themselves parallel to each other, and the girl, who stands opposite them, places the palm of her hand against the stick and turned toward her.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000038_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000038_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "She thus moves it from the perpendicular and asks the two men to hold it in a vertical position.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000040_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000040_000002.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "All the efforts made to cause the stick to slide in the open hand failed, and the excess of weight due to the vertical force always remained less than twenty five pounds, despite the very determined and sincere stresses of the two men, who, unbeknown to themselves, were exerting their strength in a HORIZONTAL direction.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000041_000001.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "Such pressure in the first place is exerted but slightly, and the stresses are gradually increased.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000042_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000042_000003.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The experimenter, therefore, needs only to exert a horizontal thrust, without doing any lifting, and such horizontal thrust is facilitated by taking the knees as points of support for her elbows.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000042_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000042_000004.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "As soon as a slight movement is effected, the hardest part of the work is over, for it is only necessary for the girl to cease to exert her stresses in order to have the chair fall back or move laterally in one direction or the other.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000045_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "There was still a considerable demand for these people in the dime museums, until the enormous increase in the number of such houses created a demand for freaks that was far in excess of the supply, and many houses were obliged to close because no freaks were obtainable, even at the enormous increase in salaries then in vogue.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3135_166688_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3135/166688/3135_166688_000047_000000.wav",
        "speaker_id": "LibriTTS_R-3135",
        "content": "The dime museum is but a memory now, and in three generations it will, in all probability, be utterly forgotten.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    }
]