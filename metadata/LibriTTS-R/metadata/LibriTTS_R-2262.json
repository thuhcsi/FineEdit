[
    {
        "item_name": "LibriTTS_R-2262_141714_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000003_000006.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "She was my constant Companion; but unhappily died upon the Road.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000003_000008.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "'tis a strange Thing that Nobody here will advance so small a Sum upon so valuable a Commodity.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000003_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000003_000012.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "'tis very possible, that the Soul of the deceas'd Lady may have taken its Residence in that Fowl.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000003_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000003_000013.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "And you wouldn't surely run the Risque of eating up your Aunt?",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000003_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000003_000014.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "To boil a Fowl is, doubtless, a most shameful Outrage done to Nature.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000003_000027",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000003_000027.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "He had a numerous Issue, as is very well known, and all of them were powerful Monarchs.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000003_000031",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000003_000031.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "Whereas we have Almanacks that are dated four thousand Centuries backwards.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000004_000002.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I shall lay no Stress on the Antiquity of my Country; for I imagine 'tis of much greater Importance to be the happiest People, than the most antient under the sun",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141714_000006_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141714/2262_141714_000006_000009.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "Agreed, quotha! they all cried, in an angry Tone, How so, pray?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000002_000002.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "When two Men defend themselves against a whole Gang, the Contest, doubtless, cannot last long.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000002_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000002_000008.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "He plunder'd without Mercy; but was liberal in his Benefactions.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000002_000019",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000002_000019.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I was look'd upon as a Man of Consequence, and I procur'd this Castle by my military Atchievements.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000002_000022",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000002_000022.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I executed my Trust, in every Respect, as I ought, in the Capacity of a Collector; but I never did, nor never intended to balance my Accounts.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000003_000001.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I was appriz'd of the whole Affair, and, accordingly, order'd his whole Retinue, consisting of four inferior Officers, to be strangled before his Face, after the same Manner as was intended for my Execution.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000003_000004.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "He is at this very Day not only the best Officer, but the richest I have in all my Court.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000003_000005.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "If my Word may be credited, I'll raise your Fortune as I have done his.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000003_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000003_000015.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "At last, being gradually overcome by the Fumes of his Liquor, he fell fast asleep.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000003_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000003_000017.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "What, said he, the King first became crazy, and then was murder'd.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000003_000018",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000003_000018.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I think I have just Grounds for Complaint.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000003_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000003_000020.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "O Fortune!",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000004_000001.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "By Virtue of their Night's Excursions, they had brought in some fresh Booty, and were busy in dividing the Spoil.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141716_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141716/2262_141716_000004_000002.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "All the Favour he could procure, in their Hurry and Tumult, was, to go away without the least Examination.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "CHAP. fourteen.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000004_000002.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I am, doubtless, said the poor Fisherman, the most unhappy Wretch that ever liv'd!",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000004_000004.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "No Man of my Profession ever had a handsomer, more compleat Housewife, than my Dame was; but I have been treacherously depriv'd of her.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000004_000005.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I had still left a poor, pitiful Cottage, but that I saw plunder'd and destroy'd.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000004_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000004_000011.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "Is there then the Man in Being more wretched than myself?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000004_000017",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000004_000017.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "Never sink Man, under the Weight of your Burden.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000007_000001.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "I have since endeavour'd to get my Bread by Fishing; but the Fish, as well as all Mankind, desert me.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000010_000001.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "What!",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000010_000004.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "Your greatest Uneasiness, said he, arose from the Narrowness of your Circumstances; but mine proceeds from an internal, and much deeper Cause.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2262_141717_000010_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2262/141717/2262_141717_000010_000007.wav",
        "speaker_id": "LibriTTS_R-2262",
        "content": "He recollected the whole Series of his Misfortunes; commencing from that of the Eunuch and the Huntsman, to his Arrival at the Free booter's Castle.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    }
]