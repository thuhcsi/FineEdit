        "speaker_id": "LibriTTS_R-908",
        "content": "A ring of amethyst I could not wear here, plainer to my sight, Than that first kiss.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
