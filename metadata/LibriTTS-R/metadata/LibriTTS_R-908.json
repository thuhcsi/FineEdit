        "speaker_id": "LibriTTS_R-908",
        "content": "Dearest, teach me so To pour out gratitude, as thou dost, good!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
