        "speaker_id": "LibriTTS_R-908",
        "content": "When we met first and loved, I did not build Upon the event with marble.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
