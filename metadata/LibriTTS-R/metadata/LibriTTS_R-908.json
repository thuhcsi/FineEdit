        "speaker_id": "LibriTTS_R-908",
        "content": "O life of this our spring! why fades the lotus of the water? Why fade these children of the spring?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
