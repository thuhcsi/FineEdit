        "speaker_id": "LibriTTS_R-908",
        "content": "Nay, I rather thrilled, Distrusting every light that seemed to gild The onward path, and feared to overlean A finger even.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
