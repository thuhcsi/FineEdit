        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/908/31957/908_31957_000011_000000.wav",
        "speaker_id": "LibriTTS_R-908",
        "content": "If I leave all for thee, wilt thou exchange And be all to me?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
