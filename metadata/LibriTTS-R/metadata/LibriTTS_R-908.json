        "speaker_id": "LibriTTS_R-908",
        "content": "all is said without a word. I sit beneath thy looks, as children do In the noon sun, with souls that tremble through Their happy eyelids from an unaverred Yet prodigal inward joy.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
