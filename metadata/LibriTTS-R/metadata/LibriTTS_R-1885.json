        "speaker_id": "LibriTTS_R-1885",
        "content": "I take this opportunity to relate the manner in which an acquaintance first commenced between dr Johnson and mr Murphy.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
