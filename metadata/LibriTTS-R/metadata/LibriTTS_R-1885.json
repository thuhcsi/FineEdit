        "speaker_id": "LibriTTS_R-1885",
        "content": "'There are (said he) inexcusable lies, and consecrated lies.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
