    {
        "item_name": "LibriTTS_R-1885_136863_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1885/136863/1885_136863_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1885",
        "content": "'You that travel about the world, have more materials for letters, than I who stay at home; and should, therefore, write with frequency equal to your opportunities.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1885_136863_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1885/136863/1885_136863_000017_000001.wav",
        "speaker_id": "LibriTTS_R-1885",
        "content": "I should be glad to have all England surveyed by you, if you would impart your observations in narratives as agreeable as your last.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
