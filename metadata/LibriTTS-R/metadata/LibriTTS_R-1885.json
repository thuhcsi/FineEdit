        "speaker_id": "LibriTTS_R-1885",
        "content": "But he gave a more eminent proof of it in our sister kingdom, as dr Johnson informed me.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
