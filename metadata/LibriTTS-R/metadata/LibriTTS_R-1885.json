        "speaker_id": "LibriTTS_R-1885",
        "content": "\"It has now been fashionable, for near half a century, to defame and vilify the house of Stuart and, to exalt and magnify the reign of Elizabeth.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
