        "speaker_id": "LibriTTS_R-1885",
        "content": "'DEAR SIR,",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "low"
