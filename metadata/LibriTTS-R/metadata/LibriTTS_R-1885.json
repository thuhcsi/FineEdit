        "speaker_id": "LibriTTS_R-1885",
        "content": "Again, towards the conclusion:",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
