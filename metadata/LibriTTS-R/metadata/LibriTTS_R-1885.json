        "speaker_id": "LibriTTS_R-1885",
        "content": "'Sir, (said he) I never saw the man, and never read the book.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
