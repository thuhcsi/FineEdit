        "speaker_id": "LibriTTS_R-1885",
        "content": "The Stuarts have found few apologists, for the dead cannot pay for praise; and who will, without reward, oppose the tide of popularity?",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
