        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1885/136863/1885_136863_000017_000003.wav",
        "speaker_id": "LibriTTS_R-1885",
        "content": "While you have been riding and running, and seeing the tombs of the learned, and the camps of the valiant, I have only staid at home, and intended to do great things, which I have not done.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1885_136863_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1885/136863/1885_136863_000018_000001.wav",
        "speaker_id": "LibriTTS_R-1885",
        "content": "mr Sharpe is of opinion that the tedious maturation of the cataract is a vulgar errour, and that it may be removed as soon as it is formed.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
