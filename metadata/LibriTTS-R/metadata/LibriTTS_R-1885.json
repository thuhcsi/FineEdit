        "speaker_id": "LibriTTS_R-1885",
        "content": "His majestick expression would have carried down to the latest posterity the glorious achievements of his country with the same fervent glow which they produced on the mind of the time.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1885_136863_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1885/136863/1885_136863_000005_000003.wav",
        "speaker_id": "LibriTTS_R-1885",
        "content": "He would have been under no temptation to deviate in any degree from truth, which he held very sacred, or to take a licence, which a learned divine told me he once seemed, in a conversation, jocularly to allow to historians.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
