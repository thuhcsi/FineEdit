[
    {
        "item_name": "LibriTTS_R-5401_102526_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000002_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The moment that the last of the Macedonian dynasty was gone, the elements of discord seemed unchained, and the double scourge of civil war and foreign invasion began to afflict the empire.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000003_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Domestic troubles were the first inevitable consequence of the extinction of the Macedonian dynasty.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000003_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The aged Theodora had named as her successor on the throne Michael Stratioticus, a contemporary of her own who had been an able soldier twenty five years back.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000003_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "But Michael the sixth. was grown aged and incompetent, and the empire was full of ambitious generals, who would not tolerate a dotard on the throne.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000003_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Before a year had passed a band of great Asiatic nobles entered into a conspiracy to overturn Michael, and replace him by Isaac Comnenus, the chief of one of the ancient Cappadocian houses, and the most popular general of the East.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000004_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Isaac Comnenus and his friends took arms, and dispossessed the aged Michael of his throne with little difficulty.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000004_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The safety of the realm was entirely in the hands of its well paid and well disciplined national army, and anything that impaired the efficiency of the army was fraught with the deadliest peril.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000005_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The Seljouk Turks were now drawing near.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000005_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "In ten fifty, they had penetrated to Bagdad, and their great chief, Togrul Beg, had declared himself \"defender of the faith and protector of the Caliph.\" Armenia had next been overrun, and those portions of it which had not been annexed to the empire, and still obeyed independent princes, had been conquered by ten sixty four.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000006_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The reign of Constantine Ducas was troubled by countless Seljouk invasions of the Armeniac, Anatolic, and Cappadocian themes.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000006_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Sometimes the invaders were driven back, sometimes they eluded the imperial troops and escaped with their booty.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000006_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "But whether successful or unsuccessful, they displayed a reckless cruelty, far surpassing anything that the Saracens had ever shown.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000006_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Wherever they passed they not merely plundered to right and left, but slew off the whole population.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000007_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Ducas died in ten sixty seven, leaving the throne to his son, Michael, a boy of fourteen years.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000007_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The usual result followed.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000007_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "To secure her son's life and throne, the Empress dowager Eudocia took a new husband, and made him guardian of the young Michael.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000007_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The new Emperor regent was Romanus Diogenes, an Asiatic noble, whose brilliant courage displayed in the Seljouk wars had dazzled the world, and caused it to forget that caution and ability are far more regal virtues than headlong valour.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000007_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Romanus took in hand with the greatest vigour the task of repelling the Turks, which his predecessor had so grievously neglected.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000008_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Hence the Emperor was not unfrequently able to catch and slay off one of the minor divisions of the Turkish army.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000008_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "But some of them always contrived to elude him; his heavy cavalry could not come up with the light Seljouk horse bowmen, who generally escaped and rode back home by a long detour, burning and murdering as they went.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000008_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Cappadocia was already desolated from end to end, and the Turkish raids had reached as far as Amorium, in Phrygia.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000009_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "In ten seventy one came the final disaster.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000012_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Either from treachery or cowardice Andronicus Ducas, the officer who commanded the reserve, led his men off without fighting.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000012_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The Emperor's division was beset on all sides by the enemy, and broke up in the dusk.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000012_000005.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Romanus himself was wounded, thrown from his horse, and made prisoner.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000012_000006.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The greater part of his men were cut to pieces.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000015_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Alp Arslan showed himself more forbearing to his prisoner than might have been expected.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000015_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "It is true that Romanus was led after his capture to the tent of the Sultan, and laid prostrate before him, that, after the Turkish custom, the conqueror might place his foot on the neck of his vanquished foe.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000015_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "But after this humiliating ceremony the Emperor was treated with kindness, and allowed after some months to ransom himself and return home. He would have fared better, however, if he had remained the prisoner of the Turk.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000015_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "During his captivity the conduct of affairs had fallen into the hands of john Ducas, uncle of the young emperor Michael.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000015_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The unscrupulous regent was determined that Romanus should not supersede him and mount the throne again.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000015_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000015_000005.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "When the released captive reappeared, john had him seized and blinded.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000015_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000015_000006.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The cruel work was so roughly done that the unfortunate Romanus died a few days later.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000016_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "After this fearful disaster Asia Minor was lost; there was no chief to take the place of Romanus, and the Seljouk hordes spread westward almost unopposed.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000016_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The next ten years were a time of chaos and disaster.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000016_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "After the death of Romanus, every general in the empire seemed to think that the time had come for him to assume the purple buskins and proclaim himself emperor. History records the names of no less than six pretenders to the throne during the next nine years, besides several rebels who took up arms without assuming the imperial title.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000016_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000016_000006.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "At last a man of ability worked himself up to the surface. This was Alexius Comnenus, nephew of the emperor Isaac Comnenus, whose short reign we related in the opening paragraph of this chapter.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000017_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Alexius was a man of courage and ability, but he displayed one of the worst types of Byzantine character.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000017_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "He was the most accomplished liar of his age, and, while winning and defending the imperial throne, committed enough acts of mean treachery, and swore enough false oaths to startle even the courtiers of Constantinople.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000017_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "He could fight when necessary, but he preferred to win by treason and perjury.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000017_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Yet as a ruler he had many virtues, and it will always be remembered to his credit that he dragged the empire out of the deepest slough of degradation and ruin that it had ever sunk into.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_102526_000017_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/102526/5401_102526_000017_000005.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Though false, he was not cruel, and seven ex emperors and usurpers, living unharmed in Constantinople under his sceptre, bore witness to the mildness of his rule.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000001_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "CHAPTER thirteen",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000002_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "METAMORPHISM AND MINERAL VEINS",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000003_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Under the action of internal agencies rocks of all kinds may be rendered harder, more firmly cemented, and more crystalline.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000003_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "These processes are known as METAMORPHISM, and the rocks affected, whether originally sedimentary or igneous, are called METAMORPHIC ROCKS.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000004_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "CONTACT METAMORPHISM.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000004_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The adjacent strata may be changed only in color, hardness, and texture.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000004_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Thus, next to a dike, bituminous coal may be baked to coke or anthracite, and chalk and limestone to crystalline marble.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000004_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Sandstone may be converted into quartzite, and shale into ARGILLITE, a compact, massive clay rock.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000004_000006.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "In sedimentary rocks there may be produced crystals of mica and of GARNET (a mineral as hard as quartz, commonly occurring in red, twelve sided crystals).",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000005_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "In contact metamorphism, thin sheets of molten rock produce less effect than thicker ones.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000005_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The strongest heat effects are naturally caused by bosses and regional intrusions, and the zone of change about them may be several miles in width.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000006_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Which will be more strongly altered, the rocks about a closed dike in which lava began to cool as soon as it filled the fissure, or the rocks about a dike which opened on the surface and through which the molten rock flowed for some time?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000008_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "REGIONAL METAMORPHISM.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000009_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "In these regions the rocks have yielded to immense pressure.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000010_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Other factors, however, have played important parts.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000010_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Rock crushing develops heat, and allows a freer circulation of heated waters and vapors.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000010_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Thus chemical reactions are greatly quickened; minerals are dissolved and redeposited in new positions, or their chemical constituents may recombine in new minerals, entirely changing the nature of the rock, as when, for example, feldspar recrystallizes as quartz and mica.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000011_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Early stages of metamorphism are seen in SLATE.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000011_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Pressure has hardened the marine muds, the arkose, or the volcanic ash from which slates are derived, and has caused them to cleave by the rearrangement of their particles.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000012_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Under somewhat greater pressure, slate becomes PHYLLITE, a clay slate whose cleavage surfaces are lustrous with flat lying mica flakes.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000012_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The same pressure which has caused the rock to cleave has set free some of its mineral constituents along the cleavage planes to crystallize there as mica.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000013_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "FOLIATION.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000013_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Under still stronger pressure the whole structure of the rock is altered.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000013_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Of this structure, called FOLIATION, we may distinguish two types,--a coarser feldspathic type, and a fine type in which other minerals than feldspar predominate.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000015_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "THE CRYSTALLINE SCHISTS, representing the finer types of foliation, consist of thin, parallel, crystalline leaves, which are often remarkably crumpled.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000015_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "These folia can be distinguished from the laminae of sedimentary rocks by their lenticular form and lack of continuity, and especially by the fact that they consist of platy, crystalline grains, and not of particles rounded by wear.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000016_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "MICA SCHIST, the most common of schists, and in fact of all metamorphic rocks, is composed of mica and quartz in alternating wavy folia.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000016_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "TALC SCHIST consists of quartz and TALC, a light colored magnesian mineral of greasy feel, and so soft that it can be scratched with the thumb nail.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000020_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "These few examples must suffice of the great class of metamorphic rocks.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000020_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The fact of change is seen in their hardness arid cementation, their more or less complete recrystallization, and their foliation; but the change is often so complete that no trace of their original structure and mineral composition remains to tell whether the rocks from which they were derived were sedimentary or igneous, or to what variety of either of these classes they belonged.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000021_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Schists may contain rolled out pebbles, showing their derivation from a conglomerate.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000021_000004.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The most thoroughly metamorphosed rocks may sometimes be traced out into unaltered sedimentary or igneous rocks, or among them may be found patches of little change where their history maybe read.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000023_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Why do metamorphic rocks appear on the surface to day?",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000024_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "MINERAL VEINS",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000026_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The most common vein stones are QUARTZ and CALCITE.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000026_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "FLUORITE (calcium fluoride), a mineral harder than calcite and crystallizing in cubes of various colors, and BARITE (barium sulphate), a heavy white mineral, are abundant in many veins.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000028_000002.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "How the gold came in the placers we may leave the pupil to suggest.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000030_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "ORIGIN OF MINERAL VEINS.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000030_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000030_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Now fissures, wherever they occur, form the trunk channels of the underground circulation. Water descends from the surface along these rifts; it moves laterally from either side to the fissure plane, just as ground water seeps through the surrounding rocks from every direction to a well; and it ascends through these natural water ways as in an artesian well, whenever they intersect an aquifer in which water is under hydrostatic pressure.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000031_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The waters which deposit vein stones and ores are commonly hot, and in many cases they have derived their heat from intrusions of igneous rock still uncooled within the crust.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000033_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The steaming water rises through fissures in volcanic rocks and is now depositing in the rifts a vein stone of quartz, with metallic ores of iron, mercury, lead, and other metals.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000034_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000034_000003.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "The minerals of veins are therefore constantly being dissolved along their upper portions and carried down the fissures by ground water to lower levels, where they are redeposited.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000035_000000.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Many of the richest ore deposits are thus due to successive concentrations: the ores were leached originally from the rocks to a large extent by laterally seeping waters; they were concentrated in the ore deposits of the vein chiefly by ascending currents; they have been reconcentrated by descending waters in the way just mentioned.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5401_39508_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5401/39508/5401_39508_000037_000001.wav",
        "speaker_id": "LibriTTS_R-5401",
        "content": "Thus in soluble rocks, such as limestones, joints enlarged by percolating water are sometimes filled with metalliferous deposits, as, for example, the lead and zinc deposits of the upper Mississippi valley.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
