        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/596/127685/596_127685_000020_000001.wav",
        "speaker_id": "LibriTTS_R-596",
        "content": "For all these the beautiful meadows near the Soda Springs form a delightful center.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
