[
    {
        "item_name": "LibriTTS_R-6978_86037_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000000_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "The princess of course ran after it at once, and she was stooping down to feel if it was hidden in the long grass, when she heard a voice calling her: 'Ingibjorg!",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000000_000003.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "I am Kisa, your sister!'",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000002_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "'Don't you remember how I always slept in your cot beside you, and how you cried till I came?",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000002_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "But girls have no memories at all!",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000002_000002.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "Why, I could find my way straight up to that cot this moment, if I was once inside the palace.'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000003_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "'Why did you go away then?' asked the princess.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "'Yes, it is quite true what Kisa said,' answered the queen; 'I should have liked to see her again.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000005_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "Perhaps, some day, she will return, and then you must bring her to me.'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_86037_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/86037/6978_86037_000006_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "As usual, her attendants let her do anything she pleased, and sitting down on a mossy bank where a little stream tinkled by, soon fell sound asleep.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000000_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "\"Sit down here,\" said Uncheedah to the boy; \"I have something to say to you.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000000_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "You see that you are now almost a man.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000000_000002.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "Observe the game you have brought me!",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000000_000003.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "It will not be long before you will leave me, for a warrior must seek opportunities to make him great among his people.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000001_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "\"You must endeavor to equal your father and grandfather,\" she went on. \"They were warriors and feast makers.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000001_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "But it is not the poor hunter who makes many feasts.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000001_000002.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "Do you not remember the 'Legend of the Feast Maker,' who gave forty feasts in twelve moons?",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000001_000003.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "And have you forgotten the story of the warrior who sought the will of the Great Mystery?",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000001_000004.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "To day you will make your first offering to him.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000002_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "The concluding sentence fairly dilated the eyes of the young hunter, for he felt that a great event was about to occur, in which he would be the principal actor.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000002_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "But Uncheedah resumed her speech.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000004_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "Then, too, he supposed that his grandmother referred to his ornaments and playthings only.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000004_000002.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "So he volunteered:",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "\"I can give up my best bow and arrows, and all the paints I have, and-and my bear's claws necklace, grandmother!\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "\"Are these the things dearest to you?\" she demanded.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000007_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "\"Not the bow and arrows, but the paints will be very hard to get, for there are no white people near; and the necklace-it is not easy to get one like it again.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "\"But think, my boy, you have not yet mentioned the thing that will be a pleasant offering to the Great Mystery.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000011_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "Uncheedah was not fully satisfied with the boy's free offerings. Perhaps it had not occurred to him what she really wanted.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000011_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "But Uncheedah knew where his affection was vested.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000011_000002.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "His faithful dog, his pet and companion-Hakadah was almost inseparable from the loving beast.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000012_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "She was sure that it would be difficult to obtain his consent to sacrifice the animal, but she ventured upon a final appeal.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000013_000000.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "\"You must remember,\" she said, \"that in this offering you will call upon him who looks at you from every creation.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000013_000001.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "In the wind you hear him whisper to you.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000013_000002.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "He gives his war whoop in the thunder.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000013_000003.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "He watches you by day with his eye, the sun; at night, he gazes upon your sleeping countenance through the moon.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000013_000004.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "In short, it is the Mystery of Mysteries, who controls all things, to whom you will make your first offering.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000013_000005.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "By this act, you will ask him to grant to you what he has granted to few men.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6978_92211_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6978/92211/6978_92211_000013_000006.wav",
        "speaker_id": "LibriTTS_R-6978",
        "content": "I know you wish to be a great warrior and hunter.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    }
