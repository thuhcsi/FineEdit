        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/492/131899/492_131899_000032_000000.wav",
        "speaker_id": "LibriTTS_R-492",
        "content": "\"Go to the Carnatic, and engage three cabins.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
