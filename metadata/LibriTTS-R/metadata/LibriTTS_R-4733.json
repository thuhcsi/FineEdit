[
    {
        "item_name": "LibriTTS_R-4733_6398_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000001_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "It might have been an unfortunate affair for his poor dad, and the whole story threw a queer light upon the social and political life of Costaguana.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000001_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000001_000008.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Mines had acquired for him a dramatic interest.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000001_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000001_000009.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "He studied their peculiarities from a personal point of view, too, as one would study the varied characters of men.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000001_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000001_000012.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Their desolation appealed to him like the sight of human misery, whose causes are varied and profound.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000003_000002.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "He simply went on acting and thinking in her sight.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000003_000005.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "For this natural reason these discussions were precious to mrs Gould in her engaged state.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000003_000006.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Charles feared that mr Gould, senior, was wasting his strength and making himself ill by his efforts to get rid of the Concession.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000005_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "You were born there, too.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000006_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "He knew his answer.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000007_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "\"That's different.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000009_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "\"It has killed him!\" he said.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000012_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "\"It has killed him!\" he repeated.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000012_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "\"He ought to have had many years yet. We are a long lived family.\"",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000013_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "It was only when, turning suddenly to her, he blurted out twice, \"I've come to you-I've come straight to you-,\" without being able to finish his phrase, that the great pitifulness of that lonely and tormented death in Costaguana came to her with the full force of its misery.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000015_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "\"Yes.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000016_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "And then they stopped.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000016_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Everywhere there were long shadows lying on the hills, on the roads, on the enclosed fields of olive trees; the shadows of poplars, of wide chestnuts, of farm buildings, of stone walls; and in mid-air the sound of a bell, thin and alert, was like the throbbing pulse of the sunset glow.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000016_000005.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "That slight girl, with her little feet, little hands, little face attractively overweighted by great coils of hair; with a rather large mouth, whose mere parting seemed to breathe upon you the fragrance of frankness and generosity, had the fastidious soul of an experienced woman.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000017_000002.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "They corrupted him thoroughly, the poor old boy.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000017_000004.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "But now I shall know how to grapple with this.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000018_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "After pronouncing these words with immense assurance, he glanced down at her, and at once fell a prey to distress, incertitude, and fear.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000020_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "She did.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000020_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "She would.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000020_000004.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "When her feet touched the ground again, the bell was still ringing in the valley; she put her hands up to her hair, breathing quickly, and glanced up and down the stony lane.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000021_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "They turned back, and after she had slipped her hand on his arm, the first words he pronounced were-",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000022_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "You've heard its name.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000022_000003.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "I am so glad poor father did get that house.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000022_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000022_000006.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "You shall be the new mistress of the Casa Gould.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000024_000003.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Uncle Harry was no adventurer.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000024_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000024_000006.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "He made use of the political cry of his time.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000024_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000024_000007.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "It was Federation.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000024_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000024_000008.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "But he was no politician.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000024_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000024_000011.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "He went to work in his own way because it seemed right, just as I feel I must lay hold of that mine.\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000026_000000.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "He explained those things.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000026_000001.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "It was late when they parted.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000027_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000027_000005.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Action is consolatory.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000027_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000027_000010.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Such were the-properly speaking-emotions of Charles Gould.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000027_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000027_000012.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "Not one of them could be aware beforehand what enormous changes the death of any given individual may produce in the very aspect of the world.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4733_6398_000028_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4733/6398/4733_6398_000028_000006.wav",
        "speaker_id": "LibriTTS_R-4733",
        "content": "The words it pronounces have the value of acts of integrity, tolerance, and compassion.",
