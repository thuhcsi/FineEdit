        "speaker_id": "LibriTTS_R-2003",
        "content": "Bunyip not got 'nuff water.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
