[
    {
        "item_name": "LibriTTS_R-2003_143254_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000001_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "CHAPTER TWENTY TWO.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "HOW HIGH THE WATER CAME.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000004_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "The thunder pealed so that the reports of our pieces seemed feeble, more like the crack of a cart whip, and their flashes were as sparks compared with the blinding lightning, which darted and quivered in the gorge, at times seeming to lick the walls, at others plunging into the rushing, seething stream, into which the rain poured in very cataracts down the rocky sides.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000006_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "Jimmy, too, seemed to be transformed into as brave a black warrior as ever fought; and it was the gallant resistance offered that checked the enemy and made them recoil.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000009_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "I stared after them, wondering that they should give way just at a time when a bold attack would probably have ended in our destruction; but I could make out nothing, only that the noise of the thunder still seemed to continue and grow into a sound like a fierce rush.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000009_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "But this was nothing new: the thunder had been going on before, and that and the blinding lightning the enemy had braved.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000009_000002.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "Our defence had had no effect upon them, save to make them attack more fiercely.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000009_000003.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "And yet they were now in full retreat, falling over each other in their haste, and we saw two thrust into the swift river.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000011_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "I turned aghast to the doctor, and then made as if to run, expecting that the next moment we should be swept away; but he caught me by the arm with a grip like iron.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"Stand still,\" he roared, with his lips to my ear.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000013_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "Just then there was another crashing peal of thunder, close upon a flash of lightning, and the hissing rain ceased as if by magic, while the sky began to grow lighter.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000014_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "The noise was not so great though, now, that we could not talk, and after recovering from the appalling shock of the new danger we had time to look around.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000019_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"How high above the surface of the water were we, do you think, when we came here?\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000020_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"I should say about twenty five feet?\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"Why, we ain't four foot above it now; and-look there!",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000021_000002.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "I say, Joe Carstairs, if I'd known we were going to be drowned I wouldn't have come.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000025_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"Here, you hold your noise,\" cried Jack Penny.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000025_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"You don't hear us holler, do you?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000025_000002.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "Lie down!\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000026_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "The dog howled softly and crouched at his master's feet, while Jack began to take off his clothes in a very slow and leisurely way.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000026_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "First he pulled off his boots, then his stockings, which he tucked methodically, along with his garters, inside his boots.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000030_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"Why, what are you going to do?\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000031_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"Do!\" he said.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000031_000002.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "You don't suppose I'm going to try in my clothes?\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143254_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143254/2003_143254_000032_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "My mirth died out as swiftly as it came, for the doctor laid his hand upon my arm and pressed it silently, to call my attention to our black followers, who were laying their bows and arrows regularly in company with their waddies, each man looking very stern and grave.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000000_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "WE AWAIT OUR FATE.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000001_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "I glanced from the blacks to the doctor, to see that he was intently gazing up the gorge where the rushing water came seething down, and I read in his face that he could not see the slightest hope.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000005_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"Can we do anything, doctor?\" I said at last in a low awe stricken voice.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000007_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"No, my lad,\" he said, \"nothing.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000009_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "For it seemed so hard to give up hope when so young and full of health and strength.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000012_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "I nodded.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000013_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"That's right,\" he said.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000013_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"I shall do the same.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000013_000002.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "We might reach some ledge lower down.\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"No water go down,\" he said.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000017_000002.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "Top along get drown, die, and bunyip pull um down an eat um!\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000018_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"I'm afraid escape is impossible, Jimmy,\" I said sadly.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000020_000000.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "\"Can't get away,\" I said.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2003_143255_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2003/143255/2003_143255_000021_000001.wav",
        "speaker_id": "LibriTTS_R-2003",
        "content": "Waitum, waitum!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
