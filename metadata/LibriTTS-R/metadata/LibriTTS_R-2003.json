        "speaker_id": "LibriTTS_R-2003",
        "content": "There's a ledge there higher up where we will place the ammunition.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
