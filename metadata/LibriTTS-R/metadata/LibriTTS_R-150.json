        "speaker_id": "LibriTTS_R-150",
        "content": "\"How am I to put you in?\" \"That is your business,\" she answered, quite snappishly.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
