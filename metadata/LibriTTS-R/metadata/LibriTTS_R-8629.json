        "speaker_id": "LibriTTS_R-8629",
        "content": "I promised, and with perfect peace in her face, she pointed to the dagger in her breast.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
