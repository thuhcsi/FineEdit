        "speaker_id": "LibriTTS_R-8629",
        "content": "Then I lifted her and laid her where you found her, on the sofa.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
