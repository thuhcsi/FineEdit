        "speaker_id": "LibriTTS_R-4153",
        "content": "CHAPTER THIRTY ONE.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4153_61735_000002_000000",
