        "speaker_id": "LibriTTS_R-8280",
        "content": "The more this thirst is fed, the more insatiate it becomes, and more fiery drink is needed.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
