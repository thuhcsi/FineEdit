        "speaker_id": "LibriTTS_R-8280",
        "content": "\"Where's that Dutch villain?\" Ward was screaming, following up his question with a volley of oaths.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
