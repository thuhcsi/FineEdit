        "speaker_id": "LibriTTS_R-8280",
        "content": "\"Let me go!\" yelled Ward, making a desperate effort to free his arms.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
