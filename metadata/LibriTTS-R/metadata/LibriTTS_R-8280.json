        "speaker_id": "LibriTTS_R-8280",
        "content": "I'll have no fighting aboard.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8280_266249_000098_000000",
