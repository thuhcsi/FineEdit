        "speaker_id": "LibriTTS_R-8280",
        "content": "\"Stay a moment,\" exclaimed Lilburn in an undertone, and laying a detaining hand upon Travilla's arm, but with his gaze intently fixed upon the older gamester.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
