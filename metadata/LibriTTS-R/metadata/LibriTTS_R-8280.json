        "speaker_id": "LibriTTS_R-8280",
        "content": "\"Look yourself.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
