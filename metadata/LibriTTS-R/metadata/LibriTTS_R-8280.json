        "speaker_id": "LibriTTS_R-8280",
        "content": "Yet there was gambling again the second night, between Ward and several others of his profession.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
