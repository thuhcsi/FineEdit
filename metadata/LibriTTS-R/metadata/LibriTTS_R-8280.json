        "speaker_id": "LibriTTS_R-8280",
        "content": "\"It came from under the table,\" gasped Ward, \"look what's there.\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
