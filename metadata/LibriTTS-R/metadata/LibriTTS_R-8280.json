        "speaker_id": "LibriTTS_R-8280",
        "content": "\"I wonder which of us it is!\" remarked the first, looking hard at our party.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8280_266249_000080_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8280/266249/8280_266249_000080_000000.wav",
        "speaker_id": "LibriTTS_R-8280",
        "content": "\"I don't know, but come on.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
