        "speaker_id": "LibriTTS_R-8280",
        "content": "\"I tell you this is growing serious,\" whispered one in a shaking voice, his very lips white with fear.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8280_266249_000106_000000",
