        "speaker_id": "LibriTTS_R-8280",
        "content": "\"How dare you, sir?",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
