        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8280/266249/8280_266249_000099_000000.wav",
        "speaker_id": "LibriTTS_R-8280",
        "content": "They kept it up till after midnight.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
