        "speaker_id": "LibriTTS_R-8280",
        "content": "\"Let's follow and see the fun.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8280_266249_000079_000000",
