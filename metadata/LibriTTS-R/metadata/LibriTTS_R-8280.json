        "speaker_id": "LibriTTS_R-8280",
        "content": "They heard him in silence, with a cool, phlegmatic indifference most exasperating to one in his present mood.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
