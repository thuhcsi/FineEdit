        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8280/266249/8280_266249_000109_000000.wav",
        "speaker_id": "LibriTTS_R-8280",
        "content": "There was nothing there.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8280_266249_000111_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8280/266249/8280_266249_000111_000000.wav",
        "speaker_id": "LibriTTS_R-8280",
        "content": "\"Oh, nonsense! what fools we are! of course somebody's ill in one of the state rooms.\" And they resumed their game for the second time.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8280_266249_000113_000000",
