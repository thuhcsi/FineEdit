        "speaker_id": "LibriTTS_R-5980",
        "content": "that's nothing,\" replied Sir Philip: \"yes, fifty times, I would, by Jove!\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
