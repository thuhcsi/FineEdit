        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000064_000000.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "\"The deuce take him!\" said Clarence: \"but tell me, is it possible that you are not in love with her still?--and why?\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
