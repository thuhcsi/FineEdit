        "speaker_id": "LibriTTS_R-5980",
        "content": "\"Why?\" said mr Percival-\"why?",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
