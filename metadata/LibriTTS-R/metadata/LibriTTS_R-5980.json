        "speaker_id": "LibriTTS_R-5980",
        "content": "Faith, Clary, you've had a squeak for your life!",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
