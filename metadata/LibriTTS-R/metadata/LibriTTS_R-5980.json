        "speaker_id": "LibriTTS_R-5980",
        "content": "Away the faithful friends went to the important business of their day.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
