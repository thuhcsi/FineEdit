        "speaker_id": "LibriTTS_R-5980",
        "content": "\"Yes,\" answered his companions; \"but you didn't keep the path.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
