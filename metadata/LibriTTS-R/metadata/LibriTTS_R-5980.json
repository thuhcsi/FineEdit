        "speaker_id": "LibriTTS_R-5980",
        "content": "The wine merchant evidently, as mr Hervey thought, leaned towards Sir Philip.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
