        "speaker_id": "LibriTTS_R-5980",
        "content": "\"Why, my boy-that's a famous fellow, faith!--why, you look the better for being drowned.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
