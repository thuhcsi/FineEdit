        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000062_000000.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "\"How?--When?--Where?\" cried Clarence Hervey, in a tone totally different from that in which he had first addressed mr Percival.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
