        "speaker_id": "LibriTTS_R-5980",
        "content": "\"Is it possible?",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5980_22680_000051_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000051_000002.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "How rejoiced I am to see you, and how rejoiced I am to be obliged to you!",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5980_22680_000051_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000051_000003.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "There is not a man in England to whom I would rather be obliged.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
