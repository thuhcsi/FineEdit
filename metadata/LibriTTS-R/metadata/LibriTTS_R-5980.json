        "speaker_id": "LibriTTS_R-5980",
        "content": "\"Ten times!",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
