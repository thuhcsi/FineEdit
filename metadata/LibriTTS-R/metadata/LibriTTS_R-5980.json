        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000013_000001.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "You turned out of the way when you met that crowd of children yonder.\"",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
