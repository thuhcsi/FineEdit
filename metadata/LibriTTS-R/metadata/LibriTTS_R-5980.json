        "speaker_id": "LibriTTS_R-5980",
        "content": "But he stopped short in the midst of his acknowledgments, when he discovered to whom he was speaking.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
