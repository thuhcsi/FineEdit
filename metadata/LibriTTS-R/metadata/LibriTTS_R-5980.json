        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000006_000001.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "Clarence Hervey was victorious; and his sense of the importance of this victory was much increased by the fumes of the wine, which began to operate upon his brain.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
