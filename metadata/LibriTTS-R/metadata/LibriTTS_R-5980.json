        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000015_000000.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "\"But,\" said Hervey, \"would you have had me run over that little child, who was stooping down just in my way?\"",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
