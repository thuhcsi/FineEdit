        "speaker_id": "LibriTTS_R-5980",
        "content": "Sir Philip, who was just going to furnish his cellars, was a person of importance to the wine merchant, who produced accordingly his choicest treasures.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
