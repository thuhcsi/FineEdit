        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000061_000000.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "\"Why, you are not in love with her ladyship, are you?\" said dr X----. \"I am not in love with Lady Delacour's picture of herself,\" replied mr Percival, \"but I was once in love with the original.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
