        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000009_000001.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "To Hyde park they repaired; Sir Philip boasting, all the way they walked, of the superior strength of his head.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
