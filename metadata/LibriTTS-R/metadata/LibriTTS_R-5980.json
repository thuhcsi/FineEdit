        "item_name": "LibriTTS_R-5980_22680_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000011_000002.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "Clarence-fairly lost.\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5980_22680_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5980/22680/5980_22680_000012_000000.wav",
        "speaker_id": "LibriTTS_R-5980",
        "content": "\"Didn't I reach the tree first?\" said Clarence.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
