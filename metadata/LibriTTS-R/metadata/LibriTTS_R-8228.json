        "speaker_id": "LibriTTS_R-8228",
        "content": "Why do ye speak against all the prophecies of the holy prophets?",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
