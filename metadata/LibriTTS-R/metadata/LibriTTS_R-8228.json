        "speaker_id": "LibriTTS_R-8228",
        "content": "Why do ye look for a Christ?",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
