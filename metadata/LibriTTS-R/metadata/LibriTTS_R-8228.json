        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8228/232690/8228_232690_000037_000001.wav",
        "speaker_id": "LibriTTS_R-8228",
        "content": "Why do ye teach this people that there shall be no Christ, to interrupt their rejoicings?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
