        "speaker_id": "LibriTTS_R-8228",
        "content": "Behold, I say they are in bondage.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
