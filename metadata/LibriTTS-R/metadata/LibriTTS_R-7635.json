        "speaker_id": "LibriTTS_R-7635",
        "content": "Chauvelin had not given up all hope.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
