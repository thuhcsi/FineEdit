        "speaker_id": "LibriTTS_R-7635",
        "content": "The supreme head of the church was a foreign potentate, guided by interests always different from those of the community, sometimes contrary to them.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
