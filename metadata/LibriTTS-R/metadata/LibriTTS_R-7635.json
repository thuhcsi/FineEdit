        "speaker_id": "LibriTTS_R-7635",
        "content": "But don't kill him,\" he added drily.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
