        "speaker_id": "LibriTTS_R-7635",
        "content": "He walked up to where Marguerite lay, and looked down into her face.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
