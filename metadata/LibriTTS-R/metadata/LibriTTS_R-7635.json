        "speaker_id": "LibriTTS_R-7635",
        "content": "\"I, myself,\" concluded Chauvelin, \"must now very reluctantly leave you. AU REVOIR, fair lady.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
