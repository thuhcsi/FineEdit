        "speaker_id": "LibriTTS_R-7635",
        "content": "HENRY the eighth.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
