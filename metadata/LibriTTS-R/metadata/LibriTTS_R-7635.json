        "speaker_id": "LibriTTS_R-7635",
        "content": "Here,\" he added, turning to the soldiers, \"the buckle end of your two belts to this confounded Jew.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
