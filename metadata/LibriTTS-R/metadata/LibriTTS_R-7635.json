        "speaker_id": "LibriTTS_R-7635",
        "content": "He smiled.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7635_105409_000109_000000",
