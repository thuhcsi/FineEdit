        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7635/105409/7635_105409_000112_000001.wav",
        "speaker_id": "LibriTTS_R-7635",
        "content": "I'll follow.\"",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7635_105409_000113_000000",
