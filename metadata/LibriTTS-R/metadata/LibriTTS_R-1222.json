[
    {
        "item_name": "LibriTTS_R-1222_133834_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "THE Sunday was a bright Sunday in autumn, clear and cool, when early in the morning Sissy and Rachael met, to walk in the country.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Though the green landscape was blotted here and there with heaps of coal, it was green elsewhere, and there were trees to see, and there were larks singing (though it was Sunday), and there were pleasant scents in the air, and all was over arched by a bright blue sky.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Under their feet, the grass was fresh; beautiful shadows of branches flickered upon it, and speckled it; hedgerows were luxuriant; everything was at peace.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000003_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Engines at pits' mouths, and lean old horses that had worn the circle of their daily labour into the ground, were alike quiet; wheels had ceased for a short space to turn; and the great wheel of earth seemed to revolve without the shocks and noises of another time.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "They walked on across the fields and down the shady lanes, sometimes getting over a fragment of a fence so rotten that it dropped at a touch of the foot, sometimes passing near a wreck of bricks and beams overgrown with grass, marking the site of deserted works.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "They followed paths and tracks, however slight.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "They had seen no one, near or distant, for a long time; and the solitude remained unbroken.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "As Sissy said it, her eyes were attracted by another of those rotten fragments of fence upon the ground.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "She got up to look at it.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000006_000005.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Here are footsteps too.—O Rachael!'",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "She ran back, and caught her round the neck.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Rachael had already started up.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'What is the matter?'",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'I don't know.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "There is a hat lying in the grass.' They went forward together.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Rachael took it up, shaking from head to foot.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000009_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "She broke into a passion of tears and lamentations: Stephen Blackpool was written in his own hand on the inside.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'O the poor lad, the poor lad!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "He has been made away with.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Is there—has the hat any blood upon it?' Sissy faltered.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "They were afraid to look; but they did examine it, and found no mark of violence, inside or out.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "They looked fearfully about them, without moving, but could see nothing more.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000012_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Rachael,' Sissy whispered, 'I will go on a little by myself.'",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "She had unclasped her hand, and was in the act of stepping forward, when Rachael caught her in both arms with a scream that resounded over the wide landscape.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Before them, at their very feet, was the brink of a black ragged chasm hidden by the thick grass.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'O, my good Lord!",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000014_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Down there!' At first this, and her terrific screams, were all that could be got from Rachael, by any tears, by any prayers, by any representations, by any means.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Rachael, dear Rachael, good Rachael, for the love of Heaven, not these dreadful cries!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000015_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Think of Stephen, think of Stephen, think of Stephen!'",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "By an earnest repetition of this entreaty, poured out in all the agony of such a moment, Sissy at last brought her to be silent, and to look at her with a tearless face of stone.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Rachael, Stephen may be living.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000017_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "You wouldn't leave him lying maimed at the bottom of this dreadful place, a moment, if you could bring help to him?'",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'No, no, no!'",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Don't stir from here, for his sake!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000019_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Let me go and listen.'",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "She shuddered to approach the pit; but she crept towards it on her hands and knees, and called to him as loud as she could call.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000020_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "She did this, twenty, thirty times.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "The wide prospect, so beautiful in its stillness but a few minutes ago, almost carried despair to her brave heart, as she rose and looked all round her, seeing no help.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000021_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Rachael, we must lose not a moment.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000021_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000021_000005.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Think of Stephen, think of Stephen!'",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "She knew by Rachael's face that she might trust her now.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000023_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Don't stop for breath.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000024_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "One of the men was in a drunken slumber, but on his comrade's shouting to him that a man had fallen down the Old Hell Shaft, he started out to a pool of dirty water, put his head in it, and came back sober.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000025_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Then a horse was found; and she got another man to ride for life or death to the railroad, and send a message to Louisa, which she wrote and gave him.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000027_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "In the midst of this, Rachael returned; and with her party there was a surgeon, who brought some wine and medicines.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000028_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "There being now people enough present to impede the work, the sobered man put himself at the head of the rest, or was put there by the general consent, and made a large ring round the Old Hell Shaft, and appointed men to keep it.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000029_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "It was five o'clock in the afternoon of the bright autumnal Sunday, before a candle was sent down to try the air, while three or four rough faces stood crowded close together, attentively watching it: the man at the windlass lowering as they were told.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000029_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000029_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "The candle was brought up again, feebly burning, and then some water was cast in.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000030_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "The signal was given and the windlass stopped, with abundant rope to spare.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000030_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000030_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "But the surgeon who held the watch, declared five minutes not to have elapsed yet, and sternly admonished them to keep silence.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000031_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "The rope came in tight and strained; and ring after ring was coiled upon the barrel of the windlass, and all eyes were fastened on the pit.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000031_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "The sobered man was brought up and leaped out briskly on the grass.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000032_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "When he said 'Alive!' a great shout arose and many eyes had tears in them.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000033_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'But he's hurt very bad,' he added, as soon as he could make himself heard again.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000033_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Where's doctor?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000033_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "He's hurt so very bad, sir, that we donno how to get him up.'",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000035_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000035_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "As these were made, they were hung upon an arm of the pitman who had last come up, with instructions how to use them: and as he stood, shown by the light he carried, leaning his powerful loose hand upon one of the poles, and sometimes glancing down the pit, and sometimes glancing round upon the people, he was not the least conspicuous figure in the scene.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000035_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000035_000004.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "It was dark now, and torches were kindled.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000036_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "It appeared from the little this man said to those about him, which was quickly repeated all over the circle, that the lost man had fallen upon a mass of crumbled rubbish with which the pit was half choked up, and that his fall had been further broken by some jagged earth at the side.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000036_000002.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "He had come straight away from his work, on being written to, and had walked the whole journey; and was on his way to mr Bounderby's country house after dark, when he fell.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000036_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000036_000004.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "The Old Hell Shaft, the pitman said, with a curse upon it, was worthy of its bad name to the last; for though Stephen could speak now, he believed it would soon be found to have mangled the life out of him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000037_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000037_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Every one waited with his grasp set, and his body bent down to the work, ready to reverse and wind in.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000037_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000037_000004.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "At length the signal was given, and all the ring leaned forward.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000039_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000039_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "That gently done, he called to him Rachael and Sissy.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000040_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "They gave him drink, moistened his face with water, and administered some drops of cordial and wine.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000048_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000048_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "A muddle!",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000050_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000050_000003.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "He would'n ha' suspect'n me.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000050_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000050_000004.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "But look up yonder, Rachael!",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000050_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000050_000005.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Look aboove!'",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000053_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'It ha' shined upon me,' he said reverently, 'in my pain and trouble down below.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000053_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000053_000006.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "But in our judgments, like as in our doins, we mun bear and forbear.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000058_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000058_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "'Shall I bring him to you?'",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000060_000000.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "Louisa returned with her father.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1222_133834_000061_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1222/133834/1222_133834_000061_000001.wav",
        "speaker_id": "LibriTTS_R-1222",
        "content": "This I leave to yo.'",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
