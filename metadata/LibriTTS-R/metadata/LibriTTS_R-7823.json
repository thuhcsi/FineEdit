[
    {
        "item_name": "LibriTTS_R-7823_103122_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "From one of the windows of the chateau tower a boy's face looked out, full of eager longing,--a fine, strong face, but sullen now, with black brows, dark, restless eyes, and lips set, as if rebellious thoughts were stirring in his mind.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "She can tell better tales than any in this weary book, the bane of my life!\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "As he spoke, the boy struck a volume that lay on the wide ledge, with a petulant energy that sent it fluttering down into the court yard below. Half ashamed and half amused, young Gaston peeped to see if this random shot had hit any one.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "But all was quiet and deserted now; so, with a boyish laugh and a daring glance at the dangerous descent, he said to the doves cooing on the roof overhead: \"Here's a fine pretext for escape.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000011_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Then swinging himself out as if it were no new feat, he climbed boldly down through the ivy that half hid the carved flowers and figures which made a ladder for his agile feet.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Had Father Nevin trusted to my honor, I would not have run away; but he locked me in, like a monk in a cell, and that I will not bear.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "The girl laughed also as she retorted, \"My tutor should not have left me to play with his dogs.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "I bore my penance better than you, and did not run away.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000018_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Come now, we'll be merry.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000019_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Since I may not play a man's part yet, amuse me like a boy, with the old tales your mother used to tell, when we watched the fagots blaze in the winter nights.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000021_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "As babies, the two slept in one cradle; as children they played and quarrelled together; and as boy and girl they defended, comforted, and amused each other.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000031_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"I am lost if he spy me, for my father vowed I should not hunt again unless I did my task.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000031_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "He will see me if I run, and where can I hide till he has past?\" whispered Gaston, ashamed of his panic, yet unwilling to pay the penalty of his prank.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000032_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "But quick witted Yvonne saved him; for lifting one end of the long web of linen, she showed a hollow whence some great stone had been removed, and Gaston slipped into the green nest, over which the linen lay smoothly when replaced.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000033_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "The mule paused in the light shadow of the willows, to crop a mouthful of grass before climbing the hill, and the chaplain seemed glad to rest a moment, for the day was warm and the road dusty.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000035_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Thanks, daughter!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000035_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "A fine day for the bleaching, but over warm for much travel.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000036_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Yvonne went to sprinkling the neglected linen, wondering with mingled anxiety and girlish merriment how Gaston fared.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000037_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Sprinkle me quickly; I am stifling in this hole,\" whispered an imploring voice.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000039_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Then, springing up, he said, throwing back his wet hair and shaking his finger at her: \"You dared not betray me, but you nearly drowned me, wicked girl.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000039_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000039_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "I cannot stop for vengeance now; but I'll toss you into the river some day, and leave you to get out as you can.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000042_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "She longed to go with him; but her part was to watch and wait, to hope and pray, till the hour came when she, like many another woman in those days, could prove herself as brave as a man, and freely risk her life for those she loved.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000044_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "I promised, and if he lives, it shall be done.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000045_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Go, my girl, and bring me news of our young lord.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000046_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "The pretty winged creature, frightened by the destruction of its home, had flown to her for refuge, and she had cherished it for its master's sake.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000047_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "His own reckless courage had brought him there; for in one of the many skirmishes in which he had taken part, he ventured too far away from his men, and was captured after fighting desperately to cut his way out.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000056_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000056_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Then Gaston remembered how he used to send messages to Yvonne by this carrier dove, and with a thrill of joy looked for the token, hardly daring to hope that any would be found.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000057_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000057_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Be ready; help will come.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000057_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000057_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Y.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000058_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000058_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"The brave girl! the loyal heart!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000059_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000059_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Then kissing the bird he bade it go, watching the silver wings flash in the sunshine as it flew away, carrying joy with it and leaving hope behind.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000060_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "After that the little courier came often unperceived, carrying letters to and fro; for Yvonne sent bits of paper, and Gaston wrote his answers with his blood and a quill from Blanchette's wing.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000061_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000061_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Her plan was perilously simple, but the only one possible; for Gaston was well guarded, and out of that lofty cell it seemed that no prisoner could escape without wings.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000062_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000062_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Thus, when the order came, written in the rude hand he had taught Yvonne long ago, \"Pull up the thread which Blanchette will bring at midnight. Watch for a light in the bay.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000062_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000062_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "He knew that the attempt might cost him his life, but was willing to gain liberty even at that price; for imprisonment seemed worse than death to his impatient spirit.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000063_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000063_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "In a moment a quick jerk at the thread bade him pull again.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000063_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000063_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "A cord came up, and when that was firmly secured, a second jerk was the signal for the last and most important haul.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000063_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000063_000003.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Up came the stout rope, knotted here and there to add safety and strength to the hands and feet that were to climb down that frail ladder, unless some cruel fate dashed the poor boy dead upon the rocks below.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000063_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000063_000004.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "The rope was made fast to an iron staple inside, the bars were torn away, and Gaston crept through the narrow opening to perch on the ledge without, while Blanchette flew down to tell Yvonne he was coming.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000064_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000064_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "More than once he thought it was all over; but the good rope held fast, and strength and courage nerved heart and limbs.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000066_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000066_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "I found him looking for you.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000066_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000066_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "He is true as steel.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000067_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000067_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"But you?\" he cried; \"I cannot leave you in peril, after all you have dared and done for me.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000068_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000068_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"No one suspects me; I am safe.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000068_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000068_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Go to my mother; she will hide you, and I will follow soon.\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000070_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000070_000003.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Hundreds of men and women were there, suffering terribly, and among them was Yvonne, brave still, but with no hope of escape; for few were saved, and then only by some lucky accident.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000070_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000070_000004.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "Like a sister of mercy she went among the poor souls crowded together in the great halls, hungry, cold, sick, and despairing, and they clung to her as if she were some strong, sweet saint who could deliver them or teach them how to die.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000072_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000072_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Which is it to be?\" she asked, as she passed one of the men who guarded them, a rough fellow, whose face was half hidden by a shaggy beard.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000075_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000075_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Courage, my sister; it is soon over.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000077_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000077_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "No need to repeat the dreadful history of the Noyades; it is enough to say that in the confusion of the moment Yvonne found opportunity to read and destroy the little paper, which said briefly:--",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000078_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000078_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"When you are flung into the river, call my name and float.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000078_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000078_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "I shall be near.\"",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000080_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000080_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "One more adventure, and that a happy one, completed their joy, and turned their flight into a triumphant march.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000081_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000081_000004.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Slip around and drive him this way.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000081_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000081_000005.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "I never miss my aim, and we will sup royally to night,\" whispered Gaston, glad to use the arms with which they had provided themselves.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000082_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000082_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "But he was off before a shot could be fired, and the disappointed hunters followed long and far, resolved not to go back empty handed.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000087_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000087_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"I taught you to stalk the deer, and spear the boar, not to hunt your fellow creatures, my lord.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000087_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000087_000001.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "But I forgive you, for it was well done, and I had a hard run to escape,\" he said, still laughing.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000089_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000089_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"A long tale, for which I have a short and happy answer.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000089_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000089_000002.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "As they went, Gaston poured out his story, and told how Yvonne was waiting for them in the wood.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7823_103122_000090_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7823/103122/7823_103122_000090_000000.wav",
        "speaker_id": "LibriTTS_R-7823",
        "content": "\"Brave lads! and here is your reward,\" answered the forester, pushing open the door and pointing to the figure of a man, with a pale face and bandaged head, lying asleep beside the fire.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    }
]