        "speaker_id": "LibriTTS_R-4513",
        "content": "What words were these?",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
