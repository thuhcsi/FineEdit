        "speaker_id": "LibriTTS_R-4513",
        "content": "The only things which are worth the trouble of saying and hearing!",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
