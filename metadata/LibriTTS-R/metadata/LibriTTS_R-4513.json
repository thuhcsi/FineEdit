        "speaker_id": "LibriTTS_R-4513",
        "content": "yes, childish prattle, repetitions, laughter at nothing, nonsense, everything that is deepest and most sublime in the world!",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
