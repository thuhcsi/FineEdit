        "speaker_id": "LibriTTS_R-2397",
        "content": "\"Major, you told me to keep watch and let you know.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
