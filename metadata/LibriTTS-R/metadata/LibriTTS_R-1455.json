        "speaker_id": "LibriTTS_R-1455",
        "content": "The actual state of this cracked, twisted, and burst disc abundantly proves this.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
