        "speaker_id": "LibriTTS_R-1455",
        "content": "There remains but one hypothesis, that of a living race to which motion, which is life, is foreign.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
