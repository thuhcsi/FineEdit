        "speaker_id": "LibriTTS_R-1455",
        "content": "I ask it to be put differently.\"",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
