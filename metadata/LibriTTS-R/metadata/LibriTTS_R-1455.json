        "speaker_id": "LibriTTS_R-1455",
        "content": "\"The hand is not necessary,\" answered Nicholl, not at all confounded; \"and as to the stone, let us suppose it to be a comet.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
