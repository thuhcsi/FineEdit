        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1455/134435/1455_134435_000015_000011.wav",
        "speaker_id": "LibriTTS_R-1455",
        "content": "\"See, come here and look,\" cried the old man. \"Grandfather Jesse's white mare has torn the black stocking she wears on her foot.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
