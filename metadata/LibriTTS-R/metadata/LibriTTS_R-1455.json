        "speaker_id": "LibriTTS_R-1455",
        "content": "\"Here it is,\" continued Barbicane.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
