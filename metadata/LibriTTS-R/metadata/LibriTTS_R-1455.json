        "speaker_id": "LibriTTS_R-1455",
        "content": "\"Now,\" said Nicholl, \"let us attack the second question, an indispensable complement of the first.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
