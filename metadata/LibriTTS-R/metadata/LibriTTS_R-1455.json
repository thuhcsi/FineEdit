        "speaker_id": "LibriTTS_R-1455",
        "content": "\"Without a doubt!\" answered Nicholl.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "low"
