        "speaker_id": "LibriTTS_R-1455",
        "content": "Instead he prayed for it.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
