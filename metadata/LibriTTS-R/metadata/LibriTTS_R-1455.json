        "speaker_id": "LibriTTS_R-1455",
        "content": "\"Make a sign to me, God,\" he cried.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
