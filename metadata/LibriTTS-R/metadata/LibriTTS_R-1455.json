        "speaker_id": "LibriTTS_R-1455",
        "content": "\"Four, five, six, seven,\" he said slowly, wetting his finger and making straight up and down marks on the window ledge.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
