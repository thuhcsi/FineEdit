        "speaker_id": "LibriTTS_R-1455",
        "content": "\"I believe it,\" said Nicholl.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very low"
    },
