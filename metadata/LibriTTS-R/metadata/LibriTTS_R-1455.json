        "speaker_id": "LibriTTS_R-1455",
        "content": "In the house people stirred about.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1455_134435_000015_000003",
