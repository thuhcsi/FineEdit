        "speaker_id": "LibriTTS_R-1455",
        "content": "\"Just so,\" said Barbicane, \"which for us has no meaning.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
