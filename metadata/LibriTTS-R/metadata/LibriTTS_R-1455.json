        "speaker_id": "LibriTTS_R-1455",
        "content": "\"Take me away.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1455_138263_000012_000000",
