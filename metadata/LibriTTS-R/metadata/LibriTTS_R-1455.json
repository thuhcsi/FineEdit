        "speaker_id": "LibriTTS_R-1455",
        "content": "\"And I answer in the negative,\" continued Barbicane.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very low"
