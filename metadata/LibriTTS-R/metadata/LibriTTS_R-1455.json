        "speaker_id": "LibriTTS_R-1455",
        "content": "When he awoke at dawn the barnyard back of the house also awoke.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
