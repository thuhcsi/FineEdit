        "speaker_id": "LibriTTS_R-1455",
        "content": "As he talked his left eyelid twitched.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
