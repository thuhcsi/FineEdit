        "speaker_id": "LibriTTS_R-1455",
        "content": "\"I think that we can answer,\" said Barbicane; \"but according to my idea the question ought not to be put in that form.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
