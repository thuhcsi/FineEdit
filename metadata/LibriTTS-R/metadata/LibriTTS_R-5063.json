        "speaker_id": "LibriTTS_R-5063",
        "content": "This newes was brought to Eddenborrow, Where Scotlands king did raigne, That brave Erle Douglas suddenlye Was with an arrow slaine.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
