        "speaker_id": "LibriTTS_R-5063",
        "content": "\"O heavy newes,\" King james did say; \"Scottland can witnesse bee, I have not any captaine more Of such account as hee.\"",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
