        "speaker_id": "LibriTTS_R-5063",
        "content": "This vow full well the king perform'd After, at Humbledowne; In one day, fifty knights were slayne, With lordes of great renowne.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
