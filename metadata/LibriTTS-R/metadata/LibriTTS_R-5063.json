        "speaker_id": "LibriTTS_R-5063",
        "content": "So thus did both these nobles dye, Whose courage none could staine; An English archer then perceiv'd The noble erle was slaine.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
