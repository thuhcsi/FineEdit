        "speaker_id": "LibriTTS_R-476",
        "content": "\"Deepest well in all Wrychester under that,\" he remarked.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-476_133471_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/476/133471/476_133471_000007_000001.wav",
        "speaker_id": "LibriTTS_R-476",
        "content": "\"You'd never think it-it's a hundred feet deep-and more!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
