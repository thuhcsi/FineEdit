        "speaker_id": "LibriTTS_R-476",
        "content": "We are going to get the pile and then we're off to South America, and you won't see us for dust.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
