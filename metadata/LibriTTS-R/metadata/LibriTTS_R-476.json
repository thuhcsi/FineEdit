        "speaker_id": "LibriTTS_R-476",
        "content": "\"Forty three,\" he called sharply, \"I want you down here.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
