        "speaker_id": "LibriTTS_R-476",
        "content": "\"Private talk.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
