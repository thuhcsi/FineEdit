        "speaker_id": "LibriTTS_R-476",
        "content": "Let's go where it's quiet.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-476_133471_000007_000000",
