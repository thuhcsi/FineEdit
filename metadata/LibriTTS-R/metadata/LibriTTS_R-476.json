        "speaker_id": "LibriTTS_R-476",
        "content": "They were desperate men, peculiarly interesting to him, and he had watched their faces furtively in the early period of his imprisonment.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
