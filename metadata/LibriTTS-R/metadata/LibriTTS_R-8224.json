[
    {
        "item_name": "LibriTTS_R-8224_274384_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000000_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "He rode before a portmanteau, and called himself Ashburnham's servant.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000001_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "The Scottish generals and commissioners affected great surprise on the appearance of the king; and though they paid him all the exterior respect due to his dignity, they instantly set a guard upon him, under color of protection, and made him in reality a prisoner.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000001_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "They informed the English parliament of this unexpected incident, and assured them that they had entered into no private treaty with the king.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000005_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "He was particularly attentive to the behavior of their preachers, on whom all depended.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000005_000005.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Have we eaten at all of the king's cost?",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000005_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000005_000006.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "or hath he given us any gift?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000005_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000005_000009.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Another preacher, after reproaching him to his face with his misgovernment, ordered this psalm to be sung:--",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "\"Why dost thou, tyrant, boast thyself, Thy wicked deeds to praise?\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000010_000002.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "The Scottish generals would enter into no confidence with him; and still treated him with distant ceremony and feigned respect.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "They required him to issue orders to Oxford and to all his other garrisons, commanding their surrender to the parliament; and the king, sensible that their resistance was to very little purpose, willingly complied.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000015_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Montrose also, after having experienced still more variety of good and bad fortune, threw down his arms, and retired out of the kingdom.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000016_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "The marquis of Worcester, a man past eighty four, was the last in England that submitted to the authority of the parliament.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000016_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "He defended Raglan Castle to extremity; and opened not its gates till the middle of August.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000017_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "The parliament and the Scots laid their proposals before the king.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000017_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "They were such as a captive, entirely at mercy, could expect from the most inexorable victor.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000017_000002.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Yet were they little worse than what were insisted on before the battle of Naseby.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000018_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "He requested a personal treaty with the parliament.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000022_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "What the parliament was most intent upon, was not their treaty with the king, to whom they paid little regard, but that with the Scots.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000022_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Two important points remained to be settled with that nation: their delivery of the king, and the estimation of their arrears.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000026_000002.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "And though the contributions which they had levied, as well as the price of their living at free quarters, must be deducted, yet still the sum which they insisted on was very considerable.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000028_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Great pains were taken by the Scots (and the English complied with their pretended delicacy) to make this estimation and payment of arrears appear a quite different transaction from that for the delivery of the king's person: but common sense requires that they should be regarded as one and the same.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000029_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Thus the Scottish nation underwent, and still undergo, (for such grievous stains are not easily wiped off,) the reproach of selling their king and betraying their prince for money.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000030_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "The infamy of this bargain had such an influence on the Scottish parliament, that they once voted that the king should be protected, and his liberty insisted on.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000031_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "The English commissioners, who, some days after, came to take him under their custody, were admitted to kiss his hands; and he received them with the same grace and cheerfulness as if they had travelled on no other errand than to pay court to him.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000032_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "On his journey, the whole country flocked to behold him, moved partly by curiosity, partly by compassion and affection.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000036_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "The parliament, though earnestly applied to by the king, refused to allow his chaplains to attend him, because they had not taken the covenant.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000037_000000.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "During the time that the king remained in the Scottish army at Newcastle, died the earl of Essex, the discarded, but still powerful and popular general of the parliament.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000037_000001.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "His death, in this conjuncture, was a public misfortune.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8224_274384_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8224/274384/8224_274384_000037_000002.wav",
        "speaker_id": "LibriTTS_R-8224",
        "content": "Fully sensible of the excesses to which affairs had been carried, and of the worse consequences which were still to be apprehended, he had resolved to conciliate a peace, and to remedy, as far as possible, all those ills to which, from mistake rather than any bad intentions, he had himself so much contributed.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    }
]