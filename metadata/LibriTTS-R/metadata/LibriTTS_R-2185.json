        "speaker_id": "LibriTTS_R-2185",
        "content": "The boys pushed aside the trailing tendrils and looked out and down.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
