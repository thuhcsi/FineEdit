        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4010/10822/4010_10822_000010_000013.wav",
        "speaker_id": "LibriTTS_R-4010",
        "content": "We are not bound to say all we think, but we are bound not even to look what we do not think.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
