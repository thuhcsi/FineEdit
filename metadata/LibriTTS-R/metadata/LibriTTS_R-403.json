        "speaker_id": "LibriTTS_R-403",
        "content": "But when he cried they gave him milk out of the cocoanuts which he was very fond of.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
