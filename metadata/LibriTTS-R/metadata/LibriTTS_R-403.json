        "speaker_id": "LibriTTS_R-403",
        "content": "At night they slept in tents made of palm leaves, on thick, soft beds of dried grass.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
