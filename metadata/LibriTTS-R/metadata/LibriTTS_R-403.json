        "speaker_id": "LibriTTS_R-403",
        "content": "One day Chee Chee climbed up a high rock and looked out over the tree tops.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
