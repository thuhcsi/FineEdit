        "speaker_id": "LibriTTS_R-403",
        "content": "And that same evening, sure enough, they saw Chee Chee's cousin and a lot of other monkeys, who had not yet got sick, sitting in the trees by the edge of a swamp, looking and waiting for them.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
