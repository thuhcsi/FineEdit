        "speaker_id": "LibriTTS_R-403",
        "content": "They even got the Doctor some tobacco one day, when he had finished what he had brought with him and wanted to smoke.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
