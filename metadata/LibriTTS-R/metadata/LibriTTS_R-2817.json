        "speaker_id": "LibriTTS_R-2817",
        "content": "I want to consult him about a little matter; but you are quite as much concerned in it, if not more.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
