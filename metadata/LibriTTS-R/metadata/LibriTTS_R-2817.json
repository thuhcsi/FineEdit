        "speaker_id": "LibriTTS_R-2817",
        "content": "\"Thank you; I will do so.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
