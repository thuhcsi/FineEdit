        "speaker_id": "LibriTTS_R-954",
        "content": "They picked up various other people who wanted to get it over, as they went along, until they had absorbed all the persons in the maze.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
