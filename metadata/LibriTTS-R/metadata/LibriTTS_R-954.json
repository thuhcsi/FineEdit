        "speaker_id": "LibriTTS_R-954",
        "content": "My friend said he would, and the shopman, thereupon, took him through the shop, and up the staircase of the house.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
