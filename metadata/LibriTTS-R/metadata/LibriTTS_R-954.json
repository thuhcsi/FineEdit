        "speaker_id": "LibriTTS_R-954",
        "content": "Harris didn't know, and suggested that the best thing to do would be to go back to the entrance, and begin again.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
