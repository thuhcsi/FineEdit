        "speaker_id": "LibriTTS_R-954",
        "content": "It is a shop now, in the market place, but it was evidently once the mansion of some great personage.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
