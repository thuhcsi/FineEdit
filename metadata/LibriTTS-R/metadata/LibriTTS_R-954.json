        "speaker_id": "LibriTTS_R-954",
        "content": "Speaking of oak staircases reminds me that there is a magnificent carved oak staircase in one of the houses in Kingston.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
