        "speaker_id": "LibriTTS_R-954",
        "content": "\"The map may be all right enough,\" said one of the party, \"if you know whereabouts in it we are now.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
