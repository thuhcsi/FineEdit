        "speaker_id": "LibriTTS_R-954",
        "content": "They said it was very kind of him, and fell behind, and followed.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
