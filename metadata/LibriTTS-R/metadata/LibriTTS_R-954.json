        "speaker_id": "LibriTTS_R-954",
        "content": "Perhaps, from the casement, standing hand in hand, they were watching the calm moonlight on the river, while from the distant halls the boisterous revelry floated in broken bursts of faint heard din and tumult.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
