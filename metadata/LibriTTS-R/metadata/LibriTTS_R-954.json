        "speaker_id": "LibriTTS_R-954",
        "content": "Well, that boy used to get ill about twice a week, so that he couldn't go to school.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
