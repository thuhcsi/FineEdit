        "speaker_id": "LibriTTS_R-954",
        "content": "Rich old couples, with no one to leave their money to, die childless.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
