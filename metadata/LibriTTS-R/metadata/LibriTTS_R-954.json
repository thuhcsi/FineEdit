        "speaker_id": "LibriTTS_R-954",
        "content": "It does not do to dwell on these things; it makes one so sad.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
