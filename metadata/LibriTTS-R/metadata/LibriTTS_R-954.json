        "speaker_id": "LibriTTS_R-954",
        "content": "It was a country cousin that Harris took in.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
