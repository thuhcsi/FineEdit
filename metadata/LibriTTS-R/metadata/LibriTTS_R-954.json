        "speaker_id": "LibriTTS_R-954",
        "content": "\"Oak,\" he explained.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
