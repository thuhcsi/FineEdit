        "speaker_id": "LibriTTS_R-954",
        "content": "That made Harris mad, and he produced his map, and explained his theory.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
