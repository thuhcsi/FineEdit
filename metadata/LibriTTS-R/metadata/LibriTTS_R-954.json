        "speaker_id": "LibriTTS_R-954",
        "content": "Anyhow, they had got something to start from then.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
