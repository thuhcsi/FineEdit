[
    {
        "item_name": "LibriTTS_R-216_122441_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000004_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "At ten o'clock in the morning the Sieur de la Coste, ensign in the king's Guards, followed by two officers and several archers of that body, came to the city registrar, named Clement, and demanded of him all the keys of the rooms and offices of the hotel.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000004_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "These keys were given up to him instantly.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000006_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "At three o'clock came two companies of the Guards, one French, the other Swiss.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000007_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "As fast as they entered, they were placed in the grand saloon, on the platforms prepared for them.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000008_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "At nine o'clock Madame la Premiere Presidente arrived.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000009_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "At ten o'clock, the king's collation, consisting of preserves and other delicacies, was prepared in the little room on the side of the church of saint Jean, in front of the silver buffet of the city, which was guarded by four archers.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000010_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "At midnight great cries and loud acclamations were heard.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000014_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "Half an hour after the entrance of the king, fresh acclamations were heard; these announced the arrival of the queen.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000014_000002.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "The queen entered the great hall; and it was remarked that, like the king, she looked dull and even weary.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000016_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "All at once the king appeared with the cardinal at one of the doors of the hall.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000016_000002.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "The cardinal was speaking to him in a low voice, and the king was very pale.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000021_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "Everybody looked and listened with astonishment, comprehending nothing of what passed.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000024_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "On his part the king returned to his apartment.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000026_000002.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "This was the costume that best became the king.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000031_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "She wore a beaver hat with blue feathers, a surtout of gray pearl velvet, fastened with diamond clasps, and a petticoat of blue satin, embroidered with silver.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000031_000002.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "On her left shoulder sparkled the diamond studs, on a bow of the same color as the plumes and the petticoat.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000032_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000032_000002.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "The only question was, had she ten or twelve?",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000033_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "At that moment the violins sounded the signal for the ballet.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000034_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "A cold sweat covered the brow of the cardinal.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000039_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "In fact the king counted them, and the twelve studs were all on her Majesty's shoulder.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000040_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "The king called the cardinal.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000042_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "\"This means, sire,\" replied the cardinal, \"that I was desirous of presenting her Majesty with these two studs, and that not daring to offer them myself, I adopted this means of inducing her to accept them.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000047_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000047_000007.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "The opening of this door disclosed a brilliant light, and she disappeared.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000052_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000052_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "D'Artagnan placed the ring on his finger, and again waited; it was evident that all was not yet over.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000052_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000052_000001.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "After the reward of his devotion, that of his love was to come.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000052_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000052_000003.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "Supper was to be served at three, and the clock of saint Jean had struck three quarters past two.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-216_122441_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/216/122441/216_122441_000054_000000.wav",
        "speaker_id": "LibriTTS_R-216",
        "content": "\"You at last?\" cried d'Artagnan.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
