        "speaker_id": "LibriTTS_R-216",
        "content": "\"Then,\" continued he, \"there is a horse for my lackey, and my valise.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
