        "speaker_id": "LibriTTS_R-216",
        "content": "thirty two A PROCURATOR'S DINNER",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
