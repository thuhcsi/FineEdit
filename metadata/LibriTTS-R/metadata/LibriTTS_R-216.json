        "speaker_id": "LibriTTS_R-216",
        "content": "Porthos smiled.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
