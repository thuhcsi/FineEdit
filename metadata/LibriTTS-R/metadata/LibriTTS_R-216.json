        "speaker_id": "LibriTTS_R-216",
        "content": "He looked to see if the dish of beans was still there; the dish of beans had disappeared.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
