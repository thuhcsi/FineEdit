        "speaker_id": "LibriTTS_R-216",
        "content": "The cousin was received with resignation, that was all.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
