        "speaker_id": "LibriTTS_R-6399",
        "content": "You preserve only the first running, which is again to be distilled seventeen times, till what remains will amount to about two drams.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
