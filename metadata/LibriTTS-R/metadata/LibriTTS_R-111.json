        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/111/126265/111_126265_000008_000001.wav",
        "speaker_id": "LibriTTS_R-111",
        "content": "Great granite rocks rise up like giants to dispute our passage, but by numerous twistings the path skirts their base, or wriggles snakelike over the top.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
