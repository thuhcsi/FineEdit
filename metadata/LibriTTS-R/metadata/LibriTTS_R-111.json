        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/111/126277/111_126277_000004_000000.wav",
        "speaker_id": "LibriTTS_R-111",
        "content": "Let me live in a house by the side of the road, And be a friend to man,",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
