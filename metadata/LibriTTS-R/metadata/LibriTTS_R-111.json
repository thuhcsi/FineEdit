        "speaker_id": "LibriTTS_R-111",
        "content": "It is a quaint little place, and might have inspired the poet to write that beautiful poem containing the lines,",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
