        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/111/126277/111_126277_000002_000000.wav",
        "speaker_id": "LibriTTS_R-111",
        "content": "There is an old road that I love to follow.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
