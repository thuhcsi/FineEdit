        "speaker_id": "LibriTTS_R-111",
        "content": "On it comes, sweeping over half submerged rocks, growling in its fury, sublime in its towering majesty, awful in its giant's strength.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-111_126265_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/111/126265/111_126265_000014_000000.wav",
        "speaker_id": "LibriTTS_R-111",
        "content": "Here we venture to a place that seems accessible in order to procure a photograph.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
