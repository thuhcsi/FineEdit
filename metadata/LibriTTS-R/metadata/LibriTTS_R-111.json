        "speaker_id": "LibriTTS_R-111",
        "content": "Its rugged coast, with rocks scattered in wild profusion, is one of the most interesting spots in all the world.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
