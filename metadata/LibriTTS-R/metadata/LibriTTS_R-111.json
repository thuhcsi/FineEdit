        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/111/126265/111_126265_000018_000001.wav",
        "speaker_id": "LibriTTS_R-111",
        "content": "Barnacles cover the top of every rock that the tide reaches, and the long, blackish, snakelike seaweed is strewn along the beach.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-111_126265_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/111/126265/111_126265_000019_000000.wav",
        "speaker_id": "LibriTTS_R-111",
        "content": "We watch the tide come creeping in, each succeeding wave running a little farther up the beach and driving us back with relentless energy from its rightful possessions.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
