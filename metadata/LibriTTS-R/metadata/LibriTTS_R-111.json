        "speaker_id": "LibriTTS_R-111",
        "content": "Then receding like a roaring lion baffled of its prey, it gathers new strength, and flings itself again and again against the rocks, like a gladiator striving for the mastery.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
