        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/111/126265/111_126265_000011_000001.wav",
        "speaker_id": "LibriTTS_R-111",
        "content": "Looking out upon the ocean, we see a wave mightier than all the others sweeping onward, as if challenging the rocks to mortal combat, its mighty curving crest white and seething with foam, hissing like a serpent.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
