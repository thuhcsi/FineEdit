[
    {
        "item_name": "LibriTTS_R-8592_285135_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000014_000001.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "These were known by their coats and pantaloons of black or brown, made to sit comfortably, with white cravats and waistcoats, broad solid looking shoes, and thick hose or gaiters.--They had all slightly bald heads, from which the right ears, long used to pen holding, had an odd habit of standing off on end.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000014_000003.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Theirs was the affectation of respectability;--if indeed there be an affectation so honorable.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000016_000000.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "The gamblers, of whom I descried not a few, were still more easily recognisable.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000016_000002.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Still all were distinguished by a certain sodden swarthiness of complexion, a filmy dimness of eye, and pallor and compression of lip.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000016_000005.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "They seem to prey upon the public in two battalions-that of the dandies and that of the military men.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000016_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000016_000006.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Of the first grade the leading features are long locks and smiles; of the second frogged coats and frowns.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000018_000001.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "All was dark yet splendid-as that ebony to which has been likened the style of Tertullian.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000020_000002.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "I well remember that my first thought, upon beholding it, was that Retzch, had he viewed it, would have greatly preferred it to his own pictural incarnations of the fiend.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000020_000004.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "I felt singularly aroused, startled, fascinated.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000020_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000020_000005.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "\"How wild a history,\" I said to myself, \"is written within that bosom!\" Then came a craving desire to keep the man in view-to know more of him.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000020_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000020_000006.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Hurriedly putting on an overcoat, and seizing my hat and cane, I made my way into the street, and pushed through the crowd in the direction which I had seen him take; for he had already disappeared. With some little difficulty I at length came within sight of him, approached, and followed him closely, yet cautiously, so as not to attract his attention.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000021_000000.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "I had now a good opportunity of examining his person.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000021_000001.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "He was short in stature, very thin, and apparently very feeble.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000022_000000.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "It was now fully night fall, and a thick humid fog hung over the city, soon ending in a settled and heavy rain.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000022_000005.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "For half an hour the old man held his way with difficulty along the great thoroughfare; and I here walked close at his elbow through fear of losing sight of him.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000022_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000022_000007.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "By and bye he passed into a cross street, which, although densely filled with people, was not quite so much thronged as the main one he had quitted.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000022_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000022_000008.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Here a change in his demeanor became evident.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000022_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000022_000011.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "A second turn brought us into a square, brilliantly lighted, and overflowing with life.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000022_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000022_000014.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "He urged his way steadily and perseveringly.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000023_000001.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "The rain fell fast; the air grew cool; and the people were retiring to their homes.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000024_000002.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "At no moment did he see that I watched him.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000026_000003.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "It was the most noisome quarter of London, where every thing wore the worst impress of the most deplorable poverty, and of the most desperate crime.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000026_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000026_000004.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "By the dim light of an accidental lamp, tall, antique, worm eaten, wooden tenements were seen tottering to their fall, in directions so many and capricious that scarce the semblance of a passage was discernible between them. The paving stones lay at random, displaced from their beds by the rankly growing grass.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000026_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000026_000005.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Horrible filth festered in the dammed up gutters. The whole atmosphere teemed with desolation.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000026_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000026_000006.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Yet, as we proceeded, the sounds of human life revived by sure degrees, and at length large bands of the most abandoned of a London populace were seen reeling to and fro. The spirits of the old man again flickered up, as a lamp which is near its death hour.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000026_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000026_000007.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Once more he strode onward with elastic tread.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000027_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000027_000005.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "Long and swiftly he fled, while I followed him in the wildest amazement, resolute not to abandon a scrutiny in which I now felt an interest all absorbing.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8592_285135_000027_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8592/285135/8592_285135_000027_000011.wav",
        "speaker_id": "LibriTTS_R-8592",
        "content": "He refuses to be alone.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    }
]