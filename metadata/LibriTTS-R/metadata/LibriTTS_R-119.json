[
    {
        "item_name": "LibriTTS_R-119_121722_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/121722/119_121722_000000_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Note, Women who have captivated men.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000001_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "CHAPTER one",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000002_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "THE GUN CLUB",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000003_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Simple tradesmen jumped their counters to become extemporized captains, colonels, and generals, without having ever passed the School of Instruction at West Point; nevertheless; they quickly rivaled their compeers of the old continent, and, like them, carried off victories by dint of lavish expenditure in ammunition, money, and men.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000004_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "But the point in which the Americans singularly distanced the Europeans was in the science of gunnery.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000004_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "In point of grazing, plunging, oblique, or enfilading, or point blank firing, the English, French, and Prussians have nothing to learn; but their cannon, howitzers, and mortars are mere pocket pistols compared with the formidable engines of the American artillery.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000005_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "This fact need surprise no one.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000006_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Now when an American has an idea, he directly seeks a second American to share it.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000006_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Given four, they name a keeper of records, and the office is ready for work; five, they convene a general meeting, and the club is fully constituted.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000006_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000006_000004.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "The inventor of a new cannon associated himself with the caster and the borer.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000006_000005.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Thus was formed the nucleus of the \"Gun Club.\" In a single month after its formation it numbered one thousand eight hundred thirty three effective members and thirty thousand five hundred sixty five corresponding members.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000009_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "The Gun Club once founded, it is easy to conceive the result of the inventive genius of the Americans.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000009_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Their military weapons attained colossal proportions, and their projectiles, exceeding the prescribed limits, unfortunately occasionally cut in two some unoffending pedestrians.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000013_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Some few of the more advanced and inveterate theorists set themselves again to work upon calculations regarding the laws of projectiles.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000013_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "They reverted invariably to gigantic shells and howitzers of unparalleled caliber.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000014_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"This is horrible!\" said Tom Hunter one evening, while rapidly carbonizing his wooden legs in the fireplace of the smoking room; \"nothing to do! nothing to look forward to!",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000014_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "When again shall the guns arouse us in the morning with their delightful reports?\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000015_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"It was delightful once upon a time! One invented a gun, and hardly was it cast, when one hastened to try it in the face of the enemy!",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000015_000003.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "But now the generals are gone back to their counters; and in place of projectiles, they despatch bales of cotton.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000018_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Fact!\" replied he.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000018_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Still, what is the use of so many studies worked out, so many difficulties vanquished?",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000018_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "It's mere waste of time!",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000020_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Well?\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000025_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"And why not?\" demanded the colonel.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000026_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Because their ideas of progress in the Old World are contrary to our American habits of thought.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000031_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Undoubtedly,\" replied Tom Hunter, stamping his crutch with fury.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000035_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Bah!\" growled Bilsby between the four teeth which the war had left him; \"that will never do!\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000036_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"By Jove!\" cried j t Maston, \"he mustn't count on my vote at the next election!\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000039_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"In that case we will accompany you,\" cried the others.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000040_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Matters were in this unfortunate condition, and the club was threatened with approaching dissolution, when an unexpected circumstance occurred to prevent so deplorable a catastrophe.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000041_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "On the morrow after this conversation every member of the association received a sealed circular couched in the following terms:",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129513_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129513/119_129513_000042_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "BALTIMORE, october third. The president of the Gun Club has the honor to inform his colleagues that, at the meeting of the fifth instant, he will bring before them a communication of an extremely interesting nature.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000001_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "CHAPTER two",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000002_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "PRESIDENT BARBICANE'S COMMUNICATION",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000003_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "They overflowed into the adjoining rooms, down the narrow passages, into the outer courtyards.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000003_000003.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "There they ran against the vulgar herd who pressed up to the doors, each struggling to reach the front ranks, all eager to learn the nature of the important communication of President Barbicane; all pushing, squeezing, crushing with that perfect freedom of action which is so peculiar to the masses when educated in ideas of \"self government.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000004_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "On that evening a stranger who might have chanced to be in Baltimore could not have gained admission for love or money into the great hall.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000004_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "That was reserved exclusively for resident or corresponding members; no one else could possibly have obtained a place; and the city magnates, municipal councilors, and \"select men\" were compelled to mingle with the mere townspeople in order to catch stray bits of news from the interior.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000005_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Nevertheless the vast hall presented a curious spectacle. Its immense area was singularly adapted to the purpose. Lofty pillars formed of cannon, superposed upon huge mortars as a base, supported the fine ironwork of the arches, a perfect piece of cast iron lacework.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000005_000003.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Models of cannon, bronze castings, sights covered with dents, plates battered by the shots of the Gun Club, assortments of rammers and sponges, chaplets of shells, wreaths of projectiles, garlands of howitzers- in short, all the apparatus of the artillerist, enchanted the eye by this wonderful arrangement and induced a kind of belief that their real purpose was ornamental rather than deadly.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000006_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "At the further end of the saloon the president, assisted by four secretaries, occupied a large platform.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000006_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "His chair, supported by a carved gun carriage, was modeled upon the ponderous proportions of a thirty two-inch mortar.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000006_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "It was pointed at an angle of ninety degrees, and suspended upon truncheons, so that the president could balance himself upon it as upon a rocking chair, a very agreeable fact in the very hot weather.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000009_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Bold in his conceptions, he contributed powerfully to the progress of that arm and gave an immense impetus to experimental researches.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000014_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "The meeting felt that the president was now approaching the critical point, and redoubled their attention accordingly.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000015_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"For some months past, my brave colleagues,\" continued Barbicane, \"I have been asking myself whether, while confining ourselves to our own particular objects, we could not enter upon some grand experiment worthy of the nineteenth century; and whether the progress of artillery science would not enable us to carry it out to a successful issue.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000016_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "A thrill of excitement ran through the meeting.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000018_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"There is no one among you, my brave colleagues, who has not seen the Moon, or, at least, heard speak of it.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000019_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Three cheers for the Moon!\" roared the Gun Club, with one voice.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000020_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Selenographic charts have been constructed with a perfection which equals, if it does not even surpass, that of our terrestrial maps.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000020_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Photography has given us proofs of the incomparable beauty of our satellite; all is known regarding the moon which mathematical science, astronomy, geology, and optics can learn about her.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000020_000003.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "But up to the present moment no direct communication has been established with her.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000022_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Permit me,\" he continued, \"to recount to you briefly how certain ardent spirits, starting on imaginary journeys, have penetrated the secrets of our satellite.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000022_000005.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "He then distinctly perceived caverns frequented by hippopotami, green mountains bordered by golden lace work, sheep with horns of ivory, a white species of deer and inhabitants with membranous wings, like bats.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000022_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000022_000008.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "This journey, like all previous ones, was purely imaginary; still, it was the work of a popular American author- I mean Edgar Poe!\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000023_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"Cheers for Edgar Poe!\" roared the assemblage, electrified by their president's words.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000024_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"I have now enumerated,\" said Barbicane, \"the experiments which I call purely paper ones, and wholly insufficient to establish serious relations with the Queen of the Night.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000024_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Nevertheless, I am bound to add that some practical geniuses have attempted to establish actual communication with her.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000024_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "Thus, a few days ago, a German geometrician proposed to send a scientific expedition to the steppes of Siberia.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000024_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000024_000006.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "It is reserved for the practical genius of Americans to establish a communication with the sidereal world.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000024_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000024_000007.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "The means of arriving thither are simple, easy, certain, infallible- and that is the purpose of my present proposal.\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000025_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "There was not a single person in the whole audience who was not overcome, carried away, lifted out of himself by the speaker's words!",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000027_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "As soon as the excitement had partially subsided, Barbicane resumed his speech in a somewhat graver voice.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000029_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "At these words a murmur of amazement escaped from a thousand panting chests; then succeeded a moment of perfect silence, resembling that profound stillness which precedes the bursting of a thunderstorm.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000029_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "In point of fact, a thunderstorm did peal forth, but it was the thunder of applause, or cries, and of uproar which made the very hall tremble.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000029_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "The president attempted to speak, but could not.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000029_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000029_000003.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "It was fully ten minutes before he could make himself heard.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129514_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129514/119_129514_000030_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "\"I have looked at the question in all its bearings, I have resolutely attacked it, and by incontrovertible calculations I find that a projectile endowed with an initial velocity of twelve thousand yards per second, and aimed at the moon, must necessarily reach it.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129515_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129515/119_129515_000001_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "CHAPTER three",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129515_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129515/119_129515_000002_000000.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "EFFECT OF THE PRESIDENT'S COMMUNICATION",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-119_129515_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129515/119_129515_000003_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "It was a scene of indescribable confusion and uproar.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-119_129515_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129515/119_129515_000005_000002.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "People have evidently been deceived by the dictionary.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129515_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129515/119_129515_000005_000003.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "In America, all is easy, all is simple; and as for mechanical difficulties, they are overcome before they arise.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-119_129515_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/119/129515/119_129515_000007_000001.wav",
        "speaker_id": "LibriTTS_R-119",
        "content": "The Yankees all turned their gaze toward her resplendent orb, kissed their hands, called her by all kinds of endearing names.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
