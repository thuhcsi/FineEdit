        "speaker_id": "LibriTTS_R-587",
        "content": "She felt a positive contempt for herself that his presence should affect her as it did; she dared not look at him lest her heart should flutter to her eyes.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
