        "speaker_id": "LibriTTS_R-587",
        "content": "As she turned in at the gate, he held out his hand to ruth.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
