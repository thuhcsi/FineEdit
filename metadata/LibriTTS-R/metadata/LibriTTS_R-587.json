        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/54108/587_54108_000035_000005.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "What was she to him anyway but a girl with whom he could flirt in his idle moments?",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
