        "speaker_id": "LibriTTS_R-587",
        "content": "She turned white and half started toward Grace, then stopped, and, turning her back upon the Phi Sigma Tau, began talking to Edna Wright.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
