        "speaker_id": "LibriTTS_R-587",
        "content": "She held them lightly in place on her shoulder.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-587_54108_000043_000000",
