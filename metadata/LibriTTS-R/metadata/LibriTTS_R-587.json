        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/54108/587_54108_000037_000000.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "\"Hadn't you better put something over your shoulders?\" he asked deferentially as she appeared.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-587_54108_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/54108/587_54108_000038_000000.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "\"And disgust the night with lack of appreciation?\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
