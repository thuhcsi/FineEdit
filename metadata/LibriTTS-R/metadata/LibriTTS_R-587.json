        "speaker_id": "LibriTTS_R-587",
        "content": "Probably the display amused him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
