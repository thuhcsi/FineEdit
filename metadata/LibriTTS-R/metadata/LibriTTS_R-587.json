        "speaker_id": "LibriTTS_R-587",
        "content": "\"It must be time to sight home now,\" said her mother; \"I am quite chilly.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
