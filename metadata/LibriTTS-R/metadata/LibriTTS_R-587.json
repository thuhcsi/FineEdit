        "speaker_id": "LibriTTS_R-587",
        "content": "mrs Levice was, without doubt, awake.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-587_54108_000077_000000",
