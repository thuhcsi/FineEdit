        "speaker_id": "LibriTTS_R-587",
        "content": "She kept before them till they reached the gate, and stood inside of it as they drew near.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
