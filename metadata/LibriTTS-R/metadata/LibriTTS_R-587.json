        "speaker_id": "LibriTTS_R-587",
        "content": "ruth went straight to the little boat aground on the shore.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-587_54108_000049_000000",
