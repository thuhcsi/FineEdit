        "speaker_id": "LibriTTS_R-587",
        "content": "Grace laughed in spite of herself at Nora's remark, but regretted it the next moment, for Eleanor saw the glances directed toward her and heard Nora's giggle.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
