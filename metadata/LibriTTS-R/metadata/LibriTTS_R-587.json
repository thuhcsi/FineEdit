        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/41619/587_41619_000028_000001.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "\"What do you suppose she's up to now?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
