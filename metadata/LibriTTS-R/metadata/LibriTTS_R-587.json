        "speaker_id": "LibriTTS_R-587",
        "content": "\"There is nothing abroad here but the stars,\" she answered, flitting before them.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
