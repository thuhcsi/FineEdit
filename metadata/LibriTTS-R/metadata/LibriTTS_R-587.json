        "speaker_id": "LibriTTS_R-587",
        "content": "Besides, Miss Pierson is too short.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-587_41619_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/41619/587_41619_000036_000000.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "\"What you say about appearance is quite true, Miss Savell,\" replied Miss Tebbs frankly.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
