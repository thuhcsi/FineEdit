        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/54108/587_54108_000048_000000.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "\"Others are enjoying themselves also,\" he remarked as their feet touched the pebbly beach.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
