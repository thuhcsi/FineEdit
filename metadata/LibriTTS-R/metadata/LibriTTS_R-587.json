        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/54108/587_54108_000081_000000.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "\"Wait for us, ruth,\" called mrs Levice, and the slight white figure stood still till they came up.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-587_54108_000082_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/587/54108/587_54108_000082_000000.wav",
        "speaker_id": "LibriTTS_R-587",
        "content": "\"You are so slow,\" she said with a reckless little laugh; \"I feel as if I could fly home.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
