        "speaker_id": "LibriTTS_R-587",
        "content": "\"And they are stanch, silent friends on such a night,\" remarked Kemp, softly.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
