        "speaker_id": "LibriTTS_R-587",
        "content": "She could not yet meet his eyes again.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
