        "speaker_id": "LibriTTS_R-7555",
        "content": "Where do you come from, and what do you want?'",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000071_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000071_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'We are twins, two shoots from one stem, which has been broken, and half lies in the ground and half sits at the head of this table.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
