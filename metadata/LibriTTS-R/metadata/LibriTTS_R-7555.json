[
    {
        "item_name": "LibriTTS_R-7555_101283_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "Well, once upon a time there lived an emperor who had half a world all to himself to rule over, and in this world dwelt an old herd and his wife and their three daughters, Anna, Stana, and Laptitza.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'And if I,' said Stana, 'should be the one chosen, I would weave my husband a shirt which will keep him unscathed when he fights with dragons; when he goes through water he will never even be wet; or if through fire, it will not scorch him.'",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'And I will have you,' 'And I you,' exclaimed two of his friends, and they all rode back to the palace together.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000015_000002.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "And then more days and nights passed, and this rumour was succeeded by another one-that Stana had procured some flax, and had dried it, and combed it, and spun it into linen, and sewed it herself into the shirt of which she had spoken over the strawberry beds.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000016_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "Now the emperor had a stepmother, and she had a daughter by her first husband, who lived with her in the palace.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "The girl's mother had always believed that her daughter would be empress, and not the 'Milkwhite Maiden,' the child of a mere shepherd.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "At last, when everything else had failed, she managed to make her brother, who was king of the neighbouring country, declare war against the emperor, and besiege some of the frontier towns with a large army. This time her scheme was successful.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000020_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "No words were needed; he saw with his own eyes that Laptitza had not kept the promise she had made at the strawberry beds, and, though it nearly broke his heart, he must give orders for her punishment.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000022_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "Not many days after, the stepmother's wish was fulfilled.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000024_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "In the place where they had been buried there sprang up two beautiful young aspens, and the stepmother, who hated the sight of the trees, which reminded her of her crime, gave orders that they should be uprooted.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000025_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "In each day they added a year's growth, and each night they added a year's growth, and at dawn, when the stars faded out of the sky, they grew three years' growth in the twinkling of an eye, and their boughs swept across the palace windows.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000026_000002.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "What craft will not do soft words may attain, and if these do not succeed there still remains the resource of tears.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000028_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "It was some time before the bait took, but at length-even emperors are only men!",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000029_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'Well, well,' he said at last, 'have your way and cut down the trees; but out of one they shall make a bed for me, and out of the other, one for you!'",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000030_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "And with this the empress was forced to be content.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000032_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "When the emperor was fast asleep, the bed began to crack loudly, and to the empress each crack had a meaning.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000033_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'Is it too heavy for you, little brother?' asked one of the beds.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000037_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "By daybreak the empress had determined how to get rid of the beds.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000037_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "She would have two others made exactly like them, and when the emperor had gone hunting they should be placed in his room.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000037_000002.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "This was done and the aspen beds were burnt in a large fire, till only a little heap of ashes was left.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000040_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "But she had not seen that where the fire burnt brightest two sparks flew up, and, after floating in the air for a few moments, fell down into the great river that flows through the heart of the country.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000043_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'But what are we to do with you?' asked the fisherman.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000046_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "And when he came back, what do you think he saw?",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000047_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "The boys grew fast.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000047_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "In every day they grew a year's growth, and in every night another year's growth, but at dawn, when the stars were fading, they grew three years' growth in the twinkling of an eye.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000047_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000047_000002.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "And they grew in other things besides height, too.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000047_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000047_000003.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "Thrice in age, and thrice in wisdom, and thrice in knowledge.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000047_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000047_000004.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "And when three days and three nights had passed they were twelve years in age, twenty four in strength, and thirty six in wisdom.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000049_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000049_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'We wish to speak with the emperor,' said one of the boys.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000050_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'You must wait until he has finished his dinner,' replied the porter.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000051_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'No, while he is eating it,' said the second boy, stepping across the threshold.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000053_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'We desire to enter,' said one of the princes sharply to a servant who stood near the door.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000054_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'That is quite impossible,' replied the servant.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000060_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000060_000002.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "What boys are they?' said the emperor all in one breath.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000062_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000062_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "The emperor, as he listened, grew red with anger.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000063_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000063_000001.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'Set the dogs after them.'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000065_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000065_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'The emperor commands you to return,' panted he: 'the empress wishes to see you.'",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7555_101283_000068_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7555/101283/7555_101283_000068_000000.wav",
        "speaker_id": "LibriTTS_R-7555",
        "content": "'Take off your caps,' said one of the courtiers.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
