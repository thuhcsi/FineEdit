        "speaker_id": "LibriTTS_R-1827",
        "content": "seven",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000051_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "eight",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000054_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Give me by all means the shorter and nobler life, instead of one that is longer but of less account!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
