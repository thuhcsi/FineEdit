[
    {
        "item_name": "LibriTTS_R-1827_143625_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "When a man prides himself on being able to understand and interpret the writings of Chrysippus, say to yourself:--",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "If Chrysippus had not written obscurely, this fellow would have had nothing to be proud of.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "But what is it that I desire?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "To understand Nature, and to follow her!",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000003.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Accordingly I ask who is the Interpreter. On hearing that it is Chrysippus, I go to him.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000004.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "But it seems I do not understand what he wrote.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000005.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "So I seek one to interpret that.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000006.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "So far there is nothing to pride myself on.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000008.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "This itself is the only thing to be proud of.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000009.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "But if I admire the interpretation and that alone, what else have I turned out but a mere commentator instead of a lover of wisdom?--except indeed that I happen to be interpreting Chrysippus instead of Homer.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000002_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000002_000010.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "So when any one says to me, Prithee, read me Chrysippus, I am more inclined to blush, when I cannot show my deeds to be in harmony and accordance with his sayings.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "At feasts, remember that you are entertaining two guests, body and soul. What you give to the body, you presently lose; what you give to the soul, you keep for ever.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "At meals, see to it that those who serve be not more in number than those who are served.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "It is absurd for a crowd of persons to be dancing attendance on half a dozen chairs.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "It is best to share with your attendants what is going forward, both in the labour of preparation and in the enjoyment of the feast itself.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000008_000002.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Thus no sudden wrath will betray you into unreasonable conduct, nor will you behave harshly by irritating another.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "When Xanthippe was chiding Socrates for making scanty preparation for entertaining his friends, he answered:--\"If they are friends of ours they will not care for that; if they are not, we shall care nothing for them!\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Asked, Who is the rich man?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000012_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Epictetus replied, \"He who is content.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000016_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "On all occasions these thoughts should be at hand:--",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Lead me, O God, and Thou, O Destiny Be what it may the goal appointed me, Bravely I'll follow; nay, and if I would not, I'd prove a coward, yet must follow still!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Again:",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Who to Necessity doth bow aright, Is learn'd in wisdom and the things of God.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Once more:--",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Crito, if this be God's will, so let it be.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000021_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "As for me, Anytus and Meletus can indeed put me to death, but injure me, never!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000023_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "We shall then be like Socrates, when we can indite hymns of praise to the Gods in prison.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000025_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "It is hard to combine and unite these two qualities, the carefulness of one who is affected by circumstances, and the intrepidity of one who heeds them not.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000025_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "But it is not impossible: else were happiness also impossible.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000025_000002.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "We should act as we do in seafaring.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000026_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "\"What can I do?\"--Choose the master, the crew, the day, the opportunity. Then comes a sudden storm.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000026_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "What matters it to me?",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000026_000002.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "my part has been fully done.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000026_000003.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "The matter is in the hands of another-the Master of the ship. The ship is foundering.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000026_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000026_000004.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "What then have I to do?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000026_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000026_000005.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "I do the only thing that remains to me-to be drowned without fear, without a cry, without upbraiding God, but knowing that what has been born must likewise perish.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000026_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000026_000006.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "For I am not Eternity, but a human being-a part of the whole, as an hour is part of the day.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000029_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Diogenes, who was sent as a spy long before you, brought us back another report than this.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000029_000002.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "He says that Death is no evil; for it need not even bring shame with it.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000029_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000029_000003.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "He says that Fame is but the empty noise of madmen.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000029_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000029_000005.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "That to be clothed in sackcloth is better than any purple robe; that sleeping on the bare ground is the softest couch; and in proof of each assertion he points to his own courage, constancy, and freedom; to his own healthy and muscular frame.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000029_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000029_000006.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "\"There is no enemy near,\" he cries, \"all is perfect peace!\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000031_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Another supplies my food, whose care it is; another my raiment; another hath given me perceptions of sense and primary conceptions.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000031_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000031_000005.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "With thoughts like these, beholding the Sun, Moon, and Stars, enjoying earth and sea, a man is neither helpless nor alone!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000033_000001.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "If I might choose, I would be found doing some deed of true humanity, of wide import, beneficent and noble.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000034_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "If death surprise me thus employed, it is enough if I can stretch forth my hands to God and say, \"The faculties which I received at Thy hands for apprehending this thine Administration, I have not neglected.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000034_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000034_000002.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Behold how I have used the senses, the primary conceptions which Thous gavest me.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000034_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000034_000003.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Have I ever laid anything to Thy charge?",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000034_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000034_000004.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Have I ever murmured at aught that came to pass, or wished it otherwise?",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000034_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000034_000005.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Have I in anything transgressed the relations of life?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000034_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000034_000007.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Take them back and place them wherever Thou wilt!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000034_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000034_000009.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "What life is fairer and more noble, what end happier than his?",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000035_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "(APPENDIX A)",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000036_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Fragments Attributed to Epictetus",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000038_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "A life entangled with Fortune is like a torrent.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000040_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "The soul that companies with Virtue is like an ever flowing source.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000041_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "three",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000042_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "It is a shame that one who sweetens his drink with the gifts of the bee, should embitter God's gift Reason with vice.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1827_143625_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000046_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Keep neither a blunt knife nor an ill disciplined looseness of tongue.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
