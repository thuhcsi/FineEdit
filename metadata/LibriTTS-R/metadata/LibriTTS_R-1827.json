        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1827/143625/1827_143625_000056_000000.wav",
        "speaker_id": "LibriTTS_R-1827",
        "content": "Freedom is the name of virtue: Slavery, of vice. . . .",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
