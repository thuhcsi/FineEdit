        "speaker_id": "LibriTTS_R-8778",
        "content": "\"Here follow pages of his wanderings in quest of God.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8778_246983_000018_000001",
