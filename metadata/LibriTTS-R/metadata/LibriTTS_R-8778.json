        "speaker_id": "LibriTTS_R-8778",
        "content": "\"'About this time I had another strange vision, whether in the body or out of the body, I cannot tell.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
