        "speaker_id": "LibriTTS_R-8778",
        "content": "Only you can't think how tired I often am of it.\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
