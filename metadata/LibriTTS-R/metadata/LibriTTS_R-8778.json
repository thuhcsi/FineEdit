        "speaker_id": "LibriTTS_R-8778",
        "content": "I marvel that I have heard of no one taking up and advocating the view.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
