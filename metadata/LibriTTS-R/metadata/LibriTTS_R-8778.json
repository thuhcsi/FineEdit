        "speaker_id": "LibriTTS_R-8778",
        "content": "But she found no one in the closet.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
