        "speaker_id": "LibriTTS_R-8778",
        "content": "Happily nothing had been done to introduce the confusing element of another will.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
