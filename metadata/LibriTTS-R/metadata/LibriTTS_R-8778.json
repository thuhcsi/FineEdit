        "speaker_id": "LibriTTS_R-8778",
        "content": "\"Every word of such a good man is precious: tell me, please.\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
