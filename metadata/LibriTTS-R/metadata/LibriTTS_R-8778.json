        "speaker_id": "LibriTTS_R-8778",
        "content": "We can't be all to any one person.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
