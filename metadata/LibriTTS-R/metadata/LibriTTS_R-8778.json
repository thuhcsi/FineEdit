        "speaker_id": "LibriTTS_R-8778",
        "content": "Every day after this, so long as the weather continued warm, it was Leopold's desire to be carried out to the meadow.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
