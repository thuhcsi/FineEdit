        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8778/246983/8778_246983_000020_000019.wav",
        "speaker_id": "LibriTTS_R-8778",
        "content": "And I followed my Lord.'\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
