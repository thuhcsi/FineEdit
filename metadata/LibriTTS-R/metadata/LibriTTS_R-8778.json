        "speaker_id": "LibriTTS_R-8778",
        "content": "\"I know one to whom the thought would not have been a new one,\" said Polwarth.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
