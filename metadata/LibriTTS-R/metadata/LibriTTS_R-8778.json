        "speaker_id": "LibriTTS_R-8778",
        "content": "At length Rachel rose softly, wiping the tears from her eyes, and left the room.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
