        "speaker_id": "LibriTTS_R-8778",
        "content": "\"I made a copy of it,--partly for security, partly that I might thoroughly enter into my brother's thoughts.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
