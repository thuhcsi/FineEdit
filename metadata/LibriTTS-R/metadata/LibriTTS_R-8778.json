        "speaker_id": "LibriTTS_R-8778",
        "content": "With that my soul would have fainted in me, had I not spread forth my wings and rushed aloft to find him.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
