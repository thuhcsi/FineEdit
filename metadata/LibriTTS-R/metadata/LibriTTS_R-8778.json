        "speaker_id": "LibriTTS_R-8778",
        "content": "No God! no Love!",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8778_246983_000017_000000",
