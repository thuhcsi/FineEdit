        "speaker_id": "LibriTTS_R-8778",
        "content": "THE CURATE'S RESOLVE.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
