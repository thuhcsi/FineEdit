        "speaker_id": "LibriTTS_R-8778",
        "content": "It had been left altogether with himself.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8778_246984_000007_000000",
