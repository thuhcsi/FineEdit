        "speaker_id": "LibriTTS_R-8778",
        "content": "That is his Godness, you know.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
