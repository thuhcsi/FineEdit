        "speaker_id": "LibriTTS_R-8778",
        "content": "The tears rose in Leopold's eyes.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8778_246974_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8778/246974/8778_246974_000016_000001.wav",
        "speaker_id": "LibriTTS_R-8778",
        "content": "Rachel lifted her baby hand, and stroked the dusky, long fingered one that lay upon the arm of the chair.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
