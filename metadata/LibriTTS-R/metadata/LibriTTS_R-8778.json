        "speaker_id": "LibriTTS_R-8778",
        "content": "\"But God knows about us all the same, and he don't limit his goodness to us by our knowledge of him.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
