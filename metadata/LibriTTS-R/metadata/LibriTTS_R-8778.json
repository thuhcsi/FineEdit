        "speaker_id": "LibriTTS_R-8778",
        "content": "The gate keeper was silent, and so were they all.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
