        "speaker_id": "LibriTTS_R-8778",
        "content": "But I fancy it's a sign that we come of God that we don't like it.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
