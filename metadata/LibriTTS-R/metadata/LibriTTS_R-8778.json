        "speaker_id": "LibriTTS_R-8778",
        "content": "The next day was Sunday.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
