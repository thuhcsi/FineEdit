        "speaker_id": "LibriTTS_R-8778",
        "content": "How gladly I would help you, mr Lingard, and I can do nothing for you.--I'm afraid your beautiful sister thinks me very forward.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
