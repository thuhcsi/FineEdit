        "speaker_id": "LibriTTS_R-8778",
        "content": "I leave all that for your own reading, mr Wingfold.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
