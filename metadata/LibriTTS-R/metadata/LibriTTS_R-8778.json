        "speaker_id": "LibriTTS_R-8778",
        "content": "I read very slowly and pick up all the crumbs.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
