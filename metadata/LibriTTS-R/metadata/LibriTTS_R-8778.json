        "speaker_id": "LibriTTS_R-8778",
        "content": "\"Not yet.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
