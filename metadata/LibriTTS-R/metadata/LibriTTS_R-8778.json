        "speaker_id": "LibriTTS_R-8778",
        "content": "I doubt if anybody knows as much as he does,\" she returned, very seriously.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8778_246974_000024_000002",
