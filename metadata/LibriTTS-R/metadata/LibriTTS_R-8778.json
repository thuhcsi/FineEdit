        "speaker_id": "LibriTTS_R-8778",
        "content": "And now this Sunday, Wingfold entered the pulpit prepared at last to utter his resolve.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
