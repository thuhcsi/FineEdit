        "speaker_id": "LibriTTS_R-8778",
        "content": "\"Have you not come upon a passage in my brother's manuscript involving the very idea?\"",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
