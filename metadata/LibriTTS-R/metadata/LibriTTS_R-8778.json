        "speaker_id": "LibriTTS_R-8778",
        "content": "It came of wanting to tell you I can't be sorry you are going when I should so dearly like to go myself.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
