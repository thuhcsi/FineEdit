        "speaker_id": "LibriTTS_R-8778",
        "content": "But I do not see the logic of it.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8778_246983_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8778/246983/8778_246983_000002_000002.wav",
        "speaker_id": "LibriTTS_R-8778",
        "content": "If we are here without God, why may we not go on there without God?",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
