[
    {
        "item_name": "LibriTTS_R-1347_135885_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "The Story of the Second old Man and the Two Black Dogs.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "Great prince of genies, you must know that we are three brothers, the two black dogs and myself.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "Our father, when he died, left each of us one thousand sequins.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "With that sum, we all became merchants.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000002_000004.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "With this view, he sold his estate, and bought goods suited to the trade intended to follow.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "I immediately shut up my shop, and taking him to a bath, gave him the best clothes I had.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "Finding on examining my books, that I had doubled my stock, that is to say, that I was worth two thousand sequins, I gave him one half; \"With that,\" said I, \"brother, you may make up your loss.\" He joyfully accepted the present, and having repaired his fortunes, we lived together, as before.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "Some time after, my second brother, who is the other of these two dogs, would also sell his estate.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "His elder brother and myself did all we could to divert him from his purpose, but without effect.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000005_000002.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "He disposed of it, and with the money bought such goods as were suitable to the trade which he designed to follow.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000005_000003.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "He joined a caravan, and departed.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "At the end of the year he returned in the same condition as my other brother.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000005_000005.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "Having myself by this time gained another thousand sequins, I made him a present of them.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "When, however, the time arrived that we were to make preparations for our voyage, to buy the goods necessary to the undertaking, I found they had spent all, and had not one dirrim left of the thousand sequins I had given to each of them.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "With the produce we bought commodities of that country, to carry back with us for sale.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "When we were ready to embark on our return, I met on the sea shore a lady, handsome enough, but poorly clad.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000008_000002.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "I ordered proper apparel to be made for her; and after having married her, according to form, I took her on board, and we set sail.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000008_000003.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "I found my wife possessed so many good qualities, that my love to her every day increased.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000008_000004.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "In the mean time my two brothers, who had not managed their affairs as successfully as I had mine, envied my prosperity; and suffered their feelings to carry them so far, that they conspired against my life; and one night, when my wife and I were asleep, threw us both into the sea.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "I had scarcely fallen into the water, when she took me up, and carried me to an island.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "I descended, opened the doors, and dug up the three thousand sequins I had formerly secreted.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000011_000002.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "I went afterwards to my shop, which I also opened; and was complimented by the merchants, my neighbours, upon my return.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000011_000003.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "When I went back to my house, I perceived there two black dogs, which came up to me in a very submissive manner: I could not divine the meaning of this circumstance, which greatly astonished me.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000011_000004.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "But the fairy, who immediately appeared, said, \"Husband, be not surprised to see these dogs, they are your brothers.\" I was troubled at this declaration, and asked her by what power they were so transformed.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000011_000005.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "\"I did it,\" said she, \"or at least authorised one of my sisters to do it, who at the same time sunk their ship.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000011_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000011_000006.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "You have lost the goods you had on board, but I will compensate you another way.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000011_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000011_000007.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "As to your two brothers, I have condemned them to remain five years in that shape.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000012_000000.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "The five years being now nearly expired, I am travelling in quest of her; and as I passed this way, I met this merchant, and the good old man who led the hind, and sat down by them.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "\"I own it is,\" replied the genie, \"and on that account I remit the merchant the second third of the crime which he has committed against me.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "The genie made him the same promise as he had given the others.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1347_135885_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/135885/1347_135885_000015_000001.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "They rejoiced to see him out of danger; and bidding him adieu, each of them proceeded on his way.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1347_164338_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/164338/1347_164338_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "I wanted to oblige him; I did not wish him to think me a coward; I was filled with curiosity; and it was too late for me to draw back, even had I determined to do so.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1347_164338_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/164338/1347_164338_000005_000005.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "That I had not had these scruples sooner was because my curiosity had quite got the better of me.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1347_164338_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1347/164338/1347_164338_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1347",
        "content": "We returned along the gallery.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    }
]