        "speaker_id": "LibriTTS_R-8347",
        "content": "A Wolf, lurking near the Shepherd's hut, saw the Shepherd and his family feasting on a roasted lamb.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
