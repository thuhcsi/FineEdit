        "speaker_id": "LibriTTS_R-8347",
        "content": "Then he picked up a stone and threw it, breaking the Goat's horn.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8347_282412_000008_000000",
