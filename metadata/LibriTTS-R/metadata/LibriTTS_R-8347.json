        "speaker_id": "LibriTTS_R-8347",
        "content": "When the Miser discovered his loss, he was overcome with grief and despair.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
