        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8347/282412/8347_282412_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8347",
        "content": "A Goat strayed away from the flock, tempted by a patch of clover. The Goatherd tried to call it back, but in vain.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
