        "speaker_id": "LibriTTS_R-8347",
        "content": "And men also relate the tale of",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8347_258283_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8347/258283/8347_258283_000007_000005.wav",
        "speaker_id": "LibriTTS_R-8347",
        "content": "The merchant uncovered her face, whereupon the place was illumined by her beauty and her seven tresses hung down to her anklets like horses' tails.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8347_258283_000007_000006",
