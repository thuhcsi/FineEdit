        "speaker_id": "LibriTTS_R-8347",
        "content": "\"Aha!\" he muttered.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
