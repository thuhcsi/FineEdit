        "speaker_id": "LibriTTS_R-8347",
        "content": "When it was the Seven Hundred and Thirty eighth Night,",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
