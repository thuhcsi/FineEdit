        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8347/258283/8347_258283_000003_000008.wav",
        "speaker_id": "LibriTTS_R-8347",
        "content": "The like of thee should not rise to the like of me, for I am the least of servants' slaves.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
