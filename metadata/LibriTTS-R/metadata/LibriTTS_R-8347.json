        "speaker_id": "LibriTTS_R-8347",
        "content": "Then he went in to the Princess and embraced her; and she kissed his hands and they wept in the standing place of parting.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
