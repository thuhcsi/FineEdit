        "speaker_id": "LibriTTS_R-8347",
        "content": "O my gold!\" cried the Miser, wildly, \"someone has robbed me!\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
