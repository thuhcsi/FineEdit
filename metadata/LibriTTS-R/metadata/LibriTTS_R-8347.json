        "speaker_id": "LibriTTS_R-8347",
        "content": "He groaned and cried and tore his hair.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
