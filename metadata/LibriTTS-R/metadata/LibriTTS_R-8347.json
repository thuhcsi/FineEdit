        "speaker_id": "LibriTTS_R-8347",
        "content": "When it was the Seven Hundred and Thirty seventh Night,",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
