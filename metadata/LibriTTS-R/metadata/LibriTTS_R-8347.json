        "speaker_id": "LibriTTS_R-8347",
        "content": "It would not obey him.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
