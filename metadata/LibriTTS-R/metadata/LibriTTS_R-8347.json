        "speaker_id": "LibriTTS_R-8347",
        "content": "Why did you not keep it in the house where you could easily get it when you had to buy things?\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
