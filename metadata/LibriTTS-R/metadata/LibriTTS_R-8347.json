        "speaker_id": "LibriTTS_R-8347",
        "content": "\"Your gold!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
