        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8347/258283/8347_258283_000003_000002.wav",
        "speaker_id": "LibriTTS_R-8347",
        "content": "So, if he send to her to consult her, let her make no opposition; for I will not return to my country without her.\" Then the handmaid returned to Hayat al Nufus; and, kissing her hands, delivered to her the message, which when she heard, she wept for very joy and returned thanks to Almighty Allah.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
