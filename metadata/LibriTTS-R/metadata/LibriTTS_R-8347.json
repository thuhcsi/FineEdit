        "speaker_id": "LibriTTS_R-8347",
        "content": "THE GOATHERD AND THE GOAT",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
