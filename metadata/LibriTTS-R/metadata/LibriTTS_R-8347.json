        "speaker_id": "LibriTTS_R-8347",
        "content": "A passerby heard his cries and asked what had happened.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
