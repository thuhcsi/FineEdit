        "speaker_id": "LibriTTS_R-8347",
        "content": "She carried with her all her waiting women and eunuchs, as well as the nurse, who had returned, after her flight, and resumed her office.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
