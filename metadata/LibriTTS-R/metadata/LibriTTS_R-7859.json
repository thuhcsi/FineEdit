[
    {
        "item_name": "LibriTTS_R-7859_102518_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102518/7859_102518_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The Persian replied with the threat that he would put the Prophet in chains when he had leisure.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102518_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102518/7859_102518_000010_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The romans drove the enemy back to the very gates of their camp, but a last charge, headed by the fierce warrior Khaled, broke their firm array when a victory seemed almost assured.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102518_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102518/7859_102518_000011_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Most of its population were massacred.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102518_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102518/7859_102518_000011_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "He could do nothing; Emesa and Heliopolis were sacked before his eyes, and after an inglorious campaign he hurried to Jerusalem, took the \"True Cross\" from its sanctuary, where he had replaced it in triumph five years before, and retired to Constantinople.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102518_000018_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102518/7859_102518_000018_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "\"Theme\" meant both the corps and the district which it defended, and the corps commander was also the provincial governor.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102518_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102518/7859_102518_000023_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Constantine the fourth., known as Pogonatus, \"the Bearded,\" reigned for seventeen years, of which more than half were spent in one long struggle with the Saracens.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000001_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "THE FIRST ANARCHY.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000003_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Ere he had reached his twenty first year Justinian had plunged into war with the Bulgarians.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "He attacked them suddenly, inflicted several defeats on their king, and took no less than thirty thousand prisoners, whom he sent over to Asia, and forced to enlist in the army of Armenia.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000003_000003.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Justinian refused to receive them, and declared war.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "His second venture in the field was disastrous: his unwilling recruits from Bulgaria deserted to the enemy, when he met the Saracens at Sebastopolis in Cilicia, and the Roman army was routed with great slaughter.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000004_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The two subsequent campaigns were equally unsuccessful, and the troops of the Caliph harried Cappadocia far and wide.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000005_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Justinian's wars depleted his treasury; yet he persisted in plunging into expensive schemes of building at the same time, and was driven to collect money by the most reckless extortion.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000005_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Both were violent and cruel: Theodotus is said to have hung recalcitrant tax payers up by ropes above smoky fires till they were nearly stifled.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000005_000003.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Stephanus thrashed and stoned every one who fell into his hands; he is reported to have actually administered a whipping to the empress dowager during the absence of her son, and Justinian did not punish him when he returned.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "While the emperor's financial expedients were making him hated by the moneyed classes, he was rendering himself no less unpopular in the army.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "As he parted from his friends he exclaimed that his days were numbered, and that he should be expecting the order for his execution to arrive at any moment.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "A mob joined him, he seized the Cathedral of saint Sophia, and then marched on the palace.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000010_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "He held the throne barely three years, amid constant revolts at home and defeats abroad.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000013_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "They enlisted in their scheme Tiberius Apsimarus, who commanded the imperial fleet in the Aegean, and proclaimed him emperor when he joined them with his galleys.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000013_000003.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The troops of Leontius betrayed the gates of the capital to the followers of the rebel admiral, and Apsimarus seized Constantinople.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000013_000005.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Accordingly the nose of Leontius was slit, and he was placed in confinement in a monastery.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The people and army were out of hand, the ephemeral emperor could count on no loyalty, and any shock was sufficient to upset his precarious throne.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000015_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "With this prince the exile so ingratiated himself that he received in marriage his sister, who was baptized and christened Theodora.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000015_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000015_000006.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The emperor learnt of the plot through his wife, and saved himself by the bold expedient of going at once to one of the two Khazar chiefs and asking for a secret interview.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000016_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "This gave him time to escape, and he fled in a fishing boat out into the Euxine with a few friends and servants who had followed him into exile. While they were out at sea a storm arose, and the boat began to fill.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "One of his companions cried to Justinian to make his peace with God, and pardon his enemies ere he died.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000016_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "But the Emperor's stern soul was not bent by the tempest.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000016_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The boat weathered the storm, and Justinian survived to carry out his cruel oath.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000017_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "But they were soon to find out that they had erred in submitting to the exile, and should have resisted him at all hazards. Justinian came back in a relentless mood, bent on nothing but revenging his mutilated nose and his ten years of exile.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "After this strange exhibition the two ex emperors were beheaded.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Their execution began a reign of terror, for Justinian had his oath to keep, and was set on wreaking vengeance on every one who had been concerned in his deposition.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000018_000003.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Then he set to work to hunt out meaner victims: many prominent citizens of Constantinople were sown up in sacks and drowned in the Bosphorus.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000018_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000018_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Soldiers were picked out by the dozen and beheaded.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000018_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000018_000006.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The chief men were caught and sent to the capital, where Justinian had them bound to spits and roasted.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000019_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "In a few years he had made himself so much detested that it might be said that he had been comparatively popular in the days of his first reign.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The six years which followed were purely anarchical.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000021_000003.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "It required a hero to restore the machinery of government and evolve order out of chaos.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000022_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "To replace Justinian by Philippicus was only to substitute King Log for King Stork.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000022_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The new emperor was a mere man of pleasure, and spent his time in personal enjoyment, letting affairs of state slide on as best they might.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000022_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "In less than two years he was upset by a conspiracy which placed on the throne Artemius Anastasius, his own chief secretary.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000022_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000022_000005.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "More merciful than any of his ephemeral predecessors, Theodosius the third. dismissed Anastasius unharmed, after compelling him to take holy orders.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000023_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "\"The affairs both of the realm and the city were neglected and decaying, civil education was disappearing, and military discipline dissolved.\" The Bulgarian and Saracen commenced once more to ravage the frontier provinces, and every year their ravages penetrated further inland.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000024_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "After inducing the Saracens, more by craft than force, to raise the siege of Amorium, Leo disowned his allegiance to the incapable Theodosius and marched toward the Bosphorus.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102519_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102519/7859_102519_000025_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The unfortunate emperor, who had not coveted the throne he occupied, nor much desired to retain it, allowed his army to risk one engagement with the troops of Leo.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000001_000000.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "fifteen.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000009_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Dangerous revolts broke out in Greece and Italy, and were not put down without much fighting.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000013_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Where Leo had chastised the adherents of superstition with whips Constantine chastised them with scorpions.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "At this time Pope Stephen, when attacked by the same enemy, sent for aid to Pipin the Frank, instead of calling on the Emperor, and for the future the papacy was for all practical purposes dependent on the Franks and not on the empire.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000015_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "We are told that he compelled many of their inmates to marry by force of threats; others were exiled to Cyprus by the hundred; not a few were flogged and imprisoned, and a certain number of prominent men were put to death.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000017_000001.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The Empress Irene was clever, domineering, and popular.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000017_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000017_000006.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Constantine was neither precocious nor unfilial, but in his twenty second year he rebelled against his mother's dictation, and took his place at the helm of the state.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000017_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000017_000007.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "Irene had actually striven to oppose him by armed force, but he pardoned her, and after secluding her for a short time, restored her to her former dignity.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000022_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000022_000003.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "But it was not till eight hundred that the final breach took place.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7859_102521_000022_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7859/102521/7859_102521_000022_000004.wav",
        "speaker_id": "LibriTTS_R-7859",
        "content": "The Iconoclastic controversy had prepared the way for it, while the fact that a woman sat on the imperial throne served as a good excuse for the Pope's action.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
