[
    {
        "item_name": "LibriTTS_R-7991_102381_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000004_000005.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I ask my friend to read some extracts from the decision.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "\"The Territory being a part of the United States, the Government and the citizen both enter it under the authority of the Constitution, with their respective rights defined and marked out; and the Federal Government can exercise no power over his person or property beyond what that instrument confers, nor lawfully deny any right which it has reserved....",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "\"The powers over person and property, of which we speak, are not only not granted to Congress, but are in express terms denied, and they are forbidden to exercise them.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "And this prohibition is not confined to the States, but the words are general, and extend to the whole territory over which the Constitution gives it power to legislate, including those portions of it remaining under territorial government, as well as that covered by States.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000007_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "And if Congress itself can not do this-if it is beyond the powers conferred on the Federal Government-it will be admitted, we presume, that it could not authorize a territorial government to exercise them.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000009_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "\"This is done in plain words-too plain to be misunderstood.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000009_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "The only power conferred is the power coupled with the duty of guarding and protecting the owner in his rights.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000011_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It was obligatory on those who selected the umpire and agreed to abide by the award.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000012_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "In eighteen forty eight it made its appearance for good purposes.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000012_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It was ushered in by a great and good man.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000012_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000012_000007.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I thought it a fallacy which would surely be exploded. I doubted then, and still more for some time afterward, when held to a dread responsibility for the position which I occupied.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000012_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000012_000013.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "This was the first fruit.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000012_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000012_000014.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "More deadly than the fatal upas, its effect was not limited to the mere spot of ground on which the dew fell from its leaves, but it spread throughout the United States; it kindled all which had been collected for years of inflammable material.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000012_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000012_000015.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It was owing to the strength of our Government and the good sense of the quiet masses of the people that it did not wrap our country in one widespread conflagration.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000014_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Can this be a definition of sovereignty?",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "This is confounding the whole theory and the history of our Government.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000015_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "The States were the grantors; they made the compact; they gave the Federal agent its powers; they inhibited themselves from doing certain things, and all else they retained to themselves.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000015_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "This Federal agent got just so much as the States chose to give-no more.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000015_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000015_000005.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Therefore its powers are not comparable to the powers of the State Legislature, because one is the creature of grant, and the other the exponent of sovereign power.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It seems to have been more malleable than gold; to have been hammered out to an extent that covers boundless regions undiscovered by those who proclaimed the doctrine.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000016_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Non intervention then meant, as the debates show, that Congress should neither prohibit nor establish slavery in the Territories.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000016_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "That I hold to now.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000016_000005.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Why, sir, the very acts which they passed at the time refute it.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "\"And that all laws, or parts of laws, usages, or customs, preexisting in the Territories acquired by the United States from Mexico, and which in said Territories restrict, abridge, or obstruct, the full enjoyment of any right of person or property of a citizen of the United States, as recognized or guaranteed by the Constitution or laws of the United States, are hereby declared and shall be held as repealed.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Upon that, mr Clay said:",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000019_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "\"mr",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000020_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "That was the position taken by mr Clay, the leader.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000020_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "A mere sentence will show with what view I regarded the dogma of non intervention when that amendment was offered.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000020_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I said:",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "\"But what is non intervention seems to vary as often as the light and shade of every fleeting cloud.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000021_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It has different meanings in every State, in every county, in every town.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000021_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "If non intervention means that we shall not have protection for our property in slaves, then I always was, and always shall be, opposed to it.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000022_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "mr Downs, one of the Committee of Thirteen, and an advocate of the measures, said:",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000024_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000024_000005.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "We differed radically then.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000025_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It has been sometimes assumed that this was the recognition of the power of the Territorial Legislature to exercise plenary legislation, as might that of a State.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000026_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "That was all the difference.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000026_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000026_000004.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It left Congress, as to its power, just where it was.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000026_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000026_000005.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I find myself physically unable to go as fully into the subject as I intended, and therefore, omitting a reference to those acts, suffice it to say that here was the recognition of the obligation of Congress to interpose against a Territorial Legislature for the protection of personal right. That is what we ask of Congress now.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000026_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000026_000006.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I am not disposed to ask this Congress to go into speculative legislation.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000026_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000026_000007.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I am not one of those who would willingly see this Congress enact a code to be applied to all Territories and for all time to come.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000026_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000026_000011.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "That is the announcement of the fifth resolution.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000027_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I honor them, and I approve their conduct.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000027_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000027_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I think their bearing was worthy of the mother State which sent them there; and I doubt not she will receive them with joy and gratitude.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000027_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000027_000004.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "They have asserted and vindicated her equality of right.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000027_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000027_000005.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "By that asserted equality of right I doubt not she will stand.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000028_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "The sixth resolution of the series declares at what time a State may form a Constitution and decide upon her domestic institutions.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000028_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I deny this right to the territorial condition, because the Territory belongs in common to the States.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000028_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Every citizen of the United States, as a joint owner of that Territory, has a right to go into it with any property which he may possess.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000028_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000028_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "These territorial inhabitants require municipal law, police, and government.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000028_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000028_000005.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "They have no right within their municipal power to attempt to decide the rights of the people of the States.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000029_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "The last resolution refers to a law founded on a provision of the Constitution, which contains an obligation of faith to every State of the Union; and that obligation of faith has been violated by thirteen States of the Confederacy-as many as originally fought the battles of the Revolution and established the Confederation.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000029_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Is it to be expected that a compact thus broken in part, violated in its important features, will be regarded as binding in all else?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000029_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000029_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "We have a right to claim abstinence from interference with our rights from any Government on the earth.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000030_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It was first for political power, and directed against new States; now it has assumed a social form, is all prevailing, and has reached the point of revolution and civil war.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000030_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "For it was only last fall that an overt act was committed by men who were sustained by arms and money, raised by extensive combination among the non slaveholding States, to carry treasonable war against the State of Virginia, because now, as before the Revolution, and ever since, she held the African in bondage.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000030_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000030_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "This is part of the history and marks the necessity of the times.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000032_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000032_000004.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "The argument, then, or the reason on which this agitation commenced, has passed away; and yet we are asked, if a party hostile to our institutions shall gain possession of the Government, that we shall stand quietly by, and wait for an overt act.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000032_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000032_000006.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Is not a declaration of war an overt act?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000032_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000032_000009.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "I can speak for myself-and I have no right to speak for others-when I say, that, if I belonged to a party organized on the basis of making war on any section or interest in the United States, if I know myself, I would instantly quit it.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000032_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000032_000012.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "We claim to have but the Constitution fairly and equally administered.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000033_000000.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Among the great purposes declared in the preamble of the Constitution is one to provide for the general welfare.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000033_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Provision for the general welfare implies general fraternity.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000033_000002.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "This Union was not expected to be held together by coercion; the power of force as a means was denied. They sought, however, to bind it perpetually together with that which was stronger than triple bars of brass and steel-the ceaseless current of kind offices, renewing and renewed in an eternal flow, and gathering volume and velocity as it rolled.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000033_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000033_000003.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It was a function intended not for the injury of any.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000033_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000033_000004.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "It declared its purpose to be the benefit of all. Concessions which were made between the different States in the Convention prove the motive.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000033_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000033_000007.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "We have tamed a wilderness; we have spanned a continent.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000033_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000033_000009.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "Higher than all this, we have achieved a moral triumph.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000034_000001.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "We have tampered with a question which has grown in magnitude by each year's delay.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7991_102381_000034_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7991/102381/7991_102381_000034_000004.wav",
        "speaker_id": "LibriTTS_R-7991",
        "content": "But so long as we deal, like the Delphic oracle, in words of double meaning, so long as we attempt to escape from responsibility, and exhibit our fear to declare the truth by the fact that we do not act upon it, we must expect speculative theory to occupy the mind of the public, and error to increase as time rolls on.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    }
]