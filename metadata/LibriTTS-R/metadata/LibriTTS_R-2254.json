        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2254_152824_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2254/152824/2254_152824_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2254",
        "content": "\"The Moose hides called it the devil fox, and swore that no man could kill; That he who hunted it, soon or late, must surely suffer some ill; But I laughed at them and their old squaw tales. Ha!",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
