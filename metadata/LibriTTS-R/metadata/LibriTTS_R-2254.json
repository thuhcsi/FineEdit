        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2254/152825/2254_152825_000006_000000.wav",
        "speaker_id": "LibriTTS_R-2254",
        "content": "Mad!",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2254_152831_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2254/152831/2254_152831_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2254",
        "content": "Gold!",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
