[
    {
        "item_name": "LibriTTS_R-4335_15081_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000004_000000.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "As spring approached, the starving multitude on Isle saint Joseph grew reckless with hunger.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000004_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Along the main shore, in spots where the sun lay warm, the spring fisheries had already begun, and the melting snow was uncovering the acorns in the woods.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000004_000005.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The ice was still thick, but the advancing season had softened it; and, as a body of them were crossing, it broke under their feet.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000004_000006.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Some were drowned; while others dragged themselves out, drenched and pierced with cold, to die miserably on the frozen lake, before they could reach a shelter.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000007_000002.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "So, too, our starving Hurons were driven out of a town which had become an abode of horror.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000007_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000007_000007.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "And, in fact, only a few days passed before we heard of the disaster which we had foreseen.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000007_000008.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "These poor people fell into ambuscades of our Iroquois enemies.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000007_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000007_000009.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Some were killed on the spot; some were dragged into captivity; women and children were burned.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000007_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000007_000012.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Go where they would, they met with slaughter on all sides.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000008_000000.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The Jesuits at saint Joseph knew not what course to take.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000008_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The doom of their flock seemed inevitable.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000009_000000.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "\"Take courage, brother,\" continued one of the chiefs, addressing Ragueneau.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000009_000002.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Turn your eyes towards Quebec, and transport thither what is left of this ruined country.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000009_000007.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "If you do as we wish, we will form a church under the protection of the fort at Quebec.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000009_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000009_000008.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Our faith will not be extinguished.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000011_000003.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Their resolution once taken, they pushed their preparations with all speed, lest the Iroquois might learn their purpose, and lie in wait to cut them off. Canoes were made ready, and on the tenth of June they began the voyage, with all their French followers and about three hundred Hurons.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000013_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Their scouts came in, and reported that they had found fresh footprints of men in the forest.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000013_000002.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "These proved, however, to be the tracks, not of enemies, but of friends.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000014_000002.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Bressani's party outnumbered them six to one; but they resolved that it should not pass without a token of their presence. Late on a dark night, the French and Hurons lay encamped in the forest, sleeping about their fires.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000014_000003.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "They had set guards: but these, it seems, were drowsy or negligent; for the ten Iroquois, watching their time, approached with the stealth of lynxes, and glided like shadows into the midst of the camp, where, by the dull glow of the smouldering fires, they could distinguish the recumbent figures of their victims.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000014_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000014_000007.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The Iroquois were surrounded, and a desperate fight ensued in the dark.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000015_000000.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The united parties soon after reached Montreal; but the Hurons refused to remain in a spot so exposed to the Iroquois.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000015_000003.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Their good will exceeded their power; for food was scarce at Quebec, and the Jesuits themselves had to bear the chief burden of keeping the sufferers alive.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000016_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "A party of Christian Indians, chiefly from Sillery, planned a stroke of retaliation, and set out for the Mohawk country, marching cautiously and sending forward scouts to scour the forest.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000016_000004.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "He had come, he declared, with no other thought than that of joining them, and turning Iroquois, as they had done.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000016_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000016_000007.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The Iroquois, in great delight, demanded to be shown where they were.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000016_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000016_000010.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Not long after, he came to Canada, and, with a view, as it was thought, to some further treachery, rejoined the French. A sharp cross questioning put him to confusion, and he presently confessed his guilt.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000017_000000.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "In the course of the summer, the French at Three Rivers became aware that a band of Iroquois was prowling in the neighborhood, and sixty men went out to meet them.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000000.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "In the forests far north of Three Rivers dwelt the tribe called the Atticamegues, or Nation of the White Fish.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "From their remote position, and the difficult nature of the intervening country, they thought themselves safe; but a band of Iroquois, marching on snow shoes a distance of twenty days' journey northward from the saint Lawrence, fell upon one of their camps in the winter, and made a general butchery of the inmates.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000008.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "With him were a large party of Atticamegues, and several Frenchmen.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000009.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Game was exceedingly scarce, and they were forced by hunger to separate, a Huron convert and a Frenchman named Fontarabie remaining with the missionary.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000010.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The snows had melted, and all the streams were swollen.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000012.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "They toiled through the naked forest, among the wet, black trees, over tangled roots, green, spongy mosses, mouldering leaves, and rotten, prostrate trunks, while the cataract foamed amidst the rocks hard by.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000013.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The Indian led the way with the canoe on his head, while Buteux and the other Frenchman followed with the baggage.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000014.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Suddenly they were set upon by a troop of Iroquois, who had crouched behind thickets, rocks, and fallen trees, to waylay them.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15081_000018_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15081/4335_15081_000018_000016.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The Iroquois rushed upon them, mangled their bodies with tomahawks and swords, stripped them, and then flung them into the torrent.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000004_000000.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Iroquois bullets and tomahawks had killed the Hurons by hundreds, but famine and disease had killed incomparably more.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000004_000004.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Game was very scarce; and, without agriculture, the country could support only a scanty and scattered population like that which maintained a struggling existence in the wilderness of the lower saint Lawrence.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000004_000005.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The mortality among the exiles was prodigious.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000007_000004.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "This brought them in contact with the Illinois, an Algonquin people, at that time very numerous, but who, like many other tribes at this epoch, were doomed to a rapid diminution from wars with other savage nations.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000007_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000007_000010.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Thus it appears that the Wyandots, whose name is so conspicuous in the history of our border wars, are descendants of the ancient Hurons, and chiefly of that portion of them called the Tobacco Nation.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000009_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "They took possession of the stone fort which the French had abandoned, and where, with reasonable vigilance, they could maintain themselves against attack.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000009_000002.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "In the succeeding autumn a small Iroquois war party had the audacity to cross over to the island, and build a fort of felled trees in the woods.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000009_000005.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "A Huron war chief, named Etienne Annaotaha, whose life is described as a succession of conflicts and adventures, and who is said to have been always in luck, landed with a few companions, and fell into an ambuscade of the Iroquois.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000009_000007.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Etienne suspected treachery, but concealed his distrust, and advanced towards the Iroquois with an air of the utmost confidence. They received him with open arms, and pressed him to accept their invitation; but he replied, that there were older and wiser men among the Hurons, whose counsels all the people followed, and that they ought to lay the proposal before them.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000009_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000009_000010.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "He set out accordingly with three of the principal Iroquois.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000010_000002.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Etienne seized the opportunity to take aside four or five of the principal chiefs, and secretly tell them his suspicions that the Iroquois were plotting to compass their destruction under cover of overtures of peace; and he proposed that they should meet treachery with treachery.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000010_000005.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The squaws began their preparations at once, and all was bustle and alacrity; for the Hurons themselves were no less deceived than were the Iroquois envoys.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000011_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Etienne's time had come.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000011_000003.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "Three of the Iroquois, immediately before the slaughter began, had received from Etienne a warning of their danger in time to make their escape.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000013_000001.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The miseries of the Hurons were lighted up with a brief gleam of joy; but it behooved them to make a timely retreat from their island before the Iroquois came to exact a bloody retribution.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000013_000004.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "The fugitives directed their course to the Grand Manitoulin Island, where they remained for a short time, and then, to the number of about four hundred, descended the Ottawa, and rejoined their countrymen who had gone to Quebec the year before.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4335_15082_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4335/15082/4335_15082_000017_000004.wav",
        "speaker_id": "LibriTTS_R-4335",
        "content": "It was built of brick, like its original, of which it was an exact facsimile; and it stood in the centre of a quadrangle, the four sides of which were formed by the bark dwellings of the Hurons, ranged with perfect order in straight lines.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    }
]