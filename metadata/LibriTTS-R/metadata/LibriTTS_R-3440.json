        "speaker_id": "LibriTTS_R-3440",
        "content": "\"No,\" said he, \"I think you have been a very good girl for quite a long time.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
