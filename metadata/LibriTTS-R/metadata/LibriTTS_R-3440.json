    },
    {
        "item_name": "LibriTTS_R-3440_171009_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000026_000001.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "Elsie left her game to try to make peace.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000029_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "\"Oh! Enna, won't you give them back?\" said Elsie, coaxingly; \"you know Flora is a visitor, and we must be very polite to her.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000030_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "\"No, I won't,\" returned Enna, flatly; \"she's got enough now.\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000031_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "\"No, I haven't; I can't build a house with those,\" Flora said, with another sob.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000032_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "Elsie stood a moment looking much perplexed; then, with a brightening face, exclaimed in her cheerful, pleasant way, \"Well, never mind, Flora, dear, I will get you my doll.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000033_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "Elsie ran out of the room and was back again almost in a moment, with the doll in her arms.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000035_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "\"I won't break it, Elsie, indeed I won't,\" replied Flora, confidently; and Elsie sat down to her game again.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
