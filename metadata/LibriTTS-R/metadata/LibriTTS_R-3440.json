        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000037_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "\"Elsie,\" he said, as he caught sight of his little daughter, \"go up to my dressing room.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
