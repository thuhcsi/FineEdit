        "speaker_id": "LibriTTS_R-3440",
        "content": "\"I don't know; nothing I guess,\" replied Lucy, indignantly.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
