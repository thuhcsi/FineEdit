        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000005_000003.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "I'm sure I am.\"",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000009_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "\"What are we going to do to day, Elsie?\" asked Caroline.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000010_000000.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "\"Whatever you all prefer,\" said Elsie.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000013_000000",
