        "speaker_id": "LibriTTS_R-3440",
        "content": "\"Will you play jack stones? here are some smooth pebbles.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000024_000000",
