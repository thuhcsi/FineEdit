        "speaker_id": "LibriTTS_R-3440",
        "content": "So come, sit down and eat your lunch, and don't fret any more.\"",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
