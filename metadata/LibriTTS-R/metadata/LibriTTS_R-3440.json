        "speaker_id": "LibriTTS_R-3440",
        "content": "\"Agreed!\" said the others, \"let's have a game.\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000025_000000",
