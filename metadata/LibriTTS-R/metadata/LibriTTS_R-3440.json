        "speaker_id": "LibriTTS_R-3440",
        "content": "I am too big for that; they are very nice for little children.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000022_000000",
