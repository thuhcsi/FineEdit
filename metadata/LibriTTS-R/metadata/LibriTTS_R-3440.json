        "speaker_id": "LibriTTS_R-3440",
        "content": "Aren't you glad?",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
