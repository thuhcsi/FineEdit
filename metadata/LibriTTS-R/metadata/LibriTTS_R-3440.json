        "speaker_id": "LibriTTS_R-3440",
        "content": "\"Strict!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3440_171009_000048_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3440/171009/3440_171009_000048_000001.wav",
        "speaker_id": "LibriTTS_R-3440",
        "content": "I consider it a very unladylike and slovenly trick.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
