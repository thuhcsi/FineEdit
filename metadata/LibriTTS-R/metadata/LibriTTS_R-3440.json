        "speaker_id": "LibriTTS_R-3440",
        "content": "\"He must be cross.\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
