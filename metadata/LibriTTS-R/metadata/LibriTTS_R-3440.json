        "speaker_id": "LibriTTS_R-3440",
        "content": "\"Doesn't your papa let you eat anything good, Elsie?\" asked Mary Leslie across the table.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
