        "speaker_id": "LibriTTS_R-1034",
        "content": "\"The weakness of a murderer!\"",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
