        "speaker_id": "LibriTTS_R-1898",
        "content": "They said at last, 'What use was it our deserting?",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
