        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1898/145702/1898_145702_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1898",
        "content": "You can then live as great lords, keep horses, and drive about in carriages.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1898_145702_000013_000000",
