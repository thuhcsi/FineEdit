        "speaker_id": "LibriTTS_R-3080",
        "content": "My father has lost his too, and my eldest brother, but we all look like people risen from the dead.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
