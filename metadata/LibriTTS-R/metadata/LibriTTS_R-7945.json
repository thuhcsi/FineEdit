        "speaker_id": "LibriTTS_R-7945",
        "content": "His skin was dark-not too dark-just a good healthy out door tan: his brows level and heavy, his gaze candour itself.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000029_000000.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "Constance clasped her hands in an ecstasy of admiration.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
