        "speaker_id": "LibriTTS_R-7945",
        "content": "'Really?",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
