        "speaker_id": "LibriTTS_R-7945",
        "content": "I only ordered one.'",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
    },
    {
