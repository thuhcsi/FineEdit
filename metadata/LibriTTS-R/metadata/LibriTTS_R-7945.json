        "speaker_id": "LibriTTS_R-7945",
        "content": "'You can't make us believe that,' said her father.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
