        "speaker_id": "LibriTTS_R-7945",
        "content": "The one insult which she could not brook was for an Italian to fail to understand her when she talked Italian.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000041_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000041_000005.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "She suppressed it quickly and turned away.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000043_000000.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "'The poor fellow is embarrassed,' apologized her father.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000043_000001.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "'His name is Tony,' he added-even he had understood that much Italian.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
