        "speaker_id": "LibriTTS_R-7945",
        "content": "The table was set on the terrace; breakfast was served and the company was gathered.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
