        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000025_000002.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "I shall never place any faith in his judgment again.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000027_000001.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "Constance patted their shaggy mouse coloured noses, made the acquaintance of the boy, whose name was Beppo, and looked about for the driver proper.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000028_000000.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "He wore a loose white shirt-immaculately white-with a red silk handkerchief knotted about his throat, brown corduroy knee breeches, and a red cotton sash with the hilt of a knife conspicuously protruding.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
