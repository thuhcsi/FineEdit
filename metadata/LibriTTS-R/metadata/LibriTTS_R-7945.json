        "speaker_id": "LibriTTS_R-7945",
        "content": "'And the driver?'",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
