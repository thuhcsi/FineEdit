        "speaker_id": "LibriTTS_R-7945",
        "content": "This morning she was very business like in her short skirt, belted jacket, and green felt Alpine hat with a feather in the side.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
