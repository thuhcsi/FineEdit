        "speaker_id": "LibriTTS_R-7945",
        "content": "Constance eyed her father sharply.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000016_000001",
