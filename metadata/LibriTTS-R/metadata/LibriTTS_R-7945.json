        "speaker_id": "LibriTTS_R-7945",
        "content": "There are two of him.'",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
