        "speaker_id": "LibriTTS_R-7945",
        "content": "There was something at once guilty and triumphant about his expression.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
