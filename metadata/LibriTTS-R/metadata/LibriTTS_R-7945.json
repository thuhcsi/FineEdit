        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "'English!' There was reproach, disgust, disillusionment, in her tone. 'Not really, father?'",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
