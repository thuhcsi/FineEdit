        "speaker_id": "LibriTTS_R-7945",
        "content": "'I don't know about his Italian, but he talks uncommonly good English.'",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
