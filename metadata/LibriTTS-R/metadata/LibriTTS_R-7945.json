        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000024_000000.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "'Very convenient, I should say.'",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000025_000000.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "'If there's anything I detest, it's an Americanized Italian-and here in Valedolmo of all places, where you have a right to demand something unique and romantic and picturesque and real.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7945_112011_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7945/112011/7945_112011_000025_000001.wav",
        "speaker_id": "LibriTTS_R-7945",
        "content": "It's too bad of Gustavo!",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
