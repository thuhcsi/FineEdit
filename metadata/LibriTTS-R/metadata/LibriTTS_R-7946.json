        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7946/111913/7946_111913_000023_000001.wav",
        "speaker_id": "LibriTTS_R-7946",
        "content": "\"As the camel walked along, the marks of his two front feet and right hind foot were quite deep and clear on the ground.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7946_111913_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7946/111913/7946_111913_000023_000003.wav",
        "speaker_id": "LibriTTS_R-7946",
        "content": "That showed that the camel was limping, and the left hind foot only just touched the ground.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
