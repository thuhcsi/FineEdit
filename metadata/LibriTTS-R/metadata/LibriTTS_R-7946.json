        "speaker_id": "LibriTTS_R-7946",
        "content": "I believe that if mr Elliott goes back with Martin and they explain things to the boy, he will come without much trouble.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
