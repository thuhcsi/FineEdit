        "speaker_id": "LibriTTS_R-7946",
        "content": "\"It was quite simple,\" the clever man answered very modestly.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
