        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7946_111913_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7946/111913/7946_111913_000021_000003.wav",
        "speaker_id": "LibriTTS_R-7946",
        "content": "On the right side of the road there were also plenty of good shrubs and bushes, but the camel had not taken a single bite at any of them.",
