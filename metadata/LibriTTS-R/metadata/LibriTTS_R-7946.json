        "speaker_id": "LibriTTS_R-7946",
        "content": "One day, as the sun began to get hot, he lay down on the grass under a tree near the roadway, and fell asleep.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
