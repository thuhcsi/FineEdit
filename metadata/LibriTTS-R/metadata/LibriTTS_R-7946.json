        "speaker_id": "LibriTTS_R-7946",
        "content": "\"But how did you know that the camel was lame in his left hind foot?\"",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
