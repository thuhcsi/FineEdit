        "speaker_id": "LibriTTS_R-7946",
        "content": "\"I believe we can bring him here easily,\" said Elliott, \"for he has confidence in me.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
