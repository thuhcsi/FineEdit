[
    {
        "item_name": "LibriTTS_R-7909_106369_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000000_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And there, when they had taken their fill of food and drink, they kept awake all night waiting for the sons of Boreas.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000001_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "I was infatuated aforetime, when in my folly I declared the will of Zeus in order and to the end.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000002_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For they are not firmly fixed with roots beneath, but constantly clash against one another to one point, and above a huge mass of salt water rises in a crest, boiling up, and loudly dashes upon the hard beach.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000002_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Wherefore now obey my counsel, if indeed with prudent mind and reverencing the blessed gods ye pursue your way; and perish not foolishly by a self sought death, or rush on following the guidance of youth.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000002_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "First entrust the attempt to a dove when ye have sent her forth from the ship.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000002_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000002_000006.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But if she flies onward and perishes midway, then do ye turn back; for it is better to yield to the immortals.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000002_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000002_000007.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For ye could not escape an evil doom from the rocks, not even if Argo were of iron.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000004_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "So high in the air does it rise turned towards the sea.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000004_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000004_000009.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But what need is there that I should sin yet again declaring everything to the end by my prophetic art?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "What shall I do, how shall I go over again such a long path through the sea, unskilled as I am, with unskilled comrades?",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000006_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And Colchian Aea lies at the edge of Pontus and of the world.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But, my friends, take thought of the artful aid of the Cyprian goddess.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000007_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And further than this ask me not.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000008_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And quickly Aeson's son, with good will exceeding, addressed him:",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But instead of that, may the god grant me death at once, and after death I shall take my share in perfect bliss.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000011_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "To all alike, however poor he was that came, the aged man gave his oracles with good will, and freed many from their woes by his prophetic art; wherefore they visited and tended him.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000011_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "The rest the old man pleased with words of wisdom and let them go; Paraebius only he bade remain there with the chiefs; and straightway he sent him and bade him bring back the choicest of his sheep.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000012_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Even as this man, loyal as he is, came hither to learn his fate.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000012_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But he was paying the sad penalty of his father's sin.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000012_000005.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "So to him the nymph thereafter made her death a curse, to him and to his children.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000012_000006.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "I indeed knew of the sin when he came; and I bid him build an altar to the Thynian nymph, and offer on it an atoning sacrifice, with prayer to escape his father's fate.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000012_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000012_000007.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Here, ever since he escaped the god sent doom, never has he forgotten or neglected me; but sorely and against his will do I send him from my doors, so eager is he to remain with me in my affliction.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And up rose Jason and up rose the sons of Boreas at the bidding of the aged sire.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000013_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And quickly they called upon Apollo, lord of prophecy, and offered sacrifice upon the health as the day was just sinking.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000013_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And the younger comrades made ready a feast to their hearts' desire.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000013_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Thereupon having well feasted they turned themselves to rest, some near the ship's hawsers, others in groups throughout the mansion.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And afterwards they raised an altar to the blessed twelve on the sea beach opposite and laid offerings thereon and then entered their swift ship to row, nor did they forget to bear with them a trembling dove; but Euphemus seized her and brought her all quivering with fear, and they loosed the twin hawsers from the land.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000017_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Their spirit melted within them; and Euphemus sent forth the dove to dart forward in flight; and they all together raised their heads to look; but she flew between them, and the rocks again rushed together and crashed as they met face to face.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Next the current whirled the ship round.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000018_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000018_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For the rocks were again parting asunder.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000018_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000018_000005.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But as they rowed they trembled, until the tide returning drove them back within the rocks.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000018_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000018_000006.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Then most awful fear seized upon all; for over their head was destruction without escape.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000018_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000018_000008.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For it seemed about to leap down upon the ship's whole length and to overwhelm them.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000019_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And the eddying current held her between the clashing rocks; and on each side they shook and thundered; and the ship's timbers were held fast. Then Athena with her left hand thrust back one mighty rock and with her right pushed the ship through; and she, like a winged arrow, sped through the air.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000019_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Nevertheless the rocks, ceaselessly clashing, shore off as she passed the extreme end of the stern ornament.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000019_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But Athena soared up to Olympus, when they had escaped unscathed.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000019_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And the rocks in one spot at that moment were rooted fast for ever to each other, which thing had been destined by the blessed gods, when a man in his ship should have passed between them alive.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000019_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000019_000006.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For they deemed that they were saved from Hades; and Tiphys first of all began to speak:",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106369_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106369/7909_106369_000020_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Son of Aeson, no longer fear thou so much the hest of thy king, since a god hath granted us escape between the rocks; for Phineus, Agenor's son, said that our toils hereafter would be lightly accomplished.\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000002_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And quickly they sighted and sailed past his shrine and the broad banks of the river and the plain, and deep flowing Calpe, and all the windless night and the day they bent to their tireless oars.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000002_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And even as ploughing oxen toil as they cleave the moist earth, and sweat streams in abundance from flank and neck; and from beneath the yoke their eyes roll askance, while the breath ever rushes from their mouths in hot gasps; and all day long they toil, planting their hoofs deep in the ground; like them the heroes kept dragging their oars through the sea.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Helpless amazement seized them as they looked; and no one dared to gaze face to face into the fair eyes of the god.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000004_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And now I bid you propitiate him with the steam of sacrifice and libations.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000004_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Be gracious, O king, be gracious in thy appearing.\"",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000005_000005.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And none but Leto, daughter of Coeus, strokes them with her dear hands.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Next, on the opposite side they saw and passed the mouth of the river Sangarius and the fertile land of the Mariandyni, and the stream of Lycus and the Anthemoeisian lake; and beneath the breeze the ropes and all the tackling quivered as they sped onward.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "During the night the wind ceased and at dawn they gladly reached the haven of the Acherusian headland.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000007_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "It rises aloft with steep cliffs, looking towards the Bithynian sea; and beneath it smooth rocks, ever washed by the sea, stand rooted firm; and round them the wave rolls and thunders loud, but above, wide spreading plane trees grow on the topmost point.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000007_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And from it towards the land a hollow glen slopes gradually away, where there is a cave of Hades overarched by wood and rocks.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000007_000005.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "From here an icy breath, unceasingly issuing from the chill recess, ever forms a glistening rime which melts again beneath the midday sun",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000007_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000007_000006.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And never does silence hold that grim headland, but there is a continual murmur from the sounding sea and the leaves that quiver in the winds from the cave.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000007_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000007_000009.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For indeed the river saved them with their ships when they were caught in a violent tempest.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And so they went up all together into the city, and all that day with friendly feelings made ready a feast within the palace of Lycus and gladdened their souls with converse.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000011_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And with a sharp cry the hero fell to the ground; and as he was struck his comrades flocked together with answering cry.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For then a second time the heroes heaped up a barrow for a comrade dead.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000013_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "The tale goes that Tiphys son of Hagnias died; nor was it his destiny thereafter to sail any further.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000013_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But him there on the spot a short sickness laid to rest far from his native land, when the company had paid due honours to the dead son of Abas.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000013_000005.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And at the cruel woe they were seized with unbearable grief.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000013_000006.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For when with due honours they had buried him also hard by the seer, they cast themselves down in helplessness on the sea shore silently, closely wrapped up, and took no thought for meat or drink; and their spirit drooped in grief, for all hope of return was gone.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000014_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Not so much for my prowess in war did Jason take me with him in quest of the fleece, far from Parthenia, as for my knowledge of ships.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Wherefore, I pray, let there be no fear for the ship.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000014_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "But quickly tell forth all this and boldly urge them to call to mind their task.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000015_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Wherefore let us not delay our attempt, but rouse yourselves to the work and cast away your griefs.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For those whom we once deemed to be men of skill, they even more than I are bowed with vexation of heart.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000017_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And after him Erginus and Nauplius and Euphemus started up, eager to steer. But the others held them back, and many of his comrades granted it to Ancaeus.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And quickly with the oars they passed out through the river Acheron and, trusting to the wind, shook out their sails, and with canvas spread far and wide they were cleaving their passage through the waves in fair weather.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000019_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And for a time they went no further, for Persephone herself sent forth the spirit of Actor's son which craved with many tears to behold men like himself, even for a moment.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000019_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And mounting on the edge of the barrow he gazed upon the ship, such as he was when he went to war; and round his head a fair helm with four peaks gleamed with its blood red crest.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000019_000003.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And again he entered the vast gloom; and they looked and marvelled; and Mopsus, son of Ampycus, with word of prophecy urged them to land and propitiate him with libations.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000019_000004.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "Quickly they drew in sail and threw out hawsers, and on the strand paid honour to the tomb of Sthenelus, and poured out drink offerings to him and sacrificed sheep as victims.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000019_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000019_000005.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And besides the drink offerings they built an altar to Apollo, saviour of ships, and burnt thigh bones; and Orpheus dedicated his lyre; whence the place has the name of Lyra.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000021_000001.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "For he longed for her love, and he promised to grant her whatever her hearts desire might be.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7909_106370_000021_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7909/106370/7909_106370_000021_000002.wav",
        "speaker_id": "LibriTTS_R-7909",
        "content": "And she in her craftiness asked of him virginity.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
