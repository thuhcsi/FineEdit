        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Did she tell you that?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
