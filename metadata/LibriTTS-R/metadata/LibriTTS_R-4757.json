        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000093_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Exactly.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000095_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000095_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Of course; and heard her too.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000095_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000095_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "She was dreadfully anxious to come with me; but that was out of the question.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
