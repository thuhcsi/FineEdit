        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Your patience one moment longer, until we see which of us has the best right to the lady.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000058_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000058_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "I have a prior claim.\"",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
