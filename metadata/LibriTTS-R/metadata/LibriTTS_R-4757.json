        "speaker_id": "LibriTTS_R-4757",
        "content": "\"She was, you mean.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000056_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000056_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Softly, my friend-softly.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000056_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000056_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "How was I to know all this?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000058_000000",
