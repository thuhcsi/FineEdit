        "speaker_id": "LibriTTS_R-4757",
        "content": "\"I seldom take the trouble to deny my acts.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
