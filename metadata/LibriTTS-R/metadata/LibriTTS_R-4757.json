        "speaker_id": "LibriTTS_R-4757",
        "content": "\"That I do not clearly see.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000098_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000098_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Here; and he told me that he had abducted her, and held her a prisoner in his own house.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
