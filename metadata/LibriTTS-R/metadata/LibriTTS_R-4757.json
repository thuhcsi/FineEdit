[
    {
        "item_name": "LibriTTS_R-4757_1811_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000001_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Another one!\" he said, coming leisurely up, and glancing at the lifeless form with a very professional eye.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000002_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "I am not even certain whether he is dead at all.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000003_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "He stood up after a moment, with some thing like a small laugh.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000004_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"If he's alive,\" he said, turning to go, \"then I never saw any one dead! Good night, sir, I wish you joy when you bring him to.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000005_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Stay!\" exclaimed the young man, \"I wish you to assist me in bringing him to yonder apothecary's shop, and you may have this for your pains.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000006_000002.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "The attire and bearing of Sir Norman proving him to be something different from their usual class of visitors, bringing one of the drowsy apprentices immediately to his side, inquiring what were his orders.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000007_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"A private room, and your master's attendance directly,\" was the authoritative reply.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000008_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "Both were to be had; the former, a hole in the wall behind the shop; the latter, a pallid, cadaverous looking person, with the air of one who had been dead a week, thought better of it and rose again.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000009_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"The man is dead, sir!\" was his criticism, \"dead as a door nail!",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000010_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "Try something-bleeding for instance,\" suggested Sir Norman.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000011_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "Again the apothecary examined the body, and again he shook his head dolefully.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000013_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "The right arm was bared; the lancet inserted, one or two black drops sluggishly followed and nothing more.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000015_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"I don't know,\" said Sir Norman, gloomily.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000015_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"I wish you would tell me that.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000016_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Can't do it, sir; my skill doesn't extend that far.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000017_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"It is very mysterious and very dreadful, and notwithstanding all you have said, I cannot believe him dead.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000019_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Gold can do anything,\" was his plaintive reply.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000020_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"I understand.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000020_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "You shall have it.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000022_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "Which he did, accordingly; and Sir Norman was left alone with all that remained of him who, two hours before, was his warm friend.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000024_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Stay!\" he said.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000028_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Really,\" said the count, with some embarrassment, \"you attack me so unexpectedly, and so like a ghost or a highwayman-by the way I have a word to say to you about highwaymen, and was seeking you to say it.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000029_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Where is Leoline?\" shouted the exasperated young knight, releasing his shoulder, and clutching him by the throat.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000029_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Tell me or, by Heaven!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000031_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Keep off!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000033_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"All in good time.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000035_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "A strange sort of smile came over the face of the count at this direful threat, as if he fancied in that case, he was safe enough; but Sir Norman, luckily, did not see it, and heard only the suave reply:",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000036_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Certainly, Sir Norman; I shall be delighted to do so.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000038_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "Go on!\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000039_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "I have nothing to go on about; it is you who are to begin the controversy.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000040_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Do you dare to play with me?\" exclaimed Sir Norman, furiously.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000040_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000040_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"I tell you to take care how you speak!",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000040_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000040_000002.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "What have you done with Leoline?\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000041_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"That is the fourth or fifth time that you've asked me that question,\" said the count, with provoking indifference.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000041_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"What do you imagine I have done with her?\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000043_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Not yet, Sir Norman.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000043_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "Be calm; talk rationally.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000045_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000045_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "No; I am never afraid to father my own deeds.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000046_000001.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Then you acknowledge it?\"",
