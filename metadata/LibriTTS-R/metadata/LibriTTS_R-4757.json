        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000060_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"What extraordinary bad taste!\" said the count, thoughtfully.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000060_000001",
