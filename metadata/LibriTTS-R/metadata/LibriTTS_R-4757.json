        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000076_000002.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "Do you give it?\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4757_1811_000080_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4757/1811/4757_1811_000080_000000.wav",
        "speaker_id": "LibriTTS_R-4757",
        "content": "\"Well,\" was that individual's eager address, \"were you successful?\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
