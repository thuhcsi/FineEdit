[
    {
        "item_name": "LibriTTS_R-298_126790_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000005_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Katy, is he gone?\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000008_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Hearts,\" repeated Katy, catching her breath.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000011_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "He died about two hours and ten minutes before the cock crowed, as near as we can say.\" She was interrupted by the physician, who, approaching, inquired, with much interest, the nature of the disorder.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000011_000002.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Glancing her eye over the figure of this new acquaintance, Katy instinctively adjusting her dress, replied,--",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000014_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "My brothers told me, again and again, to ask for my money; but I always thought accounts between relations were easily settled.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000015_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Were you related, then, to Birch?\" asked Miss Peyton, observing her to pause.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000016_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Why,\" returned the housekeeper, hesitating a little, \"I thought we were as good as so.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000016_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "I wonder if I have no claim on the house and garden; though they say, now it is Harvey's, it will surely be confiscated.\" Turning to Lawton, who had been sitting in one posture, with his piercing eyes lowering at her through his thick brows, in silence, \"Perhaps this gentleman knows-he seems to take an interest in my story.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000031_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Who administered to the case?\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000032_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"No one yet,\" said the housekeeper, with quickness.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000032_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"I expect he has made his last will and testament.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000034_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"It is doubtless wise to be prepared for death.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000035_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"And care thrown away I may well call it; for Harvey is quite too despisable to be any sort of compensation at present.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000038_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Kindly, you may be certain,\" said Katy, rather tartly.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000039_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"The doctor means medically, madam,\" observed Captain Lawton, with a face that would have honored the funeral of the deceased.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000041_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"With simples,\" returned the surgeon.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000044_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Oh!\" cried the maiden, again correcting herself, \"for the best of all reasons; there was none to be had, so I took care of him myself.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000052_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000052_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "But it is my lot to meet with men, daily, who are equally perverse, and who show a still more culpable disrespect for the information that flows from the lights of science.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000065_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000065_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"If them lights he spoke of were what was called northern lights in these parts?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000069_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000069_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Katy drew up in evident displeasure, and prompt to vindicate her character for more lofty acquirements, she said,--",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000072_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000072_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "The substance of her tale was, that a child who had been placed by the guardians of the poor in the keeping of Harvey, had, in the absence of its master, injured itself badly in the foot by a large needle.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000072_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000072_000003.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "The arrival of the peddler had altered the whole of this admirable treatment; and the consequences were expressed by Katy, as she concluded her narrative, by saying,--",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000074_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000074_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "He was impelled, by a feeling that he could not conquer, however, to look Captain Lawton in the face.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000075_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000075_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Miss Peyton entered into the situation of things at the house of the peddler, with all the interest of her excellent feelings; she listened patiently while Katy recounted, more particularly, the circumstances of the past night as they had occurred.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000076_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000076_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"For, Miss Peyton,\" continued the housekeeper, after a pause to take breath, \"I would have given up life before I would have given up that secret.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000079_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000079_000005.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Some time was occupied in joint attentions to the comfort of the wounded officer, and the doctor retired to an apartment prepared for his own accommodation; here, within a few minutes, he was surprised by the entrance of Lawton.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000082_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000082_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Does Captain Lawton want anything at my hands?\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000084_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000084_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"But happily nothing is broken. It is wonderful how well you escaped!\"",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000085_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000085_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"I have been a tumbler from my youth, and I am past minding a few falls from a horse; but, Sitgreaves,\" he added with affection, and pointing to a scar on his body, \"do you remember this bit of work?\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000086_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000086_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Perfectly well, Jack; it was bravely obtained, and neatly extracted; but don't you think I had better apply an oil to these bruises?\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000087_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000087_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Certainly,\" said Lawton, with unexpected condescension.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000089_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000089_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Quite probable.\"",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000092_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000092_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"It is now too late; but a dose of oil would carry off the humors famously.\"",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000101_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000101_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Quite.\"",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000102_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000102_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"I agree with you as a whole; but as matter is infinitely divisible, so no case exists without an exception.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000102_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000102_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Lawton, do you feel easy?\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000103_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000103_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Very.\"",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000104_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000104_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"It is not only cruel to the sufferer, but sometimes unjust to others, to take human life where a less punishment would answer the purpose. Now, Jack, if you were only-move your arm a little-if you were only-I hope you feel easier, my dear friend?\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126790_000105_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126790/298_126790_000105_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Much.\"",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000008_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "The morning found them all restored, in some measure, to their former ease of body, with the exception of the youthful captain of dragoons, who had been so deeply regretted by Dunwoodie.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000010_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Growing symptoms of a febrile pulse-no, no, my dear George, you must remain quiet and dumb; though your eyes look better, and your skin has even a moisture.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000012_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"The tongue is well, and the pulse begins to lower again.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000012_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000012_000006.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Your pulse even and soft, your skin moist, but your eye fiery, and cheek flushed.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000014_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "If it be not to enable us to decide in such matters, of what avail the lights of science?",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000014_000003.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Even that perverse fellow, john Lawton, could not behave with more obstinacy.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000020_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Had it petticoats, George?\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000022_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"It must have been Miss Jeanette Peyton-a lady of fine accomplishments, with-hem-with something of the kind of step you speak of-a very complacent eye; and as to the bloom, I dare say offices of charity can summon as fine a color to her cheeks, as glows in the faces of her more youthful nieces.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000024_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "You must observe quiet, and prepare for a meeting with your own sister, who will be here within an hour.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000025_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"What, Isabella!",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000025_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "And who sent for her?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000026_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"The major.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000030_000002.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "His case, young lady, exceeds my art to heal; and I take it Sir Henry Clinton is the best adviser he can apply to; though Major Dunwoodie has made the communication with his leech rather difficult.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000034_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"As respectfully as you please, my dear sister; there is but little danger of exceeding the truth.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000035_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"But I think mr Dunwoodie has taken a liberty that exceeds the rights of consanguinity; he has made our father's house a hospital.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000036_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"We ought to be grateful that none of the patients it contains are dearer to us.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000038_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "If,\" she added, with a tremulous lip, \"this dreadful suspicion that is affixed to his visit were removed, I could consider his wound of little moment.\"",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000039_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"You now have the fruits of rebellion brought home to you; a brother wounded and a prisoner, and perhaps a victim; your father distressed, his privacy interrupted, and not improbably his estates torn from him, on account of his loyalty to his king.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000040_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Frances continued her walk in silence.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000040_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000040_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "While facing the northern entrance to the vale, her eyes were uniformly fastened on the point where the road was suddenly lost by the intervention of a hill; and at each turn, as she lost sight of the spot, she lingered until an impatient movement of her sister quickened her pace to an even motion with that of her own.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000040_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000040_000004.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "In a few minutes the travelers approached the gate. It was thrown open by a dragoon who followed the carriage, and who had been the messenger dispatched by Dunwoodie to the father of Captain Singleton.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000040_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000040_000006.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "She was young, and of a light and fragile form, but of exquisite proportions.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000040_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000040_000007.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Her eyes were large, full, black, piercing, and at times a little wild.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000040_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000040_000008.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "Her hair was luxuriant, and as it was without the powder it was then the fashion to wear, it fell in raven blackness. A few of its locks had fallen on her cheek, giving its chilling whiteness by the contrast a more deadly character.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000042_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "The lady burst into a flood of tears.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000043_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "The meeting between the brother and sister was warm, but, by an effort on the part of the lady, more composed than her previous agitation had given reason to expect.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000044_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"The excellent fellow is never weary of kind actions.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000046_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Dunwoodie!",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000046_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000046_000002.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "I thought to have met him by the side of my brother's bed.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000047_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"He has duties that require his presence elsewhere; the English are said to be out by the way of the Hudson, and they give us light troops but little rest.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000047_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000047_000002.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "But, Isabella, the meeting has been too much for you; you tremble.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000049_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Doubtless it is his duty.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000050_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"On the march, Isabella?\" eagerly inquired her brother.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000053_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"If you can pardon the rudeness,\" said the wounded officer, making a feeble effort to raise his body, \"I would request to have Captain Lawton's company for a moment.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000055_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000055_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Lawton,\" said the youth, impatiently, as the trooper entered, \"hear you from the major?\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000058_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000058_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"And why not himself?\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000059_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000059_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"That is a question the major can answer best; but you know the redcoats are abroad, and Dunwoodie commands in the county; these English must be looked to.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000064_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000064_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Oh!",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000071_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000071_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"She must be under twenty,\" said the other, quickly.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000072_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000072_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"It depends on the way you count.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000072_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000072_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "If you begin at the heel of life, well; but if you reckon downward, as is most common, I think she is nearer forty.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000073_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000073_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"You must be silent!",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000077_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000077_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Very true,\" replied the captain, kicking a slipper towards the bed. \"Had we succeeded in getting a few good fires upon them in flank, we should have sent these brave Virginians to the right about.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000078_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000078_000001.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"Then it was necessary to rout the guides, you know, and the movement gave them the best possible opportunity to charge.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000081_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000081_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"At least they would have been, had they made an attack,\" said the captain, throwing the rest of his clothes within reach of the colonel.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-298_126791_000084_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/298/126791/298_126791_000084_000000.wav",
        "speaker_id": "LibriTTS_R-298",
        "content": "\"True-true,\" cried the colonel, with animation.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    }
