        "speaker_id": "LibriTTS_R-698",
        "content": "\"Just the girls in our class.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-698_122863_000004_000000",
