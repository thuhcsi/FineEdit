        "speaker_id": "LibriTTS_R-698",
        "content": "\"I dare you to climb up there and walk the ridgepole of mr Barry's kitchen roof.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
