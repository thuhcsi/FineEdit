        "speaker_id": "LibriTTS_R-698",
        "content": "Nevertheless, she managed to take several steps before the catastrophe came.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-698_122863_000016_000002",
