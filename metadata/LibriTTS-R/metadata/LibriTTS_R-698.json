        "speaker_id": "LibriTTS_R-698",
        "content": "\"Oh, Anne, dear Anne, speak just one word to me and tell me if you're killed.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
