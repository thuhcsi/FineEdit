        "speaker_id": "LibriTTS_R-698",
        "content": "\"Then I dare you to do it,\" said Josie defiantly.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
