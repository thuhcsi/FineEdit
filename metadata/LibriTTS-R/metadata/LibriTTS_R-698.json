        "speaker_id": "LibriTTS_R-698",
        "content": "\"My ankle,\" gasped Anne.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-698_122863_000023_000001",
