        "speaker_id": "LibriTTS_R-698",
        "content": "\"I shall walk that ridgepole, Diana, or perish in the attempt.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
