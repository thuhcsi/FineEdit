        "speaker_id": "LibriTTS_R-698",
        "content": "YOU couldn't, anyhow.\"",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
