        "speaker_id": "LibriTTS_R-698",
        "content": "Josie descended from her perch, flushed with victory, and darted a defiant glance at Anne.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
