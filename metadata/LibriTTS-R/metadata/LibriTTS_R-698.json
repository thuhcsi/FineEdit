        "speaker_id": "LibriTTS_R-698",
        "content": "\"I don't believe anybody could walk a ridgepole.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-698_122863_000010_000002",
