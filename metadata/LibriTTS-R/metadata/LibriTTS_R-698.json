        "speaker_id": "LibriTTS_R-698",
        "content": "\"Small and select,\" Anne assured Marilla.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
