        "speaker_id": "LibriTTS_R-1958",
        "content": "'He died the night before we went to Canterbury?' said i My aunt nodded.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
