        "speaker_id": "LibriTTS_R-1958",
        "content": "'I went.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
