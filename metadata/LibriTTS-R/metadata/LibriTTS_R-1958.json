        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1958/144503/1958_144503_000115_000000.wav",
        "speaker_id": "LibriTTS_R-1958",
        "content": "'Did he die in the hospital?'",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
