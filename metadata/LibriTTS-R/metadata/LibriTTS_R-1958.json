        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1958/144503/1958_144503_000052_000003.wav",
        "speaker_id": "LibriTTS_R-1958",
        "content": "So many people know me here, and think kindly of me, that I am certain.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
