        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1958/144503/1958_144503_000075_000005.wav",
        "speaker_id": "LibriTTS_R-1958",
        "content": "Always creeping along the ground to some small end or other, he will always magnify every object in the way; and consequently will hate and suspect everybody that comes, in the most innocent manner, between him and it.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
