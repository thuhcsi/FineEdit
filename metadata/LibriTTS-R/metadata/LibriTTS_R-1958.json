        "speaker_id": "LibriTTS_R-1958",
        "content": "'Next, Miss Trotwood,' said Traddles, 'that property of yours.'",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
