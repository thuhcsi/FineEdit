        "speaker_id": "LibriTTS_R-1958",
        "content": "He was sorry then.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
