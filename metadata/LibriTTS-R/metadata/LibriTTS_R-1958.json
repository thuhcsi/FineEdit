        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1958/144503/1958_144503_000083_000000.wav",
        "speaker_id": "LibriTTS_R-1958",
        "content": "'Well!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1958_144503_000084_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1958/144503/1958_144503_000084_000000.wav",
        "speaker_id": "LibriTTS_R-1958",
        "content": "'Yes, but I don't know when they may be proceeded on, or where they are,' rejoined Traddles, opening his eyes; 'and I anticipate, that, between this time and his departure, mr Micawber will be constantly arrested, or taken in execution.'",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1958_144503_000085_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1958/144503/1958_144503_000085_000001.wav",
        "speaker_id": "LibriTTS_R-1958",
        "content": "'What's the amount altogether?'",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1958_144503_000086_000000",
