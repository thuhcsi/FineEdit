        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1958/144503/1958_144503_000114_000000.wav",
        "speaker_id": "LibriTTS_R-1958",
        "content": "'You understand it now, Trot,' said my aunt.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
