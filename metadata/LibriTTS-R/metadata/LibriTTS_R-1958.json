        "speaker_id": "LibriTTS_R-1958",
        "content": "When he knew his state in this last illness, he asked them to send for me.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
