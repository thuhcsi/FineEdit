        "speaker_id": "LibriTTS_R-1958",
        "content": "'Why, the fact is,' returned Traddles, 'mr",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
