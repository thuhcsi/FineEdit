        "speaker_id": "LibriTTS_R-1958",
        "content": "'I am quite myself,' said I, after a pause.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
