        "speaker_id": "LibriTTS_R-1958",
        "content": "What should it be?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1958_144503_000087_000003",
