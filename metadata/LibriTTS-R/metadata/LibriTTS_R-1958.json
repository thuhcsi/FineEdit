        "speaker_id": "LibriTTS_R-1958",
        "content": "Dear mr Traddles and dear Trotwood, papa once free with honour, what could I wish for!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
