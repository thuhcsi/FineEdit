        "speaker_id": "LibriTTS_R-1958",
        "content": "'I must do mr Micawber the justice to say,' Traddles began, 'that although he would appear not to have worked to any good account for himself, he is a most untiring man when he works for other people.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
