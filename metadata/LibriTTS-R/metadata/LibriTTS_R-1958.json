        "speaker_id": "LibriTTS_R-1958",
        "content": "I never saw such a fellow.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
