[
    {
        "item_name": "LibriTTS_R-2733_28252_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000001_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "WINTER QUARTERS",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000002_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The habitation that had now revealed itself, well lighted and thoroughly warm, was indeed marvelous.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000003_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "This enormous cavern was neither more or less than the common junction of nearly twenty tunnels (similar to that which had been traversed by the explorers), forming ramifications in the solid rock, and the pores, as it were, by which the internal heat exuded from the heart of the mountain.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000004_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "But not a day, not an hour, was to be lost now.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000004_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The steam launch returned to Gourbi Island, and preparations were forthwith taken in hand for conveying man and beast, corn and fodder, across to the volcanic headland.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000005_000002.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "First of all, the large store of corn and fodder, the produce of the recent harvest, was landed and deposited in one of the vaults; then, on the fifteenth, about fifty head of live cattle-bullocks, cows, sheep, and pigs-were conveyed to their rocky stalls.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000005_000003.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "These were saved for the sake of preserving the several breeds, the bulk of the island cattle being slaughtered, as the extreme severity of the climate insured all meat remaining fresh for almost an indefinite period.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000006_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "And if haste were necessary, so also were care, ingenuity, and forethought.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000006_000002.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "It was indispensable that the space at their command should be properly utilized, and yet that the several portions of the store should all be readily accessible.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000007_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "On further investigation an unexpected number of galleries was discovered, so that, in fact, the interior of the mountain was like a vast bee hive perforated with innumerable cells; and in compliment to the little Italian it was unanimously voted by the colony that their new home should be called \"Nina's Hive.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000009_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"What a saving of expense it would be,\" exclaimed Ben Zoof, \"if every household could be furnished with its own private volcano!\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000010_000002.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The curtain of fire extending over the opening of the cavern provided it, as already stated, with light and heat.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000012_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The Spaniards and the Russian sailors took up their sleeping quarters in the adjacent galleries, and found the temperature quite comfortable.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000014_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The only discontented spirit was Isaac Hakkabut.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000014_000003.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "He had given out in plain terms that he did not intend to part with any of his property, except for current money, and Servadac, equally resolute, had strictly forbidden any purchases to be made, hoping to wear out the rascal's obstinacy.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000015_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Hakkabut persistently refused to credit the real situation; he could not absolutely deny that some portions of the terrestrial globe had undergone a certain degree of modification, but nothing could bring him to believe that he was not, sooner or later, to resume his old line of business in the Mediterranean.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000015_000002.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Repudiating, as he did utterly, the hypothesis that a fragment had become detached from the earth, he scanned the horizon for hours together with an old telescope, the case of which had been patched up till it looked like a rusty stove pipe, hoping to descry the passing trader with which he might effect some bartering upon advantageous terms.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000017_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The movement set him thinking.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000017_000003.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "What if he should never again behold his German fatherland?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000017_000004.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "What if his marts for business were gone for ever?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000017_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000017_000005.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "A vague idea of ruin began to take possession of his mind: he must yield to necessity; he must do the best he could.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000017_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000017_000006.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "As the result of his cogitations, he occasionally left his tartan and made a visit to the shore.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000017_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000017_000007.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "At length he endeavored to mingle with the busy group, who were hurrying on their preparations; but his advances were only met by jeers and scorn, and, ridiculed by all the rest, he was fain to turn his attention to Ben Zoof, to whom he offered a few pinches of tobacco.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000019_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Finding the subordinates incorruptible, Isaac determined to go to the fountain head.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000020_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"Tell you the truth, man!\" cried Servadac.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000020_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"Confound it, I have told you the truth twenty times.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000021_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"God and Mahomet have mercy on me!\" muttered the Jew, whose creed frequently assumed a very ambiguous character.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000023_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"But I want to go to Algiers,\" whimpered Hakkabut.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000024_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"How often am I to tell you that Algiers is no longer in existence?",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000025_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"God of Israel! what is to become of all my property?\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000026_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "I am not going to let your cursed obstinacy incur the risk of losing your cargo altogether.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000027_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"Merciful Heaven!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000028_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"You are going the right way to ruin yourself, and it would serve you right to leave you to your own devices.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000028_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "But be off!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000028_000002.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "I have no more to say.\"",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000030_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "By the twentieth all preliminary arrangements were complete, and everything ready for a final departure from the island.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000030_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The thermometer stood on an average at eight degrees below zero, and the water in the cistern was completely frozen.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000030_000002.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "It was determined, therefore, for the colony to embark on the following day, and take up their residence in Nina's Hive.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000031_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Lieutenant Procope pronounced his decided conviction that it would be impossible for the tartan to resist the pressure of the ice in the harbor of the Shelif, and that there would be far more safety in the proximity of the volcano.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000032_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Long and loud were the lamentations of the Jew.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000033_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"God of Israel!\" he said in an undertone, \"they have made no charge; the idiots have piloted me here for nothing.\"",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000034_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "For nothing!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000034_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "His whole nature exulted in the consciousness that he was enjoying a service that had been rendered gratuitously.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000035_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Destitute of human inhabitants, Gourbi Island was now left to the tenancy of such birds and beasts as had escaped the recent promiscuous slaughter.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000035_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000035_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Birds, indeed, that had migrated in search of warmer shores, had returned, proving that this fragment of the French colony was the only shred of land that could yield them any sustenance; but their life must necessarily be short.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000036_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The colony took possession of their new abode with but few formalities. Everyone, however, approved of all the internal arrangements of Nina's Hive, and were profuse in their expressions of satisfaction at finding themselves located in such comfortable quarters.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000036_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The only malcontent was Hakkabut; he had no share in the general enthusiasm, refused even to enter or inspect any of the galleries, and insisted on remaining on board his tartan.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000037_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"He is afraid,\" said Ben Zoof, \"that he will have to pay for his lodgings.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000037_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "But wait a bit; we shall see how he stands the cold out there; the frost, no doubt, will drive the old fox out of his hole.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000038_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Towards evening the pots were set boiling, and a bountiful supper, to which all were invited, was spread in the central hall.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000040_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The concert was succeeded by a ball, unquestionably the first that had ever taken place in Gallia.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000040_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000040_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "The Russian sailors exhibited some of their national dances, which gained considerable applause, even although they followed upon the marvelous fandangos of the Spaniards.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000041_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "It was nine o'clock before the festivities came to an end, and by that time the company, heated by the high temperature of the hall, and by their own exertions, felt the want of a little fresh air.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000041_000001.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Accordingly the greater portion of the party, escorted by Ben Zoof, made their way into one of the adjacent galleries that led to the shore.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000041_000002.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Servadac, with the count and lieutenant, did not follow immediately; but shortly afterwards they proceeded to join them, when on their way they were startled by loud cries from those in advance.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000042_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Their first impression was that they were cries of distress, and they were greatly relieved to find that they were shouts of delight, which the dryness and purity of the atmosphere caused to re echo like a volley of musketry.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000043_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "Reaching the mouth of the gallery, they found the entire group pointing with eager interest to the sky.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000044_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"Well, Ben Zoof,\" asked the captain, \"what's the matter now?\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2733_28252_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2733/28252/2733_28252_000045_000000.wav",
        "speaker_id": "LibriTTS_R-2733",
        "content": "\"Oh, your Excellency,\" ejaculated the orderly, \"look there! look there! The moon! the moon's come back!\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    }
]