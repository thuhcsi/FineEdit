        "speaker_id": "LibriTTS_R-8619",
        "content": "-- and the king was borne, hoary hero, to Hrones Ness.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
