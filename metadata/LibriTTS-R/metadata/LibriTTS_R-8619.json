        "speaker_id": "LibriTTS_R-8619",
        "content": "Few words he spake: \"Now hold thou, earth, since heroes may not, what earls have owned!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
