        "speaker_id": "LibriTTS_R-8619",
        "content": "-- 'twas a lord unpeered, every way blameless, till age had broken -- it spareth no mortal -- his splendid might.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
