        "speaker_id": "LibriTTS_R-8619",
        "content": "The stark heart found footprint of foe who so far had gone in his hidden craft by the creature's head.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
