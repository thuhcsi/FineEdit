        "speaker_id": "LibriTTS_R-8619",
        "content": "The fiery dragon, fearful fiend, with flame was scorched. Reckoned by feet, it was fifty measures in length as it lay.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
