        "speaker_id": "LibriTTS_R-8619",
        "content": "Alive was he still, still wielding his wits.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
