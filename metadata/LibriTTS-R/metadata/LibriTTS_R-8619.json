        "speaker_id": "LibriTTS_R-8619",
        "content": "My brave are gone. And the helmet hard, all haughty with gold, shall part from its plating.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
