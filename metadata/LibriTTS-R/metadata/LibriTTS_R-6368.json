        "speaker_id": "LibriTTS_R-6368",
        "content": "A PRESENTMENT OF THE PAST.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6368_230929_000004_000000",
