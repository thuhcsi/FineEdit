        "speaker_id": "LibriTTS_R-6196",
        "content": "The evidence of the sense, helped and guarded by a certain process of correction, I retain.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
