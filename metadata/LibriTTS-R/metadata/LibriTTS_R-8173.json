[
    {
        "item_name": "LibriTTS_R-8173_294714_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000000_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "LOVE AND MONEY.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000001_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "FEELING the embarrassment of the moment most painfully on her side, mrs Van Brandt spoke first.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000002_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"You have said nothing to me about yourself,\" she began.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000002_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Is your life a happier one than it was when we last met?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000003_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"I cannot honestly say that it is,\" I answered.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000004_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Is there any prospect of your being married?\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000005_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"My prospect of being married still rests with you.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Don't say that!\" she exclaimed, with an entreating look at me.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000006_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Don't spoil my pleasure in seeing you again by speaking of what can never be! Have you still to be told how it is that you find me here alone with my child?\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000009_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"He left me the little money he had with him when he was arrested,\" she rejoined, sadly.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000010_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Even this negative defense of Van Brandt stung me to the quick.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"I ought to have spoken more guardedly of him,\" I said, bitterly.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000012_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "She put her hand on my mouth, and stopped me before I could say any more.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000013_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"How can you speak so cruelly to me?\" she asked.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000013_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"You know-to my shame I confessed it to you the last time we met-you know that my heart, in secret, is all yours.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000013_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "What 'wrong' are you talking of?",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000013_000003.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Is it the wrong I suffered when Van Brandt married me, with a wife living at the time (and living still)?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000013_000004.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Do you think I can ever forget the great misfortune of my life-the misfortune that has made me unworthy of you?",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000013_000005.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "It is no fault of mine, God knows; but it is not the less true that I am not married, and that the little darling who is playing out there with her doll is my child.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000013_000006.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "And you talk of my being your wife-knowing that!\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"The child accepts me as her second father,\" I said.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000015_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Pride?\" she repeated.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000015_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"In such a position as mine?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000015_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "A helpless woman, with a mock husband in prison for debt!",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000015_000004.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Am I to marry you for my food and shelter?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000015_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000015_000008.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "My only friend, is it possible that you think me ungrateful enough to consent to be your wife?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000015_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000015_000009.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "The woman (in my situation) must be heartless indeed who could destroy your place in the estimation of the world and the regard of your friends!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000015_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000015_000010.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "The wretchedest creature that walks the streets would shrink from treating you in that way.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000016_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "I yielded---and spoke of it no more.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000016_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Every word she uttered only increased my admiration of the noble creature whom I had loved, and lost.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000016_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000016_000004.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Bitterly as I hated the man who had parted us, I loved her dearly enough to be even capable of helping him for her sake.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000016_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000016_000005.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Hopeless infatuation!",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000016_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000016_000006.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "I don't deny it; I don't excuse it-hopeless infatuation!",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000017_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"You have forgiven me,\" I said.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000017_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Let me deserve to be forgiven.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000017_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "It is something to be your only friend.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000017_000003.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "You must have plans for the future; tell me unreservedly how I can help you.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Complete the good work that you have begun,\" she answered, gratefully. \"Help me back to health.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000018_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Make me strong enough to submit to a doctor's estimate of my chances of living for some years yet.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000019_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"A doctor's estimate of your chances of living?\" I repeated.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000019_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"What do you mean?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"I hardly know how to tell you,\" she said, \"without speaking again of mr Van Brandt.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000021_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Does speaking of him again mean speaking of his debts?\" I asked.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000021_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Why need you hesitate?",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000022_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "She looked at me for a moment, in silent distress.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000023_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Oh! do you think I would let you give your money to Van Brandt?\" she asked, as soon as she could speak.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000023_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000023_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Never!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000023_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000023_000003.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Let me tell you the plain truth.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000023_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000023_000004.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "There is a serious necessity for his getting out of prison.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000024_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Your help?\" I exclaimed.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000025_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Yes.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000025_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "This is his position, in two words: A little while since, he obtained an excellent offer of employment abroad, from a rich relative of his, and he had made all his arrangements to accept it.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000025_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Unhappily, he returned to tell me of his good fortune, and the same day he was arrested for debt.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000025_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000025_000003.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "His relative has offered to keep the situation open for a certain time, and the time has not yet expired.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000025_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000025_000004.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "If he can pay a dividend to his creditors, they will give him his freedom; and he believes he can raise the money if I consent to insure my life.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000026_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "To insure her life!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000026_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "The snare that had been set for her was plainly revealed in those four words.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000027_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "In the eye of the law she was, of course, a single woman: she was of age; she was, to all intents and purposes, her own mistress.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000027_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "What was there to prevent her from insuring her life, if she pleased, and from so disposing of the insurance as to give Van Brandt a direct interest in her death?",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000027_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Knowing what I knew of him-believing him, as I did, to be capable of any atrocity-I trembled at the bare idea of what might have happened if I had failed to find my way back to her until a later date. Thanks to the happy accident of my position, the one certain way of protecting her lay easily within my reach.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000028_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"I am very unfortunate; I seem to have innocently disturbed and annoyed you for the second time.\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000029_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"You are quite mistaken,\" I replied.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000029_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"I am only doubting whether your plan for relieving mr Van Brandt of his embarrassments is quite so simple as you suppose.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000029_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Are you aware of the delays that are likely to take place before it will be possible to borrow money on your policy of insurance?\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000030_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"I know nothing about it,\" she said, sadly.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000031_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Will you let me ask the advice of my lawyers?",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000031_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "They are trustworthy and experienced men, and I am sure they can be of use to you.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000032_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "Cautiously as I had expressed myself, her delicacy took the alarm.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000033_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Promise that you won't ask me to borrow money of you for mr Van Brandt,\" she rejoined, \"and I will accept your help gratefully.\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000034_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "I could honestly promise that.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000034_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "My one chance of saving her lay in keeping from her knowledge the course that I had now determined to pursue.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000034_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000034_000002.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "I rose to go, while my resolution still sustained me.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000035_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "She rose, as I rose-with the tears in her eyes, and the blush on her cheeks.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000036_000000.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "\"Kiss me,\" she whispered, \"before you go!",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000036_000001.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "And don't mind my crying.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8173_294714_000036_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8173/294714/8173_294714_000036_000003.wav",
        "speaker_id": "LibriTTS_R-8173",
        "content": "It is only your goodness that overpowers me.\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
