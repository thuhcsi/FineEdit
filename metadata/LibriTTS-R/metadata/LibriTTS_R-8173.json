        "speaker_id": "LibriTTS_R-8173",
        "content": "\"For the last time!\" I thought, as I held her to me for a moment longer-\"for the last time!\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
