        "speaker_id": "LibriTTS_R-8173",
        "content": "When my interference had restored my unworthy rival to his freedom, could I submit to the degrading necessity of seeing her in his presence, of speaking to her under his eyes?",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
