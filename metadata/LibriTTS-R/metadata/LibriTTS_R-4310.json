        "speaker_id": "LibriTTS_R-4310",
        "content": "A brace of very beautiful bitches are mr f Eyer's Dorset Girl and Miss w Easton's Okeford Queen.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
