        "speaker_id": "LibriTTS_R-4310",
        "content": "POINTS OF THE CHOW CHOW: HEAD-Skull flat and broad, with little stop, well filled out under the eyes.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
