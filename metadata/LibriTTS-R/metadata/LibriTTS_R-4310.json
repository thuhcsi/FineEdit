        "speaker_id": "LibriTTS_R-4310",
        "content": "EYES-Dark and small. (In a blue dog light colour is permissible.) EARS-Small, pointed, and carried stiffly erect.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
