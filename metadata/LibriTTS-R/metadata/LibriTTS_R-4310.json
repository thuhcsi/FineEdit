        "speaker_id": "LibriTTS_R-4310",
        "content": "Dark red is the accepted colour of the Chow.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
