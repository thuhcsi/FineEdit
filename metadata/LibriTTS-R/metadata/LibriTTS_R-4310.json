        "speaker_id": "LibriTTS_R-4310",
        "content": "On one occasion after competing successfully at the Kennel Club Show at the Crystal Palace, he was taken to a coursing meeting where he won the stake in which he was entered.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
