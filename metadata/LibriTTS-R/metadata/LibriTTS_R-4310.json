        "speaker_id": "LibriTTS_R-4310",
        "content": "These were drawn up by the then Duke of Norfolk.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
