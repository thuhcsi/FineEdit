        "speaker_id": "LibriTTS_R-4310",
        "content": "Fullerton was a good looking dog, if not quite up to the form required in the show ring.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
