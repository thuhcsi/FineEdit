        "speaker_id": "LibriTTS_R-4310",
        "content": "Then in seventeen eighty the Ashdown Park Meeting came into existence.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
