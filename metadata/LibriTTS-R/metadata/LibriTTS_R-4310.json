        "speaker_id": "LibriTTS_R-4310",
        "content": "The judges would be quite wrong, but if you want a dog for show you must be sure to get a good whole coloured dark red.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
