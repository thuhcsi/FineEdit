        "speaker_id": "LibriTTS_R-4310",
        "content": "These are natural, correct and typical marks, though present day fanciers are trying to \"improve\" them away.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
