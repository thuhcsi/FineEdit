        "speaker_id": "LibriTTS_R-453",
        "content": "Stick up to her, Tom.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
