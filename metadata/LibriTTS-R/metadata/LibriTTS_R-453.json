        "speaker_id": "LibriTTS_R-453",
        "content": "'No more it is,' replied the Jew; 'Charley will talk.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-453_129308_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/453/129308/453_129308_000017_000001.wav",
        "speaker_id": "LibriTTS_R-453",
        "content": "Don't mind him, my dear; don't mind him.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-453_129308_000017_000003",
