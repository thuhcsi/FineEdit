        "speaker_id": "LibriTTS_R-453",
        "content": "'There, now. Ah!",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
