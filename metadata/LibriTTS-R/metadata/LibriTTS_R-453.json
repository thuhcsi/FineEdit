        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-453_131332_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/453/131332/453_131332_000038_000001.wav",
        "speaker_id": "LibriTTS_R-453",
        "content": "Oh, he was early there.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-453_131332_000038_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/453/131332/453_131332_000038_000002.wav",
        "speaker_id": "LibriTTS_R-453",
        "content": "If he could only be there first, and catch Bob Cratchit coming late!",
