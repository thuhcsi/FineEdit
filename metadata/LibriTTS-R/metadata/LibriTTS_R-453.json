        "speaker_id": "LibriTTS_R-453",
        "content": "I don't know one of 'em that would do it besides you; not one of 'em, my dear.'",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
