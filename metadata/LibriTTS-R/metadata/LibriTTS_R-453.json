        "speaker_id": "LibriTTS_R-453",
        "content": "'What!' cried the Jew, 'alone?'",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
