        "speaker_id": "LibriTTS_R-453",
        "content": "The old man bit his yellow fingers, and meditated for some seconds; his face working with agitation the while, as if he dreaded something, and feared to know the worst.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
