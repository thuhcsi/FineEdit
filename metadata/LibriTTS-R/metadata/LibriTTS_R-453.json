        "speaker_id": "LibriTTS_R-453",
        "content": "Stick up to her.'",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
