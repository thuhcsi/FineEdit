        "speaker_id": "LibriTTS_R-453",
        "content": "The Dodger pointed to the floor above, and made a gesture, as if to leave the room.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-453_129308_000036_000000",
