        "speaker_id": "LibriTTS_R-453",
        "content": "Scrooge sat with his door wide open, that he might see him come into the Tank.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
