        "speaker_id": "LibriTTS_R-453",
        "content": "'No, no, to be sure,' replied the Jew; 'you were too stout hearted for that.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
