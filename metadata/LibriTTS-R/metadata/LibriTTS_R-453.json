        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/453/131332/453_131332_000037_000002.wav",
        "speaker_id": "LibriTTS_R-453",
        "content": "Nothing could be heartier. His niece looked just the same.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
