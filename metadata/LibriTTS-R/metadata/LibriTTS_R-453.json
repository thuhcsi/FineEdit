        "speaker_id": "LibriTTS_R-453",
        "content": "'Ah, to be sure, my dear,' replied the Jew.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
