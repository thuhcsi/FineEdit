        "speaker_id": "LibriTTS_R-453",
        "content": "'Yes,' said the Jew, answering the mute inquiry; 'bring him down.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-453_129308_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/453/129308/453_129308_000036_000002.wav",
        "speaker_id": "LibriTTS_R-453",
        "content": "Gently, Tom!",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
