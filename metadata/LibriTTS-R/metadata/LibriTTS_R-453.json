        "speaker_id": "LibriTTS_R-453",
        "content": "But it turned out a good job for you; didn't it, Fagin!",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
