        "speaker_id": "LibriTTS_R-453",
        "content": "The Jew motioned to the Dodger to place what eatables there were, upon the table; and, seating himself opposite the housebreaker, waited his leisure.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-453_131332_000037_000001",
