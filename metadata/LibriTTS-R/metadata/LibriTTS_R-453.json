        "speaker_id": "LibriTTS_R-453",
        "content": "So did Topper when he came.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
