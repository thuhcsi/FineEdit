        "speaker_id": "LibriTTS_R-453",
        "content": "Do as she bids you, Tom, and you will make your fortune.'",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
