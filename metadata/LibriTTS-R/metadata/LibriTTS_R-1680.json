        "speaker_id": "LibriTTS_R-1680",
        "content": "Only suppose that your mother's health or yours should suffer.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
