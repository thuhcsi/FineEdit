        "speaker_id": "LibriTTS_R-1680",
        "content": "'Not at all, thank you, Dixon,' replied Margaret, coldly.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
