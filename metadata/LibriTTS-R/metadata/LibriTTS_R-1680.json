        "speaker_id": "LibriTTS_R-1680",
        "content": "They were at the lowest now; they could not be worse.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
