        "speaker_id": "LibriTTS_R-1680",
        "content": "Margaret had joined the party in the evening.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
