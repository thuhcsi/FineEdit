        "speaker_id": "LibriTTS_R-1680",
        "content": "She had heard him often boast of his power of putting any disagreeable thought far away from him.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
