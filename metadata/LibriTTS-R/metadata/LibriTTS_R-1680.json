        "speaker_id": "LibriTTS_R-1680",
        "content": "There was no comfort to be given.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
