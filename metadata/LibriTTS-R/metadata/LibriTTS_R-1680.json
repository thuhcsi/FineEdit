        "speaker_id": "LibriTTS_R-1680",
        "content": "But if she had known how long it would be before the brightness came, her heart would have sunk low down.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
