        "speaker_id": "LibriTTS_R-1680",
        "content": "It loomed through the fog like a great barrier to hope.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
