        "speaker_id": "LibriTTS_R-1680",
        "content": "Edith's astonishment and her aunt Shaw's dismay would have to be met bravely, when their letters came.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
