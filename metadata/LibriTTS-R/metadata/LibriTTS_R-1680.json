        "speaker_id": "LibriTTS_R-1680",
        "content": "She doubted if any one of that old set ever thought of her, except Henry Lennox.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
