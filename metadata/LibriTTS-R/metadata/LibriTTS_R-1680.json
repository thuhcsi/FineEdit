        "speaker_id": "LibriTTS_R-1680",
        "content": "Then she penetrated farther into what might have been.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
