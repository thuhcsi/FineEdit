    {
        "item_name": "LibriTTS_R-8459_285173_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8459/285173/8459_285173_000021_000001.wav",
        "speaker_id": "LibriTTS_R-8459",
        "content": "I love a sheep from the bottom of my heart.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
