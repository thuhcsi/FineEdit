        "speaker_id": "LibriTTS_R-2506",
        "content": "Good, honest, simple, lord loving children of Snobland.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
