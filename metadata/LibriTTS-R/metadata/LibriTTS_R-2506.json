        "speaker_id": "LibriTTS_R-2506",
        "content": "How would you account for the prodigious benevolence exercised towards the interesting young French lady?",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
