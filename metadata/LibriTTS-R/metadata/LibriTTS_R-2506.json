        "speaker_id": "LibriTTS_R-2506",
        "content": "The Right Honourable was the son of a nobleman, and practised on an old lady.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
