        "speaker_id": "LibriTTS_R-2506",
        "content": "The Mortgager and Mortgagee differ the one from the other, not more in length of purse, than the Jester and Jestee do, in that of memory.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
