        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2506/11267/2506_11267_000009_000001.wav",
        "speaker_id": "LibriTTS_R-2506",
        "content": "Bull passes the season in London, sponging for dinners, and sleeping in a garret near his Club.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2506_11267_000009_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2506/11267/2506_11267_000009_000007.wav",
        "speaker_id": "LibriTTS_R-2506",
        "content": "Faugh! the old brute!",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-2506_11267_000009_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2506/11267/2506_11267_000009_000011.wav",
        "speaker_id": "LibriTTS_R-2506",
        "content": "I told you he would.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2506_11267_000010_000001",
