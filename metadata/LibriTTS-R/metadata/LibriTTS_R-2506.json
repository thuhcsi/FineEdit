        "speaker_id": "LibriTTS_R-2506",
        "content": "What inclined Eugenius to the same opinion was as follows:",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
