        "speaker_id": "LibriTTS_R-2506",
        "content": "One day the traitor fled, with a teapot and a basketful of cold victuals.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
