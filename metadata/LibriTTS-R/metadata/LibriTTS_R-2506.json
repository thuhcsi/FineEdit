        "speaker_id": "LibriTTS_R-2506",
        "content": "Would they have been taken in by a commoner?",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
