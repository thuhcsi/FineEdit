        "speaker_id": "LibriTTS_R-2506",
        "content": "The strawberry leaves on her chariot panels are engraved on her ladyship's heart.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
