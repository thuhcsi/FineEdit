        "speaker_id": "LibriTTS_R-2506",
        "content": "There she sits, and will be ill in private.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
