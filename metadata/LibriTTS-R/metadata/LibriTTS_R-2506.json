        "speaker_id": "LibriTTS_R-2506",
        "content": "They will be at Ostend in four hours; they will inundate the Continent next week; they will carry into far lands the famous image of the British Snob.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
