        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/128/134884/128_134884_000014_000001.wav",
        "speaker_id": "LibriTTS_R-128",
        "content": "Bassorine. Gum.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
