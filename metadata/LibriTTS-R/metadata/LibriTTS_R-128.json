        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-128_134884_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/128/134884/128_134884_000014_000003.wav",
        "speaker_id": "LibriTTS_R-128",
        "content": "Beer. Grape sugar.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-128_134884_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/128/134884/128_134884_000014_000004.wav",
        "speaker_id": "LibriTTS_R-128",
        "content": "Spirits. Sugar of milk.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-128_134884_000017_000001",
