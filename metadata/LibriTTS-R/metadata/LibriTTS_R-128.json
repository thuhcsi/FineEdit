        "speaker_id": "LibriTTS_R-128",
        "content": "But the blood must be supplied to it perfect in everything but its form-that is, in its chemical composition.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
