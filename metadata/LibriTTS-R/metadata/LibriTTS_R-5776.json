[
    {
        "item_name": "LibriTTS_R-5776_46889_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000001_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "A CAPE HORN GALE.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000002_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "We stood on to the southward and westward during the remainder of that day, the wind continuing still to freshen, and the sea getting up with most fearful rapidity.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000005_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "Bob stood by my side watching the wild scene I have so feebly described, and as the sun disappeared, he turned to me and remarked:",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000006_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "\"My eyes, Harry! what d'ye think of that, lad?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000009_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "This floating anchor I will describe for the benefit of those who may not have seen such a thing, for it is a most useful affair, and no small craft should undertake a long cruise without one.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000011_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "As soon as the bars were spread open, and the swifter passed and set up, a square sheet of the stoutest canvas, painted, was spread over them, the edges laced to the swifter with a stout lacing, and the crowfoot toggled through the intermediate holes in the bars and corresponding holes in the canvas.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000013_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "I may as well state here, that for the economisation of space the buoy for floating out anchor was an india rubber ball, made of the same materials as an ordinary air cushion, and distended in the same way. This was enclosed in a strong net of three strand sinnet, which net was attached to the buoy rope.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000025_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000025_000006.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "Now, what lubber comes here with his eyes sealed up instead of looking before him?",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000025_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000025_000007.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "Jump up, Harry; quick, boy! we are in a mess here, and no mistake.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000027_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "She was not a large vessel; about two hundred tons or thereabouts, apparently; painted all black down to her copper, excepting a narrow red ribbon which marked the line of her sheer.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000028_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "She was hove to on the port tack under a storm staysail, and her topgallant masts were down on deck.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000033_000001.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "\"Honest going merchant ships ain't so plaguy careful of their spars as that chap-leastways, not such small fry as he is.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000037_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "\"Never fear,\" returned Bob confidently.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000037_000001.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "\"Our bit of a windlass and the mast breaks the force of it before it reaches the skylight.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000045_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "But he was quite of my opinion.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000051_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "\"Well,\" said I, \"I trust we shall not fall in with him again.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000060_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "It looked half inclined to break away two or three times during the morning; but as mid day approached it became as bad as ever, and I had the vexation of seeing noon pass by without so much as a momentary glimpse of the sun",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000061_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000061_000001.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "There was nothing in sight, and with this I was obliged to rest satisfied.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000063_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000063_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "We had found the day dreadfully tedious, cooped up as we were in our low cabin, and a meal was a most welcome break in the monotony.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000064_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000064_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "We sat long over this one, therefore, prolonging it to its utmost extent; and when it was over, we both turned to and cleared up the wreck.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000067_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000067_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "\"Look here, Harry; what d'ye think of this?\"",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000077_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000077_000000.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "She was fearfully close, but appeared to be at the moment sheering away from us.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5776_46889_000083_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5776/46889/5776_46889_000083_000001.wav",
        "speaker_id": "LibriTTS_R-5776",
        "content": "She rolled completely bottom upwards, and then disappeared.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
