[
    {
        "item_name": "LibriTTS_R-1445_139387_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "\"If it ain't asking what I ought not to ask, mr Angelo, how did you come to be so friendless and in such trouble when you were little?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Do you mind telling?",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "But don't, if you do.\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000005_000003.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "His estates were confiscated, his personal property seized, and there we were, in Germany, strangers, friendless, and in fact paupers.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "But what they wouldn't consent to do, we had to do without the formality of consent.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "When we escaped from that slavery at twelve years of age, we were in some respects men.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Experience had taught us some valuable things; among others, how to take care of ourselves, how to avoid and defeat sharks and sharpers, and how to conduct our own business for our own profit and without other people's help.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000007_000003.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "We traveled everywhere-years and years-picking up smatterings of strange tongues, familiarizing ourselves with strange sights and strange customs, accumulating an education of a wide and varied and curious sort.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000007_000004.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "It was a pleasant life.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000007_000005.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "We went to Venice-to London, Paris, Russia, India, China, Japan-\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Rowena was in the clouds, she walked on air; this was to be the greatest day, the most romantic episode in the colorless history of that dull country town.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "\"Good mornin', Sister Cooper\"--handshake.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "\"Good morning, Brother Higgins-Count Luigi Capello, mr Higgins\" --handshake, followed by a devouring stare and \"I'm glad to see ye,\" on the part of Higgins, and a courteous inclination of the head and a pleasant \"Most happy!\" on the part of Count Luigi.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "\"Good mornin', Roweny\"--handshake.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "None of these visitors was at ease, but, being honest people, they didn't pretend to be.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000017_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "A few tried to rise to the emergency, and got out an awkward \"My lord,\" or \"Your lordship,\" or something of that sort, but the great majority were overwhelmed by the unaccustomed word and its dim and awful associations with gilded courts and stately ceremony and anointed kingship, so they only fumbled through the handshake and passed on, speechless.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "General conversation followed, and the twins drifted about from group to group, talking easily and fluently and winning approval, compelling admiration and achieving favor from all.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000019_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Napoleon and all his kind stood accounted for-and justified.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000020_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Again she was besieged by eager questioners, and again she swam in sunset seas of glory.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000020_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "When the forenoon was nearly gone, she recognized with a pang that this most splendid episode of her life was almost over, that nothing could prolong it, that nothing quite its equal could ever fall to her fortune again.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000021_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Here a prodigious slam banging broke out below, and everybody rushed down to see.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "The young strangers were kept long at the piano.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139387_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139387/1445_139387_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "The villagers were astonished and enchanted with the magnificence of their performance, and could not bear to have them stop.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000000_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "CHAPTER sixteen -- Sold Down the River",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000003_000003.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "It made him wince, secretly-for she was a \"nigger.\" That he was one himself was far from reconciling him to that despised race.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Roxana poured out endearments upon him, to which he responded uncomfortably, but as well as he could.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "And she tried to comfort him, but that was not possible.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "These intimacies quickly became horrible to him, and within the hour he began to try to get up courage enough to tell her so, and require that they be discontinued or very considerably modified.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "But he was afraid of her; and besides, there came a lull now, for she had begun to think.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "She was trying to invent a saving plan.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000004_000005.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Finally she started up, and said she had found a way out.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Tom was dazed.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000008_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000008_000011.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Dat's de plan.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Tom's hopes began to rise, and his spirits along with them.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "He said:",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "\"It's lovely of you, Mammy-it's just-\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "White folks ain't partic'lar.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000014_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "He did not want to commit this treachery, but luck threw the man in his way, and this saved him the necessity of going up country to hunt up a purchaser, with the added risk of having to answer a lot of questions, whereas this planter was so pleased with Roxy that he asked next to none at all.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "So Tom argued with himself that it was an immense advantaged for Roxy to have a master who was pleased with her, as this planter manifestly was.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000018_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "When she went to her foul steerage bunk at last, between the clashing engines, it was not to sleep, but only to wait for the morning, and, waiting, grieve.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "It had been imagined that she \"would not know,\" and would think she was traveling upstream.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000019_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Why, she had been steamboating for years.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139397_000019_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139397/1445_139397_000019_000006.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "For one moment her petrified gaze fixed itself there.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "AUTHOR'S NOTE TO \"THOSE EXTRAORDINARY TWINS\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000002_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000002_000006.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "No-that is a thought which comes later; in the beginning he is only proposing to tell a little tale, a very little tale, a six page tale.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000003_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Much the same thing happened with PUDD'NHEAD WILSON.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000003_000003.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I had a sufficiently hard time with that tale, because it changed itself from a farce to a tragedy while I was going along with it-a most embarrassing circumstance.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000003_000006.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "It took me months to make that discovery.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000003_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000003_000007.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I carried the manuscript back and forth across the Atlantic two or three times, and read it and studied over it on shipboard; and at last I saw where the difficulty lay.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000003_000008.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I had no further trouble.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000003_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000003_000009.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I pulled one of the stories out by the roots, and left the other-a kind of literary Caesarean operation.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Originally the story was called THOSE EXTRAORDINARY TWINS.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I meant to make it very short.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000005_000005.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Among them came a stranger named Pudd'nhead Wilson, and a woman named Roxana; and presently the doings of these two pushed up into prominence a young fellow named Tom Driscoll, whose proper place was away in the obscure background.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I hunted about and found them-found them stranded, idle, forgotten, and permanently useless.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I didn't know what to do with her.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000007_000004.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I thought and thought and studied and studied; but I arrived at nothing.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000007_000005.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "I finally saw plainly that there was really no way but one-I must simply give her the grand bounce.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000007_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000007_000006.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "It grieved me to do it, for after associating with her so much I had come to kind of like her after a fashion, notwithstanding she was such an ass and said such stupid, irritating things and was so nauseatingly sentimental.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000007_000008.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "So at the top of Chapter seventeen I put a \"Calendar\" remark concerning July the Fourth, and began the chapter with this statistic:",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "It seemed abrupt, but I thought maybe the reader wouldn't notice it, because I changed the subject right away to something else.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Still the story was unsatisfactory.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000010_000002.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "There was a radical defect somewhere, and I must search it out and cure it.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1445_139404_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1445/139404/1445_139404_000011_000004.wav",
        "speaker_id": "LibriTTS_R-1445",
        "content": "Also I took the twins apart and made two separate men of them.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    }
]