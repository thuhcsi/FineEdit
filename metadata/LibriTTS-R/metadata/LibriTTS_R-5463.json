[
    {
        "item_name": "LibriTTS_R-5463_39173_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000013_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "CHAPTER twenty one.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000015_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "He now felt that he might accept the stall without discredit to himself as a clergyman in doing so. Indeed, after what mr Sowerby had said, and after Lord Lufton's assent to it, it would have been madness, he considered, to decline it.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000021_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"The house will not be furnished, will it, Mark?\" said his wife.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000032_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "It was now the month of April, and the fields were beginning to look green, and the wind had got itself out of the east and was soft and genial, and the early spring flowers were showing their bright colours in the parsonage garden, and all things were sweet and pleasant.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000032_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000032_000004.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "The parish duty was better attended to, and perhaps domestic duties also.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000032_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000032_000005.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "At such period he was a pattern parson and a pattern husband, atoning to his own conscience for past shortcomings by present zeal.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000032_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000032_000008.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "She liked to rule, and she made people feel that she liked it.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000035_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000035_000003.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "What would the men do? and what-oh! what would become of the women?",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000037_000002.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"She never told her love,\" nor did she allow concealment to \"feed on her damask cheek.\" In all her employments, in her ways about the house, and her accustomed quiet mirth, she was the same as ever.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000037_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000037_000003.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "In this she showed the peculiar strength which God had given her.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000039_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"Well, no; I think not.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000039_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "The pony carriage is wretched for three.\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000042_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"You had better say earlier, as he is always out about the parish.\"",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000043_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"Very well, say eleven.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000043_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "It is parish business about which I am going, so it need not irk his conscience to stay in for me.\"",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000044_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"Well, Lucy, we must drive ourselves, that's all.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000046_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "But she did not betray herself.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000047_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "He was going very nicely.\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000048_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"I beg Puck's pardon.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000050_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000050_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "Miss Grantly will have a large fortune, I believe.\"",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000053_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000053_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"I really think she is; not what I should call lovely, you know, but very beautiful.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000059_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000059_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"We'll take you to Barchester for that.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000062_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000062_000002.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "He ought to know that she is a mere automaton, cold, lifeless, spiritless, and even vapid.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000064_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000064_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"No, I could not.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000064_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000064_000002.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "It's horridly improper to care about such a thing, I have no doubt.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000066_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000066_000003.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "I do like Lord Lufton very much; and I do dislike Griselda Grantly almost as much.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39173_000067_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39173/5463_39173_000067_000002.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "And, Fanny, don't tell Mark to put me into a lunatic asylum.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000005_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "Could we have looked into the innermost spirit of him and his life's partner, we should have seen that mixed with the pride of his poverty there was some feeling of disgrace that he was poor, but that with her, regarding this matter, there was neither pride nor shame. The realities of life had become so stern to her that the outward aspects of them were as nothing.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000007_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"Oh, yes; there is nothing here but this young gentleman's library,\" said Lucy, moving a pile of ragged, coverless books on to the table. \"I hope he'll forgive me for moving them.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000009_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"But some of them are mine,\" said the boy; \"ain't they, Grace?\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000010_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"And are you a great scholar?\" asked Lucy, drawing the child to her.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000012_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"Greek Delectus and the irregular verbs!\" And Lucy put up her hands with astonishment.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000015_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"It is all that I can give them,\" said mr Crawley, apologetically. \"A little scholarship is the only fortune that has come in my way, and I endeavour to share that with my children.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000016_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "But, nevertheless, Grace was a pretty, simple looking girl, and clung to her ally closely, and seemed to like being fondled.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000018_000001.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "I suppose you have heard of his good fortune?\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000019_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"Yes; I have heard of it,\" said mr Crawley, gravely.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000039_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"But he will have the house, will he not?\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5463_39174_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5463/39174/5463_39174_000046_000000.wav",
        "speaker_id": "LibriTTS_R-5463",
        "content": "\"Miss Robarts, I am afraid you must excuse me,\" said he, getting up and taking his hat and stick.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
