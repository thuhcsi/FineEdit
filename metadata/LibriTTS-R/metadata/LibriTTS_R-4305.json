        "speaker_id": "LibriTTS_R-4305",
        "content": "The effects may last a week, and the skin may desquamate.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
