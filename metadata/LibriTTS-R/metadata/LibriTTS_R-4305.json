        "speaker_id": "LibriTTS_R-4305",
        "content": "The symptoms are convulsions, insensibility, coma, dilated pupils, pallor, laboured breathing, collapse.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
