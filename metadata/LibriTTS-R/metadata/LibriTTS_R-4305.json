        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000007_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Coal gas has an offensive odour, burns with a yellowish white flame, yielding water and carbonic acid. Cases of poisoning often due to escape of gas into the room.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000008_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "The breath smells of gas; there is profound stupor; the patient, if alive, exhales gas from the lungs when removed into a fresh room or into the air.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
