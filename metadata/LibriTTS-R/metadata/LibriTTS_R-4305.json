        "speaker_id": "LibriTTS_R-4305",
        "content": "Symptoms are purging, vomiting, restlessness, followed by drowsiness, insensibility, and convulsive twitchings.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
