        "speaker_id": "LibriTTS_R-4305",
        "content": "Breathing slow and stertorous, pulse weak, countenance livid.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
