        "speaker_id": "LibriTTS_R-4305",
        "content": "In poisoning, inhalation of sulphuretted hydrogen gives relief.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000024_000000",
