        "speaker_id": "LibriTTS_R-4305",
        "content": "The inflammation spreads rapidly, and there is formation of blebs with much itching. There is often great constitutional disturbance, nausea, vomiting, diarrhoea, and pains in the abdomen.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
