        "speaker_id": "LibriTTS_R-4305",
        "content": "Poisoning by this plant is rare in England, though not uncommon in the United States.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000033_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000033_000002.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Mere contact with the leaves or branches will in many people set up an acute dermatitis, with much oedema and hyperaemia of the skin.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000033_000003",
