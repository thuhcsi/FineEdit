        "speaker_id": "LibriTTS_R-4305",
        "content": "Smell of gas in the room and in patient's breath.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
