        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000029_000003.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Death due to respiratory paralysis.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
