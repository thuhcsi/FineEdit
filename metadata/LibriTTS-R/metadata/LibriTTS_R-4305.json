        "speaker_id": "LibriTTS_R-4305",
        "content": "Morrison's pills contain aloes and colocynth; aloes is also the chief ingredient in Holloway's pills.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
