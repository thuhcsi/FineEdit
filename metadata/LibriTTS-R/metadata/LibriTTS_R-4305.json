    {
        "item_name": "LibriTTS_R-4305_15448_000038_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000038_000004.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "The pupils are contracted, even to a pin's point; they are insensible to the action of light.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000038_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000038_000006.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Bowels confined, skin cold and livid or bathed in sweat.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000038_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000038_000007.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Temperature subnormal. Nausea and vomiting are sometimes present.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000038_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000038_000008.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Remissions are not infrequent, the patient appearing about to recover and then relapsing. Haemorrhage into the pons may give rise to contracted pupils.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000038_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000038_000009.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Young children and infants are specially susceptible to the poison.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000039_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "In the latter one can seldom rouse the patient, the pupils are often unequal, and hemiplegia is present.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000040_000000.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "The habitual use of opium is not uncommon, and opium eaters are able to take enormous quantities of the drug.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000040_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000040_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "The opium eater may be known by his attenuated body, withered yellow countenance, stooping posture, and glassy, sunken eyes.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000041_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Turgescence of cerebral vessels.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000041_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000041_000003.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Rarely extravasation of blood. Stomach and intestines usually healthy.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000041_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000041_000004.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Lungs gorged, skin livid.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000044_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000044_000004.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Treatment must be continued as long as life remains.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000045_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000045_000002.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Filter. Acetate of morphine passes through, and meconate of lead remains.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000045_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000045_000005.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Filter.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000045_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000045_000006.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Concentrate the solution of meconic acid, allow a portion to crystallize, and apply tests.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000046_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "When the alkaloid is heated in a watchglass with a drop of strong sulphuric acid until the acid begins to fume, and is then allowed to get quite cold, a drop of nitric acid produces a brilliant red colour.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000047_000000.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Meconic acid gives a blood red colour with perchloride of iron, not discharged by corrosive sublimate or chloride of gold.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000047_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "The similar colour produced by sulpho cyanide of potassium and perchloride of iron is discharged by chloride of gold and corrosive sublimate.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000048_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000048_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "The victim suffers from nausea and vomiting, and becomes so mentally debilitated that asylum treatment is required.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000051_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000051_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Strangury and haematuria, and redness of the skin, especially of the face, like that of scarlatina, have been noticed.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000053_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000053_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "Tea, coffee, or tannin, to precipitate the alkaloid.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000054_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000054_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "The chloro iodide of potassium and mercury precipitates it from very dilute solutions.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-4305_15448_000060_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4305/15448/4305_15448_000060_000001.wav",
        "speaker_id": "LibriTTS_R-4305",
        "content": "These are intense pallor, faintness, giddiness, dilatation of pupils, paroxysmal dyspnoea, rapid, intermittent, and weak pulse, nausea and vomiting, intense prostration verging on collapse, and convulsions.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    }
]