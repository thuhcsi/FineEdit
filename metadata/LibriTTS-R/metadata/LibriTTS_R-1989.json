        "speaker_id": "LibriTTS_R-1989",
        "content": "Out!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1989_26962_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1989/26962/1989_26962_000017_000003.wav",
        "speaker_id": "LibriTTS_R-1989",
        "content": "The bare wintry morning, the chill air, were welcome in their severity: the leafless trees, the sombre hills, were not haunted by the gods of beauty and joy, whose worship she had forsaken for ever.",
        "style_prompt": "M_p-high_s-slow_e-normal",
