        "speaker_id": "LibriTTS_R-1989",
        "content": "She wished now that she had not looked up.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
