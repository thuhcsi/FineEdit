        "speaker_id": "LibriTTS_R-1989",
        "content": "When you get out of the gates you may go more slowly, for I shall perhaps join you before you get to Trespiano.\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
