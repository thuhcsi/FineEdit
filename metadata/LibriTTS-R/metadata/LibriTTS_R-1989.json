        "speaker_id": "LibriTTS_R-1989",
        "content": "\"Here is the wallet quite ready.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
