        "speaker_id": "LibriTTS_R-1989",
        "content": "It seemed that the sun was going to chase away the greyness.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
