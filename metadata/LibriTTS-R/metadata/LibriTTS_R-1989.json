        "speaker_id": "LibriTTS_R-1989",
        "content": "The light is perhaps never felt more strongly as a divine presence stirring all those inarticulate sensibilities which are our deepest life, than in these moments when it instantaneously awakens the shadows.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1989_26962_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1989/26962/1989_26962_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1989",
        "content": "The cowl was dropped again immediately.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
