        "speaker_id": "LibriTTS_R-8413",
        "content": "\"Oh!\" thought the Tree.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
