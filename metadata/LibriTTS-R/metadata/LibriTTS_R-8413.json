        "speaker_id": "LibriTTS_R-8413",
        "content": "\"How it will shine this evening!\"",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8413_284515_000026_000000",
