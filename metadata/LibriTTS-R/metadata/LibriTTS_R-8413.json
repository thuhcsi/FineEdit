        "speaker_id": "LibriTTS_R-8413",
        "content": "\"If the evening were but come!",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8413_284515_000026_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8413/284515/8413_284515_000026_000004.wav",
        "speaker_id": "LibriTTS_R-8413",
        "content": "Perhaps the other trees from the forest will come to look at me!",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8413_284515_000026_000005",
