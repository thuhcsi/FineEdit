        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4402/3068/4402_3068_000005_000000.wav",
        "speaker_id": "LibriTTS_R-4402",
        "content": "\"Audacious wight! that thus, in complete steel arrayed, doth dare to venture cross my way, to stop the great Munchausen.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
