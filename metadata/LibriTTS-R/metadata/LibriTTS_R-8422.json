        "speaker_id": "LibriTTS_R-8422",
        "content": "Then he lay with Fakhr Taj till near daybreak, when he took leave of his wives and his uncle and mounted Kurajan's back, nor was the darkness dispelled before the two Marids set him down in the city of Oman.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
