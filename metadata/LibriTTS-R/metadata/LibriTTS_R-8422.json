        "speaker_id": "LibriTTS_R-8422",
        "content": "Upon this the two Marids seized Ra'ad Shah and bound him with a cord of palm fibre.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8422_258258_000007_000013",
