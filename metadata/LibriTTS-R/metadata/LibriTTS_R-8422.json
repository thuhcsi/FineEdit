        "speaker_id": "LibriTTS_R-8422",
        "content": "When it was the Six Hundred and Sixty third Night,",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
