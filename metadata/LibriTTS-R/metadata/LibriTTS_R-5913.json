[
    {
        "item_name": "LibriTTS_R-5913_40745_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000001_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Not many years ago there issued from a town in Estramadura a hidalgo nobly born, who, like another prodigal son, went about various parts of Spain, Italy, and Flanders, squandering his years and his wealth.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000001_000003.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "A fleet being about to sail for Tierrafirma, he agreed with the admiral for a passage, got ready his sea stores and his shroud of Spanish grass cloth, and embarking at Cadiz, gave his benediction to Spain, intending never to see it again.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000001_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000001_000004.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The fleet slipped from its moorings, and, amidst the general glee of its living freight, the sails were spread to the soft and prosperous gale, which soon wafted them out of sight of land into the wide domains of the great father of waters, the ocean.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000003_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The fleet was nearly becalmed whilst the mind of Felipe de Carrizales was actuated by these reflections.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000003_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The wind soon after rose and became so boisterous that Carrizales had enough to do to keep on his legs, and was obliged to leave off his meditations, and concern himself only with the affairs of his voyage.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000003_000003.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "To shorten the introduction of my narrative and avoid all irrelevant matter, I content myself with saying that Felipe was about eight and forty years of age when he went to the Indies, and that in the twenty years he remained there he succeeded, by dint of industry and thrift, in amassing more than a hundred and fifty thousand crowns.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000003_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000003_000004.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Seeing himself once more rich and prosperous, he was moved by the natural desire, which all men experience, to return to his native country.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000004_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Having placed his property in safety, he went in search of his friends, and found they were all dead.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000004_000003.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Carrizales contemplated his ingots with anxiety, not as a miser, for, during the few years he had been a soldier, he had learned to be liberal; but from not knowing what to do with them; for to hoard them was unprofitable, and keeping them in his house was offering a temptation to thieves.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000004_000004.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "On the other hand, all inclination for resuming the anxious life of traffic had died out in him, and at his time of life his actual wealth was more than enough for the rest of his days.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000004_000005.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He would fain have spent them in his native place, put out his money there to interest, and passed his old age in peace and quiet, giving what he could to God, since he had given more than he ought to the world.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000004_000006.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He considered, however, that the penury of his native place was great, the inhabitants very needy, and that to go and live there would be to offer himself as a mark for all the importunities with which the poor usually harass a rich neighbour, especially when there is only one in the place to whom they can have recourse in their distress.",
        "style_prompt": "M_p-high_s-fast_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000005_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He was naturally the most jealous man in the world, even without being married, and the mere thought of taking a wife called up such horrible spectres before his imagination that he resolved by all means to remain a bachelor.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000006_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Without more ado, he began to string together a long train of arguments to the following effect:--\"This girl is very handsome, and to judge from the appearance of the house, her parents cannot be rich.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000006_000002.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "She is almost a child too; assuredly a wife of her age could not give a husband any uneasiness.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000006_000003.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Let me see: say that I marry her; I will keep her close at home, I will train her up to my own hand, and so fashion her to my wishes that she will never have a thought beyond them!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000006_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000006_000005.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Whether she brings me any dower or not is a matter of no consideration, since Heaven has given me enough for both, and rich people should not look for money with a wife, but for enjoyment, for that prolongs life, whereas jarring discontent between married people makes it wear out faster than it would do otherwise.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000006_000006.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "So be it then; the die is cast, and this is the wife whom heaven destines me to have.\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000007_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Having thus soliloquised, not once but a hundred times on that day, and the two or three following, Carrizales had an interview with Leonora's parents, and found that, although poor, they were persons of good birth. He made known his intention to them, acquainted them with his condition and fortune, and begged them very earnestly to bestow their daughter upon him in marriage.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000008_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The parties took leave of each other, made the necessary inquiries, found them satisfactory on both sides, and finally Leonora was betrothed to Carrizales, who settled upon her twenty thousand ducats, so hotly enamoured was the jealous old bridegroom.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000008_000002.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The first proof he gave of his jealous temper was, in resolving that no tailor should take measure of his betrothed for any of the many wedding garments he intended to present her.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000009_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The second proof of jealousy given by Felipe was, that he would not consummate his marriage until he had provided a house after his own fancy, which he arranged in this singular manner.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000009_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He bought one for twelve thousand ducats, in one of the best wards of the city, with a fountain and pond, and a garden well stocked with orange trees.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000009_000004.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He raised the parapets round the flat roof of the house so high, that nothing could be seen above them but the sky, and that only by turning one's face upwards.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000009_000005.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "In the inner door, opening from the gateway upon the quadrangle, he fixed a turning box like that of a convent, by means of which articles were to be received from without.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000010_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Leonora knew not, poor young creature, what was before her, but she shed tears because she saw her parents weep, and taking leave of them with their blessing, she went to her new home, her husband leading her by the hand, and her slaves and servants attending her.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000011_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Having thus laid down the law for the government of his household, the worthy Estramaduran began to enjoy, as well as he could, the fruits of matrimony, which, to Leonora's inexperienced taste, were neither sweet flavoured nor insipid.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000011_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Her days were spent with her duena, her damsels, and her slaves, who, to make the time pass more agreeably, took to pampering their palates, and few days passed in which they did not make lots of things in which they consumed a great deal of honey and sugar.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000011_000002.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Their master gladly supplied them with all they could wish for in that way without stint, for by that means he expected to keep them occupied and amused, so that they should have no time to think of their confinement and seclusion.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000013_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "No tom cat ever persecuted its rats, nor was the barking of a dog ever heard within its walls; all creatures belonging to it were of the feminine gender.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000013_000004.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Her aged spouse's silver hairs seemed in Leonora's eyes locks of pure gold; for the first love known by maidens imprints itself on their hearts like a seal on melted wax.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000013_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000013_000005.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "His inordinate watchfulness seemed to her no more than the due caution of an experienced and judicious man.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000013_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000013_000006.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "She was fully persuaded that the life she led was the same as that led by all married women.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000013_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000013_000007.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Her thoughts never wandered beyond the walls of her dwelling, nor had she a wish that was not the same as her husband's.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000013_000009.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Never was there seen a convent more closely barred and bolted; never were nuns kept more recluse, or golden apples better guarded; and yet for all his precautions poor Felipe could not help falling into the pit he dreaded,--or at least believing that he had so fallen.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000014_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Of these people, their manners and customs, and the laws they observe among themselves, I should have much to say, but abstain from it for good reasons.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000014_000003.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He learned the character and habits of the old man, the beauty of Leonora, and the singular method adopted by her husband in order to keep her safe.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000014_000004.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "All this inflamed him with desire to see if it would not be possible, by force or stratagem, to effect the reduction of so well guarded a fortress.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000014_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000014_000005.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He imparted his thoughts to three of his friends, and they all agreed that he should go to work, for in such an enterprise no one lacks counsellors to aid and abet him.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000014_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000014_000007.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He shaved off the little beard he had, covered one of his eyes with a plaster, tied up one of his legs, and hobbling along on two crutches, appeared so completely metamorphosed into a lame beggar, that no real cripple could have looked less of a counterfeit than he.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000017_000002.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "I am dying with thirst, and can't sing.\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000020_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"My master, who is the most jealous man in the world; and if he knew that I was now talking here with any one, it were pity of my life.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000020_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "But who are you who ask me for water?\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000021_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Among my pupils I have three negroes, slaves to three aldermen, whom I have taught so well that they are fit to sing and play at dance or in any tavern, and they have paid me for it very well indeed.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000022_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"A deal better would I pay you to have the opportunity of taking lessons; but it is not possible, for when my master goes out in the morning he locks the door behind him, and he does the same when he comes in, leaving me shut up between two doors.\"",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000026_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"What's the good of all that,\" (here the negro sighed heavily,) \"since I can't get you into the house?\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000028_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"All that is very good; but the thing can't be done, for I never get hold of the keys, nor does my master ever let them out of his keeping; day and night they sleep under his pillow.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000029_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Well, then, there's another thing you may do, if so be you have made up a mind to be a first rate musician; if you haven't, I need not bother myself with advising you.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000030_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Have a mind, do you say?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000031_000002.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "You need not give yourself any concern about what we shall have to eat.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000031_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000031_000003.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "I will bring enough to last us both for more than a week, for I have pupils who will not let me be pinched.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000032_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"As for that matter we are all right; for with what my master allows me, and the leavings brought me by the slave girls, we should have enough for two more besides ourselves.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000032_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Only bring the hammer and pincers, and I will make an opening close to the hinge, through which you may pass them in, and I will stop it up again with mud.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000033_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000033_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Meanwhile, take care not to eat such things as are apt to make phlegm, for they do the voice no good, but a deal of harm.\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000035_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Don't think I would have you do so; God forbid!",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000036_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"I always drink in measure.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000036_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "I have a jug here that holds exactly three pints and a half.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000036_000002.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The girls fill this for me unknown to my master, and the purveyor brings me on the sly a bottle holding a good gallon, which makes up for the deficiency of the jug.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000037_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"That's the way to live, my boy, for a dry throat can neither grunt nor sing.\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000038_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Well, go your ways now, and God be with you; but don't forget to come and sing here every night until such time as you bring the tools for getting you within doors.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000041_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "If you think I teach you well, I will leave it to yourself to pay me accordingly.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000041_000002.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "And now I'll just sing you one song, but when I am inside you will see wonders.\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000043_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Having finished his song, Loaysa took his departure, and set off at a rounder pace than might have been expected of a man on crutches, to report to his friends what a good beginning he had made.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000043_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He told them what he had concerted with the negro, and the following day they procured tools of the right sort, fit to break any fastening as if it was made of straw.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000043_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000043_000006.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Then throwing aside his crutches, he began to cut capers, as if nothing ailed him, to the still greater amazement of the negro.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000044_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"You must know, brother Luis,\" said Loaysa, \"that my lameness does not come of natural infirmity, but from my own ingenious contrivance, whereby I get my bread, asking alms for the love of God.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000044_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "In this way, and with the help of my music, I lead the merriest life in the world, where others, with less cleverness and good management, would be starved to death.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000045_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"We shall see,\" said the negro; \"but now let us put this staple back in its place, so that it may not appear that it has been moved.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000046_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000046_000004.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "So persuaded was the poor fellow of this, that he did nothing all night but jangle and strum away.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000046_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000046_000005.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "They had but a short sleep that night.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000047_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "How long have you had a guitar?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000048_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000048_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The best musician in the world, and one who is to teach me in six days more than six thousand tunes!\"",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000049_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Where is he, this musician?\" said the duena.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000050_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"He is not far off,\" replied the negro; \"and if it were not for fear of my master, perhaps I would tell you where at once, and I warrant you would be glad to see him.\"",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000054_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Stop a bit and you shall hear him, and mayhap you will see him too some day.\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000056_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000056_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Never mind\" said the negro; \"there's a remedy for everything but death.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000056_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000056_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "If you only could or would keep silence-\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000057_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000057_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Keep silence!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000058_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000058_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "The negro was afraid lest his master should return and catch him talking with them; but they would not go away until he had promised that, when they least expected it, he would call them to hear a capital voice.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000058_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000058_000003.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "His master returned soon after and went into the house, locking both doors behind him as usual.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000060_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000060_000005.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Ah, senor of my soul! bring that powder, and may God reward you with all the good you can desire.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000060_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000060_000007.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "Oh, that it might please God that the old man should sleep three days and nights!",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000061_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000061_000000.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "\"Well, I'll bring it then,\" said Loaysa.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000062_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000062_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "By this time it was nearly daylight, yet the negro wished to take a lesson.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5913_40745_000063_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5913/40745/5913_40745_000063_000001.wav",
        "speaker_id": "LibriTTS_R-5913",
        "content": "He had heard, he said, that there were powders which produced that effect.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    }
