        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/168/123450/168_123450_000016_000000.wav",
        "speaker_id": "LibriTTS_R-168",
        "content": "'It's the oldest rule in the book,' said the King.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
