        "speaker_id": "LibriTTS_R-168",
        "content": "'Well, I shan't go, at any rate,' said Alice: 'besides, that's not a regular rule: you invented it just now.'",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
