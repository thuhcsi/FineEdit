        "speaker_id": "LibriTTS_R-3334",
        "content": "\"This is a turban for Aunt Phillis; and this is a pound of tobacco for old Uncle Jack, and a nice pipe, too.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
