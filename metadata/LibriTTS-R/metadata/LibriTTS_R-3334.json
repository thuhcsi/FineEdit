        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Papa knew best, after all, did he not?\" asked her father, drawing her to him, and patting her cheek.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
