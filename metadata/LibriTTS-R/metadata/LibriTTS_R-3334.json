        "speaker_id": "LibriTTS_R-3334",
        "content": "It's a nice shawl for her, papa,\" she whispered in his ear.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
