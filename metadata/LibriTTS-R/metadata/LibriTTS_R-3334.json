        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3334/171008/3334_171008_000101_000001.wav",
        "speaker_id": "LibriTTS_R-3334",
        "content": "Bid your little friends good night, my dear, and go at once.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
