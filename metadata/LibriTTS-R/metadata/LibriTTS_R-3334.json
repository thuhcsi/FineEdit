        "speaker_id": "LibriTTS_R-3334",
        "content": "Half past was her bedtime; and, as she now and then glanced up at the dial plate, she thought the hands had never moved so fast.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
