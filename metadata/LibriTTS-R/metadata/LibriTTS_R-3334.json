        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Yes, papa,\" she said softly; \"you always know best, and I am very sorry I was naughty.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
