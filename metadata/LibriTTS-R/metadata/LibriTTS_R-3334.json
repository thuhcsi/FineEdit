        "speaker_id": "LibriTTS_R-3334",
        "content": "Elsie's face clouded, and the slightest approach to a pout might have been perceived.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
