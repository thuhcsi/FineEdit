        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3334/171008/3334_171008_000079_000000.wav",
        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Oh! papa,\" she pleaded, \"won't to morrow do?",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
