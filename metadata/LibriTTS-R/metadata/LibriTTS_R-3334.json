        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Oh! yes, papa see!",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
