        "speaker_id": "LibriTTS_R-3334",
        "content": "He opened her writing desk as he spoke, and took out her account book.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
