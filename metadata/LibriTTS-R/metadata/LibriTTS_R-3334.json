        "speaker_id": "LibriTTS_R-3334",
        "content": "He answered with a kiss, and, taking her hand, led her down to the drawing room.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
