        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Yes, my dear, it is,\" he replied, comparing it with his watch.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
