        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Good morning, mammy,\" said the little girl.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
