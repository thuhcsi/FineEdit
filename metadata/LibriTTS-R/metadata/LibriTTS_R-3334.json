        "speaker_id": "LibriTTS_R-3334",
        "content": "Why, I thought we got through in a wonderfully short time.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
