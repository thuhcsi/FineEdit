        "speaker_id": "LibriTTS_R-3334",
        "content": "\"I hope my little girl is not going to be naughty,\" he said, very gravely.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
