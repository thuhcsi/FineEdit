        "speaker_id": "LibriTTS_R-3334",
        "content": "Elsie obeyed, readily and cheerfully.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3334_171008_000104_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3334/171008/3334_171008_000104_000000.wav",
        "speaker_id": "LibriTTS_R-3334",
        "content": "Elsie looked very glad, and went away feeling herself the happiest little girl in the land, in spite of the annoyance of being forced to leave the merry group in the nursery.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3334_171008_000104_000001",
