        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Yes, daughter; keep to rules.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
