        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Ah!\" he said, smiling; \"and which is my present?",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
