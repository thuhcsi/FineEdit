        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Papa,\" she asked, \"is the clock right?\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
