        "speaker_id": "LibriTTS_R-3334",
        "content": "\"I will, darling,\" he answered, pinching her cheek, \"Here, Bill\"--to a servant-\"carry these bundles to Miss Elsie's room.\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
