        "speaker_id": "LibriTTS_R-3334",
        "content": "Will that do?\"",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
