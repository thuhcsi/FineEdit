        "speaker_id": "LibriTTS_R-3334",
        "content": "Her face brightened in an instant.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
