        "speaker_id": "LibriTTS_R-3334",
        "content": "\"No, papa,\" she answered cheerfully, \"I will be good, and do whatever you bid me.\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
