        "speaker_id": "LibriTTS_R-3334",
        "content": "But here come the bundles! what a number! no wonder you were late in getting home.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
