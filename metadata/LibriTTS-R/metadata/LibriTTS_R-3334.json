        "speaker_id": "LibriTTS_R-3334",
        "content": "After tea the young people adjourned to the nursery, where they amused themselves with a variety of innocent games.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
