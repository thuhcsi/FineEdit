        "speaker_id": "LibriTTS_R-3334",
        "content": "\"Are you ready to dress me now?\"",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "very high"
