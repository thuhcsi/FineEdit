        "speaker_id": "LibriTTS_R-3330",
        "content": "Merlin became his chief adviser, and often assisted the king by his magical arts.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
