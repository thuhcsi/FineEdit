        "speaker_id": "LibriTTS_R-3330",
        "content": "The red dragon was slain, and the white one, gliding through a cleft in the rock, disappeared.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
