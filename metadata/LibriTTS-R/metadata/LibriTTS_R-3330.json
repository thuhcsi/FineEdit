        "speaker_id": "LibriTTS_R-3330",
        "content": "The edifice, when brought by the workmen to a certain height, three times fell to the ground, without any apparent cause.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
