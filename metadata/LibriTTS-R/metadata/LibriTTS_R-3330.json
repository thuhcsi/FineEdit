        "speaker_id": "LibriTTS_R-3330",
        "content": "At one time he appeared as a dwarf, at others as a damsel, a page, or even a greyhound or a stag.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
