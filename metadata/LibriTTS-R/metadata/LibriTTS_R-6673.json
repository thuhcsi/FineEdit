[
    {
        "item_name": "LibriTTS_R-6673_72311_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000000_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "AUNT JOANNA",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000003_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "It was thatched with heather, and possessed but a single chimney that rose but little above the apex of the roof, and had two slates set on the top to protect the rising smoke from being blown down the chimney into the cottage when the wind was from the west or from the east.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "The woman who lived in the cottage was called by the people of the neighbourhood Aunt Joanna.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000005_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000005_000008.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "But dancing, though denounced, still drew the more independent spirits together.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000010_000002.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "It would be handy to have a little maid by you.\"",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000017_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000017_000006.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "It's my opinion us ought to go and see.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000022_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "\"I reckon it's the old lady be down,\" replied her husband, and, throwing open the bedroom door, he said: \"Sure enough, and no mistake-there her be, dead as a dried pilchard.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000049_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Rose sighed, and went away.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000050_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000050_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "She had never been allowed to look at the treasures in the oak chest.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000050_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000050_000002.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "As far as she had been aware, Aunt Joanna had been extremely poor.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000050_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000050_000003.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "But she remembered that the old woman had at one time befriended her, and she was ready to forgive the harsh treatment to which she had finally been subjected.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000050_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000050_000004.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "In fact, she had repeatedly made overtures to her great aunt to be reconciled, but these overtures had been always rejected.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000051_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000051_000003.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "That was good enough to moulder in the grave.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000051_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000051_000006.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Aunt Joanna was given an elm, and not a mean deal board coffin, such as is provided for paupers; and a handsome escutcheon of white metal was put on the lid.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000063_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000063_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "During the night, at what time she did not know, mrs Hockin awoke with a start, and found that her husband was sitting up in bed listening. There was a moon that night, and no clouds in the sky.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000071_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000071_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "\"I reckon us had best go down together.\"",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000073_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000073_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "\"What?\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000074_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000074_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "She and her husband crept from bed, and, treading on tiptoe across the room, descended the stair.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000075_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000075_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "There was no door at the bottom, but the staircase was boarded up at the side; it opened into the kitchen.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000076_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000076_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "The moonlight poured in through the broad, low window.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000077_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000077_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "There could be no mistaking it-it was that of Aunt Joanna, clothed in the tattered sheet that Elizabeth Hockin had allowed for her grave clothes.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000079_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000079_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Then they saw Aunt Joanna go to the cupboard, open it, and return with the silver spoons; she placed all six on the sheet, and with a lean finger counted them.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000082_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000082_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "The Hockins saw the glint of the metal, and the shadow cast by each piece of money as it rolled.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000082_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000082_000002.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "The first coin lodged at the further left hand corner and the second rested near it; and so on, the pieces were rolled, and ranged themselves in order, ten in a row.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000086_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000086_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "There was no sleep for them that night.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000094_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000094_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "The moon was obscured by thick clouds, and neither of the two had the courage to descend to the kitchen.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000094_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000094_000003.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Again sleep was impossible.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000099_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000099_000002.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "We've spent some pounds over her buryin'.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000100_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000100_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "\"What have it come to?\"",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000104_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000104_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "The night was dark and stormy, with scudding clouds, so dense as to make deep night, when they did not part and allow the moon to peer forth.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000105_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000105_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "They walked timorously, and side by side, looking about them as they proceeded, and on reaching the churchyard gate they halted to pluck up courage before opening and venturing within.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000106_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000106_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Together they heaped the articles that had belonged to Aunt Joanna upon the fresh grave, but as they did so the wind caught the linen and unfurled and flapped it, and they were forced to place stones upon it to hold it down.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000107_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000107_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Then, quaking with fear, they retreated to the church porch, and Jabez, uncorking the bottle, first took a long pull himself, and then presented it to his wife.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000109_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000109_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Elizabeth caught her husband by the arm and pointed.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000110_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000110_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "They saw it drag the sheet by one corner, and then it went down underground, and the sheet followed, as though sucked down in a vortex; fold on fold it descended, till the entire sheet had disappeared.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000114_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000114_000000.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Again the lean hand with long fingers appeared above the soil, and this was seen groping about the grass till it laid hold of the teapot.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6673_72311_000114_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6673/72311/6673_72311_000114_000001.wav",
        "speaker_id": "LibriTTS_R-6673",
        "content": "Then it groped again, and gathered up the spoons, that flashed in the moonbeams.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    }
]