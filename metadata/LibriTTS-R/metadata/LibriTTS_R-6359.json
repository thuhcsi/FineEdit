[
    {
        "item_name": "LibriTTS_R-6359_64713_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000000_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Aladdin returned home in the order he had come, amidst the acclamations of the people, who wished him all happiness and prosperity.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000000_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "As soon as he dismounted, he retired to his own chamber, took the lamp, and summoned the genie as usual, who professed his allegiance.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000000_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000000_000004.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Let its walls be massive gold and silver bricks laid alternately.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000000_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000000_000006.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Let there be also kitchens and storehouses, stables full of the finest horses, with their equerries and grooms, and hunting equipage, officers, attendants, and slaves, both men and women, to form a retinue for the princess and myself.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000000_000007.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Go and execute my wishes.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000001_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "When Aladdin gave these commands to the genie, the sun was set.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000001_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The genie led him through all the apartments, where he found officers and slaves, habited according to their rank and the services to which they were appointed.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000001_000003.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The genie then showed him the treasury, which was opened by a treasurer, where Aladdin saw large vases of different sizes, piled up to the top with money, ranged all round the chamber.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000002_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "When Aladdin had examined every portion of the palace, and particularly the hall with the four and twenty windows, and found it far to exceed his fondest expectations, he said, \"Genie, there is one thing wanting, a fine carpet for the princess to walk upon from the sultan's palace to mine.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000002_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Lay one down immediately.\" The genie disappeared, and Aladdin saw what he desired executed in an instant.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000002_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The genie then returned, and carried him to his own home.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000003_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "When the sultan's porters came to open the gates, they were amazed to find what had been an unoccupied garden filled up with a magnificent palace, and a splendid carpet extending to it all the way from the sultan's palace.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000003_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "They told the strange tidings to the grand vizier, who informed the sultan, who exclaimed, \"It must be Aladdin's palace, which I gave him leave to build for my daughter.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000003_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "He has wished to surprise us, and let us see what wonders can be done in only one night.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000004_000006.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Bands of music led the procession, followed by a hundred state ushers, and the like number of black mutes, in two files, with their officers at their head.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000004_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000004_000011.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The vases, basins, and goblets were gold also, and of exquisite workmanship, and all the other ornaments and embellishments of the hall were answerable to this display.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000004_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000004_000012.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The princess, dazzled to see so much riches collected in one place, said to Aladdin, \"I thought, prince, that nothing in the world was so beautiful as the sultan my father's palace, but the sight of this hall alone is sufficient to show I was deceived.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The next morning the attendants of Aladdin presented themselves to dress him, and brought him another habit, as rich and magnificent as that worn the day before.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000006_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The sultan consented with pleasure, rose up immediately, and, preceded by the principal officers of his palace, and followed by all the great lords of his court, accompanied Aladdin.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000007_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "But what most surprises me is, that a hall of this magnificence should be left with one of its windows incomplete and unfinished.\" \"Sire,\" answered Aladdin, \"the omission was by design, since I wished that you should have the glory of finishing this hall.\" \"I take your intention kindly,\" said the sultan, \"and will give orders about it immediately.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "After the sultan had finished this magnificent entertainment, provided for him and for his court by Aladdin, he was informed that the jewellers and goldsmiths attended; upon which he returned to the hall, and showed them the window which was unfinished.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000008_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "\"I sent for you,\" said he, \"to fit up this window in as great perfection as the rest.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000010_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "When the sultan returned to his palace, he ordered his jewels to be brought out, and the jewellers took a great quantity, particularly those Aladdin had made him a present of, which they soon used, without making any great advance in their work.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000010_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "They came again several times for more, and in a month's time had not finished half their work.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000010_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "In short, they used all the jewels the sultan had, and borrowed of the vizier, but yet the work was not half done.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000011_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Aladdin, who knew that all the sultan's endeavours to make this window like the rest were in vain, sent for the jewellers and goldsmiths, and not only commanded them to desist from their work, but ordered them to undo what they had begun, and to carry all their jewels back to the sultan and to the vizier.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000011_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "He took the lamp, which he carried about him, rubbed it, and presently the genie appeared.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000011_000004.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Aladdin went out of the hall, and returning soon after, found the window, as he wished it to be, like the others.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000012_000003.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "He fancied at first that he was mistaken, and examined the two windows on each side, and afterward all the four and twenty; but when he was convinced that the window which several workmen had been so long about was finished in so short a time, he embraced Aladdin and kissed him between his eyes.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000013_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The sultan returned to the palace, and after this went frequently to the window to contemplate and admire the wonderful palace of his son in law.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000014_000003.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Thus Aladdin, while he paid all respect to the sultan, won by his affable behaviour and liberality the affections of the people.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000015_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Aladdin had conducted himself in this manner several years, when the African magician, who had for some years dismissed him from his recollection, determined to inform himself with certainty whether he perished, as he supposed, in the subterranean cave or not.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000016_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "On the very next day, the magician set out and travelled with the utmost haste to the capital of China, where, on his arrival, he took up his lodgings in a khan.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000017_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "He then quickly learnt about the wealth, charities, happiness, and splendid palace of Prince Aladdin.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000018_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "On his return he had recourse to an operation of geomancy to find out where the lamp was-whether Aladdin carried it about with him, or where he left it.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000018_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The result of his consultation informed him, to his great joy, that the lamp was in the palace.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000018_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "\"Well,\" said he, rubbing his hands in glee, \"I shall have the lamp, and I shall make Aladdin return to his original mean condition.\"",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000019_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The next day the magician learnt, from the chief superintendent of the khan where he lodged, that Aladdin had gone on a hunting expedition, which was to last for eight days, of which only three had expired.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000019_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "He went to a coppersmith, and asked for a dozen copper lamps: the master of the shop told him he had not so many by him, but if he would have patience till the next day, he would have them ready.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000020_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The next day the magician called for the twelve lamps, paid the man his full price, put them into a basket hanging on his arm, and went directly to Aladdin's palace.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000020_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "As he approached, he began crying, \"Who will exchange old lamps for new ones?\" As he went along, a crowd of children collected, who hooted, and thought him, as did all who chanced to be passing by, a madman or a fool, to offer to change new lamps for old ones.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000021_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "He repeated this so often, walking backward and forward in front of the palace, that the princess, who was then in the hall with the four and twenty windows, hearing a man cry something, and seeing a great mob crowding about him, sent one of her women slaves to know what he cried.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000022_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The slave returned, laughing so heartily that the princess rebuked her. \"Madam,\" answered the slave, laughing still, \"who can forbear laughing, to see an old man with a basket on his arm, full of fine new lamps, asking to change them for old ones?",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000022_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "the children and mob crowding about him, so that he can hardly stir, make all the noise they can in derision of him.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000023_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "If the princess chooses, she may have the pleasure of trying if this old man is so silly as to give a new lamp for an old one, without taking anything for the exchange.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000024_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The princess, who knew not the value of this lamp, and the interest that Aladdin had to keep it safe, entered into the pleasantry, and commanded a slave to take it and make the exchange.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000024_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The slave obeyed, went out of the hall, and no sooner got to the palace gates than he saw the African magician, called to him, and showing him the old lamp, said, \"Give me a new lamp for this.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000025_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The slave picked out one and carried it to the princess; but the change was no sooner made than the place rung with the shouts of the children, deriding the magician's folly.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000026_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The African magician stayed no longer near the palace, nor cried any more, \"New lamps for old ones,\" but made the best of his way to his khan.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000027_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000027_000003.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "\"I command thee,\" replied the magician, \"to transport me immediately, and the palace which thou and the other slaves of the lamp have built in this city, with all the people in it, to Africa.\" The genie made no reply, but with the assistance of the other genies, the slaves of the lamp, immediately transported him and the palace, entire, to the spot whither he had been desired to convey it.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000028_000000.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "Early the next morning, when the sultan, according to custom, went to contemplate and admire Aladdin's place, his amazement was unbounded to find that it could nowhere be seen.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000028_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "In his perplexity he ordered the grand vizier to be sent for with expedition.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000029_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000029_000002.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "On his son in law being brought before him, he would not hear a word from him, but ordered him to be put to death.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000029_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000029_000007.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "I beg you to give me forty days, and if in that time I cannot restore it, I will offer my head to be disposed of at your pleasure.\" \"I give you the time you ask, but at the end of the forty days, forget not to present yourself before me.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6359_64713_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6359/64713/6359_64713_000030_000001.wav",
        "speaker_id": "LibriTTS_R-6359",
        "content": "The lords who had courted him in the days of his splendour, now declined to have any communication with him.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    }
]