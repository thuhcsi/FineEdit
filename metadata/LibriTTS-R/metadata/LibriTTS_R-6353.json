        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6353/63255/6353_63255_000061_000001.wav",
        "speaker_id": "LibriTTS_R-6353",
        "content": "Tarrant creaked along, in pursuit, to assist Miss Chancellor; the others drew Verena into the house.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
