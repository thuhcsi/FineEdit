        "speaker_id": "LibriTTS_R-6353",
        "content": "\"Yes, if we will give up everything.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000048_000001",
