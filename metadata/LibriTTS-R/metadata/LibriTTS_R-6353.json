        "speaker_id": "LibriTTS_R-6353",
        "content": "\"Yes, I am hard; perhaps I am cruel; but we must be hard if we wish to triumph.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
