        "speaker_id": "LibriTTS_R-6353",
        "content": "I have asked you before-are you prepared to give up?\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
