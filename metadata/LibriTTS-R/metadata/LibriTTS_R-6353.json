        "speaker_id": "LibriTTS_R-6353",
        "content": "\"I can't tell what you like,\" Verena said, still looking into Olive's eyes.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000016_000000",
