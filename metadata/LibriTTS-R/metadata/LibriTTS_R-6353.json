        "speaker_id": "LibriTTS_R-6353",
        "content": "\"No, all our wretched sisters-all our hopes and purposes-all that we think Sacred and worth living for!\"",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
