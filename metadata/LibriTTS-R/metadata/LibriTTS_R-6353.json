        "speaker_id": "LibriTTS_R-6353",
        "content": "Verena, don't fail me-don't fail me!\" Olive spoke low, with a kind of passion.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
