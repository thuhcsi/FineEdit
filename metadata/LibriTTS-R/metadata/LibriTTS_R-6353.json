        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6353/63255/6353_63255_000039_000001.wav",
        "speaker_id": "LibriTTS_R-6353",
        "content": "\"I hope it isn't me.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6353/63255/6353_63255_000040_000000.wav",
        "speaker_id": "LibriTTS_R-6353",
        "content": "\"I am not angry-I am anxious.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000040_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6353/63255/6353_63255_000040_000001.wav",
        "speaker_id": "LibriTTS_R-6353",
        "content": "I am so afraid I shall lose you.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000040_000002",
