        "speaker_id": "LibriTTS_R-6353",
        "content": "\"Never to listen to one of them, never to be bribed----\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000060_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6353/63255/6353_63255_000060_000000.wav",
        "speaker_id": "LibriTTS_R-6353",
        "content": "\"You seem to have started a kind of lecture out here,\" mr Pardon said. \"You ladies had better look out, or you'll freeze together!\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
