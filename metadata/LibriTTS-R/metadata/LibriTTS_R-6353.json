        "speaker_id": "LibriTTS_R-6353",
        "content": "That was rather awful, even if it represented the fate one would like.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000062_000000",
