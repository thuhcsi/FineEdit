        "speaker_id": "LibriTTS_R-6353",
        "content": "\"Yes, I am dreadful; I know it.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
