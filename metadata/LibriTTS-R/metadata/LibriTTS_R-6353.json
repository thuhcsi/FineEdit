        "speaker_id": "LibriTTS_R-6353",
        "content": "They care only for their pleasure, for what they believe to be the right of the stronger. The stronger?",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
