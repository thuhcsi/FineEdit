        "speaker_id": "LibriTTS_R-6353",
        "content": "I am not so sure!\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6353_63255_000048_000000",
