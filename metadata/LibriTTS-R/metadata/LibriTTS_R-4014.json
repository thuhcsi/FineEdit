        "speaker_id": "LibriTTS_R-4014",
        "content": "\"But some other German aviators saw the affair, apparently recognized our uniforms, and hardly gave us time to make a decent start.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
