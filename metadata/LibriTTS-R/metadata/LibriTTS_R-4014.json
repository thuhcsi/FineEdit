        "speaker_id": "LibriTTS_R-4014",
        "content": "Well, the officer being a pretty good pilot, we decided to have that machine.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
