        "speaker_id": "LibriTTS_R-4014",
        "content": "There their front-line ranks held firm, while the new formation was being effected behind them. It was about four o'clock in the afternoon when this was complete.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000022_000000",
