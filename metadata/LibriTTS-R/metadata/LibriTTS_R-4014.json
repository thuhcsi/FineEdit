        "speaker_id": "LibriTTS_R-4014",
        "content": "Four American planes sailed off and upward to meet the oncoming German air armada.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000046_000000",
