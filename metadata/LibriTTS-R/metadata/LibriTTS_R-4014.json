        "speaker_id": "LibriTTS_R-4014",
        "content": "\"It's nothing,\" the youthful chauffeur replied.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
