        "speaker_id": "LibriTTS_R-4014",
        "content": "Then, in concerted action, the lines opened at alternate points, and pairs, dozens, scores of the huge armored tanks rolled through, their big guns already blazing shells into the ranks of the disconcerted enemy.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4014/186183/4014_186183_000023_000000.wav",
        "speaker_id": "LibriTTS_R-4014",
        "content": "Nothing could halt them.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4014/186183/4014_186183_000027_000000.wav",
        "speaker_id": "LibriTTS_R-4014",
        "content": "The sun was setting, and soon, in great measure, at least, hostilities would be suspended for the night.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000032_000001",
