        "speaker_id": "LibriTTS_R-4014",
        "content": "\"Who are you?\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
