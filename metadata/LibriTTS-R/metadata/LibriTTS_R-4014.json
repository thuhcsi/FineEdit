        "speaker_id": "LibriTTS_R-4014",
        "content": "At least that was the way it looked.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4014/186183/4014_186183_000038_000000.wav",
        "speaker_id": "LibriTTS_R-4014",
        "content": "Still going at maximum speed, and now on a straight line toward the American side, without seeking a further height, the Taube several times wavered, and, a moment later, almost turned over.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
