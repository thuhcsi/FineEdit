        "speaker_id": "LibriTTS_R-4014",
        "content": "Whatever the morrow might bring, the night promised to be fairly quiet, while each side took account of stock and made necessary repairs, or altered their plans to meet the new situation.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000035_000002",
