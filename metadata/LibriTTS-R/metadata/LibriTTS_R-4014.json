        "speaker_id": "LibriTTS_R-4014",
        "content": "It was now well into the afternoon.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4014_186183_000021_000001",
