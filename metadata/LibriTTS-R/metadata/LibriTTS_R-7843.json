[
    {
        "item_name": "LibriTTS_R-7843_110055_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000002_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "CHAPTER five",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Besides general politeness, that ready money which is current with all, there is a polite deportment suited to every profession.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000004_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Interest, custom, and the desire of particular esteem, the necessity of moderating the enthusiasm which almost constantly animates us,--are the motives which determine the different kinds of politeness that we are going to consider as regards shopkeepers, people in office, lawyers, physicians, artists, military men, and ecclesiastics.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000004_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "As all this politeness is mutual, we shall necessarily speak of the obligations imposed upon people who have intercourse with these different persons.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Politeness in shopkeepers is a road to fortune, which the greater part of them are careful not to neglect, especially at Paris, where we find particularly the model of a well bred shopkeeper.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "It is this model that we wish to hold up even to some Parisians, and to the retail dealers of the provincial towns, as well as to those who are unacquainted with trade, but are destined to that profession.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "When a customer calls, the shopkeeper should salute him politely, without inquiring after his health, unless he be intimately acquainted with him.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If the purchaser be difficult to suit, capricious, ridiculous, or even disdainful, the shopkeeper ought not to appear to perceive it; he may however in such cases, show a little coldness of manner.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "There are some merciless purchasers who contend for a few cents with all the tenacity of avarice, obstinacy and pride; however, under all these vexations, the shopkeeper must show constant urbanity.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Even though his politeness should be all lost, he should still express his regret at not having been able to suit the lady, and hope to be more fortunate another time; he should then conduct her politely to the door, which he should hold open until her carriage leaves it.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000011_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If however he has to do with those gossips who think themselves cheated unless something is abated, or who design to impose sacrifices on the shopkeepers, it is necessary to carry on this ridiculous skirmishing politely, and to yield by degrees, without exhibiting any marks of displeasure at these endless debates.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000012_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If the latter is not on foot, the bundle should not be delivered until he is seated in the carriage, and the door is ready to be shut.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000012_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If, on the contrary, the purchaser is not in a carriage, he must be asked whether he wishes to have the bundle carried home.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000012_000003.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "This politeness is indispensable if the bundle is large, and especially if the purchaser is a lady.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000013_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "It is further necessary that the person at the desk should offer small change for the balance of the purchase, and should apologise if he is obliged to give copper or heavy money; he ought to present a bill of the articles, and not show any ill humor if the purchaser thinks proper to look over it.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "There is one circumstance which tries the politeness of the most civil shopkeepers; it is when an assortment is wanted.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "We trust that the shopkeepers' clerks, in the recommendations which we are now about to give them, will not see any silly attempt to address them with smart sayings.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Every civility ought to be reciprocal, or nearly so.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000017_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Many very respectable people allow themselves so many infractions on this point, that I think it my duty to dwell upon it.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If they do not show you at first the articles you desire, and you are obliged to examine a great number, apologize to the shopkeeper for the trouble you give him.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000018_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If, after all you cannot suit yourself, renew your apologies, when you go away.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000019_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If you spend a considerable time in the selection of articles, apologize to the shopkeeper who waits for you to decide.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000020_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If the price seems to you too high, and that the shop has not fixed prices, ask an abatement in brief and civil terms, and without ever appearing to suspect the good faith of the shopkeeper.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000020_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If he does not yield, do not enter into a contest with him, but go away, after telling him politely that you think you can obtain the article cheaper elsewhere, but if not, that you will give him the preference.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000020_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000020_000003.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "We should never neglect to be agreeable.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000020_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000020_000004.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Thank him always when you go out.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000023_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "This is not very conspicuous; nor can it be, since in this case, the desire of pleasing and the expectation of gain, have no influence. Besides, as we remain but a moment with these gentlemen, and as they have business with a great many people, the observances and forms of politeness would be misplaced.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000023_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "The following are points to be observed by them, and are by no means rigid; the greater therefore the reason for conforming to them.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000024_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "The business being finished, he salutes them on leaving, as before, and never conducts them back to the door.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000024_000003.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "In proportion to their official habits, those in office ought to watch themselves with care in society.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000025_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "SECTION three.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000027_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Politeness is a very difficult thing for this respectable class, who see constantly before their eyes people always animated with a feeling which renders them little amiable, namely, interest.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000027_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Besides, being in the habit of refuting their adversaries, and being obliged to do it promptly, they acquire, in general, a kind of bluntness, a decisive tone, a spirit of contradiction, of which they ought to be distrustful in society, and also in their places of business.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000027_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000027_000003.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "They are however bound to observe attentions which are not practised by persons in office.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000027_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000027_000004.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "They rise to salute their clients, offer them a seat, and conduct them to the door when they take leave; they observe what is due to sex, rank, and age.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000028_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "As to clients, they ought to conform to the ordinary rules of civility; they ought, moreover, not to exhibit any signs of impatience while they are waiting until they can be received.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000028_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "They should take care to be clear and precise in the narration of their business, and not to importune by vain repetitions or passionate declamations, the counsellor who is listening to them.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000028_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "They should also consider that his moments are precious, and should retire so soon as they shall have sufficiently instructed him in their business.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000031_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "The observances adopted in the offices of lawyers, are likewise practised with consulting physicians; but sympathy should give to the tone or manner of the latter a more affectionate character.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000031_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Patients well educated will beware of abusing it, and will keep to themselves all complaints which are useless towards a knowledge of their malady.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000032_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "You ought to give frequent and heartfelt thanks to the physician who affords you his advice or attentions.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000032_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "The circumstance of his being unsuccessful does not exonerate you from these testimonies of gratitude; it renders them perhaps more obligatory, for delicacy requires that you should not appear tacitly to reproach him on account of his having been unfortunate in his efforts.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000033_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Being obliged to speak of different wants, and of different parts of the body, for which politeness has no appropriate language, the physician ought to avoid being obscure or gross, particularly when addressing ladies.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000034_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Every body knows, also, that however poignant may be the grief of parents, they ought never to let it appear in their conversations with the physician, that they regard him as the cause of their affliction.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000037_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "No, they have a separate existence, one which the world does not comprehend, and which they ought to conceal from the world.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000038_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If, as we shall see hereafter, one should avoid speaking of his profession, and of his personal affairs, for a still stronger reason, an artist ought to be silent about his own labors, his success, and his hopes.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000039_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "People are also generally prone to suspect artists of jealousy.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000040_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000040_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "These observations are addressed equally to authors, with this important addition.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000040_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000040_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Besides the charge of arrogance, people are much disposed to accuse them of pedantry.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000040_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000040_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Let them therefore be careful, and check constantly the desire of entering into conversation upon the interesting subjects with which they are continually occupied.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000041_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "A graceful simplicity, a happy mixture of elevation and naivete, should characterise authors and artists, but particularly female authors and artists.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000041_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Ladies who handle the pen, the lyre, or the pencil, ought to be well persuaded that any vestige of prejudice raises against them, especially in provincial places, a multitude of unfavorable observations.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000041_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "And besides, so many half instructed women have had so much the air and manners of upstarts, that this opinion is almost excusable.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000041_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000041_000004.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Do away this unjust prejudice, my female friends: it will be both easy and pleasant; you will have only to follow the influence of an elevated soul, a pure taste; you will have but to remind yourselves that simplicity is the coquetry of genius.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000042_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000042_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If he makes us a present of any of his productions, we shall owe him a call, or at least a billet of thanks.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000042_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000042_000003.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Handsome compliments, and lively testimonials of acknowledgment, ought to fill up this visit or billet. Remember, also, that to please an artist, it is necessary to flatter at once his taste, his self esteem, and his cultivation of the fine arts. Speak to him therefore like a connoisseur, or at least an admirer of music, or of painting.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000042_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000042_000004.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Ask the favor of seeing his pictures, or of hearing his symphonies.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000044_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000044_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "These words, which are designed to make of the gift a remembrance or homage, are always written under the name of the person, and signed by the author.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000044_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000044_000003.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "We will here speak of a dedication only to observe, that we cannot dedicate a work to any one, without having previously obtained his consent, either verbally or by writing.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000044_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000044_000004.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "When it is to the king, queen, or princes, it is necessary to write to their secretary, to know their wish in this respect.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000044_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000044_000006.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "If the members of the royal family have accepted the dedication, the author is generally allowed the honor of presenting his work to them.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000047_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000047_000001.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "On entering a drawing room, an officer lays down his sabre or his sword.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000048_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "In a citizen's dress, officers may wear a black cravat.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000052_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000052_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "SECTION seven.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000054_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "A priest should be considered in two points of view; when he is exercising his holy office, and when he is taking part in the relations of society.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000054_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000054_000002.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Too light conversation, dancing and love songs, would be out of place in his presence.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7843_110055_000055_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7843/110055/7843_110055_000055_000000.wav",
        "speaker_id": "LibriTTS_R-7843",
        "content": "Ecclesiastics have two shoals to avoid.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    }
]