[
    {
        "item_name": "LibriTTS_R-3747_173589_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000000_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "He would fain build up a city of refuge for the persecuted sect.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000000_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000000_000004.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "He must act, too, in the name of the Crown, and in virtue of his office of Admiral of France.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000000_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000000_000005.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "A nobleman and a soldier,--for the Admiral of France was no seaman,--he shared the ideas and habits of his class; nor is there reason to believe him to have been in advance of his time in a knowledge of the principles of successful colonization.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000000_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000000_000006.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "His scheme promised a military colony, not a free commonwealth.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000000_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000000_000007.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "The Huguenot party was already a political as well as a religious party.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000000_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000000_000009.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Joined to these were numbers on whom the faith sat lightly, whose hope was in commotion and change.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000000_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000000_000010.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Of the latter, in great part, was the Huguenot noblesse, from Conde, who aspired to the crown,",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000002_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "to the younger son of the impoverished seigneur whose patrimony was his sword.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000002_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "More than this, the restless, the factious, and the discontented, began to link their fortunes to a party whose triumph would involve confiscation of the wealth of the only rich class in France.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000003_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "America was still a land of wonder.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000003_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "The ancient spell still hung unbroken over the wild, vast world of mystery beyond the sea,--a land of romance, adventure, and gold.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000004_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Fifty eight years later the Puritans landed on the sands of Massachusetts Bay.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000004_000003.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "In their own hearts, and not in the promptings of a great leader or the patronage of an equivocal government, their enterprise found its birth and its achievement.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000004_000004.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "They were of the boldest and most earnest of their sect.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000004_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000004_000005.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "There were such among the French disciples of Calvin; but no Mayflower ever sailed from a port of France.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000004_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000004_000006.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Coligny's colonists were of a different stamp, and widely different was their fate.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000005_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "An excellent seaman and stanch Protestant, Jean Ribaut of Dieppe, commanded the expedition.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000005_000004.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "It was the coast of Florida.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000006_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "On the next morning, the first of May, they found themselves off the mouth of a great river.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000006_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "They pushed their boats ashore and disembarked,--sailors, soldiers, and eager young nobles.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000006_000003.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Corselet and morion, arquebuse and halberd, flashed in the sun that flickered through innumerable leaves, as, kneeling on the ground, they gave thanks to God, who had guided their voyage to an issue full of promise.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000007_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "But Ribaut and his followers, just escaped from the dull prison of their ships, were intent on admiring the wild scenes around them.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000007_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Never had they known a fairer May day.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000009_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "They gathered, too, from the signs of their savage visitors, that the wonderful land of Cibola, with its seven cities and its untold riches, was distant but twenty days' journey by water.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000009_000003.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "In truth, it was two thousand miles westward, and its wealth a fable.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000010_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "They named the river the River of May.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000010_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "It is now the saint John's.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000011_000003.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "At length, opening betwixt flat and sandy shores, they saw a commodious haven, and named it Port Royal.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000012_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "When they landed, all was solitude.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000012_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "The frightened Indians had fled, but they lured them back with knives, beads, and looking glasses, and enticed two of them on board their ships.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000013_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Ranging the woods, they found them full of game, wild turkeys and partridges, bears and lynxes.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000013_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Two deer, of unusual size, leaped from the underbrush.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000013_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Cross bow and arquebuse were brought to the level; but the Huguenot captain, \"moved with the singular fairness and bigness of them,\" forbade his men to shoot.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000014_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Ribaut was more than willing to humor them.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000014_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "He mustered his company on deck, and made them a harangue.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000016_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "They were alone in those fearful solitudes.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000017_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "The pressing question was how they were to subsist.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000017_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Their thought was not of subsistence, but of gold.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000017_000003.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "For a time they busied themselves with finishing their fort, and, this done, set forth in quest of adventures.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000018_000000.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "The Indians had lost fear of them.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000018_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Ribaut had enjoined upon them to use all kindness and gentleness in their dealing with the men of the woods; and they more than obeyed him.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000018_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "They were soon hand and glove with chiefs, warriors, and squaws; and as with Indians the adage that familiarity breeds contempt holds with peculiar force, they quickly divested themselves of the prestige which had attached at the outset to their supposed character of children of the sun",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000018_000003.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "Good will, however, remained, and this the colonists abused to the utmost.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000019_000002.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "When they arrived, they found the village alive with preparation, and troops of women busied in sweeping the great circular area where the ceremonies were to take place.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000019_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000019_000005.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "A scene of ravenous feasting followed, in which the French, released from durance, were summoned to share.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3747_173589_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3747/173589/3747_173589_000020_000001.wav",
        "speaker_id": "LibriTTS_R-3747",
        "content": "The Indians, never niggardly of food, brought them supplies as long as their own lasted; but the harvest was not yet ripe, and their means did not match their good will.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    }
]