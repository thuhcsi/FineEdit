        "speaker_id": "LibriTTS_R-1212",
        "content": "And this is what he saw.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1212_75242_000027_000000",
