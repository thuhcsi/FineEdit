        "speaker_id": "LibriTTS_R-1212",
        "content": "Just one of Zip's eyes stuck out of a hole where the candy had dropped off, and his poor little tail stuck out like a handle on the other side of the ball.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1212_75242_000027_000001",
