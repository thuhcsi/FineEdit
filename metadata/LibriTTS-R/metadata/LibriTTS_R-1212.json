        "speaker_id": "LibriTTS_R-1212",
        "content": "When he appeared in the door all the children stopped laughing and stepped back to give him a chance to see Zip.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
