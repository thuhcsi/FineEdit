        "speaker_id": "LibriTTS_R-1212",
        "content": "The children had never thought that the poor dog could not move his head to keep out of the water.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
