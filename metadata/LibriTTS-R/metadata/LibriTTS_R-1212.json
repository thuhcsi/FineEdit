        "speaker_id": "LibriTTS_R-1212",
        "content": "Then with one hand he gently threw the water upon the candy until it began to loosen and fall off.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
