        "speaker_id": "LibriTTS_R-1212",
        "content": "As the candy began to loosen and drop off, first one black ear stood up and then the other, and last the little legs began to shoot out.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
