        "speaker_id": "LibriTTS_R-1212",
        "content": "Besides, the doctor had been her family physician for years, and they were all very, very fond of him as well as of Zip.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
