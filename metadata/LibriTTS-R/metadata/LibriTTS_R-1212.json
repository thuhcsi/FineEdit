        "speaker_id": "LibriTTS_R-1212",
        "content": "First he released the little dog's head, which had been bent down between his fore legs.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
