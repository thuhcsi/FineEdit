        "speaker_id": "LibriTTS_R-1212",
        "content": "As by this time the children had started to bathe Zip, the doctor was told to go right upstairs.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
