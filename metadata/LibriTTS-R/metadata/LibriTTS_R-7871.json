[
    {
        "item_name": "LibriTTS_R-7871_107222_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "but whether he ever reached that city, the same authority does not state.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "\"And while the children of Israel were in the wilderness, they found a man that gathered sticks upon the Sabbath day.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000006_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "And they that found him gathering sticks brought him unto Moses and Aaron, and unto all the congregation.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The German tale is as follows:--",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000009_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Ages ago there went one Sunday morning an old man into the wood to hew sticks.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "\"Sunday on earth, or Monday in heaven, it is all one to me!\" laughed the wood cutter.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000011_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "\"Then bear your bundle forever,\" answered the stranger; \"and as you value not Sunday on earth, yours shall be a perpetual Moon day in heaven; and you shall stand for eternity in the moon, a warning to all Sabbath breakers.\" Thereupon the stranger vanished, and the man was caught up with his stock and his fagot into the moon, where he stands yet.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The man carries his bundle of thorns, the woman her butter tub.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000013_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "A similar tale is told in Swabia and in Marken.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The Dutch household myth is, that the unhappy man was caught stealing vegetables.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "\"... Now doth Cain with fork of thorns confine, On either hemisphere, touching the wave Beneath the towers of Seville.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000026_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "which may be translated thus: \"Do you know what they call the rustic in the moon, who carries the fagot of sticks?\" So that one vulgarly speaking says,--",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000027_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "\"See the rustic in the Moon, How his bundle weighs him down; Thus his sticks the truth reveal, It never profits man to steal.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000029_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Also \"Tempest,\" Act two, Scene two:--",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000033_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The dog I have myself had pointed out to me by an old Devonshire crone.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000034_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "I believe this idea of locating animals in the two great luminaries of heaven to be very ancient, and to be a relic of a primeval superstition of the Aryan race.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000035_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "There is an ancient pictorial representation of our friend the Sabbath breaker in Gyffyn Church, near Conway.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000035_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000035_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Besides these symbols is delineated in each compartment an orb of heaven.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000035_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000035_000003.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The sun, the moon, and two stars, are placed at the feet of the Angel, the Bull, the Lion, and the Eagle.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000035_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000035_000005.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "There is also a curious seal appended to a deed preserved in the Record Office, dated the ninth year of Edward the Third (thirteen thirty five), bearing the man in the moon as its device.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000035_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000035_000007.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "On the seal we see the man carrying his sticks, and the moon surrounds him.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000035_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000035_000008.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "There are also a couple of stars added, perhaps to show that he is in the sky.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000035_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000035_000009.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The legend on the seal reads:--",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000040_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000040_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "In some places a woman is believed to accompany him, and she has a butter tub with her; in other localities she is replaced by a dog.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000041_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000041_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "On going to see, there was an illuminated disk, with the figure of a man upon it.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000041_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The water was then very low, and one of the conjuring parties had lit up this disk at the water's edge.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000041_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000041_000004.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "It was an imposing sight.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000042_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Now let us turn to Scandinavian mythology, and see what we learn from that source.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107222_000045_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107222/7871_107222_000045_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The names indicate as much.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000005_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "He knew her at once, by her attributes and by her superhuman perfection, to be none other than Venus.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000005_000003.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "A thrill of passion ran through the veins of the minnesinger; and, leaving his horse, he followed the apparition.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000005_000005.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "He entered the cavern, and descended to the palace of Venus in the heart of the mountain.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Seven years of revelry and debauch were passed, and the minstrel's heart began to feel a strange void.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000006_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "At the same time his conscience began to reproach him, and he longed to make his peace with God.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000006_000003.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "In vain did he entreat Venus to permit him to depart, and it was only when, in the bitterness of his grief, he called upon the Virgin Mother, that a rift in the mountain side appeared to him, and he stood again above ground.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000007_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "How delightful to him was the cushion of moss and scanty grass after the downy couches of the palace of revelry below!",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "He plucked the little heather bells, and held them before him; the tears rolled from his eyes, and moistened his thin and wasted hands.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000007_000003.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "He looked up at the soft blue sky and the newly risen sun, and his heart overflowed.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000007_000004.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "What were the golden, jewel incrusted, lamp lit vaults beneath to that pure dome of God's building!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The chime of a village church struck sweetly on his ear, satiated with Bacchanalian songs; and he hurried down the mountain to the church which called him.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "There he made his confession; but the priest, horror struck at his recital, dared not give him absolution, but passed him on to another.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "And so he went from one to another, till at last he was referred to the Pope himself.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000008_000006.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Urban was a hard and stern man, and shocked at the immensity of the sin, he thrust the penitent indignantly from him, exclaiming, \"Guilt such as thine can never, never be remitted.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000008_000007.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Sooner shall this staff in my hand grow green and blossom, than that God should pardon thee!\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "But lo! three days after he had gone, Urban discovered that his pastoral staff had put forth buds, and had burst into flower.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000009_000003.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Since then TanhA user has not been seen.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "It is a very ancient myth Christianized, a wide spread tradition localized.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000011_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The story, either in prose or verse, has often been printed.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000011_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Some of the earliest editions are the following:--",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000012_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000012_000005.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "eight.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000013_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Let us now see some of the forms which this remarkable myth assumed in other countries.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Every popular tale has its root, a root which may be traced among different countries, and though the accidents of the story may vary, yet the substance remains unaltered.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000013_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "It has been said that the common people never invent new story radicals any more than we invent new word roots; and this is perfectly true.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000013_000003.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The same story root remains, but it is varied according to the temperament of the narrator or the exigencies of localization.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000013_000004.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The story root of the Venusberg is this:--",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The underground folk seek union with human beings.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "A man is enticed into their abode, where he unites with a woman of the underground race.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "He desires to revisit the earth, and escapes.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000017_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "He returns again to the region below.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Now, there is scarcely a collection of folk lore which does not contain a story founded on this root.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "It appears in every branch of the Aryan family, and examples might be quoted from Modern Greek, Albanian, Neapolitan, French, German, Danish, Norwegian and Swedish, Icelandic, Scotch, Welsh, and other collections of popular tales.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000018_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "I have only space to mention some.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000019_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Helgi and his brother Thorstein went on a cruise to Finnmark, or Lapland.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000019_000002.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "They reached a ness, and found the land covered with forest.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000019_000003.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Helgi explored this forest, and lighted suddenly on a party of red dressed women riding upon red horses.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000019_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000019_000005.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "They erected a tent and prepared a feast.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000019_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000019_000006.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Helgi observed that all their vessels were of silver and gold.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000019_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000019_000008.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "He feasted and lived with the trolls for three days, and then returned to his ship, bringing with him two chests of silver and gold, which Ingibjorg had given him.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000019_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000019_000010.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The ships sailed, and he returned home.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107223_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107223/7871_107223_000021_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The Scotch story of Thomas of Ercildoune is the same story.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107225_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107225/7871_107225_000004_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The four rivers already mentioned rise in it.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107225_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107225/7871_107225_000009_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Consequently, the waters of the Deluge, which covered the highest points of the surface of our orb, were unable to reach it.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7871_107225_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107225/7871_107225_000012_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Leonardo Dati, a Florentine poet of the fifteenth century, composed a geographical treatise in verse, entitled \"Della Sfera;\" and it is in Asia that he locates the garden:--",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107225_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107225/7871_107225_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "The account is briefly this:--",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7871_107225_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7871/107225/7871_107225_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7871",
        "content": "Having obtained this information, the two Eireks started, furnished with letters from the Greek Emperor.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7871_107225_000019_000000",
