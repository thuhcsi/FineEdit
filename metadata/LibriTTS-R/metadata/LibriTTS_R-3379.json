        "speaker_id": "LibriTTS_R-3379",
        "content": "'That is an odd remark,' said Frances.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
