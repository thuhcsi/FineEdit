        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3379/132592/3379_132592_000015_000000.wav",
        "speaker_id": "LibriTTS_R-3379",
        "content": "'The guilty cannot claim that protection!' said sister Agnes, 'let the Count look to his conduct, that he do not forfeit his claim!",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
