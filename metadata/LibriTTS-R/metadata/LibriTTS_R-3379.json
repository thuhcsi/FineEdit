        "speaker_id": "LibriTTS_R-3379",
        "content": "'No,' replied Frances, 'the evening service is passed.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
