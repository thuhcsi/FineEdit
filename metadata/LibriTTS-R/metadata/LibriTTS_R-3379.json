        "speaker_id": "LibriTTS_R-3379",
        "content": "'You are right,' replied sister Agnes, 'I shall be better there.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
