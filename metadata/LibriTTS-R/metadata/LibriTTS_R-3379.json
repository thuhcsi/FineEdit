        "speaker_id": "LibriTTS_R-3379",
        "content": "Was not that the vesper bell?'",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
