        "speaker_id": "LibriTTS_R-3379",
        "content": "I mean you are yet innocent of any great crime!--But you have passions in your heart,--scorpions; they sleep now-beware how you awaken them!--they will sting you, even unto death!'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
