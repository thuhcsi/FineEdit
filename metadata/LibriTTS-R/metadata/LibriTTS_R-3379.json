        "speaker_id": "LibriTTS_R-3379",
        "content": "Your services have already awakened her gratitude, and your sufferings her pity; and trust me, my friend, in a heart so sensible as hers, gratitude and pity lead to love.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
