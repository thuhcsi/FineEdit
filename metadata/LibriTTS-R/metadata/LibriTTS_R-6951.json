[
    {
        "item_name": "LibriTTS_R-6951_79737_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000004_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The other demands only firm, but gentle and steady persistence.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000004_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "But judiciously to administer a system of rewards, or even of commendations, requires tact, discrimination, and skill.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000004_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It requires some observation of the peculiar characteristics of the different minds acted upon, and of the effects produced, and often some intelligent modification of the measures is required, to fit them to varying circumstances and times.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "A mother, for example, going into the village on a summer afternoon, leaves her children playing in the yard, under the general charge of Susan, who is at work in the kitchen, whence she can observe them from time to time through the open window.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000008_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "She thinks the children will be safe, provided they remain in the yard.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000008_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The only thing to be guarded against is the danger that they may go out through the gate into the road.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000010_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "But if she prefers to depend for their safety on their voluntary obedience to her commands, and wishes, moreover, to promote the spirit of obedience by rewarding rather than punishing, she can make her rewards of the nature of hire or not, according to her mode of management.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000012_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "I do not say that this is necessarily a bad plan, though I think there is a better.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000012_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Children may, perhaps, be trained gradually to habits of obedience by a system of direct rewards, and in a manner, too, far more agreeable to the parent and better for the child than by a system of compulsion through threats and punishment.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000015_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Suppose, for example, in the case above described, the mother, on leaving the children, simply gives them the command that they are not to leave the yard, but makes no promises, and then, on returning from the village with the bonbons in her bag, simply asks Susan, when she comes in, whether the children have obeyed her injunction not to leave the yard.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000015_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "If Susan says yes, she nods to them, with a look of satisfaction and pleasure, and adds: \"I thought they would obey me.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000015_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "I am very glad.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000015_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Now I can trust them again.\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000016_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Then, by and by, towards the close of the day, perhaps, and when the children suppose that the affair is forgotten, she takes an opportunity to call them to her, saying that she has something to tell them.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "\"You remember when I went to the village to day, I left you in the yard and said that you must not go out of the gate, and you obeyed.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Perhaps you would have liked to go out into the road and play there, but you would not go because I had forbidden it.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "I am very glad that you obeyed.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "I thought of you when I was in the village, and I thought you would obey me.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "I felt quite safe about you.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000005.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "If you had been disobedient children, I should have felt uneasy and anxious.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000006.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "But I felt safe.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000007.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "When I had finished my shopping, I thought I would buy you some bonbons, and here they are.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000008.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "You can go and sit down together on the carpet and divide them.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000017_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000017_000009.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Mary can choose one, and then Jane; then Mary, and then Jane again; and so on until they are all chosen.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000019_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It may, perhaps, be said by the reader that this is substantially the same as giving a direct reward for the obedience.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000019_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000019_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "And this is one of those cases where the effect is modified very greatly by the form.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000019_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Where children are directly promised a reward if they do so and so, they naturally regard the transaction as of the nature of a contract or a bargain, such that when they have fulfilled the conditions on their part the reward is their due, as, indeed, it really is; and they come and demand it as such.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000019_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000019_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The tendency, then, is, to divest their minds of all sense of obligation in respect to doing right, and to make them feel that it is in some sense optional with them whether to do right and earn the reward, or not to do right and lose it.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000021_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The lesson which we deduce from this illustration and the considerations connected with it may be stated as follows:",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000024_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The mother who understands the full import of this principle, and whose mind becomes fully possessed of it, will find it constantly coming into practical use in a thousand ways.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000024_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Of course learning to read is irksome to him.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000024_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "He dislikes extremely to leave his play and come to take his lesson.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000024_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000024_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Sometimes a mother is inconsiderate enough to be pained at this.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000024_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000024_000005.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "She is troubled to find that her boy takes so little interest in so useful a work, and even, perhaps, scolds him, and threatens him for not loving study.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000024_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000024_000006.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "\"If you don't learn to read,\" she says to him, in a tone of irritation and displeasure, \"you will grow up a dunce, and every body will laugh at you, and you will be ashamed to be seen.\"",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000026_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "But the child has no such near, distinct, and certain prospect of the advantages of knowing how to read.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000026_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "He has scarcely any idea of these advantages at all.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000026_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000026_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "You can describe them to him, but the description will have no perceptible effect upon his mind.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000026_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000026_000005.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Those faculties by which we bring the future vividly before us so as to influence our present action, are not yet developed.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000026_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000026_000006.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "His cerebral organization has not yet advanced to that condition, any more than his bones have advanced to the hardness, rigidness, and strength of manhood.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000026_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000026_000007.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "His mind is only capable of being influenced strongly by what is present, or, at least, very near. It is the design of Divine Providence that this should be so.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000026_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000026_000008.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The child is not made to look forward much yet, and the mother who is pained and distressed because he will not look forward, shows a great ignorance of the nature of the infantile mind, and of the manner of its development.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000027_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "\"It is very irksome, I know, but you must do it.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000027_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "When you are at play, and having a very pleasant time, I know very well that it is hard for you to be called away to puzzle over your letters and your reading.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000027_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000027_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It was very hard for me when I was a child.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000027_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000027_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It is very hard for all children; but then it must be done.\"",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000028_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The child must leave his play and come to take his lesson, not because he sees that it is better for him to learn to read than to play all the time, nor because he is to receive a reward in the form of compensation, but because his mother requires him to do it.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000032_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000032_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "A most improper time would be when a command had been given and was disregarded, or was reluctantly obeyed; for then such representations would only tend to enfeeble the principle of authority by bringing in the influence of reasonings and persuasions to make up for its acknowledged inefficiency.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000032_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000032_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It is one of those cases where a force is weakened by reinforcement-as a plant, by being long held up by a stake, comes in the end not to be able to stand alone.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000036_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "One mode by which this may be done is by not springing disagreeable obligations upon a child suddenly, but by giving his mind a little time to form itself to the idea of what is to come.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000036_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The delay of a single minute would be sufficient to bring their minds round easily and gently into submission to the necessity of the case.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000037_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "\"It is bed time, children, but I would like to see you finish your tower.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000041_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "So, if children are to be called away from their play for any purpose whatever, it is always best to give them a little notice, if it be only a moment's notice, beforehand.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000041_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000041_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "You can be getting your things ready to be left.\" \"Mary, it is almost time for your lesson.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000042_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "On the same principle, if boys are at play in the open air-at ball, or skating, or flying kites-and are to be recalled by a bell, obedience to the call will be made much more easy to them by a preliminary signal, as a warning, given five minutes before the time.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000043_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Of course, it will not always be convenient to give these signals and these times of preparation.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000043_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Nor will it be always necessary to give them.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000043_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000043_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "To determine how and in what cases it is best to apply the principle here explained will require some tact and good judgment on the part of the parent.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000043_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000043_000003.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It would be folly to lay down a rigid rule of this kind to be considered as always obligatory.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000043_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000043_000004.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "All that is desirable is that the mother should understand the principle, and that she should apply it as far as she conveniently and easily can do so.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000043_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000043_000005.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "She will find in practice that when she once appreciates the value of it, and observes its kind and beneficent working, she will find it convenient and easy to apply it far more generally than she would suppose.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000045_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It is very plain that softening thus the hardship for the child of any act of obedience required of him by giving him a little time implies no abatement of the authority of the parent, nor does it detract at all from the implicitness of the obedience on the part of the child.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000045_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000045_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The submission to authority is as complete in doing a thing in five minutes if the order was to do it in five minutes, as in doing it at once if the order was to do it at once.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000046_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The idea is, that though the parent is bound fully to maintain his authority over his children, in all its force, he is also bound to make the exercise of it as little irksome and painful to them as possible, and to prevent as much as possible the pressure of it from encroaching upon their juvenile joys.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000048_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "Indeed, besides the bearing of these views on the happiness of the children, it is not at all improbable that the question of health may be seriously involved in them.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000050_000000.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "It is true that mental disturbances and agitations of this kind can not be wholly avoided.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000050_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000050_000001.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "But they should be avoided as far as possible; and the most efficient means for avoiding them is a firm, though calm and gentle, establishment and maintenance of parental authority, and not, as many mothers very mistakingly imagine, by unreasonable indulgences, and by endeavors to manage their children by persuasions, bribings, and manoeuvrings, instead of by commands.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6951_79737_000050_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6951/79737/6951_79737_000050_000002.wav",
        "speaker_id": "LibriTTS_R-6951",
        "content": "The most indulged children, and the least governed, are always the most petulant and irritable; while a strong government, if regular, uniform, and just, and if administered by gentle measures, is the most effectual of all possible instrumentalities for surrounding childhood with an atmosphere of calmness and peace.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    }
]