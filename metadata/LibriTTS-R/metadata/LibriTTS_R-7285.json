[
    {
        "item_name": "LibriTTS_R-7285_72200_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7285/72200/7285_72200_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7285",
        "content": "He stooped and felt on the ground in the darkness and rain, for a stick, by means of which to tighten it still more; for the bleeding, though considerably checked, was by no means stanched.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7285_72200_000004_000001",
