        "speaker_id": "LibriTTS_R-2061",
        "content": "After a conference with Pepperrell he hurried off to begin the blockade of Louisbourg.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-2061_147110_000015_000003",
