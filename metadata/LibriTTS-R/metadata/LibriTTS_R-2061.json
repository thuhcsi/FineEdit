        "speaker_id": "LibriTTS_R-2061",
        "content": "He was much disliked in Louisbourg.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
