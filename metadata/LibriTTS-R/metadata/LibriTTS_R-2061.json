        "speaker_id": "LibriTTS_R-2061",
        "content": "The men volunteered eagerly.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2061_147110_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2061/147110/2061_147110_000014_000000.wav",
        "speaker_id": "LibriTTS_R-2061",
        "content": "On may fifth Warren sailed into Canso.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2061_147110_000014_000002",
