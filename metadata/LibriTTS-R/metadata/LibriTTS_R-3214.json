        "speaker_id": "LibriTTS_R-3214",
        "content": "Old dotard!...\" cried he.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000014_000002.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "Dron was of this opinion, but as soon as he expressed it Karp and others attacked their ex Elder.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000016_000000",
