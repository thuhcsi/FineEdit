        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000028_000000.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "\"Arguing?",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000028_000001.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "Mutiny!...",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000028_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000028_000003.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "Traitors!\" cried Rostov unmeaningly in a voice not his own, gripping Karp by the collar.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000037_000000.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "\"Why, we've not done any harm!",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000037_000001.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "We did it just out of foolishness.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000037_000002.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "It's all nonsense...",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000038_000000.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "\"There!",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000038_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000038_000002.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "\"It's wrong, lads!\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000044_000001",
