        "speaker_id": "LibriTTS_R-3214",
        "content": "\"That's it-not against it!",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
