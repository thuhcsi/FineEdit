        "speaker_id": "LibriTTS_R-3214",
        "content": "\"The Elder?",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3214_167602_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3214/167602/3214_167602_000022_000001.wav",
        "speaker_id": "LibriTTS_R-3214",
        "content": "What do you want with him?...\" asked Karp.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
