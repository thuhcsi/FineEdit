        "speaker_id": "LibriTTS_R-3214",
        "content": "The two tall peasants had their say.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
