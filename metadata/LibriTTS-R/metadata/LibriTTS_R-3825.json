        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3825/134148/3825_134148_000033_000002.wav",
        "speaker_id": "LibriTTS_R-3825",
        "content": "In fact, he climbed up into Sylvie's lap as he spoke, and rested his head against her shoulder.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
