        "speaker_id": "LibriTTS_R-3825",
        "content": "\"But I hope to run down again in a month,\" I added.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very high"
