        "speaker_id": "LibriTTS_R-3825",
        "content": "\"But don't think about me.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
