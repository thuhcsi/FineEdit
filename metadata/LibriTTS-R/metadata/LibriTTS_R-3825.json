        "speaker_id": "LibriTTS_R-3825",
        "content": "AN OUTLANDISH WATCH.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very high"
    },
    {
