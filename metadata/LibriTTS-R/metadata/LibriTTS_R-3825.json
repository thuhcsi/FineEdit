        "speaker_id": "LibriTTS_R-3825",
        "content": "CHAPTER twenty three.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
