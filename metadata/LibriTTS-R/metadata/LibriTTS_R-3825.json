        "speaker_id": "LibriTTS_R-3825",
        "content": "I have made up my mind to accept a post in India, that has been offered me.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
