        "speaker_id": "LibriTTS_R-3825",
        "content": "\"I would stay now, if I could.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
