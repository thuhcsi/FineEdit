        "speaker_id": "LibriTTS_R-3825",
        "content": "\"Ah, she'll like 'em, I war'n' ye!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
