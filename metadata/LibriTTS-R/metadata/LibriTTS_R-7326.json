        "speaker_id": "LibriTTS_R-7326",
        "content": "(one) Whether the appetite should be considered a special power of the soul?",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
