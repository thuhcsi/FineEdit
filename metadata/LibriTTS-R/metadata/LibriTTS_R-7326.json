        "speaker_id": "LibriTTS_R-7326",
        "content": "Whether the Appetite Is a Special Power of the Soul?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
