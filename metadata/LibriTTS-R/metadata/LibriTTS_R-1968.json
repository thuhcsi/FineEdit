[
    {
        "item_name": "LibriTTS_R-1968_145732_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "They went on a long way, until they caught sight of a hind with a gold ring on its horns.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The Prince was eager to catch it, if possible, so they gave chase and rode on without stopping until all the horses began to founder beneath them.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The Prince went up to her and saluted her politely, and she received him very graciously.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The Prince thought himself in a bad plight now, as he felt the barrel floating out from the land and tossing about on the waves.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000010_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Choose me, Prince Ring.'",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000012_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "He also thanked him for his good service, and told him to choose some one of his possessions, for he would get whatever he wanted.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000012_000003.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The Giant was taken by surprise, and said:",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'There, you chose my old woman's right hand; but I must not break my word.'",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000017_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The Prince then forced himself to ask, 'What is your name?'",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The Prince now began to be less afraid of the Dog.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000020_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000020_000002.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The King replied that it was only a short time since he had come there.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "Ring was now in far greater esteem with the King than before, and Red was all the more discontented.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000023_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Don't you think that a desperate errand?' said the King, 'seeing they are so dangerous, and no one has ever yet ventured to go against them?'",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000024_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "Red answered that he had only one life to lose, and it would be interesting to see how brave he was; besides, the King would have good reason to ennoble him if he overcame them.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000024_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The King at last allowed himself, though rather unwillingly, to be won over by Red's persistency, and one day asked Ring to go and kill the oxen that were in the wood for him, and bring their horns and hides to him in the evening.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000025_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "Ring grew terribly afraid.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000026_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'How do you like them?' asked Snati.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000027_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Not well at all,' said the Prince.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000028_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'We can do nothing else,' said Snati, 'than attack them, if it is to go well; you will go against the little one, and I shall take the other.'",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000032_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "One day a good idea came into his head.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000035_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Don't remind me of them!' said the King.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000038_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'What is that?' said Ring.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000039_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "If you can bring them to me before Christmas I will give you my daughter in marriage.'",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000041_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'That you must find out for yourself,' said the King: 'I don't know.'",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000044_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'We must go up here,' said Snati.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000045_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'I don't think that will be child's play,' said the Prince.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000046_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The Prince began to get giddy, but up went Snati on to the second shelf.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000046_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000046_000003.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "After a little, however, he recovered again, and they went a short distance along a level plain, until they came to a cave.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000047_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Now you must empty all the salt into the porridge pot,' said Snati.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000048_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000048_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "Ring did so, and soon the trolls wakened up.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000051_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'I won't go,' said she, 'unless you lend me your bright gold piece.'",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000056_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000056_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "The old hag began now to long for the water, and said that the girl would be running about with the gold piece all over the plain, so she asked her son to go and get her a drop of water.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000057_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000057_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'I won't go,' said he, 'unless I get the gold cloak.'",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000059_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000059_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Die, then,' said the son.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000061_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000061_000001.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "On reaching the river he went to take a drink like his sister, but at that moment Ring and Snati sprang upon him, took the cloak from him, and threw him into the river.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000066_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000066_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Take it, then, you utter disgrace!' said the old hag, 'since you are just like these two brats.'",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000067_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000067_000002.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "Snati immediately sprang upon him, and Ring assisted in the attack, and after a hard struggle they mastered him a second time.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1968_145732_000068_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1968/145732/1968_145732_000068_000000.wav",
        "speaker_id": "LibriTTS_R-1968",
        "content": "'Now we must go in at once,' said Snati, 'and try to master her there, for if she once gets out we shall have no chance with her.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
