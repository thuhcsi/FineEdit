        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5186/7793/5186_7793_000048_000000.wav",
        "speaker_id": "LibriTTS_R-5186",
        "content": "'DEAR SIR,",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
