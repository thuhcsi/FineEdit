        "speaker_id": "LibriTTS_R-8975",
        "content": "But the latent dream thoughts, which we have solved by means of the dream interpretation, are not of this realm.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
