        "speaker_id": "LibriTTS_R-8975",
        "content": "Sachs).",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
