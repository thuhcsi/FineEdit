        "speaker_id": "LibriTTS_R-8975",
        "content": "Many things are taking place there that are not reasonable, and so it happens that we are ashamed of such dreams, and unreasonably.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
