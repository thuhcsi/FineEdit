        "speaker_id": "LibriTTS_R-8975",
        "content": "I mean the love rivalry, with the especial emphasis of the sex character.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
