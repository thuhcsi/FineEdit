        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8975/270782/8975_270782_000021_000000.wav",
        "speaker_id": "LibriTTS_R-8975",
        "content": "Let us sum up what our plunge into child psychology has given us toward the understanding of the dream.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
