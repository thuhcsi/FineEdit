        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8975/270782/8975_270782_000021_000003.wav",
        "speaker_id": "LibriTTS_R-8975",
        "content": "The estranging impression that there is so much evil in man, begins to weaken.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
