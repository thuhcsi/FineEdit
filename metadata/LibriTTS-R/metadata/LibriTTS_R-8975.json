        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8975/270782/8975_270782_000020_000000.wav",
        "speaker_id": "LibriTTS_R-8975",
        "content": "Especially noteworthy among these forbidden wishes are those of incest, i e, those directed towards sexual intercourse with parents and brothers and sisters.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8975_270782_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8975/270782/8975_270782_000020_000001.wav",
        "speaker_id": "LibriTTS_R-8975",
        "content": "You know what antipathy society feels toward such intercourse, or at least pretends to feel, and what weight is laid on the prohibitions directed against it.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
