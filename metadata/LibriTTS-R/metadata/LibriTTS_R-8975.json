        "speaker_id": "LibriTTS_R-8975",
        "content": "So we called the mode of expression of the dream work the archaic or regressive.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
