        "speaker_id": "LibriTTS_R-8975",
        "content": "But it is only a deceptive appearance by which we have allowed ourselves to be frightened.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
