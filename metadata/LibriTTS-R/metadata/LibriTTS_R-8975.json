        "speaker_id": "LibriTTS_R-8975",
        "content": "First: the regression of dream work is not only formal, it is also of greater import.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
