        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8975/270782/8975_270782_000021_000006.wav",
        "speaker_id": "LibriTTS_R-8975",
        "content": "We are not so evil as we might suspect from the interpretation of dreams.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
