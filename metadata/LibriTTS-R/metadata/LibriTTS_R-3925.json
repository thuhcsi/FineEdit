[
    {
        "item_name": "LibriTTS_R-3925_57460_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000000_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "NOTE.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000001_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Of the many fair scenes of Yedo, none is better worth visiting than the temple of Zojoji, one of the two great burial places of the Shoguns; indeed, if you wish to see the most beautiful spots of any Oriental city, ask for the cemeteries: the homes of the dead are ever the loveliest places.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000001_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000001_000003.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "At these the visitor is warned by a notice to take off his boots, a request which Englishmen, with characteristic disregard of the feelings of others, usually neglect to comply with.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000002_000001.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Iyeyasu, seeing that the Abbot was no ordinary man, stopped and asked his name, and entered the temple to rest himself.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000002_000002.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "The smooth spoken monk soon found such favour with Iyeyasu, that he chose Zojoji to be his family temple; and seeing that its grounds were narrow and inconveniently near the castle, he caused it to be removed to its present site.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000002_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000002_000004.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Nor were the privileges of the temple confined to barren honours, for it was endowed with lands of the value of five thousand kokus of rice yearly.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000005_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "The shrines are of exceeding beauty, lying on one side of a splendid avenue of Scotch firs, which border a broad, well kept gravel walk. Passing through a small gateway of rare design, we come into a large stone courtyard, lined with a long array of colossal stone lanterns, the gift of the vassals of the departed Prince.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000005_000002.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Inside this is a third court, partly covered like a cloister, the approach to which is a doorway of even greater beauty and richness than the last; the ceiling is gilt, and painted with arabesques and with heavenly angels playing on musical instruments, and the panels of the walls are sculptured in high relief with admirable representations of birds and flowers, life-size, life like, all being coloured to imitate nature.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000005_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000005_000003.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Inside this enclosure stands a shrine, before the closed door of which a priest on one side, and a retainer of the house of Tokugawa on the other, sit mounting guard, mute and immovable as though they themselves were part of the carved ornaments.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000005_000004.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Passing on one side of the shrine, we come to another court, plainer than the last, and at the back of the little temple inside it is a flight of stone steps, at the top of which, protected by a bronze door, stands a simple monumental urn of bronze on a stone pedestal.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000005_000005.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Under this is the grave itself; and it has always struck me that there is no small amount of poetical feeling in this simple ending to so much magnificence; the sermon may have been preached by design, or it may have been by accident, but the lesson is there.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000006_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "There is little difference between the three shrines, all of which are decorated in the same manner.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000006_000001.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "It is very difficult to do justice to their beauty in words.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000010_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "The temples in Yedo are not to be compared in point of beauty with those in and about Peking; what is marble there is wood here.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000010_000001.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Still they are very handsome, and in the days of its magnificence the Temple of Uyeno was one of the finest.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000010_000005.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Among these is a temple in the form of a roofless stage, in honour of the thousand handed Kwannon.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000010_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000010_000007.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "His retreat having been discovered, he was seized and brought bound to Kamakura, the chief town of the house of Gen.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000010_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000010_000010.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "To him this temple is dedicated.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000010_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000010_000011.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "A colossal bronze Buddha, twenty two feet high, set up some two hundred years ago, and a stone lantern, twenty feet high, and twelve feet round at the top, are greatly admired by the Japanese.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57460_000010_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57460/3925_57460_000010_000012.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "There are only three such lanterns in the empire; the other two being at Nanzenji-a temple in Kiyoto, and Atsura, a shrine in the province of Owari.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000001_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Chapter twenty.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000002_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "THE SACRAMENT OF CONFIRMATION.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000003_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Confirmation is a Sacrament in which, through the imposition of the Bishop's hands, unction and prayer, baptized persons receive the Holy Ghost, that they may steadfastly profess their faith and lead upright lives.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000005_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Frequent mention is made of this Sacrament in the Holy Scripture.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000009_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "It cannot be asserted that the laying on of hands and the graces which followed from it, as recorded in the Acts, were not intended to be continued after the Apostles' times, for there is no warrant for such an assumption.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000009_000002.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Hence the successors of the Apostles in the nineteenth century have precisely the same authority and obligation to confirm as they have to preach, to baptize or to ordain.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000010_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Those who were confirmed by the Apostles usually gave evidence of the grace which they received by prophecy, the gift of tongues and the manifestation of other miraculous powers.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000010_000001.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "It may be asked: Why do not these gifts accompany now the imposition of hands?",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000010_000002.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "I answer: Because they are no longer needed.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000010_000003.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "The grace which the Apostolic disciples received was for their personal sanctification.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000010_000004.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "The gift of tongues which they exercised was intended by Almighty God to edify and enlighten the spectators, and to give Divine sanction to the Apostolic ministry.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000010_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000010_000006.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "But after it had taken root in the hearts of the people and spread its branches over the earth it was left to the ordinary agencies of Providence.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000011_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "saint Augustine writes also on the same subject: \"In the first days (of the Church) the Holy Ghost came down on believers, and they spoke in tongues which they had not learned....",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000011_000003.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "If, then, there be not now a testimony to the presence of the Holy Spirit by means of these miracles, whence is it proved that he has received the Holy Spirit?",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000012_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "Following in the footsteps of the Apostles we find the Fathers of the Church, from the earliest age, recognizing Confirmation as a Divine and sacramental institution and proclaiming its salutary effects.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-3925_57660_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3925/57660/3925_57660_000015_000000.wav",
        "speaker_id": "LibriTTS_R-3925",
        "content": "saint Cyril of Jerusalem compares the sacred Chrism in Confirmation to the Eucharist: \"You were anointed with oil, being made sharers and partners of Christ.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
