        "speaker_id": "LibriTTS_R-1629",
        "content": "But O! it would have been well for the King if he had let them go!",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
