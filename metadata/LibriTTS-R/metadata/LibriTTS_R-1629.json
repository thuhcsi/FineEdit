        "speaker_id": "LibriTTS_R-1629",
        "content": "It is called the Short Parliament, for it lasted a very little while.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
