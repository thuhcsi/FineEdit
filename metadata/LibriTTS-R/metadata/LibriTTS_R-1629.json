        "speaker_id": "LibriTTS_R-1629",
        "content": "This happened in his hall.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
