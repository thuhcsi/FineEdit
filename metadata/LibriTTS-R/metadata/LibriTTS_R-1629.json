        "speaker_id": "LibriTTS_R-1629",
        "content": "At first the King tried force, then treaty, then a Scottish Parliament which did not answer at all.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
