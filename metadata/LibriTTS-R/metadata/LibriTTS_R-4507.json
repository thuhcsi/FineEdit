        "speaker_id": "LibriTTS_R-4507",
        "content": "It is the language of prisons, galleys, convicts, of everything that is most abominable in society!\" etc, etc",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
