        "speaker_id": "LibriTTS_R-4507",
        "content": "Why, argot is horrible!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
