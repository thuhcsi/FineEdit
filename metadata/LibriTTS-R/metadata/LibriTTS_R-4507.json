        "speaker_id": "LibriTTS_R-4507",
        "content": "We have never understood this sort of objections.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
