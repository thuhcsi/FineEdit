        "speaker_id": "LibriTTS_R-2691",
        "content": "\"Grandpa, please give us a little piece of meat.\"",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
