        "speaker_id": "LibriTTS_R-2691",
        "content": "But we were not much afraid when it was light enough, so that imagination could not picture them creeping stealthily behind us.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2691_156750_000016_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2691/156750/2691_156750_000016_000003.wav",
        "speaker_id": "LibriTTS_R-2691",
        "content": "Thus more friends came among us.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "low"
    },
    {
