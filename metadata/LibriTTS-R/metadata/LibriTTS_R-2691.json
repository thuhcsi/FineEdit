        "speaker_id": "LibriTTS_R-2691",
        "content": "Like a flash, she tossed the bundle from her head, sprang into the water, snatched Frances as she rose to the surface, and restored her to us without a word.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
