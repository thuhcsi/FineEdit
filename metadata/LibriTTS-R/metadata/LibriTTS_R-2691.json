        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2691/156750/2691_156750_000017_000001.wav",
        "speaker_id": "LibriTTS_R-2691",
        "content": "She searched us out, saying:",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2691_156750_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2691/156750/2691_156750_000027_000000.wav",
        "speaker_id": "LibriTTS_R-2691",
        "content": "He was as courteous to us as though we were grown ladies, shook hands, asked how we felt, begged us to be seated, and then stepped to a door and called, \"Susan!",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
