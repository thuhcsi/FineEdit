        "speaker_id": "LibriTTS_R-2691",
        "content": "Sometimes, we played on the way and made mistakes.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2691_156750_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2691/156750/2691_156750_000015_000003.wav",
        "speaker_id": "LibriTTS_R-2691",
        "content": "When late on the road, we saw coyotes sneaking out for their evening meal and heard the far away cry of the panther.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2691_156750_000015_000004",
