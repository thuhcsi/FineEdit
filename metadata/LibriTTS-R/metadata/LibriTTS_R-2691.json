        "speaker_id": "LibriTTS_R-2691",
        "content": "A sweet voice answered, \"Coming!\"",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2691_156750_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2691/156750/2691_156750_000028_000002.wav",
        "speaker_id": "LibriTTS_R-2691",
        "content": "I was satisfied just to look at them and hear them speak.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-2691_156750_000028_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/2691/156750/2691_156750_000028_000003.wav",
        "speaker_id": "LibriTTS_R-2691",
        "content": "At the close of our visit, with a knowing look, she took us to see what Aunt Lucy had baked.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-2691_156750_000029_000002",
