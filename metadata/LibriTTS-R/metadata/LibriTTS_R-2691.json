        "speaker_id": "LibriTTS_R-2691",
        "content": "Upon learning, he turned about, lifted a liver from a wooden peg and cut for each, a generous slice.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "very low",
