[
    {
        "item_name": "LibriTTS_R-1556_139350_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/139350/1556_139350_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "The principal habitation, with its annexes-kitchen, offices, and cellars-was placed in the rear-or, let us say, stern of the craft-and formed a part reserved for the Garral family and their personal servants.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_139350_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/139350/1556_139350_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Such would have been useless.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_139350_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/139350/1556_139350_000019_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "If the pilot was the material director of this immense machine-for can we not justly call it so?--another personage was its spiritual director; this was Padre Passanha, who had charge of the mission at Iquitos.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_139350_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/139350/1556_139350_000024_000001.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "They had proposed it to him, and he had accepted, and when arrived at Belem he was to marry the young couple, Minha and Manoel.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_139350_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/139350/1556_139350_000026_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "The parsonage was not enough for Padre Passanha; he ought to have a chapel.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_139350_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/139350/1556_139350_000030_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "All was ready to date, the fifth of June.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "CHAPTER thirteen.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "The mules are packed and away goes our train of lumber, rations, and camping equipage. The Indian trail is at the foot of the Vermilion Cliffs.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "On rare occasions a stream flows down this valley, but now sand dunes stretch across it.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "We find it at the Navajo Well. As we approach in the darkness the camp fire is a cheerful sight.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000008_000004.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "That painting, known as \"The Chasm of the Colorado,\" is in a hall in the Senate wing of the Capitol of the United States.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000009_000002.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "In the morning we turn to the northeast and descend from Kaibab to the back of Marble Canyon and cross it at the foot of the Vermilion Cliffs, and find our packers camped at Jacob's Pool, where a spring bursts from the cliff at the summit of a great hill of talus.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000010_000003.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "At night we camp on the bank of the Colorado River, on the same spot where our boat party had camped the year before. Leaving the party in charge of mr Graves and mr Bishop, while they are building a ferryboat, I take some Indians to explore the canyon of the Paria.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Where the declivity of the stream is great the river corrades, or cuts its bottom deeper and still deeper, ever forming narrow clefts, but when the stream has cut its channel down until the declivity is greatly reduced, it can no longer carry the load of sand with which it is fed, but drops a part of it on the way.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000011_000002.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Wherever it drops it in this manner a sand bank is formed.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000013_000002.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "At night we camp at a water pocket, a pool in a great limestone rock.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000013_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000013_000007.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "At night we come to the cliff, and under it, in a great cave, we find a lakelet.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000017_000023",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000017_000023.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "They are eaten with much gusto by the party and highly praised.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000017_000024",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000017_000024.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Some days after we learned how they are made; they are prepared of goat's flesh, bread, and turnips, and kneaded by mastication.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "The next morning we are up at daybreak.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000020_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000020_000007.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "So his talk is explained to us. Some must gather corn, others must go for wood, water must be brought from the distant wells, and the animals of the strangers must be cared for.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000021_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000021_000010.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Ears of corn, vases of holy water, and trays of meal make up a part of the paraphernalia of worship. I try to record some of the prayers, but am not very successful, as it is difficult to hold my interpreter to the work.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000025_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000025_000008.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "After a while some one gets permanent possession of the charm and the music ceases.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000026_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000026_000002.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Then we go around among the people and select the articles of pottery, stone implements, instruments and utensils made of bone, horn, shell, articles of clothing and ornament, baskets, trays, and many other things, and tell the people to bring them the next day to our rooms.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000026_000003.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "A little after sunrise they come in, and we have a busy day of barter.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000027_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000027_000002.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "The whole town comes to bid us good by.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000027_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000027_000005.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "\"Good by; good by; good by!\" At last we start.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000027_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000027_000010.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "To reach it from below, it must be climbed by niches and stairways in the rock.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000027_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000027_000011.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "It is a good site for defense.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000027_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000027_000013.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "All the water used in these three towns is derived from a well nearly a mile away-a deep pit sunk in the sand, over the site of a dune buried brook.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000028_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000028_000006.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "After supper the hours till midnight are passed in rather formal talk.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000031_000000.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Here at Walpi the great snake dance is performed.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000031_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000031_000002.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "Most of these snakes are quite harmless, but rattlesnakes abound, and they are also caught, for they play the most important role in the great snake dance.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1556_143307_000031_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1556/143307/1556_143307_000031_000009.wav",
        "speaker_id": "LibriTTS_R-1556",
        "content": "It is managed in this way: The snake is teased with the feather wand and his attention occupied by one man, while another, standing near, at a favorable moment seizes the snake just, back of the head.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    }
]