        "speaker_id": "LibriTTS_R-6930",
        "content": "\"One could almost swear to it, to observe him.\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
