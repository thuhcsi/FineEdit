        "speaker_id": "LibriTTS_R-6930",
        "content": "\"Nay, where it does exist.\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6930_75918_000029_000000",
