        "speaker_id": "LibriTTS_R-6930",
        "content": "\"What do you mean?\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
