        "speaker_id": "LibriTTS_R-6930",
        "content": "Presently she spoke:",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
