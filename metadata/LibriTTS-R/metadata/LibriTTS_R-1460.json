        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1460/138290/1460_138290_000053_000003.wav",
        "speaker_id": "LibriTTS_R-1460",
        "content": "However, I look round upon life quite cool.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1460_138290_000055_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1460/138290/1460_138290_000055_000002.wav",
        "speaker_id": "LibriTTS_R-1460",
        "content": "But I have my depths; ha, and even my great depths!",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1460_138290_000055_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1460/138290/1460_138290_000055_000004.wav",
        "speaker_id": "LibriTTS_R-1460",
        "content": "But no-O no!\"",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1460_138290_000056_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1460/138290/1460_138290_000056_000003.wav",
        "speaker_id": "LibriTTS_R-1460",
        "content": "Weren't I stale in wedlock afore ye were out of arms?",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1460_138290_000056_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1460/138290/1460_138290_000056_000004.wav",
        "speaker_id": "LibriTTS_R-1460",
        "content": "'tis a poor thing to be sixty, when there's people far past four score-a boast weak as water.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
