        "speaker_id": "LibriTTS_R-1460",
        "content": "\"Oh, oh, that's his answer!",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
