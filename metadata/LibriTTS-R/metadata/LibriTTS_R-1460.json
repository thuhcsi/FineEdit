        "speaker_id": "LibriTTS_R-1460",
        "content": "That was my depth! ...",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
