        "speaker_id": "LibriTTS_R-1460",
        "content": "He adored Bathsheba just the same.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
