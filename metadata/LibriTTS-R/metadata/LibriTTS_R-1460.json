        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1460/138290/1460_138290_000064_000010.wav",
        "speaker_id": "LibriTTS_R-1460",
        "content": "This was mere exclamation-the froth of the storm.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
