        "speaker_id": "LibriTTS_R-1460",
        "content": "Perhaps 'tis high time.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1460_138290_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1460/138290/1460_138290_000050_000000.wav",
        "speaker_id": "LibriTTS_R-1460",
        "content": "\"What a lie!\" said Gabriel.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1460_138290_000051_000000",
