        "speaker_id": "LibriTTS_R-1460",
        "content": "Who am I, then, to be treated like that?",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1460_138289_000066_000000",
