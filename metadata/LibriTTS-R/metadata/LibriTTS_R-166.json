        "speaker_id": "LibriTTS_R-166",
        "content": "\"Oh, yes, he is a peer.\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
