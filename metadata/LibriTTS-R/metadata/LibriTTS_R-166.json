        "speaker_id": "LibriTTS_R-166",
        "content": "\"And has he any other title than Lord Lambeth?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
