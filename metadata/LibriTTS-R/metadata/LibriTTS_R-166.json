        "speaker_id": "LibriTTS_R-166",
        "content": "The young Englishmen were introduced to everybody, entertained by everybody, intimate with everybody.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
