        "speaker_id": "LibriTTS_R-166",
        "content": "He had meditated upon mrs Westgate's account of her sister, and he discovered for himself that the young lady was clever, and appeared to have read a great deal.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
