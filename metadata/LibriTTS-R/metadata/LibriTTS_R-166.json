        "speaker_id": "LibriTTS_R-166",
        "content": "\"He is a peer, then?\"",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
