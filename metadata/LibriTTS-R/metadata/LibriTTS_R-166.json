        "speaker_id": "LibriTTS_R-166",
        "content": "\"His position?\" Percy Beaumont repeated.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-166_122789_000005_000000",
