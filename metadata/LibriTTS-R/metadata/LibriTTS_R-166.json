        "speaker_id": "LibriTTS_R-166",
        "content": "\"He is the son of the Duke of Bayswater,\" he added presently.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
