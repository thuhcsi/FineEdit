[
    {
        "item_name": "LibriTTS_R-166_122789_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/166/122789/166_122789_000000_000002.wav",
        "speaker_id": "LibriTTS_R-166",
        "content": "It is not proposed to narrate minutely the incidents of their sojourn on this charming shore; though if it were convenient I might present a record of impressions nonetheless delectable that they were not exhaustively analyzed.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
