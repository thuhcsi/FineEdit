        "speaker_id": "LibriTTS_R-166",
        "content": "If she was shy, she carried it off very well.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-166_122789_000001_000001",
