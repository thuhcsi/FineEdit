        "speaker_id": "LibriTTS_R-4738",
        "content": "Sydneian showers Of sweet discourse, whose powers Can crown old Winter's head with flowers.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
