        "speaker_id": "LibriTTS_R-4738",
        "content": "Now air is hush'd, save where the weak eyed bat With short shrill shriek flits by on leathern wing, Or where the beetle winds His small but sullen horn,",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "low"
