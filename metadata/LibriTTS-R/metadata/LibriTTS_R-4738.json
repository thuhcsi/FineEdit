        "speaker_id": "LibriTTS_R-4738",
        "content": "Where'er she lie, Lock'd up from mortal eye In shady leaves of destiny:",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
