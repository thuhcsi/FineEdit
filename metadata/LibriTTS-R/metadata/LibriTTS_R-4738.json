        "speaker_id": "LibriTTS_R-4738",
        "content": "Till that divine Idea take a shrine Of crystal flesh, through which to shine:",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4738_291945_000015_000000",
