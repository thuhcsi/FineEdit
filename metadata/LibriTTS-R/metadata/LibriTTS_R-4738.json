        "speaker_id": "LibriTTS_R-4738",
        "content": "I wish her beauty, That owes not all its duty To gaudy tire, or glist'ring shoe tie:",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4738_291945_000016_000000",
