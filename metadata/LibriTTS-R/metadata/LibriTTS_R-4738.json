        "speaker_id": "LibriTTS_R-4738",
        "content": "--Now, if Time knows That Her, whose radiant brows Weave them a garland of my vows;",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4738_291945_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4738/291945/4738_291945_000028_000001.wav",
        "speaker_id": "LibriTTS_R-4738",
        "content": "I unclothe and clear My wishes' cloudy character.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4738_291945_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4738/291945/4738_291945_000030_000000.wav",
        "speaker_id": "LibriTTS_R-4738",
        "content": "Let her full glory, My fancies, fly before ye; Be ye my fictions:--but her story.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
