        "speaker_id": "LibriTTS_R-4738",
        "content": "Whate'er delight Can make day's forehead bright Or give down to the wings of night.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
