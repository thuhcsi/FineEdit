        "speaker_id": "LibriTTS_R-4738",
        "content": "Then let me rove some wild and heathy scene; Or find some ruin midst its dreary dells, Whose walls more awful nod By thy religious gleams.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
