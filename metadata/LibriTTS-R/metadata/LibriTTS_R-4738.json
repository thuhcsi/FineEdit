        "speaker_id": "LibriTTS_R-4738",
        "content": "A face that's best By its own beauty drest, And can alone command the rest:",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
