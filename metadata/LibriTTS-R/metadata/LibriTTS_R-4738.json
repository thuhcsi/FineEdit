        "speaker_id": "LibriTTS_R-4738",
        "content": "While sallow Autumn fills thy lap with leaves; Or Winter, yelling through the troublous air, Affrights thy shrinking train, And rudely rends thy robes;",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
