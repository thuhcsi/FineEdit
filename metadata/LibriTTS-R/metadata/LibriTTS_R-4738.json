        "speaker_id": "LibriTTS_R-4738",
        "content": "Till that ripe birth Of studied Fate stand forth, And teach her fair steps to our earth;",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
