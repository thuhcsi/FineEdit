        "speaker_id": "LibriTTS_R-4738",
        "content": "Soft silken hours, Open suns, shady bowers; 'Bove all, nothing within that lowers.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
