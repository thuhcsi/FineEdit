        "speaker_id": "LibriTTS_R-4738",
        "content": "Something more than Taffata or tissue can, Or rampant feather, or rich fan.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
