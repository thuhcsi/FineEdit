[
    {
        "item_name": "LibriTTS_R-27_123349_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000001_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "At length all differences were compromised.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000001_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "It was determined that an attempt should be forthwith made on the western coast of Scotland, and that it should be promptly followed by a descent on England.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000003_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Monmouth was to command in England.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000003_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Ambitious hopes, which had seemed to be extinguished, revived in his bosom.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000004_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "It was determined that two Englishmen, Ayloffe and Rumbold, should accompany Argyle to Scotland, and that Fletcher should go with Monmouth to England.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000004_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "When Grey repeated with approbation what Wildman had said about Richmond and Richard, the well read and thoughtful Scot justly remarked that there was a great difference between the fifteenth century and the seventeenth.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000005_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Six thousand pounds had been expected thence.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000006_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "It is remarkable that the most illustrious and the most grossly injured man among the British exiles stood far aloof from these rash counsels. john Locke hated tyranny and persecution as a philosopher; but his intellect and his temper preserved him from the violence of a partisan. He had lived on confidential terms with Shaftesbury, and had thus incurred the displeasure of the court.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000006_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "In one point, however, he was vulnerable.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000006_000003.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "He was a student of Christ Church in the University of Oxford.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000006_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000006_000006.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Locke had, at Oxford, abstained from expressing any opinion on the politics of the day.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000006_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000006_000007.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Spies had been set about him.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000006_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000006_000011.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "When it was found that treachery could do nothing, arbitrary power was used.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000006_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000006_000012.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "After vainly trying to inveigle Locke into a fault, the government resolved to punish him without one.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000008_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "A proclamation was accordingly issued directing that Scotland should be put into a state of defence.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000008_000005.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "john Murray, Marquess of Athol, was appointed Lord Lieutenant of Argyleshire, and, at the head of a great body of his followers, occupied the castle of Inverary.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000008_000006.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Some suspected persons were arrested.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000008_000007.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Others were compelled to give hostages.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000009_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The King said that he had received from unquestionable sources intelligence of designs which were forming against the throne by his banished subjects in Holland.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000009_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Some of the exiles were cutthroats, whom nothing but the special providence of God had prevented from committing a foul murder; and among them was the owner of the spot which had been fixed for the butchery.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000010_000003.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "It seemed probable that he would consent to form a close alliance with the United Provinces and the House of Austria.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000010_000005.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The personal interest of William was also on this occasion identical with the interest of his father in law.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000011_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "But the case was one which required rapid and vigorous action; and the nature of the Batavian institutions made such action almost impossible. The Union of Utrecht, rudely formed, amidst the agonies of a revolution, for the purpose of meeting immediate exigencies, had never been deliberately revised and perfected in a time of tranquillity.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000011_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000011_000007.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "One of those boards sate at Amsterdam, was partly nominated by the authorities of that city, and seems to have been entirely animated by their spirit.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000012_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Excellent judges of character pronounced him to be the most shallow, fickle, passionate, presumptuous, and garrulous of men.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000012_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000012_000004.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Then, instead of applying, as he should have done, to the States General, who sate close to his own door, he sent a messenger to the magistrates of Amsterdam, with a request that the suspected ships might be detained.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000012_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000012_000007.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Skelton now addressed himself to the States General.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000012_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000012_000013.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The Admiralty of Amsterdam made this error a plea for doing nothing; and, before the error could be rectified, the three ships had sailed.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000013_000003.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "But no effectual step was taken for the purpose of detaining him; and on the afternoon of the second of May he stood out to sea before a favourable breeze.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000014_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The voyage was prosperous.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000014_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "On the sixth the Orkneys were in sight. Argyle very unwisely anchored off Kirkwall, and allowed two of his followers to go on shore there.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000014_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The Bishop ordered them to be arrested. The refugees proceeded to hold a long and animated debate on this misadventure: for, from the beginning to the end of their expedition, however languid and irresolute their conduct might be, they never in debate wanted spirit or perseverance.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000014_000003.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Some were for an attack on Kirkwall.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000015_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "This delay was full of danger.",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000015_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "It was speedily known at Edinburgh that the rebel squadron had touched at the Orkneys.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000015_000004.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "At Dunstaffnage he sent his second son Charles on Shore to call the Campbells to arms.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000015_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000015_000006.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The herdsmen and fishermen were indeed ready to rally round Mac Callum More; but, of the heads of the clan, some were in confinement, and others had fled.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000015_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000015_000011.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "It was hinted that the late King had died by poison.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_123349_000015_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/123349/27_123349_000015_000012.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "A chief object of the expedition was declared to be the entire suppression, not only of Popery, but of Prelacy, which was termed the most bitter root and offspring of Popery; and all good Scotchmen were exhorted to do valiantly for the cause of their country and of their God.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000000_000002.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "But on the square of them, each side was extended the space of twenty feet.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000015_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And he called all the ancients, and all the governors, and his officers of war, and communicated to them the secret of his counsel:",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000020_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Then Holofernes called the captains, and officers of the power of the Assyrians: and he mustered men for the expedition, and the king commanded him, a hundred and twenty thousand fighting men on foot, and twelve thousand archers, horsemen.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000021_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000021_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And he made all his warlike preparations to go before with a multitude of innumerable camels, with all provisions sufficient for the armies in abundance, and herds of oxen, and flocks of sheep, without number.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000024_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And he went forth he and all the army, with the chariots, and horsemen, and archers, who covered the face of the earth, like locusts.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000026_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And he took by assault the renowned city of Melothus, and pillaged all the children of Tharsis, and the children of Ismahel, who were over against the face of the desert, and on the south of the land of Cellon.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000032_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Judith Chapter three",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000034_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000034_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Then the kings and the princes of all the cities and provinces, of Syria, Mesopotamia, and Syria Sobal, and Libya, and Cilicia sent their ambassadors, who coming to Holofernes, said:",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000037_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Let all we have be subject to thy law,",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000044_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000044_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And though they did these things, they could not for all that mitigate the fierceness of his heart:",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000049_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000049_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Judith Chapter four",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000057_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000057_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And all the people cried to the Lord with great earnestness, and they humbled their souls in fastings, and prayers, both they and their wives.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000059_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000059_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And they cried to the Lord the God of Israel with one accord, that their children might not be made a prey, and their wives carried off, and their cities destroyed, and their holy things profaned, and that they might not be made a reproach to the Gentiles.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000062_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000062_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Remember Moses the servant of the Lord overcame Amalec that trusted in his own strength, and in his power, and in his army, and in his shields, and in his chariots, and in his horsemen, not by fighting with the sword, but by holy prayers:",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000064_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000064_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "So they being moved by this exhortation of his, prayed to the Lord, and continued in the sight of the Lord.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000072_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000072_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And why they above all that dwell in the east, have despised us, and have not come out to meet us, that they might receive us with peace?",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000079_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000079_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And when the Egyptians had cast them out from them, and the plague had ceased from them, and they had a mind to take them again, and bring them back to their service,",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000093_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000093_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "But if there be no offence of this people in the sight of their God, we cannot resist them because their God will defend them: and we shall be a reproach to the whole earth.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000098_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000098_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Judith Chapter six",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000105_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000105_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And that thou mayst know that thou shalt experience these things together with them, behold from this hour thou shalt be associated to their people, that when they shall receive the punishment they deserve from my sword, thou mayst fall under the same vengeance.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000116_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000116_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Saying: The God of our fathers, whose power thou hast set forth, will make this return to thee, that thou rather shalt see their destruction.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000117_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000117_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And when the Lord our God shall give this liberty to his servants, let God be with thee also in the midst of us: that as it shall please thee, so thou with all thine mayst converse with us.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000121_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000121_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The church...",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000121_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000121_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "That is, the synagogue or place where they met for prayer.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000122_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000122_000000.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Judith Chapter seven",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000123_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000123_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "The distress of the besieged.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000125_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000125_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Now there were in his troops a hundred and twenty thousand footmen, and two and twenty thousand horsemen, besides the preparations of those men who had been taken, and who had been brought away out of the provinces and cities of all the youth.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000126_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000126_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "All these prepared themselves together to fight against the children of Israel, and they came by the hillside to the top, which looketh toward Dothain, from the place which is called Belma, unto Chelmon, which is over against Esdrelon.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000127_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000127_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "But the children of Israel, when they saw the multitude of them, prostrated themselves upon the ground, putting ashes upon their heads, praying with one accord, that the God of Israel would shew his mercy upon his people.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000128_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000128_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "And taking their arms of war, they posted themselves at the places, which by a narrow pathway lead directly between the mountains, and they guarded them all day and night.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000130_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000130_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "Nevertheless there were springs not far from the walls, out of which they were seen secretly to draw water, to refresh themselves a little rather than to drink their fill.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000142_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000142_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "We have sinned with our fathers, we have done unjustly, we have committed iniquity:",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000144_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000144_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "That they may not say among the Gentiles: Where is their God?",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000147_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000147_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "For perhaps he will put a stop to his indignation, and will give glory to his own name.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000148_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/27/124992/27_124992_000148_000001.wav",
        "speaker_id": "LibriTTS_R-27",
        "content": "But if after five days be past there come no aid, we will do the things which you have spoken.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-27_124992_000149_000000",
