        "speaker_id": "LibriTTS_R-6373",
        "content": "I then, however, examined it with attention, and found it, to my great relief, uninjured.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
