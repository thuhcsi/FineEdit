        "speaker_id": "LibriTTS_R-6373",
        "content": "My implements were all safe, and, fortunately, I had lost neither ballast nor provisions.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
