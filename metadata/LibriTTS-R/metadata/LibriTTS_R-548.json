        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/548/126959/548_126959_000023_000000.wav",
        "speaker_id": "LibriTTS_R-548",
        "content": "three.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-548_126959_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/548/126959/548_126959_000024_000002.wav",
        "speaker_id": "LibriTTS_R-548",
        "content": "But should any difference arise between them they are to have recourse to law and oaths, according as may be agreed between the parties.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
