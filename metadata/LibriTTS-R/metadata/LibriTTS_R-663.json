        "speaker_id": "LibriTTS_R-663",
        "content": "This was a serious undertaking, but it was all they could do.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
