        "speaker_id": "LibriTTS_R-4750",
        "content": "Fight Of The hebrews With The Canaanites Without The Consent Of Moses; And Their Defeat.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
