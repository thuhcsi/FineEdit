        "speaker_id": "LibriTTS_R-839",
        "content": "\"Mercy, look at these cod!\" he said.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
