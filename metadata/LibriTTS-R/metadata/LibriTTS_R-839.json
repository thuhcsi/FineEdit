        "speaker_id": "LibriTTS_R-839",
        "content": "\"Bah!",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "very low"
    },
    {
