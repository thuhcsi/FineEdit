        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/839/130898/839_130898_000019_000001.wav",
        "speaker_id": "LibriTTS_R-839",
        "content": "\"But what crowds of them!",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-839_130898_000019_000002",
