        "speaker_id": "LibriTTS_R-839",
        "content": "IN THE AFTERMATH of this storm, we were thrown back to the east. Away went any hope of",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
