        "speaker_id": "LibriTTS_R-839",
        "content": "On september fifth seventeen eighty one, under the Count de Grasse, it took part in the Battle of Chesapeake Bay.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very low"
    },
    {
