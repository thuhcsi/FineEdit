        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/839/130898/839_130898_000017_000001.wav",
        "speaker_id": "LibriTTS_R-839",
        "content": "\"Why, I thought cod were flat, like dab or sole!\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
