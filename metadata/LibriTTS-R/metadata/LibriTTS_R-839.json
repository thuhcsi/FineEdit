        "speaker_id": "LibriTTS_R-839",
        "content": "\"I'll go all out,\" Conseil replied.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
