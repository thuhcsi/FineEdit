        "speaker_id": "LibriTTS_R-839",
        "content": "What swarms!\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-839_130898_000020_000000",
