        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/421/128336/421_128336_000009_000000.wav",
        "speaker_id": "LibriTTS_R-421",
        "content": "\"Do you know me?\"",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
    },
    {
