        "speaker_id": "LibriTTS_R-6097",
        "content": "But now her hands like moonlight brush the keys With velvet grace, melodious delight; And now a sad refrain from overseas Goes sobbing on the bosom of the night.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
