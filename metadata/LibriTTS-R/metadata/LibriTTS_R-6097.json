[
    {
        "item_name": "LibriTTS_R-6097_293616_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Ours from the bleak beginning, through the aeons of death like sleep; Ours from the shock when the naked rock was hurled from the hissing deep; Ours through the twilight ages of weary glacier creep.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000007_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Wind of the East, wind of the West, wandering to and fro, Chant your songs in our topmost boughs, that the sons of men may know The peerless pine was the first to come, and the pine will be last to go!",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "We pillar the halls of perfumed gloom; we plume where the eagles soar; The North wind swoops from the brooding Pole, and our ancients crash and roar; But where one falls from the crumbling walls shoots up a hardy score.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000009_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "We spring from the gloom of the canyon's womb; in the valley's lap we lie; From the white foam fringe where the breakers cringe to the peaks that tusk the sky We climb, and we peer in the crag locked mere that gleams like a golden eye,--",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000010_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Gain to the verge of the hog back ridge where the vision ranges free: Pines and pines and the shadow of pines as far as the eye can see; A steadfast legion of stalwart knights in dominant empery.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000011_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Sun, moon and stars, give answer; shall we not staunchly stand Even as now, forever, wards of the wilder strand, Sentinels of the stillness, lords of the last lone land!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000012_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "THE HARPY",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000014_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "There is no hope for such as I, on earth nor yet in Heaven; Unloved I live, unloved I die, unpitied, unforgiven; A loathed jade I ply my trade, unhallowed and unshriven.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000017_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "For life is not the thing we thought, and not the thing we plan; And woman in a bitter world must do the best she can; Must yield the stroke, and bear the yoke, and serve the will of man;",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000021_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Wherefore, the wolf pack having gorged upon the lamb, their prey, With siren smile and serpent guile I make the wolf pack pay; With velvet paws and flensing claws, a tigress roused to slay.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000022_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "One who in youth sought truest truth, and found a devil's lies; A symbol of the sin of man, a human sacrifice: Yet shall I blame on man the shame?",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000022_000001.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Could it be otherwise?",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000025_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "THE LURE OF LITTLE VOICES",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000026_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "There's a cry from out the Loneliness-Oh, listen, Honey, listen! Do you hear it, do you fear it, you're a holding of me so? You're a sobbing in your sleep, dear, and your lashes, how they glisten- Do you hear the Little Voices all a begging me to go?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000027_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "All a begging me to leave you.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000029_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "They miss my little camp fires, ever brightly, bravely gleaming In the womb of desolation where was never man before; As comradeless I sought them, lion hearted, loving, dreaming; And they hailed me as a comrade, and they loved me evermore.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000031_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "I'm afraid to tell you, Honey, I can take no bitter leaving; But softly in the sleep time from your love I'll steal away. Oh, it's cruel, dearie, cruel, and it's God knows how I'm grieving; But His Loneliness is calling and He knows I must obey.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000032_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000032_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "THE SONG OF THE WAGE SLAVE",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6097_293616_000034_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293616/6097_293616_000034_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "GRIN",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000001_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "MY MADONNA",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000002_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "I haled me a woman from the street, Shameless, but, oh, so fair! I bade her sit in the model's seat, And I painted her sitting there.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000004_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "She laughed at my picture, and went away. Then came, with a knowing nod, A connoisseur, and I heard him say: \"'tis Mary, the Mother of God.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000005_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "So I painted a halo round her hair, And I sold her, and took my fee, And she hangs in the church of Saint Hilaire, Where you and all may see.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000006_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "UNFORGOTTEN",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000010_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "THE RECKONING",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000012_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "It's great to go out every night on fun or pleasure bent, To wear your glad rags always, and to never save a cent; To drift along regardless, have a good time every trip; To hit the high spots sometimes, and to let your chances slip; To know you're acting foolish, yet to go on fooling still, Till Nature calls a show down, and you Pay the bill.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000017_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Blind fools of fate, and slaves of circumstance, Life is a fiddler, and we all must dance. From gloom where mocks that will o'-wisp, Freewill, I heard a voice cry: \"Say, give us a chance.\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000018_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Chance!",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000018_000001.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Oh, there is no chance.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000018_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000018_000003.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "Man, the marionette, Resumes his part.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000018_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000018_000004.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "The gods will work the wires. They've got it all down fine, you bet, you bet!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000019_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "It's all decreed: the mighty earthquake crash; The countless constellations' wheel and flash; The rise and fall of empires, war's red tide, The composition of your dinner hash.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000023_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "THE MEN THAT DON'T FIT IN",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000024_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "There's a race of men that don't fit in, A race that can't stay still; So they break the hearts of kith and kin, And they roam the world at will. They range the field and they rove the flood, And they climb the mountain's crest; Theirs is the curse of the gipsy blood, And they don't know how to rest.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000027_000001.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "He is one of the Legion Lost; He was never meant to win; He's a rolling stone, and it's bred in the bone; He's a man who won't fit in.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6097_293619_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6097/293619/6097_293619_000028_000000.wav",
        "speaker_id": "LibriTTS_R-6097",
        "content": "MUSIC IN THE BUSH",
        "style_prompt": "M_p-normal_s-slow_e-high",
