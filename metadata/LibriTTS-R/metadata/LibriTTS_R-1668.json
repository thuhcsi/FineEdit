        "speaker_id": "LibriTTS_R-1668",
        "content": "But nothing of the kind happened, although on two occasions I thought the wished moment had come.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
