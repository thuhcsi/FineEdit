        "speaker_id": "LibriTTS_R-1668",
        "content": "The person-owner or tenant, I forget which-who lived in the house was an old woman named Dona Pascuala, whom I never saw without a cigar in her mouth.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
