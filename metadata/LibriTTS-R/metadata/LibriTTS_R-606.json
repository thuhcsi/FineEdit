        "speaker_id": "LibriTTS_R-606",
        "content": "\"How is everything down on the earth?\"",
        "style_prompt": "M_p-low_s-slow_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
