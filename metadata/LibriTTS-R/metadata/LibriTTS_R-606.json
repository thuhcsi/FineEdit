        "speaker_id": "LibriTTS_R-606",
        "content": "His mother's name was Thorun.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
