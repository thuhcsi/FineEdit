        "speaker_id": "LibriTTS_R-606",
        "content": "So the balloon was brought and inflated, and the Man got into the basket and gave the word to let go, and then the balloon mounted up into the sky in the direction of the moon.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
