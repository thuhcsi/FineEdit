        "speaker_id": "LibriTTS_R-606",
        "content": "I was awakened early in the morning by a wild storm wind and of course I had to make haste to the middle of the Valley to enjoy it.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
