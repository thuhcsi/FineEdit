        "speaker_id": "LibriTTS_R-606",
        "content": "So he thanked her and entered the house, and she asked,",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
