        "speaker_id": "LibriTTS_R-606",
        "content": "Therefore he begged the magistrate to wait a few minutes while he looked through his telescope to see if the Man in the Moon was there.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
