        "speaker_id": "LibriTTS_R-606",
        "content": "\"Can you tell me the way to Norwich, sir?\"",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
