        "speaker_id": "LibriTTS_R-606",
        "content": "\"Is this the town of Norwich, madam?\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
