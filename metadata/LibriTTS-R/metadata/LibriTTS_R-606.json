        "speaker_id": "LibriTTS_R-606",
        "content": "The nights are too hot.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
