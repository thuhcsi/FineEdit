        "speaker_id": "LibriTTS_R-606",
        "content": "This was in the winter of eighteen seventy three, when the snow laden peaks were swept by a powerful norther.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
