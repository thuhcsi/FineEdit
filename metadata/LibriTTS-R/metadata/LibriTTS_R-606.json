        "speaker_id": "LibriTTS_R-606",
        "content": "A good looking woman answered his knock at the door, and he asked politely,",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
