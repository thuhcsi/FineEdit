        "speaker_id": "LibriTTS_R-606",
        "content": "But he plucked up courage and said to the farmer,",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
