        "speaker_id": "LibriTTS_R-606",
        "content": "\"This person is evidently crazy; so take him to the lunatic asylum and keep him there.\"",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
