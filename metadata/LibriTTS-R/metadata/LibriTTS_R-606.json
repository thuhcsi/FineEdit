        "speaker_id": "LibriTTS_R-606",
        "content": "We can inflate this balloon and send the Man out of the Moon home in it.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
