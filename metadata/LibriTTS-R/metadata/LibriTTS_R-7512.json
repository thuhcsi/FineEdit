[
    {
        "item_name": "LibriTTS_R-7512_98636_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000001_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "OLD AGE.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000002_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "No Japanese woman is ashamed to show that she is getting along in years, but all take pains that every detail of the dress and coiffure shall show the full age of the wearer.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000002_000001.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "The baby girl is dressed in the brightest of colors and the largest of patterns, and looks like a gay butterfly or tropical bird.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000002_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "As she grows older, colors become quieter, figures smaller, stripes narrower, until in old age she becomes a little gray moth or plain colored sparrow.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000005_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "In the code of morals of the Japanese, obedience to father, husband, or son is exalted into the chief womanly virtue, but the obedience and respect of children, both male and female, to their parents, also occupies a prominent position in their ethical system.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000005_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "She has, besides, reached an age when she is not expected to remain at home, and she may go out into the streets, to the theatre, or other shows, without the least restraint or fear of losing her dignity.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "A Japanese woman loses her beauty early.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "But I have spoken so far only of those happy women whose sons grow to maturity, and who manage to evade the dangerous reefs of divorce upon which so many lives are shipwrecked.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000007_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "Even these, who in this country often lead hard and unrewarded lives of toil among their happier relatives, find in old age a pleasanter lot than that of youth.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "One of the happiest old ladies I have ever seen was one who had had a rough and stormy life.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000008_000001.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "The mother of many children, most of whom had died in infancy, she was at last left childless and a widow.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000008_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "In her children's death the last tie that bound her to her husband's family was broken, and, rather than be a burden to them, she made her home for many years with her own younger brother, taking up again the many cares and duties of a mother's life in sharing with the mother the bringing up of a large family of children.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000008_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000008_000004.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "That was years ago, and the old aunty's hard times are nearly over.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000008_000005.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "Hale and hearty at three score years and ten, she has seen these children grow up one by one, until now some have gone to new homes of their own.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000008_000007.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "They now, in their turn, enjoy giving her pleasure, and return to her all the love she has lavished upon them.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000008_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000008_000008.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "It is a joy to see her childlike pride and confidence in them all, and to know that they have filled the place left vacant by the dead with whom had died all her hopes of earthly happiness.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000009_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "The old women of Japan,--how their withered faces, bent frames, and shrunken, yellow hands abide in one's memory!",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000010_000004.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "Mounted on little ladders, they pick and scrape with knives until the wall is clear and fresh, with no insidious growth to push the great uncemented stones out of their places.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000011_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "As they go from house to house, gaining a miserable pittance by their weird music, they seem the embodiment of all that is hopeless and broken hearted.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000011_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000011_000003.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "What they are or whence they come, I know not, but they always remind me of the grasshopper in the fable, who danced and sang through the brief summer, to come, wailing and wretched, seeking aid from her thriftier neighbor when at last the winter closed in upon her.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000012_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "Suddenly I see her pause before the gateway of a temple.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "Two weeks later, amid such rain as Japanese skies know all too well how to let fall, I attended her funeral at the cemetery of Aoyama.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "The cemetery chapel was crowded, but a place was reserved for me, on account of special ties that bound me to the family, just behind the long line of white robed mourners.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000016_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "We often exclaim in impatience at the thought of the weakness and dependence of old age, and pray that we may die in the fullness of our powers, before the decay of advancing years has made us a burden upon our friends.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "It is not only for the women of Japan, but for the men as well, that old age is a time of peace and happiness.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000002.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "A man thus rarely makes provision for the future, and looks with scorn on foreign customs which seem to betoken a fear lest, in old age, ungrateful children may neglect their parents and cast them aside.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000003.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "The feeling, so strong in America, that dependence is of itself irksome and a thing to be dreaded, is altogether strange to the Japanese mind.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000007.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "This habit of thought may account for the utter want of provision for the future, and the disregard for things pertaining to the accumulation of wealth, which often strikes curiously the foreigner in Japan.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000008.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "A Japanese considers his provision for the future made when he has brought up and educated for usefulness a large family of children. He invests his capital in their support and education, secure of bountiful returns in their gratitude and care for his old age.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000013.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "A cultivated Japanese of the old times must receive an education fitting him especially for such pursuits.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000014.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "At these meetings of friends, artistically or poetically inclined, the time is spent in making poems and exchanging wittily turned sentiments, to be read, commented on, and responded to; or in the making of drawings, with a few bold strokes of the brush, in illustration of some subject given out.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000017_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000017_000015.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "Such enjoyments as these, the Japanese believe, cannot be appreciated or even understood by the practical, rush ahead American, the product of the wonderful but material civilization of the West.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7512_98636_000020_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7512/98636/7512_98636_000020_000001.wav",
        "speaker_id": "LibriTTS_R-7512",
        "content": "Sometimes there will be a separate suite of rooms provided for them; sometimes a little house away from the noises of the household, and separated from the main building by a well kept little garden.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    }
]