[
    {
        "item_name": "LibriTTS_R-1235_135883_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135883/1235_135883_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Will you absolutely take away the life of a poor innocent?\" \"Yes,\" replied the genie, \"I am resolved.\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135883_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135883/1235_135883_000008_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Allow me one word.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1235_135883_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135883/1235_135883_000008_000003.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "When I have done this, I will come back and submit to whatever you shall please to command.\" \"But,\" said the genie, \"if I grant you the time you ask, I doubt you will never return?\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135883_000008_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135883/1235_135883_000008_000005.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "\"I ask a year,\" said the merchant; \"I cannot in less settle my affairs, and prepare myself to die without regret.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135883_000008_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135883/1235_135883_000008_000006.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "But I promise you, that this day twelve months I will return under these trees, to put myself into your hands.\" \"Do you take heaven to be witness to this promise?\" said the genie.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "The Story of the First Old Man and the Hind.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "She was only twelve years of age when I married her, so that I may justly say, she ought to regard me equally as her father, her kinsman, and her husband.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "We lived together twenty years, without any children.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Her barrenness did not effect any change in my love; I still treated her with much kindness and affection.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000003_000003.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "My wife being jealous, cherished a hatred for both mother and child, but concealed her aversion so well, that I knew nothing of it till it was too late.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000004_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Before I went, I recommended to my wife, of whom I had no mistrust, the slave and her son, and prayed her to take care of them during my absence, which was to be for a whole year.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "She applied herself to magic, and when she had learnt enough of that diabolical art to execute her horrible design, the wretch carried my son to a desolate place, where, by her enchantments, she changed him into a calf, and gave him to my farmer to fatten, pretending she had bought him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Her enmity did not stop at this abominable action, but she likewise changed the slave into a cow, and gave her also to my farmer.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000005_000000.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "At my return, I enquired for the mother and child.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "\"Your slave,\" said she, \"is dead; and as for your son, I know not what is become of him, I have not seen him this two months.\" I was afflicted at the death of the slave, but as she informed me my son had only disappeared, I was in hopes he would shortly return. However, eight months passed, and I heard nothing of him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I bound her, but as I was going to sacrifice her, she bellowed piteously, and I could perceive tears streaming from her eyes.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000005_000005.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "This seemed to me very extraordinary, and finding myself moved with compassion, I could not find in my heart to give her a blow, but ordered my farmer to get me another.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000006_000000.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "My wife, who was present, was enraged at my tenderness, and resisting an order which disappointed her malice, she cried out, \"What are you doing, husband?",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000006_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Sacrifice that cow; your farmer has not a finer, nor one fitter for the festival.\" Out of deference to my wife, I came again to the cow, and combating my compassion, which suspended the sacrifice, was going to give her the fatal blow, when the victim redoubling her tears, and bellowing, disarmed me a second time.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I then put the mallet into the farmer's hands, and desired him to take it and sacrifice her himself, for her tears and bellowing pierced my heart.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Though I knew not the calf was my son, yet I could not forbear being moved at the sight of him.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000008_000000.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I was more surprised and affected with this action, than with the tears of the cow.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "As soon as my wife heard me give this order, she exclaimed, \"What are you about, husband?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000009_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Take my advice, sacrifice no other calf but that.\" \"Wife,\" I replied, \"I will not sacrifice him, I will spare him, and pray do not you oppose me.\" The wicked woman had no regard to my wishes; she hated my son too much to consent that I should save him.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000009_000003.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I let the knife fall, and told my wife positively that I would have another calf to sacrifice, and not that.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "\"I come,\" said he, \"to communicate to you a piece of intelligence, for which I hope you will return me thanks.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000010_000003.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "Yesterday, as I carried back the calf which you would not sacrifice, I perceived she laughed when she saw him, and in a moment after fell a weeping.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000010_000005.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "rather,' replied she, the calf you bring back is our landlord's son; I laughed for joy to see him still alive, and wept at the remembrance of the sacrifice that was made the other day of his mother, who was changed into a cow.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000011_000000.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I leave you to judge how much I was surprised.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000011_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000011_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I went immediately to my farmer, to speak to his daughter myself.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000011_000002.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "As soon as I arrived, I went forthwith to the stall where my son was kept; he could not return my embraces, but received them in such a manner, as fully satisfied me he was my son.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000012_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "As to what relates to my wife, I also agree; a person who has been capable of committing such a criminal action, justly deserves to be punished.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000012_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000012_000002.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I leave her to your disposal, only I must pray you not to take her life.\" \"I am going then,\" answered she, \"to treat her as she treated your son.\" \"To this I consent,\" said I, \"provided you first of all restore to me my son.\"",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1235_135884_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1235/135884/1235_135884_000014_000001.wav",
        "speaker_id": "LibriTTS_R-1235",
        "content": "I doubt not but in acknowledgment you will make your deliverer your wife, as I have promised.\" He joyfully consented; but before they married, she changed my wife into a hind; and this is she whom you see here.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    }
]