[
    {
        "item_name": "LibriTTS_R-8014_112586_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000008_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "PREFACE.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000009_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The publication comes at an appropriate time, when there is an awakening of interest in the Irish language, and in Irish lore of every kind, unparalleled in our history.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000010_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "But the book has a further mission.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000010_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "There are many English and many Anglo Irish people who think, merely from ignorance, that Ireland was a barbarous and half savage country before the English came among the people and civilised them.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000010_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "This book, so far as it finds its way among the two classes above mentioned, will, I fancy, open their eyes.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000011_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "But there were, and are, Englishmen better informed about our country. More than three hundred years ago the great English poet, Edmund Spenser, lived for some time in Ireland, and made himself well acquainted with its history.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000013_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "But it is better not to pursue these observations farther here, as it would be only anticipating what will be found in the body of the book.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "This book is the last of a series of three, of which the second is abridged from the first, and the third from both.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000017_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "This Third book-\"The Story of Ancient Irish Civilisation\"--gives in simple, plain language, an account of the condition of the country in the olden time; but as it is here to speak for itself, I need not describe it further.",
        "style_prompt": "F_p-high_s-normal_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000017_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "For all the statements it contains, full and satisfactory authorities will be found in the two larger works.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000018_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "I have done my best to make all three readable and interesting, as well as instructive.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000019_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000019_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The ordinary history of our country has been written by many, and the reader has a wide choice.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8014_112586_000019_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112586/8014_112586_000019_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "But in the matter of our Social History he has no choice at all.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000000_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "An oval face, broad above and narrow below, golden hair, fair skin, white, delicate, and well formed hands with slender tapering fingers: these were considered as marking the type of beauty and of high family descent; they were the Marks of Aristocracy.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000000_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "To these natural advantages the people added by the usual artificial means.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000000_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000000_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Among the higher classes the finger nails were kept carefully cut and rounded.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000000_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000000_000003.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "It was considered shameful for a man of position to have rough unkempt nails. Crimson coloured finger nails were greatly admired; and ladies sometimes dyed them this colour.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000001_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "An entry in Cormac's Glossary plainly indicates that the blush of the cheeks was sometimes heightened by a colouring matter obtained from the alder tree: and the sprigs and berries of the elder were applied to the same purpose.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000001_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Among Greek and Roman ladies the practice was very general of painting the cheeks, eyebrows, and other parts of the face.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000002_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The hair was combed daily after a bath.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000002_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The heroes of the Fena of Erin, before sitting down to their dinner after a hard day's hunting, always took a bath and carefully combed their long hair.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000003_000003.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "In nearly all the figures of the Book of Kells, for example (seventh or eighth century), the hair is combed and dressed with the utmost care, so beautifully adjusted indeed that it could have been done only by skilled professional hairdressers, and must have occupied much time.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000003_000005.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "I do not find mentioned anywhere that the Irish dyed their hair, as was the custom among the Greeks and romans.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000004_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The men were as particular about the beard as about the hair.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000004_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The fashion of wearing the beard varied.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000004_000003.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Nearly all have a mustache, in most cases curled up and pointed at the ends as we often see now.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000005_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "From what precedes it will be understood that combs were in general use with men as well as with women; and many specimens of combs are now found in the remains of ancient dwellings.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000006_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Bathing was very usual, at least among the upper classes, and baths and the use of baths are constantly mentioned in the old tales and other writings.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000006_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "In every public hostel, in every monastery, and in every high class house, there was a bath, with its accompaniments.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000006_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Soap was used both in bathing and washing.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000007_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Silk and satin, which were of course imported, were much worn among the higher classes.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000007_000003.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The furs of animals, such as seals, otters, badgers, foxes, etc, were much used for capes and jackets, and for the edgings of various garments, so that skins of all the various kinds were valuable.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000007_000004.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "They formed, too, an important item of everyday traffic, and they were also exported.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000008_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The ancient Irish loved bright colours.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000008_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000008_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Even the single outer cloak was often striped, spotted, or chequered in various colours.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000008_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000008_000003.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "King Domnall, in the seventh century, on one occasion sent a many coloured tunic to his foster son Prince Congal: like Joseph's coat of many colours.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000009_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "A very common article of dress was a large cloak, generally without sleeves, varying in length, but commonly covering the whole person from the shoulders down.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000009_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "A short cape was often worn on the shoulders, sometimes carrying a hood to cover the head.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000009_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000009_000003.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The outer covering of the general run of the peasantry was just one loose sleeved coat or mantle, generally of frieze, which covered them down to the ankles; and which they wore winter and summer.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000009_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000009_000005.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The over garments were fastened by brooches, pins, buttons, girdles, strings, and loops, many of them beautifully made and ornamented.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000010_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "When terminating below the ankles it was held down by a slender strap passing under the foot.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000010_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Like other Irish garments it was generally striped or speckled in various colours.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000013_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Married women usually had the head covered either with a hood or with a long web of linen wreathed round and round in several folds.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000013_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The veil was in constant use among the higher classes, and when not actually worn was usually carried, among other small articles, in a lady's ornamental hand bag.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000014_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Shoes were often made of untanned hide stitched with thongs, with several layers for a sole.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000014_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "But there was a more shapely shoe, made of fully tanned leather, having serviceable sole and heel, and often ornamented with patterns stamped in.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000015_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "The Irish were excessively fond of personal ornaments, which among the higher classes were made of expensive materials, such as gold, silver, gems, white bronze, etc",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_112602_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/112602/8014_112602_000016_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Thin circular gold plates were also worn fastened on the breast: and as for brooches, they were of all shapes and sizes, some plain, simple, and cheap, some of gold or other expensive material, of elaborate workmanship.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000005_000001.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "\"Suffer not,\" they said, \"that we, who are Tuscans by birth, should remain any more in poverty and exile.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000005_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000005_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "And take heed also to thyself and thine own kingdom if thou permit this new fashion of driving forth kings to go unpunished.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000005_000004.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "But when men heard of his coming, so mighty a city was Clusium in those days, and so great the fame of King Porsenna, there was such fear as had never been before.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000005_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000005_000005.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Nevertheless they were steadfastly purposed to hold out.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000007_000000.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "There was a certain hill which men called Janiculum on the side of the river, and this hill King Porsenna took by a sudden attack.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000007_000002.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Do ye therefore break it down with axe and fire as best ye can.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000007_000003.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "In the meanwhile I, so far as one man may do, will stay the enemy.\" And as he spake he ran forward to the farther end of the bridge and made ready to keep the way against the enemy.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000007_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000007_000005.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "So these three for a while stayed the first onset of the enemy; and the men of Rome meanwhile brake down the bridge.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-8014_280382_000007_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8014/280382/8014_280382_000007_000009.wav",
        "speaker_id": "LibriTTS_R-8014",
        "content": "Nor did such valor fail to receive due honor from the city.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    }
]