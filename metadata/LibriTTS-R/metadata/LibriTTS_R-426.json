        "speaker_id": "LibriTTS_R-426",
        "content": "As for Anthony Pye, why need you care if he does dislike you?",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
