        "speaker_id": "LibriTTS_R-426",
        "content": "Oh, Marilla, I HAVE tried so hard to be patient and to win Anthony's liking . . . and now it has all gone for nothing.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
