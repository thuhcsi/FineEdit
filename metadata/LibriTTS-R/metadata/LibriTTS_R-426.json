        "speaker_id": "LibriTTS_R-426",
        "content": "\"Joseph, are you going to obey me or are you NOT?\" said Anne.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
