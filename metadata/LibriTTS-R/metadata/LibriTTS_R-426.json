        "speaker_id": "LibriTTS_R-426",
        "content": "But she decided not to.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-426_122822_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/426/122822/426_122822_000032_000001.wav",
        "speaker_id": "LibriTTS_R-426",
        "content": "She looked at Anthony Pye, and Anthony Pye looked back unabashed and unashamed.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
