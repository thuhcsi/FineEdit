        "speaker_id": "LibriTTS_R-426",
        "content": "\"'I always met the Twin Sailors at the Striped Rocks.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
