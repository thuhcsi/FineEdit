        "speaker_id": "LibriTTS_R-426",
        "content": "\"Anthony, was it you?\"",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
