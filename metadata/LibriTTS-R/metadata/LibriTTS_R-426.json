        "speaker_id": "LibriTTS_R-426",
        "content": "We all make mistakes . . . but people forget them.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
