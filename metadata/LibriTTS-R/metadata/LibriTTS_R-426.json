        "speaker_id": "LibriTTS_R-426",
        "content": "I have my suspicions about that oldest Twin. I believe he'd be a pirate if he dared.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very fast",
