        "speaker_id": "LibriTTS_R-426",
        "content": "So all her boasts had come to this . . . she had actually whipped one of her pupils.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
