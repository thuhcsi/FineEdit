        "speaker_id": "LibriTTS_R-426",
        "content": "We sailed into a great harbor, all the color of gold, and I stepped right out of the boat on a big meadow all covered with buttercups as big as roses.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
