        "speaker_id": "LibriTTS_R-426",
        "content": "I can't forget the expression in Paul Irving's eyes . . . he looked so surprised and disappointed.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
