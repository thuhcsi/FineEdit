        "speaker_id": "LibriTTS_R-426",
        "content": "Think of that, teacher, I've been in the sunset.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
