        "speaker_id": "LibriTTS_R-426",
        "content": "\"Well, never mind.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
