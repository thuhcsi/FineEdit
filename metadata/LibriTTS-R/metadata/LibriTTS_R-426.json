        "speaker_id": "LibriTTS_R-426",
        "content": "Then he dodged back just in time.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
