        "speaker_id": "LibriTTS_R-426",
        "content": "\"Throw it into the fire,\" said Anne.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "normal"
    },
    {
