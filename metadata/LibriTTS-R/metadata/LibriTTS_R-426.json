        "speaker_id": "LibriTTS_R-426",
        "content": "\"I can't help it.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
