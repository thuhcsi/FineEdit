        "speaker_id": "LibriTTS_R-426",
        "content": "How Jane would triumph!",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "high"
