        "speaker_id": "LibriTTS_R-426",
        "content": "The youngest Twin Sailor is very good tempered but the oldest Twin Sailor can look dreadfully fierce at times.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
