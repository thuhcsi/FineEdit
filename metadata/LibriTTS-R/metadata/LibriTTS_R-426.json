        "speaker_id": "LibriTTS_R-426",
        "content": "And how mr Harrison would chuckle!",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
