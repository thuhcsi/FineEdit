[
    {
        "item_name": "LibriTTS_R-1323_138617_000003_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/138617/1323_138617_000003_000011.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "There is, consequently, such a Being; that is, there is a Deity.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_138617_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/138617/1323_138617_000009_000000.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "In such a chain, too, or succession of objects, each part is caused by that which preceded it, and causes that which succeeds it.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1323_138617_000009_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/138617/1323_138617_000009_000004.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "Did I show you the particular causes of each individual in a collection of twenty particles of matter, I should think it very unreasonable, should you afterwards ask me, what was the cause of the whole twenty.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_138617_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/138617/1323_138617_000010_000001.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "It is observed by arithmeticians, that the products of nine, compose always either nine, or some lesser product of nine, if you add together all the characters of which any of the former products is composed.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000000_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000000_000004.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "They rose up against the first magistrate merely in order to assert the supremacy of the law.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000000_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000000_000005.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "They were for the most part strongly attached to the Church established by law.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000001_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000001_000000.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "In Scotland the course of events was very different.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000002_000000.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "William saw that he must not think of paying to the laws of Scotland that scrupulous respect which he had wisely and righteously paid to the laws of England.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000002_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000002_000001.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "It was absolutely necessary that he should determine by his own authority how that Convention which was to meet at Edinburgh should be chosen, and that he should assume the power of annulling some judgments and some statutes.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000002_000002.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "He accordingly summoned to the parliament house several Lords who had been deprived of their honours by sentences which the general voice loudly condemned as unjust; and he took on himself to dispense with the Act which deprived Presbyterians of the elective franchise.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000003_000000.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "The consequence was that the choice of almost all the shires and burghs fell on Whig candidates.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000003_000001.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "The defeated party complained loudly of foul play, of the rudeness of the populace, and of the partiality of the presiding magistrates; and these complaints were in many cases well founded.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000004_000000.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "Nor was it only at the elections that the popular feeling, so long and so severely compressed, exploded with violence.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000004_000002.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "Unhappily throughout a large part of Scotland the clergy of the Established Church were, to use the phrase then common, rabbled. The morning of Christmas day was fixed for the commencement of these outrages.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000004_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000004_000003.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "For nothing disgusted the rigid Covenanter more than the reverence paid by the prelatist to the ancient holidays of the Church. That such reverence may be carried to an absurd extreme is true.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000004_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000004_000004.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "But a philosopher may perhaps be inclined to think the opposite extreme not less absurd, and may ask why religion should reject the aid of associations which exist in every nation sufficiently civilised to have a calendar, and which are found by experience to have a powerful and often a salutary effect.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000004_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000004_000007.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "To these austere fanatics a holiday was an object of positive disgust and hatred.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000005_000001.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "Each band marched to the nearest manse, and sacked the cellar and larder of the minister, which at that season were probably better stocked than usual.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000005_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000005_000004.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "He was then carried to the market place, and exposed during some time as a malefactor.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000006_000002.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "About two hundred curates-so the episcopal parish priests were called-were expelled.",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000006_000003.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "The graver Covenanters, while they applauded the fervour of their riotous brethren, were apprehensive that proceedings so irregular might give scandal, and learned, with especial concern, that here and there an Achan had disgraced the good cause by stooping to plunder the Canaanites whom he ought only to have smitten.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "The Scottish Bishops, in great dismay, sent the Dean of Glasgow to plead the cause of their persecuted Church at Westminster.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000007_000002.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "But, though he had, at the request of a large number of the noblemen and gentlemen of Scotland, taken on himself provisionally the executive administration of that kingdom, the means of maintaining order there were not at his command.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000007_000003.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "He had not a single regiment north of the Tweed, or indeed within many miles of that river.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000007_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000007_000004.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "It was vain to hope that mere words would quiet a nation which had not, in any age, been very amenable to control, and which was now agitated by hopes and resentments, such as great revolutions, following great oppressions, naturally engender.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000007_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000007_000006.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "But this proclamation, not being supported by troops, was very little regarded.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1323_149236_000007_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1323/149236/1323_149236_000007_000008.wav",
        "speaker_id": "LibriTTS_R-1323",
        "content": "It was a Sunday; but to rabble a congregation of prelatists was held to be a work of necessity and mercy.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    }
]