        "speaker_id": "LibriTTS_R-5060",
        "content": "But in the morning, I found on my finger his seal ring, in place of my own which he had taken.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
