        "speaker_id": "LibriTTS_R-5060",
        "content": "And this, O my brother, is my story and the cause of my madness.\" Then she poured forth tears and repeated these couplets,",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
