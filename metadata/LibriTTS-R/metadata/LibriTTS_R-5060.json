        "speaker_id": "LibriTTS_R-5060",
        "content": "\"O Thou whose boons to me are more than one!",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
