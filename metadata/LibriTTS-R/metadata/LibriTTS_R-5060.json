        "speaker_id": "LibriTTS_R-5060",
        "content": "Then Marzawan returned to his mother's house, where he passed the night.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
