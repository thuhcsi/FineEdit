[
    {
        "item_name": "LibriTTS_R-5325_36587_000002_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000002_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "ARRESTS OF DEVELOPMENT.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000003_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "There is a difference between arrested development and arrested growth, for parts in the former state continue to grow whilst still retaining their early condition.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000003_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Various monstrosities come under this head; and some, as a cleft palate, are known to be occasionally inherited.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000003_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000003_000005.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "The frontal sinus, or the projection over the eye brows, is largely developed, and the jaws are prognathous to an \"effrayant\" degree; so that these idiots somewhat resemble the lower types of mankind.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000003_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000003_000006.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Their intelligence, and most of their mental faculties, are extremely feeble. They cannot acquire the power of speech, and are wholly incapable of prolonged attention, but are much given to imitation.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000003_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000003_000007.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "They are strong and remarkably active, continually gambolling and jumping about, and making grimaces.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000003_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000003_000008.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "They often ascend stairs on all fours; and are curiously fond of climbing up furniture or trees.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000003_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000003_000010.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Idiots also resemble the lower animals in some other respects; thus several cases are recorded of their carefully smelling every mouthful of food before eating it.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000004_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "REVERSION.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000005_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Many of the cases to be here given, might have been introduced under the last heading.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000005_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000005_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "When a structure is arrested in its development, but still continues growing, until it closely resembles a corresponding structure in some lower and adult member of the same group, it may in one sense be considered as a case of reversion.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000005_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000005_000006.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "I was led to this as a probable conclusion, by the additional mammae being generally placed symmetrically on the breast; and more especially from one case, in which a single efficient mamma occurred in the inguinal region of a woman, the daughter of another woman with supernumerary mammae.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000005_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000005_000011.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "It is well known that some Lemurs normally have two pairs of mammae on the breast.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000005_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000005_000014.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "On the whole, we may well doubt if additional mammae would ever have been developed in both sexes of mankind, had not his early progenitors been provided with more than a single pair.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000006_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000006_000008.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "I was chiefly led to the conclusion that the presence of supernumerary digits might be due to reversion from the fact that such digits, not only are strongly inherited, but, as I then believed, had the power of regrowth after amputation, like the normal digits of the lower vertebrata.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000006_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000006_000009.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "But I have explained in the second edition of my Variation under Domestication why I now place little reliance on the recorded cases of such regrowth.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000006_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000006_000010.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Nevertheless it deserves notice, inasmuch as arrested development and reversion are intimately related processes; that various structures in an embryonic or arrested condition, such as a cleft palate, bifid uterus, etc, are frequently accompanied by polydactylism.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000006_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000006_000013.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "These remarks will be rendered clearer by the following illustrations.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000007_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "In various mammals the uterus graduates from a double organ with two distinct orifices and two passages, as in the marsupials, into a single organ, which is in no way double except from having a slight internal fold, as in the higher apes and man.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000007_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "The rodents exhibit a perfect series of gradations between these two extreme states.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000007_000002.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "In all mammals the uterus is developed from two simple primitive tubes, the inferior portions of which form the cornua; and it is in the words of dr Farre, \"by the coalescence of the two cornua at their lower extremities that the body of the uterus is formed in man; while in those animals in which no middle portion or body exists, the cornua remain ununited.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000008_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Here perhaps we have an instance of a simple arrest of embryonic development, with subsequent growth and perfect functional development; for either side of the partially double uterus is capable of performing the proper office of gestation.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000008_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000008_000007.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "No one will pretend that so perfect a structure as the abnormal double uterus in woman could be the result of mere chance.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000009_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000009_000011.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "This is its condition in the human foetus when two months old; and through arrested development, it sometimes remains thus in man when adult, more especially in the lower prognathous races.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000009_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000009_000012.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Hence Canestrini concludes that some ancient progenitor of man must have had this bone normally divided into two portions, which afterwards became fused together.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000010_000003.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "He says that, according to my theory, \"every transient condition of an organ, during its development, is not only a means to an end, but once was an end in itself.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000010_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000010_000004.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "This does not seem to me necessarily to hold good.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000010_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000010_000005.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Why should not variations occur during an early period of development, having no relation to reversion; yet such variations might be preserved and accumulated, if in any way serviceable, for instance, in shortening and simplifying the course of development?",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000011_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "In man, the canine teeth are perfectly efficient instruments for mastication.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000011_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000011_000002.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "The conical form is best expressed in the Melanian races, especially the Australian.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000011_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000011_000007.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "In these cases, open spaces between the teeth in the one jaw are left for the reception of the canines of the opposite jaw.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000012_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "He who rejects with scorn the belief that the shape of his own canines, and their occasional great development in other men, are due to our early forefathers having been provided with these formidable weapons, will probably reveal, by sneering, the line of his descent.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000013_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Many muscles are occasionally developed in man, which are proper to the Quadrumana or other mammals.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000013_000003.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "In only two out of thirty female subjects was this muscle developed on both sides, but in three others the rudimentary ligament was present.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000013_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000013_000004.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "This muscle, therefore, appears to be much more common in the male than in the female sex; and on the belief in the descent of man from some lower form, the fact is intelligible; for it has been detected in several of the lower animals, and in all of these it serves exclusively to aid the male in the act of reproduction.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000014_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000014_000010.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "In a single male subject, having a strong bodily frame, and well formed skull, no less than seven muscular variations were observed, all of which plainly represented muscles proper to various kinds of apes.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000014_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000014_000011.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "This man, for instance, had on both sides of his neck a true and powerful \"levator claviculae,\" such as is found in all kinds of apes, and which is said to occur in about one out of sixty human subjects.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000014_000020",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000014_000020.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Certain variations are more common in man, and others in woman, without our being able to assign any reason.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000014_000021",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000014_000021.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "mr Wood, after describing numerous variations, makes the following pregnant remark.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_36587_000014_000023",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/36587/5325_36587_000014_000023.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "The Rev.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000007_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "With the Kaffirs, who differ much from negroes, \"the skin, except among the tribes near Delagoa Bay, is not usually black, the prevailing colour being a mixture of black and red, the most common shade being chocolate.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000007_000002.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Dark complexions, as being most common, are naturally held in the highest esteem.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000007_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000007_000003.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "To be told that he is light coloured, or like a white man, would be deemed a very poor compliment by a Kaffir.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000008_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Turning to other quarters of the world; in Java, a yellow, not a white girl, is considered, according to Madame Pfeiffer, a beauty.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000009_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000009_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Although the hair on the head is thus cherished, that on the face is considered by the North American Indians \"as very vulgar,\" and every hair is carefully eradicated.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000009_000002.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "This practice prevails throughout the American continent from Vancouver's Island in the north to Tierra del Fuego in the south.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000010_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "It is remarkable that throughout the world the races which are almost completely destitute of a beard dislike hairs on the face and body, and take pains to eradicate them.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000010_000002.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "mr Veitch states that the Japanese ladies \"all objected to our whiskers, considering them very ugly, and told us to cut them off, and be like Japanese men.\" The New Zealanders have short, curled beards; yet they formerly plucked out the hairs on the face.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000013_000000.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "I have met with very few statements opposed to this conclusion.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000013_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000013_000002.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "mr Reade found that he agreed with the negroes in their estimation of the beauty of the native girls; and that their appreciation of the beauty of European women corresponded with ours. They admire long hair, and use artificial means to make it appear abundant; they admire also a beard, though themselves very scantily provided.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000013_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000013_000003.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "mr Reade feels doubtful what kind of nose is most appreciated; a girl has been heard to say, \"I do not want to marry him, he has got no nose\"; and this shews that a very flat nose is not admired.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000013_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000013_000009.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Burton, believes that a woman whom we consider beautiful is admired throughout the world.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000014_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000014_000004.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "The practice of beardless races extirpating every trace of a beard, and often all the hairs on the body affords one illustration.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000014_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000014_000006.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Many American Indians are known to admire a head so extremely flattened as to appear to us idiotic.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000016_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "But the fashions of savages are far more permanent than ours; and whenever their bodies are artificially modified, this is necessarily the case.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000016_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000016_000006.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Fanciers always wish each character to be somewhat increased; they do not admire a medium standard; they certainly do not desire any great and abrupt change in the character of their breeds; they admire solely what they are accustomed to, but they ardently desire to see each characteristic feature a little more developed.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000017_000001.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "It is certainly not true that there is in the mind of man any universal standard of beauty with respect to the human body.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000017_000002.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "It is, however, possible that certain tastes may in the course of time become inherited, though there is no evidence in favour of this belief: and if so, each race would possess its own innate ideal standard of beauty.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000017_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000017_000008.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "No doubt characters of all kinds may be too much developed for beauty.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-5325_50109_000017_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/5325/50109/5325_50109_000017_000009.wav",
        "speaker_id": "LibriTTS_R-5325",
        "content": "Hence a perfect beauty, which implies many characters modified in a particular manner, will be in every race a prodigy.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    }
