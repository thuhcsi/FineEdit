[
    {
        "item_name": "LibriTTS_R-3979_10701_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000005_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"My lord,\" he said at last, \"I do know the road for which you ask, but your kindness and the friendship I have conceived for you make me loth to point it out.\"",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000006_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"But why not?\" inquired the prince.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000006_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000006_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"What danger can there be?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000007_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"The very greatest danger,\" answered the dervish.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000007_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"Other men, as brave as you, have ridden down this road, and have put me that question.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000007_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000007_000002.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "I did my best to turn them also from their purpose, but it was of no use. Not one of them would listen to my words, and not one of them came back.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000008_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000008_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "But what dangers can there be in the adventure which courage and a good sword cannot meet?\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000009_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000009_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"And suppose,\" answered the dervish, \"that your enemies are invisible, how then?\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000011_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000011_000004.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "On each side you will see vast heaps of big black stones, and will hear a multitude of insulting voices, but pay no heed to them, and, above all, beware of ever turning your head. If you do, you will instantly become a black stone like the rest.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000011_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000011_000005.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "For those stones are in reality men like yourself, who have been on the same quest, and have failed, as I fear that you may fail also.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000013_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "Then it came to a sudden halt, and the prince at once got down and flung the bridle on his horse's neck.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000014_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"Who is this imbecile?\" cried some, \"stop him at once.\" \"Kill him,\" shrieked others, \"Help! robbers!",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000019_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000019_000003.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "Still, we must hope for better luck.\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000021_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000021_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"That, holy dervish,\" replied Prince Perviz, \"was my elder brother, who is now dead, though how he died I cannot say.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000026_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "But may I ask the purpose of your question?\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000027_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"Good dervish,\" answered the princess, \"I have heard such glowing descriptions of these three things, that I cannot rest till I possess them.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000028_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"Madam,\" said the dervish, \"they are far more beautiful than any description, but you seem ignorant of all the difficulties that stand in your way, or you would hardly have undertaken such an adventure. Give it up, I pray you, and return home, and do not ask me to help you to a cruel death.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000029_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"Holy father,\" answered the princess, \"I come from far, and I should be in despair if I turned back without having attained my object.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000032_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000032_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "It is possible that you may succeed, but all the same, the risk is great.\"",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000035_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000035_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "The first thing the princess did on arriving at the mountain was to stop her ears with cotton, and then, making up her mind which was the best way to go, she began her ascent.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000036_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "At the sight of the bird, the princess hastened her steps, and without vexing herself at the noise which by this time had grown deafening, she walked straight up to the cage, and seizing it, she said: \"Now, my bird, I have got you, and I shall take good care that you do not escape.\" As she spoke she took the cotton from her ears, for it was needed no longer.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000037_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "Although confined in a cage, I was content with my lot, but if I must become a slave, I could not wish for a nobler mistress than one who has shown so much constancy, and from this moment I swear to serve you faithfully. Some day you will put me to the proof, for I know who you are better than you do yourself.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000039_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000039_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "She then returned to the cage, and said: \"Bird, there is still something else, where shall I find the Singing Tree?\"",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000042_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "When the Princess Parizade held in her hands the three wonders promised her by the old woman, she said to the bird: \"All that is not enough. It was owing to you that my brothers became black stones.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000044_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"No, I have not forgotten,\" replied the bird, \"but what you ask is very difficult.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000044_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000044_000003.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "Take it, and, as you go down the mountain, scatter a little of the water it contains over every black stone and you will soon find your two brothers.\"",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000045_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000045_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "Princess Parizade took the pitcher, and, carrying with her besides the cage the twig and the flask, returned down the mountain side.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000045_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000045_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "At every black stone she stopped and sprinkled it with water, and as the water touched it the stone instantly became a man.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000046_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"Why, what are you doing here?\" she cried.",
        "style_prompt": "F_p-high_s-fast_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000047_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "\"We have been asleep,\" they said.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000048_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000048_000002.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "Look round and see if there is one left.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3979_10701_000051_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10701/3979_10701_000051_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "Then they rode away, followed by the knights and gentlemen, who begged to be permitted to escort them.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10702_000059_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10702/3979_10702_000059_000000.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "The bird stopped singing at once, and all the other birds stopped too.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3979_10702_000068_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3979/10702/3979_10702_000068_000001.wav",
        "speaker_id": "LibriTTS_R-3979",
        "content": "This was done.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    }
]