[
    {
        "item_name": "LibriTTS_R-7733_106800_000002_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000002_000002.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "The first night we camped on the south fork of Big Creek, four miles west of Hays City.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"All right, Colonel; send along a wagon or two to bring in the meat,\" I said.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000005_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"I am not in the habit of sending out my wagons until I know that there is something to be hauled in; kill your buffaloes first, and then I'll send out the wagons,\" was the Colonel's reply.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "The following afternoon he again requested me to go out and get some fresh buffalo meat.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000006_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000006_000003.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "He came up rather angrily, and demanded an explanation.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000007_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"I can't allow any such business as this, Cody,\" said he.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000012_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000012_000003.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "It was hard to convince Pat, however, of the truth.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "None of these, however, discovering Indians, they all returned to camp about the same time, finding it in a state of great excitement, it having been attacked a few hours previously by a party of Indians, who had succeeded in killing two men and in making off with sixty horses belonging to Company h",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000016_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000016_000007.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "We fought them until dark, all the time driving them before us.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000017_000002.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "Major Brown declared it was a crack shot, because it broke the plate.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000023_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"Well, Cody, go ahead,\" said he; \"I'll leave it to you; but remember that I don't want a dry camp.\"",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000024_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"No danger of that,\" said I; and then I rode on, leaving him to return to the command.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000025_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000025_000002.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "I disentangled myself, and jumped behind the dead body.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000025_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000025_000003.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "Looking in the direction whence the shot had come I saw two Indians, and at once turned my gun loose on them, but in the excitement of the moment I missed my aim.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000026_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "On the opposite side of the creek, going over the hill, I observed a few lodges moving rapidly away, and also some mounted warriors, who could see me, and who kept blazing away with their guns.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000026_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000026_000001.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "The two Indians who had fired at me, and had killed my horse, were retreating across the creek on a beaver dam.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000026_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000026_000006.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "The redskins whirled and made off.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000031_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "It was eleven o'clock at night when I got back to the camp.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000031_000001.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "A light was still burning in the General's tent, he having remained awake, anxiously awaiting my return.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000033_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000033_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"Cody, we're in a nice fix now,\" said General Carr.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000036_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"Never you mind the train, General.",
        "style_prompt": "F_p-low_s-fast_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000036_000001.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "You say you are looking for a good camp.",
        "style_prompt": "F_p-normal_s-fast_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000036_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000036_000002.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "How does that beautiful spot down in the valley suit you?\" I asked him.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000037_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"That will do.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000037_000001.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "I can easily descend with the cavalry, but how to get the wagons down there is a puzzler to me,\" said he.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000038_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"By the time you are located in your camp, your wagons shall be there,\" said i",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000039_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"All right, Cody, I'll leave it to you, as you seem to want to be boss,\" he replied, pleasantly.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000039_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000039_000002.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "The wagon train was a mile in the rear, and when it came up one of the drivers asked, \"How are we going down there?\"",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000041_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000041_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"We can never do it; it's too steep; the wagons will run over the mules,\" said another wagon master.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000043_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000043_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "I told Wilson, the chief wagon master, to bring on his mess wagon, which was at the head of the train, and I would try the experiment at least. Wilson drove the team and wagon to the brink of the hill, and following my directions he brought out some extra chains with which we locked the wheels on each side, and then rough locked them.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000043_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000043_000001.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "We now started the wagon down the hill.",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000043_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000043_000003.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "Three other wagons immediately followed in the same way, and in half an hour every wagon was in camp, without the least accident having occurred.",
        "style_prompt": "F_p-low_s-fast_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000050_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000050_000000.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "\"Where's your command?",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000053_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000053_000002.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "The camp presented a pitiful sight, indeed.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7733_106800_000054_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7733/106800/7733_106800_000054_000002.wav",
        "speaker_id": "LibriTTS_R-7733",
        "content": "He then picked out five hundred of the best men and horses, and, taking his pack train with him, started south for the Canadian River, leaving the rest of the troops at the supply camp.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    }
]