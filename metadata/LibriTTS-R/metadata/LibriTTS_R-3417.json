        "speaker_id": "LibriTTS_R-3417",
        "content": "Pennell taking verge plate bearings on bow and quarter. Cherry Garrard noting results.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
