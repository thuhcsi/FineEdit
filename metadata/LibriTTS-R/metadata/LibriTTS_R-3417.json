        "speaker_id": "LibriTTS_R-3417",
        "content": "Evans taking verge plate bearings abeam. Atkinson noting results.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
