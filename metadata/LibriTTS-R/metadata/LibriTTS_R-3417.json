        "speaker_id": "LibriTTS_R-3417",
        "content": "After many frowns fortune has treated us to the kindest smile-for twenty four hours we have had a calm with brilliant sunshine.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
