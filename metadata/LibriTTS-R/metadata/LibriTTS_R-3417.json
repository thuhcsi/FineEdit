        "speaker_id": "LibriTTS_R-3417",
        "content": "I have observed several floes with an entirely new type of surface.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000059_000000",
