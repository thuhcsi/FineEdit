        "speaker_id": "LibriTTS_R-3417",
        "content": "We steered for the Cape, fully expecting to find the edge of the pack ice ranging westward from it.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
