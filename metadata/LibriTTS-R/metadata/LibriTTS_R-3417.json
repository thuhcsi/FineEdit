        "speaker_id": "LibriTTS_R-3417",
        "content": "'Many of us spent the night on deck as we pushed through the pack.' We have passed some very large floes evidently frozen in the strait.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
