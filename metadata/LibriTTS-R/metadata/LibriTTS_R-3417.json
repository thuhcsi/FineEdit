        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3417/6522/3417_6522_000061_000014.wav",
        "speaker_id": "LibriTTS_R-3417",
        "content": "We made fast with ice anchors.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000061_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3417/6522/3417_6522_000061_000015.wav",
        "speaker_id": "LibriTTS_R-3417",
        "content": "Wilson, Evans, and I went to the Cape, which I had now rechristened Cape Evans in honour of our excellent second in command.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000061_000016",
