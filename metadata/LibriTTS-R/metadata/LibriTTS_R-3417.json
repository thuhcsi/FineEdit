        "speaker_id": "LibriTTS_R-3417",
        "content": "Bowers taking altitudes of objects as they come abeam. Nelson noting results.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
