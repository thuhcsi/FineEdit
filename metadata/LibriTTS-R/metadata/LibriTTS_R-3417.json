        "speaker_id": "LibriTTS_R-3417",
        "content": "Such weather in such a place comes nearer to satisfying my ideal of perfection than any condition that I have ever experienced.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
