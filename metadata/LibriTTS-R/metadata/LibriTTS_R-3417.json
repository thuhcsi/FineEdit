        "speaker_id": "LibriTTS_R-3417",
        "content": "A glance at the land showed, as we expected, ideal spots for our wintering station.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000061_000020",
