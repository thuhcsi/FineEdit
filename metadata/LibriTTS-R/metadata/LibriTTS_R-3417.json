        "speaker_id": "LibriTTS_R-3417",
        "content": "At this point it was evident that we had a considerable choice of wintering spots.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
