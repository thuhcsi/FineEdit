        "speaker_id": "LibriTTS_R-3417",
        "content": "Rennick sounding with Thomson machine. Drake noting results.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
