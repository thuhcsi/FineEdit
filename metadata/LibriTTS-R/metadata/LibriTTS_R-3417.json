        "speaker_id": "LibriTTS_R-3417",
        "content": "One can only suppose the whales are satiated.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000056_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3417/6522/3417_6522_000056_000001.wav",
        "speaker_id": "LibriTTS_R-3417",
        "content": "It was good to see them again, and perhaps after all we are better this side of the Island.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000056_000002",
