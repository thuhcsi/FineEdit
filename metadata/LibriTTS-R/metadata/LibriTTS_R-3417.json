        "speaker_id": "LibriTTS_R-3417",
        "content": "The most favourable circumstance of all is the stronge chance of communication with Cape Armitage being established at an early date.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000062_000002",
