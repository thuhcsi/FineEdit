        "speaker_id": "LibriTTS_R-3417",
        "content": "Bruce continually checking speed with hand log.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
