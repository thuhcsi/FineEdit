        "speaker_id": "LibriTTS_R-3417",
        "content": "We are within five miles of Cape Royds and ought to get there.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
