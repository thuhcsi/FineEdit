        "speaker_id": "LibriTTS_R-3417",
        "content": "It gives one a homely feeling to see such a familiar scene.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000057_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3417/6522/3417_6522_000057_000001.wav",
        "speaker_id": "LibriTTS_R-3417",
        "content": "We pushed past these cliffs into streams of heavy bay ice, making fair progress; as we proceeded the lanes became scarcer, the floes heavier, but the latter remain loose.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000057_000002",
