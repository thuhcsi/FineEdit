        "speaker_id": "LibriTTS_R-3417",
        "content": "We could have gone to either of the small islands, to the mainland, the Glacier Tongue, or pretty well anywhere except Hut Point.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000061_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/3417/6522/3417_6522_000061_000009.wav",
        "speaker_id": "LibriTTS_R-3417",
        "content": "My main wish was to choose a place that would not be easily cut off from the Barrier, and my eye fell on a cape which we used to call the Skuary a little behind us.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
