        "speaker_id": "LibriTTS_R-3417",
        "content": "How, I ask myself, was our depot party to get back to home quarters?",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-3417_6522_000063_000000",
