[
    {
        "item_name": "LibriTTS_R-7331_86025_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'This is my house, and is to be yours,' said Habogi, as he jumped down and held out his arms to lift Helga from the horse.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000014_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "The girl's heart sank a little, as she thought that the man who possessed such wonderful sheep, and cows, and horses, might have built himself a prettier place to live in; but she did not say so.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "And, taking her arm, he led her up the steps.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "But when she got inside, she stood quite bewildered at the beauty of all around her.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "None of her friends owned such things, not even the miller, who was the richest man she knew.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000015_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "There were carpets everywhere, thick and soft, and of deep rich colours; and the cushions were of silk, and made you sleepy even to look at them; and curious little figures in china were scattered about.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000015_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000015_000003.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "Helga felt as if it would take her all her life to see everything properly, and it only seemed a second since she had entered the house, when Habogi came up to her.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000016_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "In three days he will bring you back here, with your parents and sisters, and any guests you may invite, in your company.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000016_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "By that time the feast will be ready.'",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "Helga had so much to think about, that the ride home appeared very short.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86025_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86025/7331_86025_000017_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "And after they had given her some supper they begged her to tell them all she had done.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000000_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000000_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "And the wolverine laughed and said: 'Oh, that will do just as well'; and began to run down the side of the mountain.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000001_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "But the faster the wolverine ran, the faster the rock rolled, and by and by the little creature began to get very tired, and was sorry he had not left the rock to itself.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000003_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'Why did you not leave me alone?' asked the rock.",
        "style_prompt": "F_p-low_s-slow_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'I did not want to move-I hate moving.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000003_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "But you WOULD have it, and I certainly sha'n't move now till I am forced to.'",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000004_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000004_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'I will call my brothers,' answered the wolverine.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000005_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000005_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'How DID you get under that rock?' asked they, making a ring round him; but they had to repeat their question several times before the wolverine would answer, for he, like many other persons, found it hard to confess that he had brought his troubles on himself.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000006_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000006_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'Well, I was dull, and wanted someone to play with me,' he said at last, in sulky voice, 'and I challenged the rock to catch me.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000006_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "It was just an accident.'",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000008_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000008_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'You are no good at all,' cried the wolverine crossly, for it was suffering great pain, 'and if you cannot get me free, I shall see what my friends the lightning and thunder can do.' And he called loudly to the lightning to come and help him as quickly as possible.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000009_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "So the lightning disappeared into the cloud for a moment to gather up fresh strength, and then came rushing down, right upon the rock, which it sent flying in all directions, and took the wolverine's coat so neatly that, though it was torn into tiny shreds, the wolverine himself was quite unharmed.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'That was rather clumsy of you,' said he, standing up naked in his flesh.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000010_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000010_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "It took him a long time, for there were a great many of them, but at last he had them all in his hand.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000011_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000011_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'I'll go to my sister the frog,' he thought to himself, 'and she will sew them together for me'; and he set off at once for the swamp in which his sister lived.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000013_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "When the wolverine, who was very particular about his clothes, came to put it on, he grew very angry.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'What a useless creature you are!' cried he.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000014_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'Do you expect me to go about in such a coat as that?",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000014_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "Why it bulges all down the back, as if I had a hump, and it is so tight across the chest that I expect it to burst every time I breathe.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000015_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'I tore my coat this morning,' he began, when he had found her sitting at the door of her house eating an apple.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000015_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000015_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'It was all in little bits, and I took it to our sister the frog to ask her to sew it for me.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000015_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000015_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "But just look at the way she has done it!",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000015_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000015_000004.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "However, the mouse was used to it and only answered: 'I think you had better stay here till it is done, and if there is any alteration needed I can make it.' So the wolverine sat down on a heap of dry ferns, and picking up the apple, he finished it without even asking the mouse's leave.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000016_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000016_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "At last the coat was ready, and the wolverine put it on.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000018_000000.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "He wandered about for many days, till he reached a place where food was very scarce, and for a whole week he went without any.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000018_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000018_000001.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "He was growing desperate, when he suddenly came upon a bear that was lying asleep.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7331_86027_000018_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7331/86027/7331_86027_000018_000002.wav",
        "speaker_id": "LibriTTS_R-7331",
        "content": "'Ah! here is food at last!' thought he; but how was he to kill the bear, who was so much bigger than himself?",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
