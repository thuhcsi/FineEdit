        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6467/94831/6467_94831_000008_000000.wav",
        "speaker_id": "LibriTTS_R-6467",
