        "speaker_id": "LibriTTS_R-6467",
        "content": "But his words did not deceive George Strong, who understood only too well Tom's propensity for mischief.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
