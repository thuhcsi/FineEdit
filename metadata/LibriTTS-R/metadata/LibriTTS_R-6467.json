        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6467/94831/6467_94831_000004_000002.wav",
        "speaker_id": "LibriTTS_R-6467",
        "content": "I'm first rate, never was better in my life!\" And he gave the hand a hard squeeze.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
