        "speaker_id": "LibriTTS_R-6467",
        "content": "\"How are you-pretty well?",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
