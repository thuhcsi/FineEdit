        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6467/94831/6467_94831_000000_000000.wav",
        "speaker_id": "LibriTTS_R-6467",
        "content": "\"Splendid, sir,\" said Tom.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6467_94831_000000_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6467/94831/6467_94831_000000_000001.wav",
        "speaker_id": "LibriTTS_R-6467",
        "content": "\"Oh, how do you do, mr Strong?\" and he ran to meet the head teacher.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6467_94831_000001_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6467/94831/6467_94831_000001_000001.wav",
        "speaker_id": "LibriTTS_R-6467",
        "content": "\"How about it?\" And his eyes twinkled.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6467_94831_000002_000000",
