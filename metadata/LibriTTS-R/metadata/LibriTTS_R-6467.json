        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6467/94831/6467_94831_000004_000000.wav",
        "speaker_id": "LibriTTS_R-6467",
        "content": "\"Hullo, Aleck!\" cried Tom rushing up and grabbing the colored man by the hand.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
