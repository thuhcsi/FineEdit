        "speaker_id": "LibriTTS_R-6467",
        "content": "\"Why, nothing, Aleck, my boy.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6467_94831_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6467/94831/6467_94831_000006_000002.wav",
        "speaker_id": "LibriTTS_R-6467",
        "content": "I've gained fifteen pounds, and-\"",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
