[
    {
        "item_name": "LibriTTS_R-7795_105407_000001_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000001_000002.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "She had abandoned all hope of saving him: she saw him gradually hemmed in on all sides, and, in despair, she gazed round her into the darkness, and wondered whence he would presently come, to fall into the death trap which his relentless enemy had prepared for him.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000003_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000003_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Her feet were sore.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000003_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000003_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Her knees shook under her, from sheer bodily fatigue.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000003_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000003_000003.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "She would see her husband, tell him all, and, if he was ready to forgive the crime, which she had committed in her blind ignorance, she would yet have the happiness of dying by his side.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000004_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000004_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "They had come to their destination.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000004_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000004_000002.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "No doubt on the right, somewhere close ahead, was the footpath that led to the edge of the cliff and to the hut.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000006_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000006_000002.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "The Jew had remained on the road, with his cart and nag.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000010_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000010_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Very good.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000010_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000010_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "You shall lead us.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000010_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000010_000003.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Do you understand?\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000012_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000012_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Now listen very attentively, all of you,\" continued Chauvelin, impressively, and addressing the soldiers collectively, \"for after this we may not be able to exchange another word, so remember every syllable I utter, as if your very lives depended on your memory.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000012_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000012_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Perhaps they do,\" he added drily.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000014_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"You, who have crept up to the hut, will try to peep inside.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000014_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000014_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "If an Englishman is there with those traitors, a man who is tall above the average, or who stoops as if he would disguise his height, then give a sharp, quick whistle as a signal to your comrades.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000014_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000014_000003.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Do you understand?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000017_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000017_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "There was a little pause, then Chauvelin continued,--",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000020_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Then get along as noiselessly as possible, and I will follow you.\"",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000023_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Here, you . . .",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000023_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000023_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Aaron, Moses, Abraham, or whatever your confounded name may be,\" he said to the old man, who had quietly stood beside his lean nag, as far away from the soldiers as possible.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000024_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000024_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Benjamin Rosenbaum, so it please your Honour,\" he replied humbly.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000025_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000025_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"It does not please me to hear your voice, but it does please me to give you certain orders, which you will find it wise to obey.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000026_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000026_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"So it please your Honour . . .\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000027_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000027_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Hold your confounded tongue.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000027_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000027_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "You shall stay here, do you hear?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000027_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000027_000004.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Do you understand?\"",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000028_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000028_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"But your Honour-\" protested the Jew pitiably.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000029_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000029_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"There is no question of 'but' or of any argument,\" said Chauvelin, in a tone that made the timid old man tremble from head to foot.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000029_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"If, when I return, I do not find you here, I most solemnly assure you that, wherever you may try to hide yourself, I can find you, and that punishment swift, sure and terrible, will sooner or later overtake you. Do you hear me?\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000030_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"But your Excellency . . .\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000031_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"I said, do you hear me?\"",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000036_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Will your horse and cart be safe alone, here, do you think?\" he asked roughly.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000037_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "There seems no doubt that, if he gets scared, he will either make a bolt of it, or shriek his head off.\"",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000038_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"But what am I to do with the brute?\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000039_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Will you send him back to Calais, citoyen?\"",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000042_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000042_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Well, you lazy, lumbering old coward,\" said Chauvelin at last, \"you had better shuffle along behind us.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000044_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000044_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"Quick!\" said Chauvelin, impatiently, \"we have already wasted much valuable time.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000046_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000046_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Marguerite had not lost a single one of Chauvelin's words of command. Her every nerve was strained to completely grasp the situation first, then to make a final appeal to those wits which had so often been called the sharpest in Europe, and which alone might be of service now.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000047_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000047_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Certainly the situation was desperate enough; a tiny band of unsuspecting men, quietly awaiting the arrival of their rescuer, who was equally unconscious of the trap laid for them all.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000047_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000047_000002.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "She vaguely wondered who the others were, who were also calmly waiting for the Scarlet Pimpernel, while death lurked behind every boulder of the cliffs.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000048_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000048_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "She feared to lose her way, or she would have rushed forward and found that wooden hut, and perhaps been in time to warn the fugitives and their brave deliverer yet.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000049_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000049_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "But she did not know if her shrieks would reach the ears of the doomed men. Her effort might be premature, and she would never be allowed to make another.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000050_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000050_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "She felt neither soreness nor weariness; indomitable will to reach her husband in spite of adverse Fate, and of a cunning enemy, killed all sense of bodily pain within her, and rendered her instincts doubly acute.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000052_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000052_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Suddenly, those same keen instincts within her made her pause in her mad haste, and cower still further within the shadow of the hedge.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000054_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000054_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Marguerite had guessed rather than recognized her.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000054_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000054_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "It was the DAY DREAM, Percy's favourite yacht, and all her crew of British sailors: her white sails, glistening in the moonlight, seemed to convey a message to Marguerite of joy and hope, which yet she feared could never be.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000055_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000055_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "The sight of the schooner seemed to infuse into the poor, wearied woman the superhuman strength of despair.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000055_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000055_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "There was the edge of the cliff, and some way below was the hut, where presently, her husband would meet his death.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000057_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000057_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Only for a moment, though; the next she had cowered, like some animal doubled up within itself.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000057_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000057_000002.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Suddenly, as she gazed, she saw at some little distance on her left, and about midway down the cliffs, a rough wooden construction, through the wall of which a tiny red light glimmered like a beacon.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000059_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000059_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "On she pressed, forgetting the deadly foe on her track, running, stumbling, foot sore, half dazed, but still on . . .",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000059_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000059_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "When, suddenly, a crevice, or stone, or slippery bit of rock, threw her violently to the ground.",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000059_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000059_000003.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "But now she realised that other steps, quicker than her own, were already close at her heels.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000060_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000060_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "She lay in the shadow of a great boulder; Chauvelin could not see her features, but he passed his thin, white fingers over her face.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000061_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000061_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"A woman!\" he whispered, \"by all the saints in the calendar.\"",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000062_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000062_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"We cannot let her loose, that's certain,\" he muttered to himself.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000062_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000062_000001.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "\"I wonder now . . .\"",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7795_105407_000066_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7795/105407/7795_105407_000066_000000.wav",
        "speaker_id": "LibriTTS_R-7795",
        "content": "Her senses were leaving her; half choked with the tight grip round her mouth, she had no strength to move or to utter the faintest sound.",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    }
]