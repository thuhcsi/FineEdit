        "speaker_id": "LibriTTS_R-9026",
        "content": "Begbie adjourned the court with the pious wish that the murderer should go out and cut the throats of the jury.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
