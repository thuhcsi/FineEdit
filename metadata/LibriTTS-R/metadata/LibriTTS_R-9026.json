        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/9026/282385/9026_282385_000013_000001.wav",
        "speaker_id": "LibriTTS_R-9026",
        "content": "In the early days gold commissioners not only settled all mining disputes, but acted as judge and jury.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
