        "speaker_id": "LibriTTS_R-9026",
        "content": "On his way down the prisoner escaped from the constable. This type of hair trigger gunmen at once fled the country when Begbie came.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-9026_282385_000012_000000",
