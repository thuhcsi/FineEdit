        "speaker_id": "LibriTTS_R-9026",
        "content": "There was still a basket of champagne left.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-9026_282385_000014_000008",
