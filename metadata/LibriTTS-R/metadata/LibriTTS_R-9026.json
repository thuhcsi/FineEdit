        "speaker_id": "LibriTTS_R-9026",
        "content": "He danced the hurdy gurdy on that basket till he cut his feet.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
