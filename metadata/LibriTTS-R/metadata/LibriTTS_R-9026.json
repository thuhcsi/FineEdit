        "speaker_id": "LibriTTS_R-9026",
        "content": "I ken a body made a strike. He looked a little lord. He had a clan o' followers Amang a needy horde.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
