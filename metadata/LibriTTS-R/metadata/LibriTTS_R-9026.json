        "speaker_id": "LibriTTS_R-9026",
        "content": "The miner stood and proudly surveyed his own figure in the glass.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
