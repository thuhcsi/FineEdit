        "speaker_id": "LibriTTS_R-9026",
        "content": "Dead silence fell in the court room.",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "very high"
