        "speaker_id": "LibriTTS_R-9026",
        "content": "Milk was retailed frozen at a dollar a pound.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
