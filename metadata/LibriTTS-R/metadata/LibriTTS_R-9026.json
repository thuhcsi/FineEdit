        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/9026/282385/9026_282385_000014_000003.wav",
        "speaker_id": "LibriTTS_R-9026",
        "content": "He came to the best saloon of Barkerville.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
