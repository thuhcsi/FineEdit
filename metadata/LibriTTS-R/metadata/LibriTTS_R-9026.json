        "speaker_id": "LibriTTS_R-9026",
        "content": "He gathered his last nuggets and hurled them in handfuls at the mirror, shattering it in countless pieces.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
