        "speaker_id": "LibriTTS_R-9026",
        "content": "Champagne in pint bottles sold at two ounces of gold.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
