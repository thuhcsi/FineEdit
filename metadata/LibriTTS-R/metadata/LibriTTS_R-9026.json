        "speaker_id": "LibriTTS_R-9026",
        "content": "A lunatic escaped from a madhouse could not have been more foolish.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
