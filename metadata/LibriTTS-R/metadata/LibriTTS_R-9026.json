        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/9026/282385/9026_282385_000014_000000.wav",
        "speaker_id": "LibriTTS_R-9026",
        "content": "The effect of sudden wealth on some of the hungry, ragged horde who infested Cariboo was of a sort to discount fiction.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
