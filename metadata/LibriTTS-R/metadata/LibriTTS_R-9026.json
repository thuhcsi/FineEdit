        "speaker_id": "LibriTTS_R-9026",
        "content": "The disreputable also found their own places.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
