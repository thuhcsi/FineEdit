        "speaker_id": "LibriTTS_R-4411",
        "content": "He turned a scarred formless muddle of paint towards Maisie, and the eyes strained as though they would catch her wonder and surprise.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
