        "speaker_id": "LibriTTS_R-4411",
        "content": "'Well?' said Dick, his face steadily turned away.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "very low"
    },
    {
