        "speaker_id": "LibriTTS_R-4411",
        "content": "Oh yes-thank you.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
