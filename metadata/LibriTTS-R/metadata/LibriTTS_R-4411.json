        "speaker_id": "LibriTTS_R-4411",
        "content": "Wait a moment, dear.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
