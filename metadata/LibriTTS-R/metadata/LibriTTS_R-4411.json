        "speaker_id": "LibriTTS_R-4411",
        "content": "But I can't.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4411_14501_000009_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4411/14501/4411_14501_000009_000002.wav",
        "speaker_id": "LibriTTS_R-4411",
        "content": "Oh, Dickie, you wouldn't ask me-would you?' wailed Maisie.",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
