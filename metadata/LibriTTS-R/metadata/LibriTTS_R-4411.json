        "speaker_id": "LibriTTS_R-4411",
        "content": "One thing and one thing only could she do for him.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
