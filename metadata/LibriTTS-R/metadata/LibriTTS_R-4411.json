        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4411/14501/4411_14501_000017_000000.wav",
        "speaker_id": "LibriTTS_R-4411",
        "content": "When you're better you shall go away and get something to eat.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-4411_14501_000017_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4411/14501/4411_14501_000017_000001.wav",
        "speaker_id": "LibriTTS_R-4411",
        "content": "What sort of a passage did you have coming over?'",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
