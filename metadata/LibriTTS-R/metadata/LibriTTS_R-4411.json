        "speaker_id": "LibriTTS_R-4411",
        "content": "And now you've come and seen, and I'm-immensely grateful.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
