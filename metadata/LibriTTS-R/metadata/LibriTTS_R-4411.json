        "speaker_id": "LibriTTS_R-4411",
        "content": "He was conscious that Maisie was catching her breath, but was as unprepared as herself for the torrent of emotion that followed.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
