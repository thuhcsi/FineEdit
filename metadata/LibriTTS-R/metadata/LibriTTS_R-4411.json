        "speaker_id": "LibriTTS_R-4411",
        "content": "He was savagely angry against Torpenhow, who had brought upon him this humiliation and troubled his miserable peace.",
        "style_prompt": "F_p-high_s-normal_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "normal"
    },
    {
