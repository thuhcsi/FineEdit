        "speaker_id": "LibriTTS_R-4411",
        "content": "Then his dark hour came and he was alone with himself and his desires to get what help he could from the darkness.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
