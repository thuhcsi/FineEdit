        "speaker_id": "LibriTTS_R-4411",
        "content": "Maisie had never feared her companion before.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
