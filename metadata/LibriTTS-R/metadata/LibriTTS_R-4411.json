        "speaker_id": "LibriTTS_R-4411",
        "content": "'Well?'",
        "style_prompt": "F_p-high_s-slow_e-low",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
