        "speaker_id": "LibriTTS_R-4411",
        "content": "She drew herself out of his arms at last and waited, trembling and most unhappy.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
