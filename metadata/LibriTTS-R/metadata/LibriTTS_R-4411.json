        "speaker_id": "LibriTTS_R-4411",
        "content": "She had dropped into a chair and was sobbing with her face hidden in her hands.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
