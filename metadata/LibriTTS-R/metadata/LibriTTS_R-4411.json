        "speaker_id": "LibriTTS_R-4411",
        "content": "I told you how it would be.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
