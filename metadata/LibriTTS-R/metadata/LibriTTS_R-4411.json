        "speaker_id": "LibriTTS_R-4411",
        "content": "'Indeed, I can't.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
