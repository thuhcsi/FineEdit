        "speaker_id": "LibriTTS_R-4411",
        "content": "He could not realise at first that Maisie, whom he had ordered to go had left him without a word of farewell.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
