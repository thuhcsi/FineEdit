        "speaker_id": "LibriTTS_R-4411",
        "content": "Her Dick had gone blind and left in his place some one that she could hardly recognise till he spoke.",
        "style_prompt": "F_p-high_s-slow_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
