        "speaker_id": "LibriTTS_R-4411",
        "content": "'Who is asking you to do anything, Maisie?",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
