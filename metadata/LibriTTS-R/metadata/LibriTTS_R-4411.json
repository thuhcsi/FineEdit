        "speaker_id": "LibriTTS_R-4411",
        "content": "Dick's shoulders straightened again, for the words lashed like a whip.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "slow",
