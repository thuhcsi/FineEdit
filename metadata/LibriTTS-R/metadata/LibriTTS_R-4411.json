        "speaker_id": "LibriTTS_R-4411",
        "content": "For Dick was reserved more searching torment.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
