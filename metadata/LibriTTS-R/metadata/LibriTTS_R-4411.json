        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4411/14501/4411_14501_000014_000003.wav",
        "speaker_id": "LibriTTS_R-4411",
        "content": "You're only a little upset by the journey, and I don't suppose you've had any breakfast.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
    },
    {
