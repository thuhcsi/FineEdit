        "speaker_id": "LibriTTS_R-4411",
        "content": "Don't cry.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-4411_14501_000014_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4411/14501/4411_14501_000014_000002.wav",
        "speaker_id": "LibriTTS_R-4411",
        "content": "You're quite right, and you've nothing to reproach yourself with-you never had.",
