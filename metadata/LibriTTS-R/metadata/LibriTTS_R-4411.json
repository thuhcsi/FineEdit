        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4411/14501/4411_14501_000015_000000.wav",
        "speaker_id": "LibriTTS_R-4411",
        "content": "'I wanted to come.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-4411_14501_000015_000001",
