        "speaker_id": "LibriTTS_R-4411",
        "content": "'You don't know how I hate myself.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
    },
    {
