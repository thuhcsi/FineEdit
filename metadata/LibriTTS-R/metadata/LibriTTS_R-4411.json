        "speaker_id": "LibriTTS_R-4411",
        "content": "But for Dick's sake-whatever this mad blankness might mean-she must make no sign.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
    },
    {
