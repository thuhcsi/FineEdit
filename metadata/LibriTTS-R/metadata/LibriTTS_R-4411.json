        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/4411/14501/4411_14501_000010_000002.wav",
        "speaker_id": "LibriTTS_R-4411",
        "content": "But it was the worn out eyes that Maisie feared.",
        "style_prompt": "F_p-high_s-normal_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "normal",
