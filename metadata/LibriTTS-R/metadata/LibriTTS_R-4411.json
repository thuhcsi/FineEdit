        "speaker_id": "LibriTTS_R-4411",
        "content": "'I do despise myself-indeed I do.",
        "style_prompt": "F_p-high_s-slow_e-high",
        "gender": "F",
        "pitch": "very high",
        "speed": "slow",
        "energy": "very high"
