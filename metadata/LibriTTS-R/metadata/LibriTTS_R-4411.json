        "speaker_id": "LibriTTS_R-4411",
        "content": "What do you think of her?'",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "very high",
        "speed": "fast",
        "energy": "normal"
    },
    {
