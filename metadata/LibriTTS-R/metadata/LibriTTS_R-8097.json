        "speaker_id": "LibriTTS_R-8097",
        "content": "When the work of plowing was done, they patiently watched him sow the seed.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-8097_282406_000003_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8097/282406/8097_282406_000003_000002.wav",
        "speaker_id": "LibriTTS_R-8097",
        "content": "It was their feast, they thought.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-8097_282406_000004_000000",
