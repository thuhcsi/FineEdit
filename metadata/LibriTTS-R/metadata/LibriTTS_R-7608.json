        "speaker_id": "LibriTTS_R-7608",
        "content": "\"No, you manage it, Tom, until it's in good running shape.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
