        "speaker_id": "LibriTTS_R-7608",
        "content": "\"Why-why are we out here?\" asked mr Fenwick.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "low"
    },
