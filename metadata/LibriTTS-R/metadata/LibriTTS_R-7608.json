        "speaker_id": "LibriTTS_R-7608",
        "content": "\"Why-why!\" he exclaimed.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-7608_115034_000063_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/7608/115034/7608_115034_000063_000001.wav",
        "speaker_id": "LibriTTS_R-7608",
        "content": "They had quickly passed over Cape May, across the sandy beach, and were now well out over the Atlantic.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
