        "speaker_id": "LibriTTS_R-7608",
        "content": "The owner of the WHIZZER, happened to look down through a plate glass window in the floor of car.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
