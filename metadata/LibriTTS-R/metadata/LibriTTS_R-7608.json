        "speaker_id": "LibriTTS_R-7608",
        "content": "\"Isn't it dangerous-in an airship that hasn't been thoroughly tried yet?\"",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
