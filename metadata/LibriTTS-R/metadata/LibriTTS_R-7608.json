        "speaker_id": "LibriTTS_R-7608",
        "content": "I don't want to 'hoodoo' it.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
