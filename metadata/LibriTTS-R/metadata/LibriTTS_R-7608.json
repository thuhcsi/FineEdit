        "speaker_id": "LibriTTS_R-7608",
        "content": "\"The wind has increased to a gale, and will be dead against us,\" answered Tom.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7608_115034_000059_000000",
