        "speaker_id": "LibriTTS_R-7608",
        "content": "The airship was moving slowly, as it was beating against the wind.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "high"
    },
    {
