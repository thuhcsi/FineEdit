        "speaker_id": "LibriTTS_R-7608",
        "content": "Leaning out of the cabin window, mr Fenwick shouted to his friend:",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
