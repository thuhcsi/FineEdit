        "speaker_id": "LibriTTS_R-7608",
        "content": "What he saw caused him to give a gasp of astonishment.",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "very high"
    },
    {
