        "speaker_id": "LibriTTS_R-7608",
        "content": "\"Hey, Will!",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-7608_115034_000052_000001",
