        "speaker_id": "LibriTTS_R-7608",
        "content": "I worked as hard as I could, and never got more than two feet off the ground.",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "very high"
    },
    {
