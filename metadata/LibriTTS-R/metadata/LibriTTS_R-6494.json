        "speaker_id": "LibriTTS_R-6494",
        "content": "When the apes awoke and missed Janshah and his men, they knew that they had fled.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
