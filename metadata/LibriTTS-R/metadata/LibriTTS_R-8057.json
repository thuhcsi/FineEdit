        "speaker_id": "LibriTTS_R-8057",
        "content": "Why, he couldn't do that,\" observed the King, who was trying to rearrange the ruffle around his neck.",
        "style_prompt": "F_p-normal_s-normal_e-low",
        "gender": "F",
        "pitch": "normal",
