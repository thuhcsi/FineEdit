        "speaker_id": "LibriTTS_R-8057",
        "content": "\"Well,\" said he, \"let's go home.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
