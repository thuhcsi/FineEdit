        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8057/296395/8057_296395_000010_000001.wav",
        "speaker_id": "LibriTTS_R-8057",
        "content": "Kittens born of such parents have no desire for the domestic hearth, and are wild and suspicions to a degree.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
