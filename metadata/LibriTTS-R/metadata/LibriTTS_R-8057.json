        "speaker_id": "LibriTTS_R-8057",
        "content": "The Boolooroo tells them whom to vote for, and if they don't obey they are severely punished.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8057_284428_000060_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/8057/284428/8057_284428_000060_000005.wav",
        "speaker_id": "LibriTTS_R-8057",
        "content": "It ought to be for life.",
        "style_prompt": "F_p-high_s-fast_e-high",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
