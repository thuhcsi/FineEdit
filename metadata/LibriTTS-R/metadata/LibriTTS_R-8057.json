        "speaker_id": "LibriTTS_R-8057",
        "content": "\"Yes, you are.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-8057_284428_000067_000000",
