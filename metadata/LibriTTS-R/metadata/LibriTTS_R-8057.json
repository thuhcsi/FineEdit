        "speaker_id": "LibriTTS_R-8057",
        "content": "It can't be done.\"",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
        "energy": "normal"
