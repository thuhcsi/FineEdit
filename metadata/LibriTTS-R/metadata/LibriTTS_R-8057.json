        "speaker_id": "LibriTTS_R-8057",
        "content": "\"I'm no murderer, thank goodness, and I wouldn't kill you if I could-much as you deserve it.\"",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
