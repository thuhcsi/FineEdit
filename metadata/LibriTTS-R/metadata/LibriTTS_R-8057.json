        "speaker_id": "LibriTTS_R-8057",
        "content": "\"Why not?\" asked Cap'n Bill.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "very low"
