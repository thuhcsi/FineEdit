        "speaker_id": "LibriTTS_R-8057",
        "content": "\"How long have you lived?\" asked Button Bright.",
        "style_prompt": "F_p-normal_s-fast_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
