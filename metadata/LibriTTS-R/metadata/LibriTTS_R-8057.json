        "speaker_id": "LibriTTS_R-8057",
        "content": "\"Nothing can kill me.\"",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "very low"
