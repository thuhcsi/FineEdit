        "speaker_id": "LibriTTS_R-6758",
        "content": "Her lips moved, and she poured forth her last petitions, that left her as rising flakes of fire, kindled by her pure and ardent soul.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "low"
    },
    {
