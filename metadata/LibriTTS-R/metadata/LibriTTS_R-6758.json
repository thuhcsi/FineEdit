        "speaker_id": "LibriTTS_R-6758",
        "content": "Her eyes were brimming, and sobs came from her infant breast.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
