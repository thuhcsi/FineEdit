        "speaker_id": "LibriTTS_R-6758",
        "content": "There is no Fritz; you cast my soul into the brook and I was carried over the mill wheel.\"",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
