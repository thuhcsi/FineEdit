        "speaker_id": "LibriTTS_R-6758",
        "content": "But see, he is a good man, and he is a great architect.\"",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
