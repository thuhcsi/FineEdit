        "speaker_id": "LibriTTS_R-6758",
        "content": "He is there in summer, and it is furnished magnificently.",
        "style_prompt": "F_p-normal_s-fast_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000024_000009",
