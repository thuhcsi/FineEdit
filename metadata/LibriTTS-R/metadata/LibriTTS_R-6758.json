        "speaker_id": "LibriTTS_R-6758",
        "content": "All again was hushed.",
        "style_prompt": "F_p-normal_s-slow_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000017_000001",
