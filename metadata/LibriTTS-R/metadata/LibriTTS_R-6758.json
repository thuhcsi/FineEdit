        "speaker_id": "LibriTTS_R-6758",
        "content": "She bent her ear to them and caught the words: \"I am not, because you would not.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
