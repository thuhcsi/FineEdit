        "speaker_id": "LibriTTS_R-6758",
        "content": "She did not understand what was being taken from her, but she wept in sympathy with the rest.",
        "style_prompt": "F_p-low_s-normal_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
