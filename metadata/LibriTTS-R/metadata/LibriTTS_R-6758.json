        "speaker_id": "LibriTTS_R-6758",
        "content": "There would have been all this-but thou wouldest it not.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "very slow",
        "energy": "very low"
    },
    {
