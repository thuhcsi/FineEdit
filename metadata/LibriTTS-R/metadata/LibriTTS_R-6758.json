        "speaker_id": "LibriTTS_R-6758",
        "content": "Be of good cheer.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "low"
    },
    {
