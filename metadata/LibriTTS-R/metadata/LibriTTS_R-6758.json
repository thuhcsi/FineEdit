        "speaker_id": "LibriTTS_R-6758",
        "content": "But he will not suffer the old, humble Arler cottage here to be meddled with.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
