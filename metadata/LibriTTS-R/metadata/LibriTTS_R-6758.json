        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6758/72288/6758_72288_000011_000000.wav",
        "speaker_id": "LibriTTS_R-6758",
        "content": "A woman, a mother, was dying.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
