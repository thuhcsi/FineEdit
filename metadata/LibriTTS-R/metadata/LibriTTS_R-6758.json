    {
        "item_name": "LibriTTS_R-6758_72288_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6758/72288/6758_72288_000024_000001.wav",
        "speaker_id": "LibriTTS_R-6758",
        "content": "But do you not know that the king has ennobled him?",
        "style_prompt": "F_p-low_s-normal_e-high",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6758/72288/6758_72288_000024_000002.wav",
        "speaker_id": "LibriTTS_R-6758",
        "content": "He has done such great things in the Residenz.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000024_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6758/72288/6758_72288_000024_000005.wav",
        "speaker_id": "LibriTTS_R-6758",
        "content": "But although he is such a famous man his heart is in the right place.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000024_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6758/72288/6758_72288_000024_000006.wav",
        "speaker_id": "LibriTTS_R-6758",
        "content": "He never forgets that he was born in Siebenstein.",
        "style_prompt": "F_p-low_s-normal_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000024_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6758/72288/6758_72288_000024_000007.wav",
        "speaker_id": "LibriTTS_R-6758",
        "content": "Look what a beautiful house he has built for himself and his family on the mountain side.",
        "style_prompt": "F_p-low_s-fast_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "fast",
        "energy": "normal"
    },
    {
