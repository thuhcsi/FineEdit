        "speaker_id": "LibriTTS_R-6758",
        "content": "Then she stooped over him, and saw the glaze of death in his eyes, and his lips moved.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
