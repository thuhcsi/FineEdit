        "speaker_id": "LibriTTS_R-6758",
        "content": "Anna staggered to her feet, and turned to go back to her cottage, and as she opened the door, heard the cuckoo call two.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
