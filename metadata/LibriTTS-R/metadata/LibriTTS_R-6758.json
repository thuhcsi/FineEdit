        "speaker_id": "LibriTTS_R-6758",
        "content": "And as she stood she heard the talk of the people about her.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
