        "speaker_id": "LibriTTS_R-6758",
        "content": "She waited, quivering in every limb, holding her breath-hoping, fearing, waiting.",
        "style_prompt": "F_p-normal_s-slow_e-low",
        "gender": "F",
        "pitch": "normal",
        "speed": "slow",
