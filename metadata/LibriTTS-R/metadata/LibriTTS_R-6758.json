        "speaker_id": "LibriTTS_R-6758",
        "content": "A spasm contracted Anna's heart.",
        "style_prompt": "F_p-low_s-slow_e-low",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000017_000000",
