        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/6758/72288/6758_72288_000006_000007.wav",
        "speaker_id": "LibriTTS_R-6758",
        "content": "Mother, remember me-I die for the dear Fatherland.\"",
        "style_prompt": "F_p-normal_s-normal_e-high",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
