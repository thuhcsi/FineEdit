        "speaker_id": "LibriTTS_R-6758",
        "content": "Her head reposed on her husband's breast as he sat on the bed and held her in his arms.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
