        "speaker_id": "LibriTTS_R-6758",
        "content": "Frantic with shame, with sorrow, not knowing what she did, or whither she went, Anna made for the front door of the house, ran forth and stood in the village square.",
        "style_prompt": "F_p-low_s-slow_e-normal",
        "gender": "F",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-6758_72288_000020_000000",
