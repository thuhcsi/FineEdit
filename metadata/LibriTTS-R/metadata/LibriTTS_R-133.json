        "speaker_id": "LibriTTS_R-133",
        "content": "Very, very carefully peter stole forward, making no sound at all.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-133_142924_000004_000001",
