        "speaker_id": "LibriTTS_R-133",
        "content": "My, how Strutter can drum!\"",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "very slow",
        "energy": "very low"
    },
    {
