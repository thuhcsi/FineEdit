        "speaker_id": "LibriTTS_R-133",
        "content": "As he drew nearer to it, it sounded louder and louder.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-133_142924_000004_000000",
