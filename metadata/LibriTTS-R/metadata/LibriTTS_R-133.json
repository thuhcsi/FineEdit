        "speaker_id": "LibriTTS_R-133",
        "content": "\"I had forgotten all about him.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-133_142924_000002_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/133/142924/133_142924_000002_000003.wav",
        "speaker_id": "LibriTTS_R-133",
        "content": "I certainly must go over and pay him a call and find out where mrs Grouse is.",
        "style_prompt": "M_p-high_s-slow_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
