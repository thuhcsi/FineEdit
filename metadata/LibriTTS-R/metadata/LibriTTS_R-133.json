        "speaker_id": "LibriTTS_R-133",
        "content": "It was like the long roll on a bass drum.",
        "style_prompt": "M_p-high_s-slow_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "slow",
        "energy": "high"
