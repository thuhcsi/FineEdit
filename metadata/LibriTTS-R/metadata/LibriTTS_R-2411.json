        "speaker_id": "LibriTTS_R-2411",
        "content": "This good woman seemed very willing to accommodate the strangers, who were soon compelled to accept the only two beds in the place.",
        "style_prompt": "F_p-high_s-fast_e-normal",
        "gender": "F",
        "pitch": "high",
        "speed": "fast",
