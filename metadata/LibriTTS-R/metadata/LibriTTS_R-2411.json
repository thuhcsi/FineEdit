        "speaker_id": "LibriTTS_R-2411",
        "content": "They parted with mutual regret.",
        "style_prompt": "F_p-normal_s-normal_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
