        "speaker_id": "LibriTTS_R-2411",
        "content": "Rocks on rocks piled, as if by magic spell, Here scorch'd by lightnings, there with ivy green.",
        "style_prompt": "F_p-normal_s-slow_e-normal",
        "gender": "F",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "normal"
    },
