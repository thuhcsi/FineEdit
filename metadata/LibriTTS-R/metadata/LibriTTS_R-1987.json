[
    {
        "item_name": "LibriTTS_R-1987_144135_000002_000014",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000002_000014.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Very well.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000005_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000005_000010.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Next there followed a few reflections of a correctitude so remarkable that I have no choice but to quote them.",
        "style_prompt": "M_p-low_s-fast_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000005_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000005_000015.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "In conclusion, the writer gave way to unconcealed despair, and wound up with the following verses:",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000007_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000007_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "True, the last line did not scan, but that was a trifle, since the quatrain at least conformed to the mode then prevalent.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000007_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000007_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Neither signature nor date were appended to the document, but only a postscript expressing a conjecture that Chichikov's own heart would tell him who the writer was, and stating, in addition, that the said writer would be present at the Governor's ball on the following night.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000013_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000013_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "\"I think that you have not met my daughter before?\" said Madame.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000013_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000013_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "\"She is just fresh from school.\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000014_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000014_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "He replied that he HAD had the happiness of meeting Mademoiselle before, and under rather unexpected circumstances; but on his trying to say something further his tongue completely failed him.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000015_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000015_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Chichikov stood rooted to the spot, like a man who, after issuing into the street for a pleasant walk, has suddenly come to a halt on remembering that something has been left behind him.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000015_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000015_000007.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Every one of them had made up her mind to use upon him her every weapon, and to exhibit whatsoever might chance to constitute her best point.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000015_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000015_000008.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Yet the ladies' wiles proved useless, for Chichikov paid not the smallest attention to them, even when the dancing had begun, but kept raising himself on tiptoe to peer over people's heads and ascertain in which direction the bewitching maiden with the golden hair had gone.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000015_000012",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000015_000012.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "But Chichikov never even noticed him; he saw in the distance only the golden haired beauty.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000015_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000015_000013.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "At that moment she was drawing on a long glove and, doubtless, pining to be flying over the dancing floor, where, with clicking heels, four couples had now begun to thread the mazes of the mazurka.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000015_000015",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000015_000015.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "However, Chichikov slipped past the mazurka dancers, and, almost treading on their heels, made his way towards the spot where Madame and her daughter were seated.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000015_000016",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000015_000016.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Yet he approached them with great diffidence and none of his late mincing and prancing.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000016_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000016_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Nevertheless, something strange, something which he could not altogether explain, had come upon him.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000016_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000016_000002.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "It seemed as though the ball, with its talk and its clatter, had suddenly become a thing remote-that the orchestra had withdrawn behind a hill, and the scene grown misty, like the carelessly painted in background of a picture.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000017_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000017_000002.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "On perceiving an empty chair beside the mother and daughter, he hastened to occupy it, and though conversation at first hung fire, things gradually improved, and he acquired more confidence.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000018_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000018_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "At this point I must reluctantly deviate to say that men of weight and high office are always a trifle ponderous when conversing with ladies. Young lieutenants-or, at all events, officers not above the rank of captain-are far more successful at the game.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000019_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000019_000005.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "This was unwise of him, since it never does to disregard ladies' opinions. Later but too late-he was destined to learn this to his cost.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000020_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000020_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "In short, dissatisfaction began to display itself on every feminine face.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000021_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000021_000003.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "On sighting him in the distance, Chichikov at once decided to sacrifice himself.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000021_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000021_000004.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "That is to say, he decided to vacate his present enviable position and make off with all possible speed, since he could see that an encounter with the newcomer would do him no good.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000022_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000022_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "\"Ah, my fine landowner of Kherson!\" he cried with a smile which set his fresh, spring rose pink cheeks a quiver.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000022_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000022_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "\"Have you been doing much trade in departed souls lately?\" With that he turned to the Governor.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000022_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000022_000002.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "\"I suppose your Excellency knows that this man traffics in dead peasants?\" he bawled.",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000022_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000022_000006.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Yes, by God I would!\"",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000023_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000023_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Chichikov's discomfiture was complete.",
        "style_prompt": "M_p-low_s-fast_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000024_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000024_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "And, behold, no sooner do I arrive here than I am told that he has bought three million roubles' worth of peasants for transferment!",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000024_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000024_000002.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "For transferment, indeed!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "very slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000024_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000024_000003.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "And he wanted to bargain with me for my DEAD ones!",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000024_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000024_000006.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Yes, by God, you are an utter swine!",
        "style_prompt": "M_p-low_s-slow_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000025_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000025_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "The half tipsy Nozdrev, without noticing them, continued his harangue as before.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000026_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000026_000003.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "You ought to be ashamed of yourself.",
        "style_prompt": "M_p-low_s-normal_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000026_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000026_000006.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Indeed, if you had stood there and said to me, 'Nozdrev, tell me on your honour which of the two you love best-your father or Chichikov?' I should have replied, 'Chichikov, by God!'\" With that he tackled our hero again, \"Come, come, my friend!\" he urged.",
        "style_prompt": "M_p-low_s-slow_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000026_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000026_000007.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "\"Let me imprint upon your cheeks a baiser or two.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000026_000009",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000026_000009.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "No, do not resist me, Chichikov, but allow me to imprint at least one baiser upon your lily white cheek.\" And in his efforts to force upon Chichikov what he termed his \"baisers\" he came near to measuring his length upon the floor.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000028_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000028_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "He felt much as does a man who, shod with well polished boots, has just stepped into a dirty, stinking puddle.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000028_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000028_000002.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "He tried to put away from him the occurrence, and to expand, and to enjoy himself once more.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000028_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000028_000004.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "But all was of no avail-matters kept going as awry as a badly bent hoop.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000029_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000029_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "His heart ached with a dull, unpleasant sensation, with a sort of oppressive emptiness.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "\"The devil take those who first invented balls!\" was his reflection. \"Who derives any real pleasure from them?",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "In this province there exist want and scarcity everywhere: yet folk go in for balls!",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000002.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "How absurd, too, were those overdressed women!",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000003",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000003.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "One of them must have had a thousand roubles on her back, and all acquired at the expense of the overtaxed peasant, or, worse still, at that of the conscience of her neighbour. Yes, we all know why bribes are accepted, and why men become crooked in soul.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000004.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "It is all done to provide wives-yes, may the pit swallow them up!--with fal lals.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000005",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000005.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "And for what purpose?",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000006",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000006.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "That some woman may not have to reproach her husband with the fact that, say, the Postmaster's wife is wearing a better dress than she is-a dress which has cost a thousand roubles!",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000007.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "'Balls and gaiety, balls and gaiety' is the constant cry.",
        "style_prompt": "M_p-normal_s-slow_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000008",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000008.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Yet what folly balls are!",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000010",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000010.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "A grown, middle aged man-a man dressed in black, and looking as stiff as a poker-suddenly takes the floor and begins shuffling his feet about, while another man, even though conversing with a companion on important business, will, the while, keep capering to right and left like a billy goat!",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000011",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000011.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Mimicry, sheer mimicry!",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000013",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000013.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "No; a ball leaves one feeling that one has done a wrong thing-so much so that one does not care even to think of it.",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000030_000019",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000030_000019.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Are, therefore, such functions right or wrong?",
        "style_prompt": "M_p-high_s-normal_e-high",
        "gender": "M",
        "pitch": "very high",
        "speed": "normal",
        "energy": "very high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000031_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000031_000000.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Such were the unfavourable comments which Chichikov passed upon balls in general.",
        "style_prompt": "M_p-normal_s-normal_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000031_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000031_000001.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "With it all, however, there went a second source of dissatisfaction.",
        "style_prompt": "M_p-normal_s-fast_e-high",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000031_000004",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000031_000004.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "Still more, on viewing the matter clearly, he felt vexed to think that he himself had been so largely the cause of the catastrophe.",
        "style_prompt": "M_p-normal_s-normal_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1987_144135_000033_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1987/144135/1987_144135_000033_000007.wav",
        "speaker_id": "LibriTTS_R-1987",
        "content": "We will reserve it for the ensuing chapter.",
        "style_prompt": "M_p-low_s-normal_e-normal",
        "gender": "M",
        "pitch": "low",
        "speed": "normal",
        "energy": "normal"
    }
]