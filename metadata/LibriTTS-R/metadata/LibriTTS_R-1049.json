        "speaker_id": "LibriTTS_R-1049",
        "content": "What was the further probability?",
        "style_prompt": "M_p-high_s-fast_e-high",
        "gender": "M",
        "pitch": "high",
        "speed": "fast",
        "energy": "high"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000025_000007",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000025_000007.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "Clear!--clear as noonday!",
        "style_prompt": "M_p-high_s-slow_e-low",
        "gender": "M",
        "pitch": "very high",
        "speed": "very slow",
        "energy": "low"
    },
    {
