        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000047_000000.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "Bryce had now got all the information he wanted, and he made the old parish clerk a small present and turned to go.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
