        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000035_000000.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"Who was she?\" demanded Bryce.",
        "style_prompt": "M_p-normal_s-slow_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "slow",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000036_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000036_000000.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"Governess at the vicarage,\" replied Claybourne.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000036_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000036_000001.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"Nice, sweet young lady.\"",
        "style_prompt": "M_p-normal_s-slow_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very slow",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000037_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000037_000000.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"And the man she married?--mr",
        "style_prompt": "M_p-high_s-fast_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "very fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000037_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000037_000001.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "Brake,\" continued Bryce.",
        "style_prompt": "M_p-low_s-normal_e-low",
        "gender": "M",
        "pitch": "very low",
        "speed": "normal",
        "energy": "very low"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000037_000002",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000037_000002.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"Who was he?\"",
        "style_prompt": "M_p-high_s-normal_e-normal",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000038_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000038_000000.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"A young gentleman that used to come here for the fishing, now and then,\" answered Claybourne, pointing at the river.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "very fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000038_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000038_000001.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"Famous for our trout we are here, you know, sir.",
        "style_prompt": "M_p-normal_s-fast_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000039_000000",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000039_000000.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"You remember him, too?\" asked Bryce.",
        "style_prompt": "M_p-high_s-normal_e-low",
        "gender": "M",
        "pitch": "high",
        "speed": "normal",
        "energy": "low"
    },
    {
