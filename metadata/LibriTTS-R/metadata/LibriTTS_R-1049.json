        "speaker_id": "LibriTTS_R-1049",
        "content": "\"Do you know what Brake was?\" asked Bryce.",
        "style_prompt": "M_p-normal_s-normal_e-normal",
        "gender": "M",
        "pitch": "normal",
        "speed": "normal",
        "energy": "normal"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000045_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000045_000001.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"As you say he came here for a good many times before the marriage, I suppose you'd hear something about his profession, or trade, or whatever it was?\"",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
        "item_name": "LibriTTS_R-1049_133454_000046_000001",
        "wav_path": "/apdcephfs_qy3/share_1474453/shuoyizhou/data_preprocess/LibriTTS-R/LibriTTS_R/1049/133454/1049_133454_000046_000001.wav",
        "speaker_id": "LibriTTS_R-1049",
        "content": "\"A banker-that was his trade, sir.",
        "style_prompt": "M_p-normal_s-fast_e-low",
        "gender": "M",
        "pitch": "normal",
        "speed": "fast",
        "energy": "low"
    },
    {
