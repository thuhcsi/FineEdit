        "speaker_id": "LibriTTS_R-5672",
        "content": "It refers as well to every other type of moving picture that gets into the slum.",
        "style_prompt": "M_p-low_s-fast_e-high",
        "gender": "M",
        "pitch": "low",
        "speed": "fast",
